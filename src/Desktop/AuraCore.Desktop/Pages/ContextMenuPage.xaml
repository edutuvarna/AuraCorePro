<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AuraCore.Desktop.Pages.ContextMenuPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Padding="32">
        <StackPanel Spacing="16" MaxWidth="960">

            <StackPanel Spacing="4">
                <TextBlock x:Name="PageTitle" Text="Context Menu Customizer" Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock x:Name="PageSubtitle" Text="Clean up and customize your right-click context menu"
                           Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button x:Name="ScanBtn" Content="Scan Context Menu" Click="ScanBtn_Click"
                        Style="{StaticResource AccentButtonStyle}" Padding="24,10" />
                <Button x:Name="ApplyBtn" Content="Apply Changes (0)" Click="ApplyBtn_Click"
                        Padding="24,10" IsEnabled="False" />
                <ProgressRing x:Name="Progress" IsActive="False" Visibility="Collapsed" Width="28" Height="28" />
                <TextBlock x:Name="StatusText" Text="Click Scan to check your context menu settings"
                           VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <!-- Classic Menu Toggle -->
            <Border x:Name="ClassicMenuCard" Visibility="Collapsed"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="10" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ToggleSwitch x:Name="ClassicMenuToggle" Grid.Column="0" OnContent="" OffContent=""
                                  VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="Classic Context Menu (Windows 10 style)" FontWeight="SemiBold" FontSize="14" />
                        <TextBlock Text="Bypass the Windows 11 simplified menu — show all options directly without 'Show more options'"
                                   FontSize="12" Opacity="0.6" TextWrapping="Wrap" />
                    </StackPanel>
                    <Border Grid.Column="2" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                            CornerRadius="4" Padding="8,4" VerticalAlignment="Center">
                        <TextBlock x:Name="ClassicMenuStatus" FontSize="11" Opacity="0.7" />
                    </Border>
                </Grid>
            </Border>

            <!-- Tweaks by Category -->
            <StackPanel x:Name="TweakList" Spacing="12" />

            <!-- Result -->
            <Border x:Name="ResultCard" Visibility="Collapsed"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="10" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="4">
                    <TextBlock x:Name="ResultTitle" Style="{StaticResource BodyStrongTextBlockStyle}" Foreground="#2E7D32" />
                    <TextBlock x:Name="ResultDetail" Style="{StaticResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
