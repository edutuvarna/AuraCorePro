<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:AuraCore.UI.Avalonia.Views.Controls"
             x:Class="AuraCore.UI.Avalonia.Views.Pages.BatteryOptimizerView">
  <ScrollViewer>
    <StackPanel Spacing="16">

      <!-- Header -->
      <controls:ModuleHeader x:Name="PageHeader" Title=""
                             Subtitle="">
        <controls:ModuleHeader.Actions>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Classes="action-btn" Click="BatteryReport_Click"
                    Padding="14,8" VerticalAlignment="Center">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="📊" FontSize="{DynamicResource FontSizeBody}"/>
                <TextBlock x:Name="BatteryReportLabel" Text=""
                           FontSize="{DynamicResource FontSizeBodySmall}" FontWeight="SemiBold"/>
              </StackPanel>
            </Button>
            <Button Classes="action-btn" Click="Scan_Click"
                    Padding="14,8" VerticalAlignment="Center">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="🔍" FontSize="{DynamicResource FontSizeBody}"/>
                <TextBlock x:Name="ScanLabel" Text=""
                           FontSize="{DynamicResource FontSizeBodySmall}" FontWeight="SemiBold"/>
              </StackPanel>
            </Button>
            <!-- PageTitle: invisible, code-behind writes localized string -->
            <TextBlock x:Name="PageTitle" IsVisible="False"/>
          </StackPanel>
        </controls:ModuleHeader.Actions>
      </controls:ModuleHeader>

      <!-- Hidden bridge for code-behind subtitle writes -->
      <TextBlock x:Name="SubText"
                 Text=""
                 FontSize="{DynamicResource FontSizeBodySmall}"
                 Foreground="{DynamicResource TextMutedBrush}"
                 IsVisible="False"/>

      <!-- Battery Status Card -->
      <controls:GlassCard>
        <Grid ColumnDefinitions="Auto,*">
          <StackPanel Spacing="4" Margin="0,0,24,0">
            <TextBlock x:Name="ChargePct" Text="--%"
                       FontSize="42" FontWeight="Bold"
                       Foreground="{DynamicResource AccentPrimaryBrush}"/>
            <TextBlock x:Name="ChargeStatus" Text=""
                       FontSize="{DynamicResource FontSizeBodySmall}"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
            <TextBlock x:Name="EstRemaining" Text=""
                       FontSize="{DynamicResource FontSizeLabel}"
                       Foreground="{DynamicResource TextMutedBrush}"/>
          </StackPanel>
          <Grid Grid.Column="1" RowDefinitions="*,*" ColumnDefinitions="*,*">
            <StackPanel Spacing="2">
              <TextBlock x:Name="HealthLabel" Text=""
                         FontSize="{DynamicResource FontSizeLabel}"
                         Foreground="{DynamicResource TextMutedBrush}"/>
              <TextBlock x:Name="HealthGrade" Text="--"
                         FontSize="{DynamicResource FontSizeBody}" FontWeight="Bold"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Spacing="2">
              <TextBlock x:Name="WearLabel" Text=""
                         FontSize="{DynamicResource FontSizeLabel}"
                         Foreground="{DynamicResource TextMutedBrush}"/>
              <TextBlock x:Name="WearPct" Text="--%"
                         FontSize="{DynamicResource FontSizeBody}" FontWeight="Bold"
                         Foreground="{DynamicResource StatusWarningBrush}"/>
            </StackPanel>
            <StackPanel Grid.Row="1" Spacing="2">
              <TextBlock x:Name="DesignLabel" Text=""
                         FontSize="{DynamicResource FontSizeLabel}"
                         Foreground="{DynamicResource TextMutedBrush}"/>
              <TextBlock x:Name="DesignCap" Text="--"
                         FontSize="{DynamicResource FontSizeBodySmall}"
                         Foreground="{DynamicResource TextSecondaryBrush}"/>
            </StackPanel>
            <StackPanel Grid.Row="1" Grid.Column="1" Spacing="2">
              <TextBlock x:Name="FullChargeLabel" Text=""
                         FontSize="{DynamicResource FontSizeLabel}"
                         Foreground="{DynamicResource TextMutedBrush}"/>
              <TextBlock x:Name="FullCap" Text="--"
                         FontSize="{DynamicResource FontSizeBodySmall}"
                         Foreground="{DynamicResource TextSecondaryBrush}"/>
            </StackPanel>
          </Grid>
        </Grid>
      </controls:GlassCard>

      <!-- Power Plans Card -->
      <controls:GlassCard>
        <StackPanel Spacing="12">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Border Width="20" Height="20" CornerRadius="6"
                    Background="{DynamicResource StatusSuccessBgBrush}">
              <TextBlock Text="⚡" FontSize="{DynamicResource FontSizeLabel}"
                         Foreground="{DynamicResource StatusSuccessBrush}"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock x:Name="PowerPlansLabel" Text=""
                       FontSize="{DynamicResource FontSizeBodySmall}" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
          </StackPanel>
          <ItemsControl x:Name="PlanList">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Margin="0,0,0,4" CornerRadius="{StaticResource RadiusMd}"
                        BorderThickness="1" Padding="14,8"
                        Background="{DynamicResource BgCardBrush}"
                        BorderBrush="{DynamicResource BorderSubtleBrush}">
                  <Grid ColumnDefinitions="*,60">
                    <TextBlock Text="{Binding Name}"
                               FontSize="{DynamicResource FontSizeBodySmall}" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{Binding ActiveLabel}"
                               FontSize="{DynamicResource FontSizeLabel}" FontWeight="Bold"
                               Foreground="{Binding ActiveBrush}"
                               VerticalAlignment="Center" TextAlignment="Center"/>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </controls:GlassCard>

      <!-- High Drain Apps Card -->
      <controls:GlassCard>
        <StackPanel Spacing="12">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Border Width="20" Height="20" CornerRadius="6"
                    Background="{DynamicResource AccentBgBrush}">
              <TextBlock Text="🔋" FontSize="{DynamicResource FontSizeLabel}"
                         Foreground="{DynamicResource AccentPrimaryBrush}"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock x:Name="HighDrainLabel" Text=""
                       FontSize="{DynamicResource FontSizeBodySmall}" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
          </StackPanel>
          <ItemsControl x:Name="DrainList">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Margin="0,0,0,4" CornerRadius="{StaticResource RadiusMd}"
                        BorderThickness="1" Padding="14,8"
                        Background="{DynamicResource BgCardBrush}"
                        BorderBrush="{DynamicResource BorderSubtleBrush}">
                  <Grid ColumnDefinitions="*,80,60">
                    <TextBlock Text="{Binding Name}"
                               FontSize="{DynamicResource FontSizeBodySmall}" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{Binding Cpu}"
                               FontSize="{DynamicResource FontSizeLabel}"
                               Foreground="{DynamicResource AccentBlueBrush}"
                               VerticalAlignment="Center" TextAlignment="Right"/>
                    <TextBlock Grid.Column="2" Text="{Binding Impact}"
                               FontSize="{DynamicResource FontSizeLabel}" FontWeight="SemiBold"
                               Foreground="{Binding ImpactBrush}"
                               VerticalAlignment="Center" TextAlignment="Center"/>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </controls:GlassCard>

    </StackPanel>
  </ScrollViewer>
</UserControl>
