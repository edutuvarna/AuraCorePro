<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AuraCore.UI.Avalonia.Views.Pages.SchedulerView">
  <ScrollViewer>
    <StackPanel Spacing="16" Margin="0,0,0,24">

      <!-- Header -->
      <StackPanel Spacing="4">
        <TextBlock x:Name="PageTitle" Text="Auto-Schedule" FontSize="18" FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>
        <TextBlock Text="Schedule automatic optimization tasks" FontSize="12"
                   Foreground="{DynamicResource TextMutedBrush}"/>
      </StackPanel>

      <!-- Section label -->
      <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
        <Border Width="18" Height="18" CornerRadius="5">
          <Border.Background>
            <SolidColorBrush Color="#F59E0B" Opacity="0.15"/>
          </Border.Background>
          <TextBlock Text="&#x23F0;" FontSize="9" Foreground="#F59E0B"
                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
        <TextBlock Text="SCHEDULED TASKS" FontSize="10" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
      </StackPanel>

      <!-- Task cards container (populated in code-behind) -->
      <StackPanel x:Name="TaskList" Spacing="8"/>

      <!-- Info banner -->
      <Border CornerRadius="{StaticResource RadiusMd}" Padding="16,10" BorderThickness="1">
        <Border.Background>
          <SolidColorBrush Color="#F59E0B" Opacity="0.06"/>
        </Border.Background>
        <Border.BorderBrush>
          <SolidColorBrush Color="#F59E0B" Opacity="0.15"/>
        </Border.BorderBrush>
        <TextBlock Text="Tasks run automatically in the background when enabled. Select an interval and toggle on to activate."
                   FontSize="11" Foreground="#F59E0B" TextWrapping="Wrap"/>
      </Border>

    </StackPanel>
  </ScrollViewer>
</UserControl>
