# =============================================
# AuraCore Pro - .gitignore
# =============================================

# Build outputs
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Rr]elease/
x64/
x86/
publish/
publish-linux/

# Superpowers brainstorm session data
.superpowers/

# Phase 6.14 — RN mobile project
mobile/node_modules/
mobile/.expo/
mobile/.expo-shared/
mobile/dist/
mobile/web-build/
mobile/.eas/
mobile/google-services.json
mobile/*.keystore
mobile/*.jks
mobile/android/
mobile/ios/

# Visual Studio
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.rsuser

# NuGet
packages/
*.nupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/

# Windows App SDK / WinUI3
AppPackages/
BundleArtifacts/
*.appx
*.appxbundle
*.appxupload
*.msix
*.msixbundle
*.msixupload
Generated Files/

# WebView2 cache
**/EBWebView/
**/*.exe.WebView2/

# Project-specific build artifacts
*.pri
*.xbf
*.g.cs
*.g.i.cs
*.g.cs.backup

# Backup files
*.bak
*.bak2
*.orig

# OS files
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Logs
*.log
*.log.*

# Secrets (never commit)
appsettings.*.json
!appsettings.json
!appsettings.Development.json

# Inno Setup output
Output/

# Python cache
__pycache__/
*.pyc

# Node modules (admin panel)
node_modules/

# Temp files
*.tmp
*.temp
~$*

# Phase 6.2 — Verify.Xunit pixel-regression received artifacts (never commit;
# promote .received.* → .verified.* via accept-workflow instead).
tests/AuraCore.Tests.UI.Avalonia/goldens/*.received.png
tests/AuraCore.Tests.UI.Avalonia/goldens/*.received.txt
# Phase 6.10 — admin-panel build artifacts (source IS tracked at admin-panel/)
admin-panel/node_modules/
admin-panel/.next/
admin-panel/out/
