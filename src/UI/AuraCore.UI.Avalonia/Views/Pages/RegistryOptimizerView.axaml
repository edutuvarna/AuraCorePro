<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:AuraCore.UI.Avalonia.Views.Controls"
             x:Class="AuraCore.UI.Avalonia.Views.Pages.RegistryOptimizerView">
  <ScrollViewer>
    <StackPanel Spacing="16">

      <!-- Header -->
      <controls:ModuleHeader Title="Registry Optimizer"
                             Subtitle="Find and fix broken registry entries">
        <controls:ModuleHeader.Actions>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Classes="action-btn" Click="Scan_Click" Padding="14,8" VerticalAlignment="Center">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="&#x1F50D;" FontSize="{DynamicResource FontSizeBody}"/>
                <TextBlock x:Name="ScanLabel" Text="Scan"
                           FontSize="{DynamicResource FontSizeBodySmall}" FontWeight="SemiBold"/>
              </StackPanel>
            </Button>
            <Button x:Name="FixBtn" Click="Fix_Click"
                    Background="{DynamicResource AccentPrimaryBrush}" Foreground="#0A0A0F"
                    Padding="16,8" CornerRadius="{StaticResource RadiusMd}"
                    FontWeight="Bold" FontSize="{DynamicResource FontSizeBodySmall}"
                    IsEnabled="False" Content="Fix Issues"/>
            <!-- PageTitle: invisible, code-behind writes localized string -->
            <TextBlock x:Name="PageTitle" IsVisible="False"/>
          </StackPanel>
        </controls:ModuleHeader.Actions>
      </controls:ModuleHeader>

      <!-- Hidden bridges for code-behind -->
      <TextBlock x:Name="SubText"
                 Text="Find and fix broken registry entries"
                 FontSize="{DynamicResource FontSizeBodySmall}"
                 Foreground="{DynamicResource TextMutedBrush}"
                 IsVisible="False"/>

      <!-- Stats row -->
      <controls:StatRow>
        <controls:StatCard Label="ISSUES"
                           Value="{Binding #TotalIssues.Text}"
                           ValueBrush="{DynamicResource AccentPrimaryBrush}"/>
        <controls:StatCard Label="SAFE"
                           Value="{Binding #SafeIssues.Text}"
                           ValueBrush="{DynamicResource StatusSuccessBrush}"/>
        <controls:StatCard Label="CAUTION"
                           Value="{Binding #CautionIssues.Text}"
                           ValueBrush="{DynamicResource WarningBrush}"/>
      </controls:StatRow>

      <!-- Hidden stat TextBlocks — code-behind writes .Text directly -->
      <TextBlock x:Name="TotalIssues"   Text="--" IsVisible="False"/>
      <TextBlock x:Name="SafeIssues"    Text="--" IsVisible="False"/>
      <TextBlock x:Name="CautionIssues" Text="--" IsVisible="False"/>

      <!-- Issue list card -->
      <controls:GlassCard>
        <ScrollViewer>
          <ItemsControl x:Name="IssueList">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Padding="12,8" Margin="0,0,0,4" CornerRadius="{StaticResource RadiusMd}"
                        BorderThickness="1"
                        Background="{DynamicResource BgCardBrush}"
                        BorderBrush="{DynamicResource BorderSubtleBrush}">
                  <Grid ColumnDefinitions="*,120,80">
                    <StackPanel VerticalAlignment="Center">
                      <TextBlock Text="{Binding Desc}"
                                 FontSize="{DynamicResource FontSizeBodySmall}" FontWeight="SemiBold"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 TextTrimming="CharacterEllipsis"/>
                      <TextBlock Text="{Binding KeyPath}"
                                 FontSize="{DynamicResource FontSizeLabel}"
                                 Foreground="{DynamicResource TextMutedBrush}"
                                 TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="{Binding Category}"
                               FontSize="{DynamicResource FontSizeLabel}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center" TextAlignment="Center"/>
                    <Border Grid.Column="2" CornerRadius="8" Padding="6,2"
                            Background="{Binding RiskBg}"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                      <TextBlock Text="{Binding Risk}"
                                 FontSize="{DynamicResource FontSizeLabel}" FontWeight="SemiBold"
                                 Foreground="{Binding RiskFg}"/>
                    </Border>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </controls:GlassCard>

      <!-- Status text — code-behind writes progress/result -->
      <TextBlock x:Name="StatusText" Text=""
                 FontSize="{DynamicResource FontSizeBodySmall}"
                 Foreground="{DynamicResource TextMutedBrush}"
                 Margin="0,4,0,0"/>

    </StackPanel>
  </ScrollViewer>
</UserControl>
