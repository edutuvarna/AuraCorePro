<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AuraCore.Desktop.Pages.RamOptimizerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Padding="32">
        <StackPanel Spacing="16" MaxWidth="900">

            <!-- HEADER -->
            <StackPanel Spacing="2">
                <TextBlock x:Name="PageTitle" Text="RAM Optimizer"
                           Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock x:Name="PageSubtitle" Text="Analyze memory usage and reclaim wasted RAM"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <!-- ACTION BAR -->
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="ScanBtn" Grid.Column="0"
                        Content="Analyze Memory" Click="ScanBtn_Click"
                        Style="{StaticResource AccentButtonStyle}" Padding="24,10" />
                <Button x:Name="OptimizeBtn" Grid.Column="1"
                        Content="Optimize RAM" Click="OptimizeBtn_Click"
                        Padding="24,10" IsEnabled="False" />
                <ToggleSwitch x:Name="TrendToggle" Grid.Column="2"
                              Header="Track Trends" OnContent="ON" OffContent="OFF"
                              Toggled="TrendToggle_Toggled" VerticalAlignment="Center" />
                <ProgressRing x:Name="Progress" Grid.Column="3"
                              IsActive="False" Visibility="Collapsed" Width="28" Height="28"
                              VerticalAlignment="Center"/>
                <TextBlock x:Name="StatusText" Grid.Column="4"
                           Text="Click Analyze to scan memory usage"
                           VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </Grid>

            <!-- LEAK DETECTION ALERT -->
            <Border x:Name="LeakAlertCard" Visibility="Collapsed"
                    Background="#14E65100" CornerRadius="10" Padding="14,10"
                    BorderBrush="#33E65100" BorderThickness="0.5">
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="8" Height="8" CornerRadius="4" VerticalAlignment="Top"
                            Margin="0,5,0,0">
                        <Border.Background>
                            <SolidColorBrush Color="#FFE65100"/>
                        </Border.Background>
                    </Border>
                    <StackPanel Grid.Column="1" Spacing="6">
                        <TextBlock Text="Possible memory leaks detected"
                                   FontWeight="SemiBold" FontSize="13"
                                   Foreground="#FFE65100" />
                        <TextBlock x:Name="LeakDetailText" Text="" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap"/>
                        <StackPanel x:Name="LeakList" Spacing="4" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- MEMORY OVERVIEW (4 stat cards) -->
            <Border x:Name="MemoryOverview" Visibility="Collapsed"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="10" Padding="20"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="12">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Total RAM -->
                        <Border Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                CornerRadius="8" Padding="14,10">
                            <StackPanel Spacing="4">
                                <TextBlock x:Name="LblTotalRam" Text="Total RAM" FontSize="11"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock x:Name="TotalRamText" Text="--"
                                           FontSize="20" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>

                        <!-- In Use -->
                        <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                CornerRadius="8" Padding="14,10">
                            <StackPanel Spacing="4">
                                <TextBlock x:Name="LblInUse" Text="In Use" FontSize="11"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock x:Name="UsedRamText" Text="--"
                                           FontSize="20" FontWeight="SemiBold"
                                           Foreground="#FFE65100"/>
                            </StackPanel>
                        </Border>

                        <!-- Available -->
                        <Border Grid.Column="2" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                CornerRadius="8" Padding="14,10">
                            <StackPanel Spacing="4">
                                <TextBlock x:Name="LblAvail" Text="Available" FontSize="11"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock x:Name="AvailRamText" Text="--"
                                           FontSize="20" FontWeight="SemiBold"
                                           Foreground="#FF2E7D32"/>
                            </StackPanel>
                        </Border>

                        <!-- Reclaimable -->
                        <Border Grid.Column="3" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                CornerRadius="8" Padding="14,10">
                            <StackPanel Spacing="4">
                                <TextBlock x:Name="LblReclaim" Text="Reclaimable" FontSize="11"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock x:Name="ReclaimText" Text="--"
                                           FontSize="20" FontWeight="SemiBold"
                                           Foreground="#FF1565C0"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <ProgressBar x:Name="MemBar" Minimum="0" Maximum="100"
                                 Height="6" CornerRadius="3" />
                    <TextBlock x:Name="MemPctText" Text="" FontSize="11"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                </StackPanel>
            </Border>

            <!-- PROCESS LIST (populated by code-behind) -->
            <StackPanel x:Name="ProcessList" Spacing="4" />

            <!-- OPTIMIZATION RESULT -->
            <Border x:Name="ResultCard" Visibility="Collapsed"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="10" Padding="16,14"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <FontIcon Glyph="&#xE73E;" FontSize="20" Foreground="#FF2E7D32"
                              VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Spacing="2">
                        <TextBlock x:Name="ResultTitle" Text="" FontSize="14"
                                   FontWeight="SemiBold" Foreground="#FF2E7D32"/>
                        <TextBlock x:Name="ResultDetail" Text="" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
