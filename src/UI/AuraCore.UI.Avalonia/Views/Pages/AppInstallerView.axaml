<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:AuraCore.UI.Avalonia.Views.Controls"
             x:Class="AuraCore.UI.Avalonia.Views.Pages.AppInstallerView">
  <ScrollViewer>
    <StackPanel Spacing="16">

      <!-- Header -->
      <controls:ModuleHeader x:Name="PageHeader" Title=""
                             Subtitle="">
        <controls:ModuleHeader.Actions>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <!-- Windows-only badge -->
            <Border Padding="8,4" CornerRadius="4" VerticalAlignment="Center">
              <Border.Background>
                <SolidColorBrush Color="#F59E0B" Opacity="0.1"/>
              </Border.Background>
              <TextBlock x:Name="WinOnlyBadge" Text="" FontSize="{DynamicResource FontSizeLabel}"
                         Foreground="#F59E0B" FontWeight="SemiBold"/>
            </Border>
            <!-- PageTitle: invisible, code-behind writes localized string -->
            <TextBlock x:Name="PageTitle" IsVisible="False"/>
          </StackPanel>
        </controls:ModuleHeader.Actions>
      </controls:ModuleHeader>

      <!-- Tab Bar -->
      <StackPanel Orientation="Horizontal" Spacing="8">
        <Border x:Name="SearchTab" CornerRadius="8" Padding="12,6" Cursor="Hand"
                PointerPressed="Tab_Click" Tag="search">
          <Border.Background>
            <SolidColorBrush Color="#00D4AA" Opacity="0.15"/>
          </Border.Background>
          <TextBlock x:Name="SearchTabLabel" Text="" FontSize="{DynamicResource FontSizeBodySmall}" FontWeight="SemiBold"
                     Foreground="{DynamicResource AccentPrimaryBrush}"/>
        </Border>
        <Border x:Name="BundlesTab" CornerRadius="8" Padding="12,6" Cursor="Hand"
                PointerPressed="Tab_Click" Tag="bundles">
          <Border.Background>
            <SolidColorBrush Color="#FFFFFF" Opacity="0.04"/>
          </Border.Background>
          <TextBlock x:Name="BundlesTabLabel" Text="" FontSize="{DynamicResource FontSizeBodySmall}" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextMutedBrush}"/>
        </Border>
        <Border x:Name="InstalledTab" CornerRadius="8" Padding="12,6" Cursor="Hand"
                PointerPressed="Tab_Click" Tag="installed">
          <Border.Background>
            <SolidColorBrush Color="#FFFFFF" Opacity="0.04"/>
          </Border.Background>
          <TextBlock x:Name="InstalledTabLabel" Text="" FontSize="{DynamicResource FontSizeBodySmall}" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextMutedBrush}"/>
        </Border>
        <Border x:Name="UpdatesTab" CornerRadius="8" Padding="12,6" Cursor="Hand"
                PointerPressed="Tab_Click" Tag="updates">
          <Border.Background>
            <SolidColorBrush Color="#FFFFFF" Opacity="0.04"/>
          </Border.Background>
          <TextBlock x:Name="UpdatesTabLabel" Text="" FontSize="{DynamicResource FontSizeBodySmall}" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextMutedBrush}"/>
        </Border>
      </StackPanel>

      <!-- Install Queue Panel (visible when queue has items) -->
      <Border x:Name="QueuePanel" CornerRadius="{StaticResource RadiusMd}" BorderThickness="1"
              Padding="14,10" IsVisible="False">
        <Border.Background>
          <SolidColorBrush Color="#00D4AA" Opacity="0.04"/>
        </Border.Background>
        <Border.BorderBrush>
          <SolidColorBrush Color="#00D4AA" Opacity="0.12"/>
        </Border.BorderBrush>
        <StackPanel Spacing="8">
          <Grid ColumnDefinitions="*,Auto">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Border Width="16" Height="16" CornerRadius="4">
                <Border.Background>
                  <SolidColorBrush Color="#00D4AA" Opacity="0.2"/>
                </Border.Background>
                <TextBlock Text="▶" FontSize="{DynamicResource FontSizeLabel}" FontWeight="Bold"
                           Foreground="#00D4AA"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
              <TextBlock x:Name="QueueTitle" Text=""
                         FontSize="{DynamicResource FontSizeBodySmall}" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextSecondaryBrush}"/>
            </StackPanel>
            <Button Grid.Column="1" x:Name="CancelQueueBtn" Content=""
                    FontSize="{DynamicResource FontSizeLabel}"
                    Padding="10,3" Click="CancelQueue_Click" IsVisible="False"/>
          </Grid>
          <ItemsControl x:Name="QueueList"/>
        </StackPanel>
      </Border>

      <!-- Tab 1: Search -->
      <StackPanel x:Name="SearchPanel" Spacing="12">
        <TextBox x:Name="SearchBox" Watermark="" KeyDown="SearchBox_KeyDown"/>

        <controls:GlassCard>
          <StackPanel Spacing="8">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Border Width="16" Height="16" CornerRadius="4">
                <Border.Background>
                  <SolidColorBrush Color="#00D4AA" Opacity="0.15"/>
                </Border.Background>
                <TextBlock Text="⌕" FontSize="{DynamicResource FontSizeLabel}" FontWeight="Bold"
                           Foreground="#00D4AA"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
              <TextBlock x:Name="SearchResultsLabel" Text="" FontSize="{DynamicResource FontSizeBodySmall}"
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource TextSecondaryBrush}"/>
            </StackPanel>
            <ItemsControl x:Name="SearchResults"/>
            <TextBlock x:Name="SearchEmpty" Text=""
                       FontSize="{DynamicResource FontSizeBodySmall}"
                       Foreground="{DynamicResource TextMutedBrush}"
                       HorizontalAlignment="Center" Margin="0,12"/>
          </StackPanel>
        </controls:GlassCard>
      </StackPanel>

      <!-- Tab 2: Bundles -->
      <StackPanel x:Name="BundlesPanel" Spacing="12" IsVisible="False">
        <TextBlock x:Name="BundlesDesc" Text=""
                   FontSize="{DynamicResource FontSizeBodySmall}"
                   Foreground="{DynamicResource TextMutedBrush}"/>
        <!-- Bundle cards generated in code-behind -->
        <WrapPanel x:Name="BundleCards" Orientation="Horizontal"/>
        <!-- Bundle detail / app list -->
        <controls:GlassCard x:Name="BundleDetailPanel" IsVisible="False">
          <StackPanel Spacing="8">
            <Grid ColumnDefinitions="*,Auto,Auto">
              <TextBlock x:Name="BundleDetailTitle" Text=""
                         FontSize="{DynamicResource FontSizeBody}" FontWeight="Bold"
                         Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
              <Button Grid.Column="1" x:Name="BundleSelectAllBtn" Content=""
                      FontSize="{DynamicResource FontSizeLabel}" Padding="10,4"
                      Click="BundleSelectAll_Click" Margin="0,0,6,0"/>
              <Button Grid.Column="2" x:Name="BundleInstallBtn" Content=""
                      FontSize="{DynamicResource FontSizeLabel}" Padding="10,4"
                      Click="BundleInstall_Click" Classes="accent"/>
            </Grid>
            <ItemsControl x:Name="BundleAppList"/>
          </StackPanel>
        </controls:GlassCard>
      </StackPanel>

      <!-- Tab 3: Installed -->
      <StackPanel x:Name="InstalledPanel" Spacing="12" IsVisible="False">
        <controls:GlassCard>
          <StackPanel Spacing="8">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Border Width="16" Height="16" CornerRadius="4">
                <Border.Background>
                  <SolidColorBrush Color="#8B5CF6" Opacity="0.15"/>
                </Border.Background>
                <TextBlock Text="▣" FontSize="{DynamicResource FontSizeLabel}" FontWeight="Bold"
                           Foreground="#8B5CF6"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
              <TextBlock x:Name="InstalledAppsLabel" Text="" FontSize="{DynamicResource FontSizeBodySmall}"
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource TextSecondaryBrush}"/>
              <TextBlock x:Name="InstalledCount" Text=""
                         FontSize="{DynamicResource FontSizeBodySmall}"
                         Foreground="{DynamicResource TextMutedBrush}" Margin="6,0,0,0"/>
            </StackPanel>
            <ItemsControl x:Name="InstalledList"/>
          </StackPanel>
        </controls:GlassCard>
      </StackPanel>

      <!-- Tab 4: Updates -->
      <StackPanel x:Name="UpdatesPanel" Spacing="12" IsVisible="False">
        <controls:GlassCard>
          <StackPanel Spacing="8">
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <Border Width="16" Height="16" CornerRadius="4">
                  <Border.Background>
                    <SolidColorBrush Color="#F59E0B" Opacity="0.15"/>
                  </Border.Background>
                  <TextBlock Text="⬆" FontSize="{DynamicResource FontSizeLabel}" FontWeight="Bold"
                             Foreground="#F59E0B"
                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock x:Name="AvailableUpdatesLabel" Text="" FontSize="{DynamicResource FontSizeBodySmall}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBlock x:Name="UpdateCount" Text=""
                           FontSize="{DynamicResource FontSizeBodySmall}"
                           Foreground="{DynamicResource TextMutedBrush}" Margin="6,0,0,0"/>
              </StackPanel>
              <Button x:Name="UpdateAllBtn" Grid.Column="1" Content=""
                      Click="UpdateAll_Click" Classes="accent" Padding="10,4"
                      FontSize="{DynamicResource FontSizeLabel}"/>
            </Grid>
            <ItemsControl x:Name="UpdateList"/>
          </StackPanel>
        </controls:GlassCard>
      </StackPanel>

      <!-- Status Bar -->
      <controls:GlassCard>
        <TextBlock x:Name="StatusText" Text=""
                   FontSize="{DynamicResource FontSizeLabel}"
                   Foreground="{DynamicResource TextMutedBrush}"/>
      </controls:GlassCard>

    </StackPanel>
  </ScrollViewer>
</UserControl>
