<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="AuraCore.Desktop.Pages.PrivacyCleanerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer Padding="32">
        <StackPanel Spacing="16" MaxWidth="960">

            <!-- HEADER -->
            <StackPanel Spacing="2">
                <TextBlock x:Name="PageTitle" Text="Privacy Cleaner" Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock x:Name="PageSubtitle" Text="Remove privacy-sensitive data traces from your system"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <InfoBar x:Name="PrivacyWarning" Title="Browser data will be deleted"
                     Message="Cleaning browser history, cookies, or cache will log you out of websites and remove saved form data."
                     Severity="Warning" IsOpen="False" IsClosable="True" />

            <!-- ACTION BAR -->
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button x:Name="ScanBtn" Content="Scan Privacy Data" Click="ScanBtn_Click"
                        Style="{StaticResource AccentButtonStyle}" Padding="24,10" />
                <Button x:Name="CleanBtn" Content="Clean Selected (0)" Click="CleanBtn_Click"
                        Padding="24,10" IsEnabled="False" />
                <ProgressRing x:Name="Progress" IsActive="False" Visibility="Collapsed" Width="28" Height="28" />
                <TextBlock x:Name="StatusText" Text="Click Scan to find privacy-sensitive data"
                           VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <!-- SUMMARY CARDS -->
            <Border x:Name="SummaryCard" Visibility="Collapsed"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="10" Padding="20"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                            CornerRadius="8" Padding="14,10">
                        <StackPanel Spacing="4">
                            <TextBlock x:Name="LblTotalSize" Text="Total Size" FontSize="11"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock x:Name="TotalSizeText" Text="0"
                                       FontSize="20" FontWeight="SemiBold" Foreground="#FFE040FB"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                            CornerRadius="8" Padding="14,10">
                        <StackPanel Spacing="4">
                            <TextBlock x:Name="LblItemsFound" Text="Items Found" FontSize="11"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock x:Name="TotalItemsText" Text="0"
                                       FontSize="20" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                            CornerRadius="8" Padding="14,10">
                        <StackPanel Spacing="4">
                            <TextBlock x:Name="LblCategories" Text="Categories" FontSize="11"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock x:Name="TotalCategoriesText" Text="0"
                                       FontSize="20" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- CATEGORY LIST -->
            <StackPanel x:Name="CategoryList" Spacing="8" />

            <!-- RESULT CARD -->
            <Border x:Name="ResultCard" Visibility="Collapsed"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="10" Padding="16,14"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <FontIcon Glyph="&#xE72E;" FontSize="20" Foreground="#FFE040FB"
                              VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Spacing="2">
                        <TextBlock x:Name="ResultTitle" FontSize="14" FontWeight="SemiBold"
                                   Foreground="#FFE040FB"/>
                        <TextBlock x:Name="ResultDetail" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
