<Page x:Class="AuraCore.Desktop.Pages.HostsEditorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid RowDefinitions="Auto,Auto,*,Auto">

    <!-- Header -->
    <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,16">
      <TextBlock x:Name="PageTitle" Style="{StaticResource TitleTextBlockStyle}"/>
      <TextBlock x:Name="PageSubtitle" Opacity="0.6" FontSize="13" TextWrapping="Wrap"/>
    </StackPanel>

    <!-- Toolbar -->
    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
      <Button x:Name="AddBtn" Click="Add_Click" Style="{StaticResource AccentButtonStyle}" Padding="14,8">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <FontIcon Glyph="&#xE710;" FontSize="13"/>
          <TextBlock x:Name="AddBtnText"/>
        </StackPanel>
      </Button>
      <Button x:Name="SaveBtn" Click="Save_Click" Padding="14,8">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <FontIcon Glyph="&#xE74E;" FontSize="13"/>
          <TextBlock x:Name="SaveBtnText"/>
        </StackPanel>
      </Button>
      <Button x:Name="BackupBtn" Click="Backup_Click" Padding="14,8">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <FontIcon Glyph="&#xE8C8;" FontSize="13"/>
          <TextBlock x:Name="BackupBtnText"/>
        </StackPanel>
      </Button>
      <Button x:Name="ImportBtn" Click="Import_Click" Padding="14,8">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <FontIcon Glyph="&#xE8B5;" FontSize="13"/>
          <TextBlock x:Name="ImportBtnText"/>
        </StackPanel>
      </Button>
      <ProgressRing x:Name="ScanProgress" IsActive="False" Width="20" Height="20" VerticalAlignment="Center"/>
      <TextBlock x:Name="StatusText" VerticalAlignment="Center" FontSize="12" Opacity="0.6"/>
    </StackPanel>

    <!-- Table -->
    <Border Grid.Row="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            CornerRadius="10" Padding="16"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
      <Grid RowDefinitions="Auto,*">
        <Grid Grid.Row="0" ColumnDefinitions="60,160,*,*,80,Auto" Margin="0,0,0,8" Padding="4,0">
          <TextBlock Grid.Column="0" Text="On" FontSize="11" Opacity="0.5" FontWeight="SemiBold"/>
          <TextBlock Grid.Column="1" Text="IP Address" FontSize="11" Opacity="0.5" FontWeight="SemiBold"/>
          <TextBlock Grid.Column="2" Text="Hostname" FontSize="11" Opacity="0.5" FontWeight="SemiBold"/>
          <TextBlock Grid.Column="3" Text="Comment" FontSize="11" Opacity="0.5" FontWeight="SemiBold"/>
          <TextBlock Grid.Column="4" Text="Source" FontSize="11" Opacity="0.5" FontWeight="SemiBold"/>
          <TextBlock Grid.Column="5" Text="Actions" FontSize="11" Opacity="0.5" FontWeight="SemiBold" Width="80"/>
        </Grid>
        <ScrollViewer Grid.Row="1">
          <StackPanel x:Name="EntryList" Spacing="1"/>
        </ScrollViewer>
      </Grid>
    </Border>

    <!-- Admin warning -->
    <Border Grid.Row="3" Background="#1AFFA000" CornerRadius="8" Padding="12,8"
            BorderBrush="#40FFA000" BorderThickness="1" Margin="0,12,0,0"
            x:Name="AdminWarning" Visibility="Collapsed">
      <StackPanel Orientation="Horizontal" Spacing="8">
        <FontIcon Glyph="&#xE7BA;" FontSize="14" Foreground="#FFA000"/>
        <TextBlock x:Name="AdminWarnText" FontSize="12" TextWrapping="Wrap" VerticalAlignment="Center"/>
      </StackPanel>
    </Border>

  </Grid>
</Page>