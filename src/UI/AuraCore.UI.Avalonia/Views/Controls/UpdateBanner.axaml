<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AuraCore.UI.Avalonia.Views.Controls.UpdateBanner"
             IsVisible="False"
             Background="{DynamicResource BgCardElevatedBrush}">
  <Border Padding="12,8" BorderBrush="{DynamicResource TextSecondaryBrush}" BorderThickness="0,0,0,1">
    <Grid ColumnDefinitions="*,Auto,Auto" VerticalAlignment="Center">
      <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="10">
        <TextBlock Text="&#x1F514;" FontSize="16" VerticalAlignment="Center"/>
        <TextBlock x:Name="BannerText"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   VerticalAlignment="Center"/>
      </StackPanel>
      <Button Grid.Column="1" x:Name="UpdateBtn"
              Classes="primary"
              Margin="8,0,4,0"/>
      <Button Grid.Column="2" x:Name="LaterBtn"/>
    </Grid>
  </Border>
</UserControl>
