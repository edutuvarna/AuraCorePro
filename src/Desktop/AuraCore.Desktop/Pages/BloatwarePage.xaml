<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AuraCore.Desktop.Pages.BloatwarePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Padding="32">
        <StackPanel Spacing="20" MaxWidth="960">

            <StackPanel Spacing="4">
                <TextBlock x:Name="PageTitle" Text="Bloatware Removal" Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock x:Name="PageSubtitle" Text="Detect and remove pre-installed Windows apps you don't need"
                           Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <!-- Action Bar -->
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button x:Name="ScanBtn" Content="Scan Apps" Click="ScanBtn_Click"
                        Style="{StaticResource AccentButtonStyle}" Padding="24,10" />
                <Button x:Name="RemoveBtn" Content="Remove Selected (0)" Click="RemoveBtn_Click"
                        Padding="24,10" IsEnabled="False" />
                <ProgressRing x:Name="Progress" IsActive="False" Visibility="Collapsed" Width="28" Height="28" />
                <TextBlock x:Name="StatusText" Text="Click Scan to detect installed apps"
                           VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <!-- Summary Card -->
            <Border x:Name="SummaryCard" Visibility="Collapsed"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <Grid ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="2">
                        <TextBlock Text="Total apps" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="TotalAppsText" Style="{StaticResource SubtitleTextBlockStyle}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="2">
                        <TextBlock Text="Removable" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="RemovableText" Style="{StaticResource SubtitleTextBlockStyle}" Foreground="#E65100" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="2">
                        <TextBlock Text="Safe to remove" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="SafeCountText" Style="{StaticResource SubtitleTextBlockStyle}" Foreground="#2E7D32" />
                    </StackPanel>
                    <StackPanel Grid.Column="3" Spacing="2">
                        <TextBlock Text="System required" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="SystemCountText" Style="{StaticResource SubtitleTextBlockStyle}" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Filter Buttons -->
            <StackPanel x:Name="FilterBar" Orientation="Horizontal" Spacing="8" Visibility="Collapsed">
                <Button x:Name="FilterAll" Content="All" Click="Filter_Click" Tag="all" />
                <Button x:Name="FilterSafe" Content="Safe" Click="Filter_Click" Tag="safe" />
                <Button x:Name="FilterCaution" Content="Caution" Click="Filter_Click" Tag="caution" />
                <Button x:Name="FilterOem" Content="OEM" Click="Filter_Click" Tag="oem" />

                <Border Width="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" Margin="4,4" />

                <Button x:Name="PresetFresh" Content="Fresh Windows Cleanup" Click="PresetFresh_Click"
                        Style="{StaticResource AccentButtonStyle}" Padding="14,6" FontSize="12" />
                <Button x:Name="SelectAllSafe" Content="Select All Safe" Click="SelectAllSafe_Click"
                        Padding="14,6" FontSize="12" />
                <Button x:Name="DeselectAll" Content="Deselect All" Click="DeselectAll_Click"
                        Padding="14,6" FontSize="12" />
            </StackPanel>

            <!-- App List -->
            <!-- Search -->
            <TextBox x:Name="SearchBox" PlaceholderText="Search apps by name..." Visibility="Collapsed"
                     TextChanged="SearchBox_TextChanged" />

            <StackPanel x:Name="AppList" Spacing="4" />

            <!-- Result Card -->
            <Border x:Name="ResultCard" Visibility="Collapsed"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="4">
                    <TextBlock x:Name="ResultTitle" Style="{StaticResource BodyStrongTextBlockStyle}" Foreground="#2E7D32" />
                    <TextBlock x:Name="ResultDetail" Style="{StaticResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
