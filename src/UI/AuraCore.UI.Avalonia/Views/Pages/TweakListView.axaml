<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AuraCore.UI.Avalonia.Views.Pages.TweakListView">
  <Grid RowDefinitions="Auto,Auto,*,Auto">

    <!-- Header -->
    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,16">
      <StackPanel Spacing="4">
        <TextBlock x:Name="PageTitle" Text="Tweaks" FontSize="16" FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>
        <TextBlock x:Name="PageSubtitle" Text="Toggle system tweaks"
                   FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
      </StackPanel>
      <Button Grid.Column="1" Classes="action-btn" Click="Scan_Click"
              VerticalAlignment="Center" Padding="14,8">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <TextBlock Text="&#x1F504;" FontSize="12"/>
          <TextBlock x:Name="ScanLabel" Text="Scan" FontSize="11" FontWeight="SemiBold"/>
        </StackPanel>
      </Button>
    </Grid>

    <!-- Stats -->
    <Border Grid.Row="1" CornerRadius="{StaticResource RadiusMd}"
            BorderThickness="1" Padding="16,10" Margin="0,0,0,12">
      <Border.Background>
        <SolidColorBrush Color="#FFFFFF" Opacity="0.025"/>
      </Border.Background>
      <Border.BorderBrush>
        <SolidColorBrush Color="#FFFFFF" Opacity="0.05"/>
      </Border.BorderBrush>
      <Grid ColumnDefinitions="*,*,*">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <Border Width="20" Height="20" CornerRadius="5" VerticalAlignment="Center">
            <Border.Background>
              <SolidColorBrush Color="#3B82F6" Opacity="0.12"/>
            </Border.Background>
            <TextBlock Text="&#x25CF;" FontSize="8" Foreground="#3B82F6"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <TextBlock Text="Total:" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
          <TextBlock x:Name="TotalCount" Text="--" FontSize="13" FontWeight="Bold"
                     Foreground="#3B82F6" VerticalAlignment="Center"/>
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
          <TextBlock Text="Applied:" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
          <TextBlock x:Name="AppliedCount" Text="--" FontSize="13" FontWeight="Bold"
                     Foreground="{DynamicResource SuccessBrush}" VerticalAlignment="Center"/>
        </StackPanel>
        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
          <TextBlock Text="Available:" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
          <TextBlock x:Name="AvailableCount" Text="--" FontSize="13" FontWeight="Bold"
                     Foreground="{DynamicResource AccentBlueBrush}" VerticalAlignment="Center"/>
        </StackPanel>
      </Grid>
    </Border>

    <!-- Tweak List -->
    <Border Grid.Row="2" CornerRadius="{StaticResource RadiusLg}"
            BorderThickness="1" Padding="4">
      <Border.Background>
        <SolidColorBrush Color="#FFFFFF" Opacity="0.025"/>
      </Border.Background>
      <Border.BorderBrush>
        <SolidColorBrush Color="#FFFFFF" Opacity="0.05"/>
      </Border.BorderBrush>
      <ScrollViewer>
        <StackPanel x:Name="TweakPanel" Spacing="2"/>
      </ScrollViewer>
    </Border>

    <!-- Apply Button -->
    <Grid Grid.Row="3" ColumnDefinitions="*,Auto" Margin="0,12,0,0">
      <TextBlock x:Name="StatusText" Text="" FontSize="11"
                 Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
      <Button Grid.Column="1" x:Name="ApplyBtn" Click="Apply_Click"
              Background="{DynamicResource AccentPrimaryBrush}" Foreground="#0A0A0F"
              Padding="20,10" CornerRadius="{StaticResource RadiusMd}"
              FontWeight="Bold" FontSize="12" IsEnabled="False">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <TextBlock Text="&#x26A1;" FontSize="12"/>
          <TextBlock x:Name="ApplyLabel" Text="Apply Selected" FontSize="12" FontWeight="Bold"/>
        </StackPanel>
      </Button>
    </Grid>
  </Grid>
</UserControl>
