<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:AuraCore.UI.Avalonia.Views.Controls"
             x:Class="AuraCore.UI.Avalonia.Views.Pages.GamingModeView">
  <ScrollViewer>
    <StackPanel Spacing="16">

      <!-- Header -->
      <controls:ModuleHeader x:Name="ModuleHdr"
                             Title=""
                             Subtitle="Boost gaming performance with one click">
        <controls:ModuleHeader.Actions>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button x:Name="ActivateBtn" Click="Activate_Click"
                    Background="{DynamicResource AccentPrimaryBrush}" Foreground="#0A0A0F"
                    Padding="20,10" CornerRadius="{StaticResource RadiusMd}"
                    FontWeight="Bold" FontSize="{DynamicResource FontSizeBody}"
                    VerticalAlignment="Center">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="⚡" FontSize="{DynamicResource FontSizeSubheading}"/>
                <TextBlock x:Name="ActivateLabel" Text=""
                           FontSize="{DynamicResource FontSizeBody}" FontWeight="Bold"/>
              </StackPanel>
            </Button>
            <!-- PageTitle: invisible, code-behind writes localized string -->
            <TextBlock x:Name="PageTitle" IsVisible="False"/>
          </StackPanel>
        </controls:ModuleHeader.Actions>
      </controls:ModuleHeader>

      <!-- Hidden bridge for code-behind subtitle writes -->
      <TextBlock x:Name="SubText"
                 Text=""
                 FontSize="{DynamicResource FontSizeBodySmall}"
                 Foreground="{DynamicResource TextSecondaryBrush}"
                 IsVisible="False"/>

      <!-- Auto-Detect Card -->
      <Border CornerRadius="{StaticResource RadiusMd}" Padding="16,12"
              BorderThickness="1" x:Name="AutoDetectBorder">
        <Border.Background>
          <SolidColorBrush Color="#A855F7" Opacity="0.06"/>
        </Border.Background>
        <Border.BorderBrush>
          <SolidColorBrush Color="#A855F7" Opacity="0.12"/>
        </Border.BorderBrush>
        <Grid ColumnDefinitions="Auto,*,Auto">
          <Border Width="10" Height="10" CornerRadius="5" x:Name="AutoDetectDot"
                  Background="#555570" VerticalAlignment="Center" Margin="0,0,12,0"/>
          <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
            <TextBlock x:Name="AutoDetectLabel" Text=""
                       FontSize="{DynamicResource FontSizeBody}" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
            <TextBlock x:Name="DetectedGameLabel" Text=""
                       FontSize="{DynamicResource FontSizeBodySmall}"
                       Foreground="{DynamicResource AccentPrimaryBrush}" IsVisible="False"/>
          </StackPanel>
          <ToggleSwitch Grid.Column="2" x:Name="AutoDetectToggle"
                        IsChecked="False" OnContent="ON" OffContent="OFF"
                        Checked="AutoDetectToggle_Changed" Unchecked="AutoDetectToggle_Changed"
                        VerticalAlignment="Center"/>
        </Grid>
      </Border>

      <!-- Status Card -->
      <controls:GlassCard x:Name="StatusBorder">
        <Grid ColumnDefinitions="Auto,*,Auto">
          <Border Width="10" Height="10" CornerRadius="5" x:Name="StatusDot"
                  Background="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
          <TextBlock Grid.Column="1" x:Name="StatusLabel" Text=""
                     FontSize="{DynamicResource FontSizeBody}" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
          <TextBlock Grid.Column="2" x:Name="PowerPlanText" Text=""
                     FontSize="{DynamicResource FontSizeBodySmall}"
                     Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
        </Grid>
      </controls:GlassCard>

      <!-- Active Session Badge (hidden until gaming mode active) -->
      <Border x:Name="ActiveBadge" IsVisible="False"
              CornerRadius="{StaticResource RadiusMd}" Padding="14,10" BorderThickness="1">
        <Border.Background>
          <SolidColorBrush Color="#22C55E" Opacity="0.08"/>
        </Border.Background>
        <Border.BorderBrush>
          <SolidColorBrush Color="#22C55E" Opacity="0.2"/>
        </Border.BorderBrush>
        <Grid ColumnDefinitions="Auto,*,Auto">
          <Border Width="8" Height="8" CornerRadius="4" Background="#22C55E"
                  VerticalAlignment="Center" Margin="0,0,10,0"/>
          <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
            <TextBlock x:Name="GamingActiveLabel" Text=""
                       FontSize="{DynamicResource FontSizeBodySmall}" FontWeight="Bold"
                       Foreground="#22C55E"/>
            <TextBlock x:Name="SessionDurationText" Text=""
                       FontSize="{DynamicResource FontSizeLabel}"
                       Foreground="{DynamicResource TextMutedBrush}"/>
          </StackPanel>
          <TextBlock Grid.Column="2" x:Name="ActiveBadgeIcon" Text="🎮"
                     FontSize="{DynamicResource FontSizeHeading}" VerticalAlignment="Center"/>
        </Grid>
      </Border>

      <!-- GPU / Network / WU Status Row (hidden until active) -->
      <Grid ColumnDefinitions="*,*,*" x:Name="StatusRowGrid" IsVisible="False">
        <!-- GPU Status -->
        <Border CornerRadius="{StaticResource RadiusMd}" Padding="10,8" Margin="0,0,3,0"
                BorderThickness="1">
          <Border.Background>
            <SolidColorBrush Color="#8B5CF6" Opacity="0.06"/>
          </Border.Background>
          <Border.BorderBrush>
            <SolidColorBrush Color="#8B5CF6" Opacity="0.12"/>
          </Border.BorderBrush>
          <StackPanel Spacing="2" HorizontalAlignment="Center">
            <TextBlock Text="GPU"
                       FontSize="{DynamicResource FontSizeLabel}" FontWeight="Bold"
                       Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
            <TextBlock x:Name="GpuStatusLabel" Text="--"
                       FontSize="{DynamicResource FontSizeLabel}" FontWeight="SemiBold"
                       Foreground="#8B5CF6" HorizontalAlignment="Center" TextAlignment="Center"
                       TextWrapping="Wrap"/>
          </StackPanel>
        </Border>
        <!-- Network QoS Status -->
        <Border Grid.Column="1" CornerRadius="{StaticResource RadiusMd}" Padding="10,8" Margin="3,0,3,0"
                BorderThickness="1">
          <Border.Background>
            <SolidColorBrush Color="#3B82F6" Opacity="0.06"/>
          </Border.Background>
          <Border.BorderBrush>
            <SolidColorBrush Color="#3B82F6" Opacity="0.12"/>
          </Border.BorderBrush>
          <StackPanel Spacing="2" HorizontalAlignment="Center">
            <TextBlock x:Name="NetworkStatLabel" Text=""
                       FontSize="{DynamicResource FontSizeLabel}" FontWeight="Bold"
                       Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
            <TextBlock x:Name="NetworkQosLabel" Text="--"
                       FontSize="{DynamicResource FontSizeLabel}" FontWeight="SemiBold"
                       Foreground="#3B82F6" HorizontalAlignment="Center" TextAlignment="Center"
                       TextWrapping="Wrap"/>
          </StackPanel>
        </Border>
        <!-- Windows Update Status -->
        <Border Grid.Column="2" CornerRadius="{StaticResource RadiusMd}" Padding="10,8" Margin="3,0,0,0"
                BorderThickness="1">
          <Border.Background>
            <SolidColorBrush Color="#F59E0B" Opacity="0.06"/>
          </Border.Background>
          <Border.BorderBrush>
            <SolidColorBrush Color="#F59E0B" Opacity="0.12"/>
          </Border.BorderBrush>
          <StackPanel Spacing="2" HorizontalAlignment="Center">
            <TextBlock x:Name="WinUpdateStatLabel" Text=""
                       FontSize="{DynamicResource FontSizeLabel}" FontWeight="Bold"
                       Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
            <TextBlock x:Name="WinUpdateLabel" Text="--"
                       FontSize="{DynamicResource FontSizeLabel}" FontWeight="SemiBold"
                       Foreground="#F59E0B" HorizontalAlignment="Center" TextAlignment="Center"
                       TextWrapping="Wrap"/>
          </StackPanel>
        </Border>
      </Grid>

      <!-- Optimizations Card -->
      <controls:GlassCard>
        <StackPanel Spacing="12">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Border Width="16" Height="16" CornerRadius="4">
              <Border.Background>
                <SolidColorBrush Color="#A855F7" Opacity="0.15"/>
              </Border.Background>
              <TextBlock Text="⚙" FontSize="{DynamicResource FontSizeLabel}" Foreground="#A855F7"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock x:Name="OptimizationsLabel" Text=""
                       FontSize="{DynamicResource FontSizeLabel}" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextMutedBrush}"/>
          </StackPanel>
          <StackPanel x:Name="TogglePanel" Spacing="6"/>
        </StackPanel>
      </controls:GlassCard>

      <!-- Background Processes Card -->
      <controls:GlassCard>
        <StackPanel Spacing="12">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Border Width="16" Height="16" CornerRadius="4">
              <Border.Background>
                <SolidColorBrush Color="#EC4899" Opacity="0.15"/>
              </Border.Background>
              <TextBlock Text="◼" FontSize="{DynamicResource FontSizeLabel}" Foreground="#EC4899"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock x:Name="BgProcessesLabel" Text=""
                       FontSize="{DynamicResource FontSizeLabel}" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextMutedBrush}"/>
          </StackPanel>
          <ScrollViewer MaxHeight="300">
            <ItemsControl x:Name="ProcessList">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Padding="12,6" Margin="2,1" CornerRadius="6">
                    <Border.Background>
                      <SolidColorBrush Color="#FFFFFF" Opacity="0.02"/>
                    </Border.Background>
                    <Grid ColumnDefinitions="Auto,*,80,80">
                      <CheckBox IsChecked="{Binding Suggest}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                      <TextBlock Grid.Column="1" Text="{Binding Name}"
                                 FontSize="{DynamicResource FontSizeBodySmall}" FontWeight="SemiBold"
                                 Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                      <TextBlock Grid.Column="2" Text="{Binding MemText}"
                                 FontSize="{DynamicResource FontSizeBodySmall}"
                                 Foreground="{DynamicResource AccentBlueBrush}" VerticalAlignment="Center"
                                 TextAlignment="Right"/>
                      <TextBlock Grid.Column="3" Text="{Binding Category}"
                                 FontSize="{DynamicResource FontSizeLabel}"
                                 Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"
                                 TextAlignment="Right"/>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </StackPanel>
      </controls:GlassCard>

    </StackPanel>
  </ScrollViewer>
</UserControl>
