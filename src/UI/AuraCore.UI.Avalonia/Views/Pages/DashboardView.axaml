<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AuraCore.UI.Avalonia.Views.Pages.DashboardView">

  <ScrollViewer>
    <StackPanel Spacing="12" MaxWidth="900">

      <!-- ── HERO ──────────────────────────────────────── -->
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Spacing="2">
          <TextBlock x:Name="HeroTitle" Text="Dashboard"
                     FontSize="22" FontWeight="Bold"
                     Foreground="{DynamicResource TextPrimaryBrush}"/>
          <TextBlock x:Name="WelcomeLabel" Text="AI Powered System Intelligence"
                     FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
        </StackPanel>
        <Border Grid.Column="1" CornerRadius="12"
                Background="#1500D4AA" Padding="10,5"
                VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Border Width="7" Height="7" CornerRadius="4"
                    Background="{DynamicResource SuccessBrush}"/>
            <TextBlock x:Name="StatusLabel" Text="LIVE"
                       FontSize="10" FontWeight="SemiBold"
                       Foreground="{DynamicResource AccentPrimaryBrush}"/>
          </StackPanel>
        </Border>
      </Grid>

      <!-- ── KPI Cards (accent stripe style) ───────────── -->
      <Grid ColumnDefinitions="*,*,*,*">
        <!-- CPU -->
        <Border Grid.Column="0" Margin="0,0,6,0" CornerRadius="{StaticResource RadiusMd}"
                Background="{DynamicResource BgCardBrush}"
                BorderBrush="{DynamicResource BorderCardBrush}" BorderThickness="1">
          <Grid>
            <Border Background="#3B82F6" Width="3" CornerRadius="8,0,0,8" HorizontalAlignment="Left"/>
            <StackPanel Margin="14,12,12,12" Spacing="6">
              <TextBlock x:Name="CpuLabel" Text="CPU" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
              <StackPanel Orientation="Horizontal" Spacing="2">
                <TextBlock x:Name="CpuValue" Text="--" FontSize="24" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Text="%" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                           VerticalAlignment="Bottom" Margin="0,0,0,4"/>
              </StackPanel>
              <Border Height="3" CornerRadius="2" Background="#1A1A28">
                <Border x:Name="CpuBar" Height="3" CornerRadius="2"
                        Background="#3B82F6" HorizontalAlignment="Left" Width="0"/>
              </Border>
            </StackPanel>
          </Grid>
        </Border>
        <!-- RAM -->
        <Border Grid.Column="1" Margin="3,0" CornerRadius="{StaticResource RadiusMd}"
                Background="{DynamicResource BgCardBrush}"
                BorderBrush="{DynamicResource BorderCardBrush}" BorderThickness="1">
          <Grid>
            <Border Background="#8B5CF6" Width="3" CornerRadius="8,0,0,8" HorizontalAlignment="Left"/>
            <StackPanel Margin="14,12,12,12" Spacing="6">
              <TextBlock x:Name="RamLabel" Text="RAM" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
              <StackPanel Orientation="Horizontal" Spacing="2">
                <TextBlock x:Name="RamValue" Text="--" FontSize="24" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock x:Name="RamTotal" Text="/ -- GB" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"
                           VerticalAlignment="Bottom" Margin="0,0,0,4"/>
              </StackPanel>
              <Border Height="3" CornerRadius="2" Background="#1A1A28">
                <Border x:Name="RamBar" Height="3" CornerRadius="2"
                        Background="#8B5CF6" HorizontalAlignment="Left" Width="0"/>
              </Border>
            </StackPanel>
          </Grid>
        </Border>
        <!-- Disk -->
        <Border Grid.Column="2" Margin="3,0" CornerRadius="{StaticResource RadiusMd}"
                Background="{DynamicResource BgCardBrush}"
                BorderBrush="{DynamicResource BorderCardBrush}" BorderThickness="1">
          <Grid>
            <Border Background="#F59E0B" Width="3" CornerRadius="8,0,0,8" HorizontalAlignment="Left"/>
            <StackPanel Margin="14,12,12,12" Spacing="6">
              <TextBlock x:Name="DiskLabel" Text="Disk (C:)" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
              <StackPanel Orientation="Horizontal" Spacing="2">
                <TextBlock x:Name="DiskValue" Text="--" FontSize="24" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Text="GB" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                           VerticalAlignment="Bottom" Margin="0,0,0,4"/>
              </StackPanel>
              <Border Height="3" CornerRadius="2" Background="#1A1A28">
                <Border x:Name="DiskBar" Height="3" CornerRadius="2"
                        Background="#F59E0B" HorizontalAlignment="Left" Width="0"/>
              </Border>
            </StackPanel>
          </Grid>
        </Border>
        <!-- Uptime -->
        <Border Grid.Column="3" Margin="6,0,0,0" CornerRadius="{StaticResource RadiusMd}"
                Background="{DynamicResource BgCardBrush}"
                BorderBrush="{DynamicResource BorderCardBrush}" BorderThickness="1">
          <Grid>
            <Border Background="#EC4899" Width="3" CornerRadius="8,0,0,8" HorizontalAlignment="Left"/>
            <StackPanel Margin="14,12,12,12" Spacing="6">
              <TextBlock x:Name="UptimeLabel" Text="Uptime" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
              <TextBlock x:Name="UptimeValue" Text="--" FontSize="22" FontWeight="Bold"
                         Foreground="{DynamicResource TextPrimaryBrush}"/>
              <TextBlock x:Name="OsLabel" Text="" FontSize="10"
                         Foreground="{DynamicResource TextMutedBrush}"/>
            </StackPanel>
          </Grid>
        </Border>
      </Grid>

      <!-- ── System Information ────────────────────────── -->
      <Border CornerRadius="{StaticResource RadiusMd}"
              Background="{DynamicResource BgCardBrush}"
              BorderBrush="{DynamicResource BorderCardBrush}" BorderThickness="1" Padding="16,14">
        <StackPanel Spacing="12">
          <TextBlock Text="System Information" FontSize="13" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextPrimaryBrush}"/>
          <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto">
            <StackPanel Grid.Row="0" Grid.Column="0" Spacing="2" Margin="0,0,12,8">
              <TextBlock Text="Operating System" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
              <TextBlock x:Name="SysOsText" Text="--" FontSize="12"
                         Foreground="{DynamicResource TextPrimaryBrush}"/>
            </StackPanel>
            <StackPanel Grid.Row="0" Grid.Column="1" Spacing="2" Margin="0,0,0,8">
              <TextBlock Text="Processor" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
              <TextBlock x:Name="SysCpuText" Text="--" FontSize="12"
                         Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
            </StackPanel>
            <StackPanel Grid.Row="1" Grid.Column="0" Spacing="2" Margin="0,0,12,0">
              <TextBlock Text="Memory" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
              <TextBlock x:Name="SysRamText" Text="--" FontSize="12"
                         Foreground="{DynamicResource TextPrimaryBrush}"/>
            </StackPanel>
            <StackPanel Grid.Row="1" Grid.Column="1" Spacing="2">
              <TextBlock Text="Uptime" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
              <TextBlock x:Name="SysUptimeText" Text="--" FontSize="12"
                         Foreground="{DynamicResource TextPrimaryBrush}"/>
            </StackPanel>
          </Grid>
        </StackPanel>
      </Border>

      <!-- ── Quick Actions ─────────────────────────────── -->
      <Border CornerRadius="{StaticResource RadiusMd}"
              Background="{DynamicResource BgCardBrush}"
              BorderBrush="{DynamicResource BorderCardBrush}" BorderThickness="1" Padding="16,14">
        <StackPanel Spacing="10">
          <TextBlock x:Name="QuickActionsLabel" Text="Quick Actions" FontSize="13" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextPrimaryBrush}"/>
          <StackPanel x:Name="QuickActionsPanel" Spacing="6"/>
        </StackPanel>
      </Border>

      <!-- ── Recent Activity ───────────────────────────── -->
      <Border CornerRadius="{StaticResource RadiusMd}"
              Background="{DynamicResource BgCardBrush}"
              BorderBrush="{DynamicResource BorderCardBrush}" BorderThickness="1" Padding="16,14">
        <StackPanel Spacing="10">
          <TextBlock Text="Recent Activity" FontSize="13" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextPrimaryBrush}"/>
          <StackPanel x:Name="ActivityLogPanel" Spacing="4">
            <TextBlock Text="No recent activity" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- ── Live indicator ────────────────────────────── -->
      <TextBlock Text="Live - updating every 2 seconds"
                 FontSize="10" Foreground="{DynamicResource TextMutedBrush}"
                 HorizontalAlignment="Center" Opacity="0.4"/>

    </StackPanel>
  </ScrollViewer>
</UserControl>
