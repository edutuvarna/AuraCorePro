<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:AuraCore.UI.Avalonia.Views.Controls"
             x:Class="AuraCore.UI.Avalonia.Views.Pages.SystemHealthView">
  <ScrollViewer>
    <StackPanel Spacing="20">

      <!-- Header -->
      <controls:ModuleHeader x:Name="ModuleHdr" Title=""
                             Subtitle="">
        <controls:ModuleHeader.Actions>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Classes="action-btn" Click="ExportPdf_Click"
                    VerticalAlignment="Center" Padding="14,8">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="&#x1F4C4;" FontSize="{DynamicResource FontSizeBody}"/>
                <TextBlock x:Name="ExportPdfLabel" Text=""
                           FontSize="{DynamicResource FontSizeBodySmall}" FontWeight="SemiBold"/>
              </StackPanel>
            </Button>
            <Button Classes="action-btn" Click="Scan_Click"
                    VerticalAlignment="Center" Padding="16,10">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="&#x1F504;" FontSize="{DynamicResource FontSizeBody}"/>
                <TextBlock x:Name="ScanBtnText" Text=""
                           FontSize="{DynamicResource FontSizeBody}" FontWeight="SemiBold"/>
              </StackPanel>
            </Button>
            <!-- PageTitle: invisible, code-behind writes localized string -->
            <TextBlock x:Name="PageTitle" IsVisible="False"/>
          </StackPanel>
        </controls:ModuleHeader.Actions>
      </controls:ModuleHeader>

      <!-- Intro Card -->
      <controls:GlassCard>
        <StackPanel Spacing="8">
          <TextBlock x:Name="IntroTitle" Text="" FontWeight="SemiBold"
                     FontSize="{DynamicResource FontSizeBody}"/>
          <TextBlock x:Name="IntroBody"
                     Text=""
                     FontSize="{DynamicResource FontSizeBodySmall}"
                     TextWrapping="Wrap"
                     Foreground="{DynamicResource TextMutedBrush}"/>
        </StackPanel>
      </controls:GlassCard>

      <!-- Health Score + System Info Row -->
      <Grid ColumnDefinitions="Auto,*">

        <!-- Health Score Badge -->
        <controls:GlassCard Grid.Column="0" Margin="0,0,16,0">
          <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8" MinWidth="148" MinHeight="148">
            <!-- Glow backdrop -->
            <Border CornerRadius="40" Width="80" Height="80" HorizontalAlignment="Center">
              <Border.Background>
                <RadialGradientBrush>
                  <GradientStop Offset="0" Color="#3B82F620"/>
                  <GradientStop Offset="1" Color="#3B82F600"/>
                </RadialGradientBrush>
              </Border.Background>
              <TextBlock x:Name="ScoreValue" Text="--" FontSize="36" FontWeight="ExtraBold"
                         Foreground="{DynamicResource AccentPrimaryBrush}"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock x:Name="HealthScoreLabel" Text="" FontSize="{DynamicResource FontSizeBodySmall}"
                       Foreground="{DynamicResource TextMutedBrush}"
                       HorizontalAlignment="Center"/>
            <Border x:Name="ScoreBadge" CornerRadius="12" Padding="12,4" HorizontalAlignment="Center"
                    Background="{DynamicResource AccentBgBrush}">
              <TextBlock x:Name="ScoreLabel" Text=""
                         FontSize="{DynamicResource FontSizeBodySmall}" FontWeight="SemiBold"
                         Foreground="{DynamicResource AccentPrimaryBrush}"/>
            </Border>
          </StackPanel>
        </controls:GlassCard>

        <!-- System Info Cards 2x2 -->
        <Grid Grid.Column="1" RowDefinitions="*,*" ColumnDefinitions="*,*">

          <!-- OS Card -->
          <controls:GlassCard Grid.Row="0" Grid.Column="0" Margin="0,0,8,8">
            <StackPanel Spacing="6">
              <Grid ColumnDefinitions="*,Auto">
                <StackPanel>
                  <TextBlock x:Name="LabelOs" Text=""
                             FontSize="{DynamicResource FontSizeLabel}" FontWeight="SemiBold"
                             Foreground="#666680"/>
                  <TextBlock x:Name="OsName" Text="--"
                             FontSize="{DynamicResource FontSizeBody}" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"
                             Margin="0,4,0,0"/>
                  <TextBlock x:Name="OsVersion" Text=""
                             FontSize="{DynamicResource FontSizeLabel}"
                             Foreground="#555570" Margin="0,2,0,0"/>
                </StackPanel>
                <Border Grid.Column="1" Width="24" Height="24" CornerRadius="6"
                        Background="#3B82F61E" Padding="4" VerticalAlignment="Top">
                  <TextBlock Text="&#x25A3;" FontSize="{DynamicResource FontSizeBodySmall}"
                             Foreground="#3B82F6"
                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
              </Grid>
            </StackPanel>
          </controls:GlassCard>

          <!-- Processor Card -->
          <controls:GlassCard Grid.Row="0" Grid.Column="1" Margin="8,0,0,8">
            <StackPanel Spacing="6">
              <Grid ColumnDefinitions="*,Auto">
                <StackPanel>
                  <TextBlock x:Name="LabelCpu" Text=""
                             FontSize="{DynamicResource FontSizeLabel}" FontWeight="SemiBold"
                             Foreground="#666680"/>
                  <TextBlock x:Name="CpuName" Text="--"
                             FontSize="{DynamicResource FontSizeBody}" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"
                             Margin="0,4,0,0"/>
                  <TextBlock x:Name="CpuCores" Text=""
                             FontSize="{DynamicResource FontSizeLabel}"
                             Foreground="#555570" Margin="0,2,0,0"/>
                </StackPanel>
                <Border Grid.Column="1" Width="24" Height="24" CornerRadius="6"
                        Background="#A855F71E" Padding="4" VerticalAlignment="Top">
                  <TextBlock Text="&#x25C6;" FontSize="{DynamicResource FontSizeBodySmall}"
                             Foreground="#A855F7"
                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
              </Grid>
            </StackPanel>
          </controls:GlassCard>

          <!-- Memory Card -->
          <controls:GlassCard Grid.Row="1" Grid.Column="0" Margin="0,8,8,0">
            <StackPanel Spacing="6">
              <Grid ColumnDefinitions="*,Auto">
                <StackPanel>
                  <TextBlock x:Name="LabelMemory" Text=""
                             FontSize="{DynamicResource FontSizeLabel}" FontWeight="SemiBold"
                             Foreground="#666680"/>
                  <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,4,0,0">
                    <TextBlock x:Name="RamUsed" Text="--" FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource AccentBlueBrush}"/>
                    <TextBlock x:Name="RamTotal" Text=""
                               FontSize="{DynamicResource FontSizeBody}"
                               Foreground="{DynamicResource TextMutedBrush}"
                               VerticalAlignment="Bottom" Margin="0,0,0,3"/>
                  </StackPanel>
                </StackPanel>
                <Border Grid.Column="1" Width="24" Height="24" CornerRadius="6"
                        Background="#14B8A61E" Padding="4" VerticalAlignment="Top">
                  <TextBlock Text="&#x25CF;" FontSize="{DynamicResource FontSizeBodySmall}"
                             Foreground="#14B8A6"
                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
              </Grid>
              <!-- Gradient progress bar -->
              <Border Height="5" CornerRadius="3" Background="#FFFFFF0A">
                <Border x:Name="RamBar" Height="5" CornerRadius="3"
                        HorizontalAlignment="Left" Width="0">
                  <Border.Background>
                    <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
                      <GradientStop Offset="0" Color="#3B82F6"/>
                      <GradientStop Offset="1" Color="#60A5FA"/>
                    </LinearGradientBrush>
                  </Border.Background>
                </Border>
              </Border>
            </StackPanel>
          </controls:GlassCard>

          <!-- Uptime Card -->
          <controls:GlassCard Grid.Row="1" Grid.Column="1" Margin="8,8,0,0">
            <StackPanel Spacing="6">
              <Grid ColumnDefinitions="*,Auto">
                <StackPanel>
                  <TextBlock x:Name="LabelUptime" Text=""
                             FontSize="{DynamicResource FontSizeLabel}" FontWeight="SemiBold"
                             Foreground="#666680"/>
                  <TextBlock x:Name="UptimeVal" Text="--" FontSize="22" FontWeight="Bold"
                             Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,4,0,0"/>
                  <TextBlock x:Name="ProcessCount" Text=""
                             FontSize="{DynamicResource FontSizeLabel}"
                             Foreground="#555570" Margin="0,2,0,0"/>
                </StackPanel>
                <Border Grid.Column="1" Width="24" Height="24" CornerRadius="6"
                        Background="#F59E0B1E" Padding="4" VerticalAlignment="Top">
                  <TextBlock Text="&#x25B2;" FontSize="{DynamicResource FontSizeBodySmall}"
                             Foreground="#F59E0B"
                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
              </Grid>
            </StackPanel>
          </controls:GlassCard>

        </Grid>
      </Grid>

      <!-- Storage Drives -->
      <controls:GlassCard>
        <StackPanel Spacing="8">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Border Width="20" Height="20" CornerRadius="6" Background="#14B8A614">
              <TextBlock Text="&#x25A3;" FontSize="{DynamicResource FontSizeBodySmall}"
                         Foreground="#14B8A6"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock x:Name="LabelStorage" Text=""
                       FontSize="{DynamicResource FontSizeBody}" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
          </StackPanel>
          <ItemsControl x:Name="DriveList">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Margin="0,0,0,8" CornerRadius="{StaticResource RadiusMd}"
                        BorderThickness="1" Padding="16">
                  <Border.Background>
                    <SolidColorBrush Color="#FFFFFF" Opacity="0.02"/>
                  </Border.Background>
                  <Border.BorderBrush>
                    <SolidColorBrush Color="#FFFFFF" Opacity="0.04"/>
                  </Border.BorderBrush>
                  <Grid RowDefinitions="Auto,Auto,Auto">
                    <Grid ColumnDefinitions="*,Auto">
                      <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="{Binding Name}"
                                   FontSize="{DynamicResource FontSizeBody}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="{Binding Label}"
                                   FontSize="{DynamicResource FontSizeBodySmall}"
                                   Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
                      </StackPanel>
                      <TextBlock Grid.Column="1" Text="{Binding SizeText}"
                                 FontSize="{DynamicResource FontSizeBody}"
                                 Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </Grid>
                    <Border Grid.Row="1" Height="5" CornerRadius="3" Background="#FFFFFF0A" Margin="0,10,0,4">
                      <Border Height="5" CornerRadius="3" Background="{Binding BarBrush}"
                              HorizontalAlignment="Left" Width="{Binding BarWidth}"/>
                    </Border>
                    <Grid Grid.Row="2" ColumnDefinitions="*,Auto">
                      <TextBlock Text="{Binding FreeText}"
                                 FontSize="{DynamicResource FontSizeBodySmall}"
                                 Foreground="{DynamicResource TextMutedBrush}"/>
                      <TextBlock Grid.Column="1" Text="{Binding UsedPct}"
                                 FontSize="{DynamicResource FontSizeBodySmall}" FontWeight="SemiBold"
                                 Foreground="{Binding PctBrush}"/>
                    </Grid>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </controls:GlassCard>

      <!-- CPU Cores -->
      <controls:GlassCard>
        <StackPanel Spacing="8">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Border Width="20" Height="20" CornerRadius="6" Background="#3B82F614">
              <TextBlock Text="&#x25C6;" FontSize="{DynamicResource FontSizeBodySmall}"
                         Foreground="#3B82F6"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock x:Name="LabelCpuCores" Text=""
                       FontSize="{DynamicResource FontSizeBody}" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
          </StackPanel>
          <StackPanel x:Name="CpuCoresPanel" Spacing="6"/>
        </StackPanel>
      </controls:GlassCard>

      <!-- GPU Section (conditionally visible) -->
      <StackPanel x:Name="GpuHeader" Orientation="Horizontal" Spacing="8" IsVisible="False">
        <Border Width="20" Height="20" CornerRadius="6" Background="#A855F714">
          <TextBlock Text="&#x25B6;" FontSize="{DynamicResource FontSizeBodySmall}"
                     Foreground="#A855F7"
                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
        <TextBlock x:Name="LabelGraphics" Text=""
                   FontSize="{DynamicResource FontSizeBody}" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
      </StackPanel>

      <ItemsControl x:Name="GpuList">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Margin="0,0,0,8" CornerRadius="{StaticResource RadiusMd}"
                    BorderThickness="1" Padding="16">
              <Border.Background>
                <SolidColorBrush Color="#FFFFFF" Opacity="0.02"/>
              </Border.Background>
              <Border.BorderBrush>
                <SolidColorBrush Color="#FFFFFF" Opacity="0.04"/>
              </Border.BorderBrush>
              <Grid ColumnDefinitions="*,Auto">
                <StackPanel Spacing="4">
                  <TextBlock Text="{Binding Name}"
                             FontSize="{DynamicResource FontSizeBody}" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextPrimaryBrush}"/>
                  <TextBlock Text="{Binding Detail}"
                             FontSize="{DynamicResource FontSizeBodySmall}"
                             Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
                <Border Grid.Column="1" Width="24" Height="24" CornerRadius="6"
                        Background="#A855F71E" Padding="4" VerticalAlignment="Top">
                  <TextBlock Text="&#x25B6;" FontSize="{DynamicResource FontSizeBodySmall}"
                             Foreground="#A855F7"
                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

    </StackPanel>
  </ScrollViewer>
</UserControl>
