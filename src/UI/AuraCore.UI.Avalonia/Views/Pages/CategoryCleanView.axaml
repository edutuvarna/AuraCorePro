<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:AuraCore.UI.Avalonia.Views.Controls"
             x:Class="AuraCore.UI.Avalonia.Views.Pages.CategoryCleanView">
  <ScrollViewer>
    <StackPanel Spacing="16">

      <!-- Header -->
      <controls:ModuleHeader Title="Cleanup"
                             Subtitle="Scan and clean system files">
        <controls:ModuleHeader.Actions>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button x:Name="ExcludeListBtn" Classes="action-btn" Click="ExcludeList_Click"
                    VerticalAlignment="Center" Padding="10,8" IsVisible="False"
                    ToolTip.Tip="Manage exclude list">
              <StackPanel Orientation="Horizontal" Spacing="4">
                <TextBlock Text="&#x1F6AB;" FontSize="{DynamicResource FontSizeBody}"/>
                <TextBlock Text="Excludes"
                           FontSize="{DynamicResource FontSizeLabel}" FontWeight="SemiBold"/>
              </StackPanel>
            </Button>
            <Button Classes="action-btn" Click="Scan_Click"
                    VerticalAlignment="Center" Padding="14,8">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="&#x1F50D;" FontSize="{DynamicResource FontSizeBody}"/>
                <TextBlock x:Name="ScanLabel" Text="Scan"
                           FontSize="{DynamicResource FontSizeBodySmall}" FontWeight="SemiBold"/>
              </StackPanel>
            </Button>
            <!-- PageTitle: invisible, code-behind writes localized string -->
            <TextBlock x:Name="PageTitle" IsVisible="False"/>
          </StackPanel>
        </controls:ModuleHeader.Actions>
      </controls:ModuleHeader>

      <!-- Hidden bridge TextBlocks — code-behind writes via .Text -->
      <StackPanel IsVisible="False" Height="0">
        <TextBlock x:Name="PageSubtitle" Text="Scan and clean system files"/>
      </StackPanel>

      <!-- AI Recommendation Badge (only visible when disk pressure > 85%) -->
      <Border x:Name="AiBadge" CornerRadius="{StaticResource RadiusMd}" BorderThickness="1"
              Padding="12,8" IsVisible="False">
        <Border.Background>
          <SolidColorBrush Color="#F59E0B" Opacity="0.08"/>
        </Border.Background>
        <Border.BorderBrush>
          <SolidColorBrush Color="#F59E0B" Opacity="0.25"/>
        </Border.BorderBrush>
        <Grid ColumnDefinitions="Auto,*,Auto">
          <Border CornerRadius="10" Background="#30F59E0B" Padding="6,3" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <TextBlock Text="&#x1F916;" FontSize="{DynamicResource FontSizeLabel}"/>
              <TextBlock Text="AI" FontSize="{DynamicResource FontSizeLabel}" FontWeight="Bold" Foreground="#F59E0B"/>
            </StackPanel>
          </Border>
          <TextBlock Grid.Column="1" x:Name="AiBadgeText" FontSize="{DynamicResource FontSizeBodySmall}"
                     Margin="10,0,0,0" Foreground="#F5C563" VerticalAlignment="Center" TextWrapping="Wrap"
                     Text="Disk pressure is high. Running a cleanup is recommended."/>
          <TextBlock Grid.Column="2" x:Name="AiBadgeSavings" FontSize="{DynamicResource FontSizeBody}"
                     FontWeight="Bold" Foreground="#F59E0B" VerticalAlignment="Center" Margin="10,0,0,0"/>
        </Grid>
      </Border>

      <!-- Stats Card -->
      <controls:GlassCard>
        <Grid ColumnDefinitions="*,*,*,Auto">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="Categories:"
                       FontSize="{DynamicResource FontSizeBodySmall}"
                       Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
            <TextBlock x:Name="CatCount" Text="--"
                       FontSize="{DynamicResource FontSizeBody}" FontWeight="Bold"
                       Foreground="{DynamicResource AccentPrimaryBrush}" VerticalAlignment="Center"/>
          </StackPanel>
          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
            <TextBlock Text="Files:"
                       FontSize="{DynamicResource FontSizeBodySmall}"
                       Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
            <TextBlock x:Name="FileCount" Text="--"
                       FontSize="{DynamicResource FontSizeBody}" FontWeight="Bold"
                       Foreground="{DynamicResource AccentBlueBrush}" VerticalAlignment="Center"/>
          </StackPanel>
          <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
            <TextBlock Text="Total Size:"
                       FontSize="{DynamicResource FontSizeBodySmall}"
                       Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
            <TextBlock x:Name="TotalSize" Text="--"
                       FontSize="{DynamicResource FontSizeBody}" FontWeight="Bold"
                       Foreground="{DynamicResource AccentPurpleBrush}" VerticalAlignment="Center"/>
          </StackPanel>
          <Button Grid.Column="3" Classes="action-btn" Click="SelectAll_Click"
                  Padding="10,4" VerticalAlignment="Center">
            <TextBlock x:Name="SelectAllLabel" Text="Select All"
                       FontSize="{DynamicResource FontSizeLabel}" FontWeight="SemiBold"/>
          </Button>
        </Grid>
      </controls:GlassCard>

      <!-- Category List Card -->
      <controls:GlassCard>
        <ScrollViewer>
          <StackPanel x:Name="CategoryPanel" Spacing="6"/>
        </ScrollViewer>
      </controls:GlassCard>

      <!-- History Section (collapsible, junk-cleaner only) -->
      <Border x:Name="HistorySection" CornerRadius="{StaticResource RadiusMd}" BorderThickness="1"
              Padding="0" Margin="0" IsVisible="False">
        <Border.Background>
          <SolidColorBrush Color="#FFFFFF" Opacity="0.02"/>
        </Border.Background>
        <Border.BorderBrush>
          <SolidColorBrush Color="#FFFFFF" Opacity="0.04"/>
        </Border.BorderBrush>
        <Expander Header="Cleanup History" Padding="10,4" IsExpanded="False">
          <ScrollViewer MaxHeight="140">
            <StackPanel x:Name="HistoryPanel" Spacing="3"/>
          </ScrollViewer>
        </Expander>
      </Border>

      <!-- Clean Button Row -->
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock x:Name="StatusText" Text=""
                   FontSize="{DynamicResource FontSizeBodySmall}"
                   Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
        <Button Grid.Column="1" x:Name="CleanBtn" Click="Clean_Click"
                Background="{DynamicResource AccentPrimaryBrush}" Foreground="#0A0A0F"
                Padding="20,10" CornerRadius="{StaticResource RadiusMd}"
                FontWeight="Bold" FontSize="{DynamicResource FontSizeBody}" IsEnabled="False">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="&#x2702;" FontSize="{DynamicResource FontSizeBody}"/>
            <TextBlock x:Name="CleanLabel" Text="Clean Selected"
                       FontSize="{DynamicResource FontSizeBody}" FontWeight="Bold"/>
          </StackPanel>
        </Button>
      </Grid>

    </StackPanel>
  </ScrollViewer>
</UserControl>
