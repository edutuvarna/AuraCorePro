<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:AuraCore.UI.Avalonia.Views.Controls"
        x:Class="AuraCore.UI.Avalonia.Views.MainWindow"
        Title="AuraCore Pro"
        Width="900" Height="600"
        MinWidth="780" MinHeight="520"
        Background="{DynamicResource BgDeepBrush}"
        WindowStartupLocation="CenterScreen"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="40">

  <Grid ColumnDefinitions="190,*">

    <!-- ══ SIDEBAR ══════════════════════════════════════════ -->
    <Border Grid.Column="0"
            Background="{DynamicResource SidebarBgBrush}"
            BorderBrush="{DynamicResource BorderSubtleBrush}"
            BorderThickness="0,0,1,0">
      <Grid RowDefinitions="Auto,*,Auto">

        <!-- Logo + Title -->
        <StackPanel Grid.Row="0" Margin="12,10,12,10" Spacing="4">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <ctrl:OrbitalLogo Width="26" Height="26"/>
            <StackPanel VerticalAlignment="Center">
              <TextBlock Text="AuraCore" FontSize="13" FontWeight="Bold"
                         Foreground="{DynamicResource TextPrimaryBrush}"/>
              <TextBlock Text="PRO v1.7" FontSize="8"
                         Foreground="{DynamicResource TextMutedBrush}" FontWeight="SemiBold"/>
            </StackPanel>
          </StackPanel>
          <!-- User + Tier Badge -->
          <Border CornerRadius="8" Padding="8,7" Margin="0,6,0,0"
                  BorderThickness="1">
            <Border.Background>
              <SolidColorBrush Color="#FFFFFF" Opacity="0.024"/>
            </Border.Background>
            <Border.BorderBrush>
              <SolidColorBrush Color="#FFFFFF" Opacity="0.05"/>
            </Border.BorderBrush>
            <Grid ColumnDefinitions="Auto,*,Auto">
              <Border Width="26" Height="26" CornerRadius="6">
                <Border.Background>
                  <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                    <GradientStop Offset="0" Color="#8B5CF6"/>
                    <GradientStop Offset="1" Color="#EC4899"/>
                  </LinearGradientBrush>
                </Border.Background>
                <TextBlock x:Name="UserAvatarInitials" Text="G" FontSize="10" FontWeight="Bold"
                           Foreground="White" HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
              </Border>
              <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1" Margin="8,0,0,0">
                <TextBlock x:Name="UserEmailLabel" Text="Guest" FontSize="10.5" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis"/>
                <TextBlock x:Name="UserStatusLabel" Text="Not signed in" FontSize="8"
                           FontWeight="Bold" Foreground="{DynamicResource AccentPrimaryBrush}"/>
              </StackPanel>
              <Border Grid.Column="2" x:Name="TierBadge" CornerRadius="6"
                      Padding="6,2" VerticalAlignment="Center" Background="#2000D4AA">
                <TextBlock x:Name="TierBadgeText" Text="FREE" FontSize="8" FontWeight="Bold"
                           Foreground="{DynamicResource AccentPrimaryBrush}"/>
              </Border>
            </Grid>
          </Border>
        </StackPanel>

        <!-- Dynamic Navigation (built from code-behind) -->
        <ScrollViewer Grid.Row="1" Margin="5,0">
          <StackPanel x:Name="NavPanel" Spacing="1"/>
        </ScrollViewer>

        <!-- Bottom: Platform + Settings -->
        <StackPanel Grid.Row="2" Margin="8,0,8,10" Spacing="4">
          <Border Background="{DynamicResource BgCardBrush}"
                  CornerRadius="{StaticResource RadiusSm}"
                  Padding="10,6" Margin="0,0,0,6">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Border Width="8" Height="8" CornerRadius="4"
                      Background="{DynamicResource SuccessBrush}"/>
              <TextBlock x:Name="PlatformLabel" Text="Windows"
                         FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
            </StackPanel>
          </Border>
          <Button Tag="settings" Classes="nav-item" Click="Nav_Click">
            <StackPanel Orientation="Horizontal" Spacing="10">
              <TextBlock Text="&#x2699;" FontSize="14" VerticalAlignment="Center"/>
              <TextBlock x:Name="SettingsNavLabel" Text="Settings" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>
        </StackPanel>

      </Grid>
    </Border>

    <!-- ══ CONTENT AREA ═════════════════════════════════════ -->
    <Border Grid.Column="1" Background="{DynamicResource BgDeepBrush}">
      <Grid RowDefinitions="*,Auto">
        <ContentControl x:Name="ContentArea" Margin="20"/>

        <!-- ── Global Status Bar ─────────────────────────── -->
        <Border Grid.Row="1" Padding="12,5" BorderThickness="0,1,0,0">
          <Border.Background>
            <SolidColorBrush Color="#0A0A14" Opacity="0.95"/>
          </Border.Background>
          <Border.BorderBrush>
            <SolidColorBrush Color="#FFFFFF" Opacity="0.05"/>
          </Border.BorderBrush>
          <Grid ColumnDefinitions="*,Auto,Auto">
            <!-- Left: Status text -->
            <TextBlock x:Name="GlobalStatusText" Text="Ready" FontSize="10"
                       Foreground="{DynamicResource TextMutedBrush}"
                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
            <!-- Center: Progress info -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6"
                        VerticalAlignment="Center" Margin="16,0">
              <TextBlock x:Name="GlobalProgressText" Text="" FontSize="10"
                         Foreground="{DynamicResource AccentPrimaryBrush}"/>
              <Border x:Name="GlobalProgressBarBorder" Width="80" Height="4"
                      CornerRadius="2" IsVisible="False"
                      VerticalAlignment="Center">
                <Border.Background>
                  <SolidColorBrush Color="#FFFFFF" Opacity="0.06"/>
                </Border.Background>
                <Border x:Name="GlobalProgressBarFill" HorizontalAlignment="Left"
                        Width="0" Height="4" CornerRadius="2">
                  <Border.Background>
                    <SolidColorBrush Color="#00D4AA"/>
                  </Border.Background>
                </Border>
              </Border>
            </StackPanel>
            <!-- Right: Memory usage -->
            <TextBlock Grid.Column="2" x:Name="GlobalMemoryText" Text="" FontSize="10"
                       Foreground="{DynamicResource TextMutedBrush}"
                       VerticalAlignment="Center"/>
          </Grid>
        </Border>
      </Grid>
    </Border>

  </Grid>
</Window>
