<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AuraCore.UI.Avalonia.App"
             RequestedThemeVariant="Dark">

  <Application.Styles>
    <FluentTheme />
    <StyleInclude Source="avares://AuraCore.Pro/Themes/AuraCoreTheme.axaml" />
    <StyleInclude Source="avares://AuraCore.Pro/Themes/AuraCoreThemeV2.axaml"/>
    <StyleInclude Source="avares://AuraCore.Pro/Themes/Icons.axaml"/>
  </Application.Styles>
</Application>
