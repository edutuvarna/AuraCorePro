<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="AuraCore.Desktop.Pages.PrivacyCleanerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer Padding="32">
        <StackPanel Spacing="20" MaxWidth="960">

            <StackPanel Spacing="4">
                <TextBlock x:Name="PageTitle" Text="Privacy Cleaner" Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock x:Name="PageSubtitle" Text="Remove privacy-sensitive data traces from your system"
                           Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <InfoBar x:Name="PrivacyWarning" Title="Browser data will be deleted"
                     Message="Cleaning browser history, cookies, or cache will log you out of websites and remove saved form data."
                     Severity="Warning" IsOpen="False" IsClosable="True" />

            <!-- Action Buttons -->
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button x:Name="ScanBtn" Content="Scan Privacy Data" Click="ScanBtn_Click"
                        Style="{StaticResource AccentButtonStyle}" Padding="24,10" />
                <Button x:Name="CleanBtn" Content="Clean Selected (0)" Click="CleanBtn_Click"
                        Padding="24,10" IsEnabled="False" />
                <ProgressRing x:Name="Progress" IsActive="False" Visibility="Collapsed" Width="28" Height="28" />
                <TextBlock x:Name="StatusText" Text="Click Scan to find privacy-sensitive data"
                           VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <!-- Summary Card -->
            <Border x:Name="SummaryCard" Visibility="Collapsed"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <Grid ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="2">
                        <TextBlock Text="Total Size" FontSize="11" Opacity="0.5" />
                        <TextBlock x:Name="TotalSizeText" Text="0" FontSize="22" FontWeight="Bold" Foreground="#E040FB" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="2">
                        <TextBlock Text="Items Found" FontSize="11" Opacity="0.5" />
                        <TextBlock x:Name="TotalItemsText" Text="0" FontSize="22" FontWeight="Bold" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="2">
                        <TextBlock Text="Categories" FontSize="11" Opacity="0.5" />
                        <TextBlock x:Name="TotalCategoriesText" Text="0" FontSize="22" FontWeight="Bold" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Category List -->
            <StackPanel x:Name="CategoryList" Spacing="8" />

            <!-- Result Card -->
            <Border x:Name="ResultCard" Visibility="Collapsed"
                    CornerRadius="8" Padding="20" BorderThickness="1"
                    Background="#1A7B1FA2" BorderBrush="#337B1FA2">
                <StackPanel Spacing="4" HorizontalAlignment="Center">
                    <TextBlock x:Name="ResultTitle" Text="" FontSize="18" FontWeight="Bold"
                               Foreground="#E040FB" HorizontalAlignment="Center" />
                    <TextBlock x:Name="ResultDetail" Text="" FontSize="13" Opacity="0.6" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
