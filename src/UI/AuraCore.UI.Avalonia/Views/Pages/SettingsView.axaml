<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AuraCore.UI.Avalonia.Views.Pages.SettingsView">
  <ScrollViewer>
    <StackPanel Spacing="20">

      <!-- Header -->
      <StackPanel Spacing="4">
        <TextBlock x:Name="HeaderTitle" Text="Settings" FontSize="16" FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>
        <TextBlock x:Name="HeaderSub" Text="Configure AuraCore Pro preferences"
                   FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"/>
      </StackPanel>

      <!-- Appearance -->
      <Border CornerRadius="{StaticResource RadiusLg}" BorderThickness="1" Padding="16">
        <Border.Background>
          <SolidColorBrush Color="#FFFFFF" Opacity="0.025"/>
        </Border.Background>
        <Border.BorderBrush>
          <SolidColorBrush Color="#FFFFFF" Opacity="0.05"/>
        </Border.BorderBrush>
        <StackPanel Spacing="12">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Border Width="16" Height="16" CornerRadius="4">
              <Border.Background>
                <SolidColorBrush Color="#14B8A6" Opacity="0.15"/>
              </Border.Background>
              <TextBlock Text="&#x25CF;" FontSize="8" Foreground="#14B8A6"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock x:Name="AppearanceLabel" Text="Appearance" FontSize="13" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
          </StackPanel>
          <Grid ColumnDefinitions="*,Auto">
            <StackPanel>
              <TextBlock x:Name="ThemeKeyLabel" Text="Theme" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}"/>
              <TextBlock x:Name="ThemeDescLabel" Text="Choose between dark and light mode" FontSize="11"
                         Foreground="{DynamicResource TextMutedBrush}"/>
            </StackPanel>
            <Button Grid.Column="1" x:Name="ThemeToggleBtn" Click="ThemeToggle_Click"
                    CornerRadius="{StaticResource RadiusMd}"
                    Background="#12FFFFFF" Padding="14,8" Cursor="Hand">
              <TextBlock x:Name="ThemeLabel" Text="Dark" FontSize="12" FontWeight="SemiBold"
                         Foreground="{DynamicResource AccentPrimaryBrush}"/>
            </Button>
          </Grid>
          <Grid ColumnDefinitions="*,Auto">
            <StackPanel>
              <TextBlock x:Name="LangKeyLabel" Text="Language" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}"/>
              <TextBlock x:Name="LangDescLabel" Text="Interface language" FontSize="11"
                         Foreground="{DynamicResource TextMutedBrush}"/>
            </StackPanel>
            <Button Grid.Column="1" x:Name="LangToggleBtn" Click="LangToggle_Click"
                    CornerRadius="{StaticResource RadiusMd}"
                    Background="#12FFFFFF" Padding="14,8" Cursor="Hand">
              <TextBlock x:Name="LangLabel" Text="English" FontSize="12" FontWeight="SemiBold"
                         Foreground="{DynamicResource AccentPrimaryBrush}"/>
            </Button>
          </Grid>
        </StackPanel>
      </Border>

      <!-- AI Telemetry -->
      <Border CornerRadius="{StaticResource RadiusLg}" BorderThickness="1" Padding="16">
        <Border.Background>
          <SolidColorBrush Color="#FFFFFF" Opacity="0.025"/>
        </Border.Background>
        <Border.BorderBrush>
          <SolidColorBrush Color="#FFFFFF" Opacity="0.05"/>
        </Border.BorderBrush>
        <StackPanel Spacing="12">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Border Width="16" Height="16" CornerRadius="4">
              <Border.Background>
                <SolidColorBrush Color="#14B8A6" Opacity="0.15"/>
              </Border.Background>
              <TextBlock Text="&#x1F9E0;" FontSize="8" Foreground="#14B8A6"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock x:Name="AiTelemetryLabel" Text="AI Telemetry" FontSize="13" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
          </StackPanel>
          <Grid ColumnDefinitions="*,Auto">
            <StackPanel>
              <TextBlock x:Name="AiTelemetryDescLabel" Text="Share anonymous AI data" FontSize="12"
                         Foreground="{DynamicResource TextPrimaryBrush}"/>
              <TextBlock x:Name="AiTelemetryNoteLabel" Text="CPU/RAM averages, disk trends. No personal data."
                         FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
            </StackPanel>
            <ToggleSwitch Grid.Column="1" x:Name="AiTelemetryToggle"
                          OnContent="On" OffContent="Off"
                          IsCheckedChanged="AiTelemetryToggle_Changed"/>
          </Grid>
        </StackPanel>
      </Border>

      <!-- Replaces the removed AI model picker. Task 14+ will add the AI Features page icon. -->
      <Border Classes="info-card" Margin="0,12,0,0"
              Background="#14B088FF"
              BorderBrush="#33B088FF"
              BorderThickness="1"
              CornerRadius="6"
              Padding="12,10">
        <StackPanel Orientation="Horizontal" Spacing="10">
          <TextBlock Text="&#x2756;"
                     FontSize="14"
                     Foreground="{DynamicResource AccentPurpleBrush}"
                     VerticalAlignment="Center" />
          <TextBlock VerticalAlignment="Center"
                     TextWrapping="Wrap"
                     Foreground="{DynamicResource TextSecondaryBrush}"
                     Text="AI models are managed in AI Features &#x2192; Chat. Open Chat to download or switch models." />
        </StackPanel>
      </Border>

      <!-- About -->
      <Border CornerRadius="{StaticResource RadiusLg}" BorderThickness="1" Padding="16">
        <Border.Background>
          <SolidColorBrush Color="#FFFFFF" Opacity="0.025"/>
        </Border.Background>
        <Border.BorderBrush>
          <SolidColorBrush Color="#FFFFFF" Opacity="0.05"/>
        </Border.BorderBrush>
        <StackPanel Spacing="12">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Border Width="16" Height="16" CornerRadius="4">
              <Border.Background>
                <SolidColorBrush Color="#14B8A6" Opacity="0.15"/>
              </Border.Background>
              <TextBlock Text="&#x2139;" FontSize="8" Foreground="#14B8A6"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock x:Name="AboutLabel" Text="About" FontSize="13" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
          </StackPanel>
          <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto">
            <TextBlock Text="Version" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                       Margin="0,0,24,8"/>
            <TextBlock Grid.Column="1" Text="1.7.0 (Avalonia Cross-Platform)" FontSize="12"
                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
            <TextBlock Grid.Row="1" Text="Runtime" FontSize="12"
                       Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,24,8"/>
            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="RuntimeLabel" Text=".NET 8"
                       FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
            <TextBlock Grid.Row="2" Text="Platform" FontSize="12"
                       Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,24,8"/>
            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="PlatformLabel" Text="Windows"
                       FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
            <TextBlock Grid.Row="3" Text="UI Framework" FontSize="12"
                       Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,24,0"/>
            <TextBlock Grid.Row="3" Grid.Column="1" Text="Avalonia 11.2" FontSize="12"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
          </Grid>
        </StackPanel>
      </Border>

      <!-- Account -->
      <Border CornerRadius="{StaticResource RadiusLg}" BorderThickness="1" Padding="16">
        <Border.Background>
          <SolidColorBrush Color="#FFFFFF" Opacity="0.025"/>
        </Border.Background>
        <Border.BorderBrush>
          <SolidColorBrush Color="#FFFFFF" Opacity="0.05"/>
        </Border.BorderBrush>
        <StackPanel Spacing="12">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Border Width="16" Height="16" CornerRadius="4">
              <Border.Background>
                <SolidColorBrush Color="#14B8A6" Opacity="0.15"/>
              </Border.Background>
              <TextBlock Text="&#x25CB;" FontSize="8" Foreground="#14B8A6"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock x:Name="AccountLabel" Text="Account" FontSize="13" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
          </StackPanel>
          <Grid ColumnDefinitions="*,Auto">
            <StackPanel>
              <TextBlock x:Name="AccountEmail" Text="Not signed in" FontSize="12"
                         Foreground="{DynamicResource TextPrimaryBrush}"/>
              <TextBlock x:Name="AccountTier" Text="Free" FontSize="11"
                         Foreground="{DynamicResource TextMutedBrush}"/>
            </StackPanel>
            <Button Grid.Column="1" x:Name="LogoutBtn" Click="Logout_Click"
                    Background="{DynamicResource ErrorBgBrush}" Foreground="#EF4444"
                    Padding="16,8" CornerRadius="{StaticResource RadiusMd}"
                    FontWeight="SemiBold" FontSize="12" Content="Sign Out"/>
          </Grid>
        </StackPanel>
      </Border>

      <!-- Links -->
      <Border CornerRadius="{StaticResource RadiusLg}"
              Background="{DynamicResource AccentBgBrush}" Padding="16,12"
              BorderBrush="{DynamicResource AccentBorderBrush}" BorderThickness="1">
        <Grid ColumnDefinitions="Auto,*">
          <TextBlock Text="&#x1F310;" FontSize="16" VerticalAlignment="Center" Margin="0,0,12,0"/>
          <TextBlock Grid.Column="1" Text="auracore.pro - Windows Optimization SaaS"
                     FontSize="12" Foreground="{DynamicResource AccentPrimaryBrush}"
                     VerticalAlignment="Center"/>
        </Grid>
      </Border>

    </StackPanel>
  </ScrollViewer>
</UserControl>
