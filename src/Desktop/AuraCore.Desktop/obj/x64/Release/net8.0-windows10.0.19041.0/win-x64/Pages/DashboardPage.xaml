<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="AuraCore.Desktop.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer Padding="32">
        <StackPanel Spacing="24" MaxWidth="900">

            <StackPanel Spacing="4">
                <TextBlock x:ConnectionId='31' x:Name="PageTitle" Text="Dashboard" Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock x:ConnectionId='32' x:Name="WelcomeText" Text="AI Powered Windows Intelligence"
                           Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <!-- Live Stats -->
            <Grid ColumnSpacing="12" RowSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="16" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <StackPanel Spacing="6">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE950;" FontSize="14" Foreground="#3B82F6" />
                            <TextBlock Text="CPU" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                        <TextBlock x:ConnectionId='28' x:Name="CpuText" Text="--%" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <ProgressBar x:ConnectionId='29' x:Name="CpuBar" Minimum="0" Maximum="100" Height="6" CornerRadius="3" Foreground="#3B82F6" />
                        <TextBlock x:ConnectionId='30' x:Name="CpuDetail" Text="" FontSize="11" Opacity="0.5" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="16" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <StackPanel Spacing="6">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE964;" FontSize="14" Foreground="#8B5CF6" />
                            <TextBlock Text="RAM" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                        <TextBlock x:ConnectionId='25' x:Name="RamText" Text="--%" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <ProgressBar x:ConnectionId='26' x:Name="RamBar" Minimum="0" Maximum="100" Height="6" CornerRadius="3" Foreground="#8B5CF6" />
                        <TextBlock x:ConnectionId='27' x:Name="RamDetail" Text="" FontSize="11" Opacity="0.5" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="16" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <StackPanel Spacing="6">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xEDA2;" FontSize="14" Foreground="#F59E0B" />
                            <TextBlock Text="Disk (C:)" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                        <TextBlock x:ConnectionId='22' x:Name="DiskText" Text="--%" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <ProgressBar x:ConnectionId='23' x:Name="DiskBar" Minimum="0" Maximum="100" Height="6" CornerRadius="3" Foreground="#F59E0B" />
                        <TextBlock x:ConnectionId='24' x:Name="DiskDetail" Text="" FontSize="11" Opacity="0.5" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="16" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <StackPanel Spacing="6">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE95E;" FontSize="14" Foreground="#10B981" />
                            <TextBlock Text="Health" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                        <TextBlock x:ConnectionId='19' x:Name="HealthText" Text="--" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <ProgressBar x:ConnectionId='20' x:Name="HealthBar" Minimum="0" Maximum="100" Height="6" CornerRadius="3" Foreground="#10B981" />
                        <TextBlock x:ConnectionId='21' x:Name="HealthDetail" Text="" FontSize="11" Opacity="0.5" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- System Info -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="6">
                    <TextBlock Text="System Information" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <TextBlock x:ConnectionId='15' x:Name="OsText" FontSize="13" Opacity="0.7" />
                    <TextBlock x:ConnectionId='16' x:Name="CpuNameText" FontSize="13" Opacity="0.7" />
                    <TextBlock x:ConnectionId='17' x:Name="RamTotalText" FontSize="13" Opacity="0.7" />
                    <TextBlock x:ConnectionId='18' x:Name="UptimeText" FontSize="13" Opacity="0.7" />
                </StackPanel>
            </Border>

            <!-- AI Tip -->
            <Border x:ConnectionId='2' x:Name="AiTipCard" Visibility="Collapsed"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <FontIcon x:ConnectionId='11' x:Name="AiTipIcon" Grid.Column="0" Glyph="&#xE99A;" FontSize="24" VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                        <TextBlock x:ConnectionId='13' x:Name="AiTipTitle" Text="" FontWeight="SemiBold" FontSize="14" />
                        <TextBlock x:ConnectionId='14' x:Name="AiTipDesc" Text="" FontSize="12" Opacity="0.7" TextWrapping="Wrap" />
                    </StackPanel>
                    <Button x:ConnectionId='12' x:Name="AiTipAction" Grid.Column="2" Content="Fix" Padding="16,8"
                            VerticalAlignment="Center"                           Visibility="Collapsed" />
                </Grid>
            </Border>

            <!-- Quick Actions -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE945;" FontSize="16" Foreground="#06B6D4" />
                        <TextBlock Text="Quick Actions" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:ConnectionId='8'                         Padding="16,10" CornerRadius="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE74D;" FontSize="14" />
                                <TextBlock Text="Scan Junk" />
                            </StackPanel>
                        </Button>
                        <Button x:ConnectionId='9'                        Padding="16,10" CornerRadius="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE964;" FontSize="14" />
                                <TextBlock Text="Optimize RAM" />
                            </StackPanel>
                        </Button>
                        <Button x:ConnectionId='10'                           Padding="16,10" CornerRadius="8"
                                Style="{StaticResource AccentButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE95E;" FontSize="14" />
                                <TextBlock Text="Health Scan" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    <TextBlock x:ConnectionId='7' x:Name="QuickActionStatus" Text="" FontSize="12"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>

            <!-- Disk Full Prediction -->
            <Border x:ConnectionId='3' x:Name="DiskPredictionCard" Visibility="Collapsed"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <FontIcon Glyph="&#xEDA2;" FontSize="20" Foreground="#F59E0B" />
                    <StackPanel Spacing="2">
                        <TextBlock Text="Disk Space Prediction" FontWeight="SemiBold" FontSize="13" />
                        <TextBlock x:ConnectionId='6' x:Name="DiskPredictionText" Text="" FontSize="12" Opacity="0.7" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Recent Activity Log -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE9D5;" FontSize="16" Foreground="#8B5CF6" />
                        <TextBlock Text="Recent Activity" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    </StackPanel>
                    <StackPanel x:ConnectionId='5' x:Name="ActivityLogPanel" Spacing="4">
                        <TextBlock Text="No recent activity" FontSize="12" Opacity="0.4" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Live indicator -->
            <TextBlock x:ConnectionId='4' x:Name="LiveText" Text="Live — updating every 3 seconds"
                       FontSize="11" Opacity="0.3" HorizontalAlignment="Center" />

        </StackPanel>
    </ScrollViewer>
</Page>

