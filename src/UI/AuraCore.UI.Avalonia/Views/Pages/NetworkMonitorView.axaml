<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:AuraCore.UI.Avalonia.Views.Controls"
             x:Class="AuraCore.UI.Avalonia.Views.Pages.NetworkMonitorView">
  <ScrollViewer>
    <StackPanel Spacing="16">

      <!-- Header -->
      <controls:ModuleHeader x:Name="ModuleHdr"
                             Title=""
                             Subtitle="Real-time network interface statistics and per-adapter bandwidth">
        <controls:ModuleHeader.Actions>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button x:Name="RefreshBtn" Content="" Click="Scan_Click" Classes="action-btn" Padding="14,8"
                    VerticalAlignment="Center"/>
            <!-- PageTitle: invisible, code-behind writes localized string -->
            <TextBlock x:Name="PageTitle" IsVisible="False"/>
          </StackPanel>
        </controls:ModuleHeader.Actions>
      </controls:ModuleHeader>

      <!-- Stats row -->
      <controls:StatRow>
        <controls:StatCard x:Name="StatIfaces"
                           Value="{Binding #IfaceCount.Text}"
                           ValueBrush="{DynamicResource TextPrimaryBrush}"/>
        <controls:StatCard x:Name="StatSent"
                           Value="{Binding #TotalSent.Text}"
                           ValueBrush="{DynamicResource AccentBlueBrush}"/>
        <controls:StatCard x:Name="StatRecv"
                           Value="{Binding #TotalRecv.Text}"
                           ValueBrush="{DynamicResource StatusSuccessBrush}"/>
      </controls:StatRow>

      <!-- Hidden stat TextBlocks — code-behind writes .Text directly -->
      <TextBlock x:Name="IfaceCount" Text="--" IsVisible="False"/>
      <TextBlock x:Name="TotalSent"  Text="--" IsVisible="False"/>
      <TextBlock x:Name="TotalRecv"  Text="--" IsVisible="False"/>

      <!-- Network interfaces list card -->
      <controls:GlassCard>
        <StackPanel Spacing="12">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Border Width="20" Height="20" CornerRadius="6"
                    Background="{DynamicResource BgCardBrush}">
              <TextBlock Text="◉" FontSize="{DynamicResource FontSizeLabel}"
                         Foreground="{DynamicResource AccentPrimaryBrush}"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock x:Name="IfacesSectionLabel" Text=""
                       FontSize="{DynamicResource FontSizeBodySmall}" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
          </StackPanel>
          <ItemsControl x:Name="IfaceList"/>
        </StackPanel>
      </controls:GlassCard>

    </StackPanel>
  </ScrollViewer>
</UserControl>
