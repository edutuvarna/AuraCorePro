<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AuraCore.UI.Avalonia.Views.Pages.SettingsView">
  <ScrollViewer>
    <StackPanel Spacing="20">

      <!-- Header -->
      <StackPanel Spacing="4">
        <TextBlock x:Name="HeaderTitle" FontSize="16" FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>
        <TextBlock x:Name="HeaderSub"
                   FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"/>
      </StackPanel>

      <!-- Appearance -->
      <Border CornerRadius="{StaticResource RadiusLg}" BorderThickness="1" Padding="16">
        <Border.Background>
          <SolidColorBrush Color="#FFFFFF" Opacity="0.025"/>
        </Border.Background>
        <Border.BorderBrush>
          <SolidColorBrush Color="#FFFFFF" Opacity="0.05"/>
        </Border.BorderBrush>
        <StackPanel Spacing="12">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Border Width="16" Height="16" CornerRadius="4">
              <Border.Background>
                <SolidColorBrush Color="#14B8A6" Opacity="0.15"/>
              </Border.Background>
              <TextBlock Text="●" FontSize="8" Foreground="#14B8A6"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock x:Name="AppearanceLabel" FontSize="13" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
          </StackPanel>
          <StackPanel Spacing="6">
            <TextBlock x:Name="ThemeKeyLabel"
                       FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock x:Name="ThemeDescLabel"
                       FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
            <StackPanel Orientation="Horizontal" Spacing="14" Margin="0,8,0,0">
              <RadioButton x:Name="ThemeSystemRb" GroupName="Theme"/>
              <RadioButton x:Name="ThemeLightRb"  GroupName="Theme"/>
              <RadioButton x:Name="ThemeDarkRb"   GroupName="Theme"/>
            </StackPanel>
          </StackPanel>
          <Grid ColumnDefinitions="*,Auto">
            <StackPanel>
              <TextBlock x:Name="LangKeyLabel" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}"/>
              <TextBlock x:Name="LangDescLabel" FontSize="11"
                         Foreground="{DynamicResource TextMutedBrush}"/>
            </StackPanel>
            <Button Grid.Column="1" x:Name="LangToggleBtn" Click="LangToggle_Click"
                    CornerRadius="{StaticResource RadiusMd}"
                    Background="#12FFFFFF" Padding="14,8" Cursor="Hand">
              <TextBlock x:Name="LangLabel" FontSize="12" FontWeight="SemiBold"
                         Foreground="{DynamicResource AccentPrimaryBrush}"/>
            </Button>
          </Grid>
        </StackPanel>
      </Border>

      <!-- AI Telemetry -->
      <Border CornerRadius="{StaticResource RadiusLg}" BorderThickness="1" Padding="16">
        <Border.Background>
          <SolidColorBrush Color="#FFFFFF" Opacity="0.025"/>
        </Border.Background>
        <Border.BorderBrush>
          <SolidColorBrush Color="#FFFFFF" Opacity="0.05"/>
        </Border.BorderBrush>
        <StackPanel Spacing="12">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Border Width="16" Height="16" CornerRadius="4">
              <Border.Background>
                <SolidColorBrush Color="#14B8A6" Opacity="0.15"/>
              </Border.Background>
              <TextBlock Text="🧠" FontSize="8" Foreground="#14B8A6"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock x:Name="AiTelemetryLabel" FontSize="13" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
          </StackPanel>
          <Grid ColumnDefinitions="*,Auto">
            <StackPanel>
              <TextBlock x:Name="AiTelemetryDescLabel" FontSize="12"
                         Foreground="{DynamicResource TextPrimaryBrush}"/>
              <TextBlock x:Name="AiTelemetryNoteLabel"
                         FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
            </StackPanel>
            <ToggleSwitch Grid.Column="1" x:Name="AiTelemetryToggle"
                          OnContent="On" OffContent="Off"
                          IsCheckedChanged="AiTelemetryToggle_Changed"/>
          </Grid>
        </StackPanel>
      </Border>

      <!-- Replaces the removed AI model picker. Task 14+ will add the AI Features page icon. -->
      <Border Classes="info-card" Margin="0,12,0,0"
              Background="#14B088FF"
              BorderBrush="#33B088FF"
              BorderThickness="1"
              CornerRadius="6"
              Padding="12,10">
        <StackPanel Orientation="Horizontal" Spacing="10">
          <TextBlock Text="❖"
                     FontSize="14"
                     Foreground="{DynamicResource AccentPurpleBrush}"
                     VerticalAlignment="Center" />
          <TextBlock x:Name="AiModelNoteLabel"
                     VerticalAlignment="Center"
                     TextWrapping="Wrap"
                     Foreground="{DynamicResource TextSecondaryBrush}" />
        </StackPanel>
      </Border>

      <!-- About -->
      <Border CornerRadius="{StaticResource RadiusLg}" BorderThickness="1" Padding="16">
        <Border.Background>
          <SolidColorBrush Color="#FFFFFF" Opacity="0.025"/>
        </Border.Background>
        <Border.BorderBrush>
          <SolidColorBrush Color="#FFFFFF" Opacity="0.05"/>
        </Border.BorderBrush>
        <StackPanel Spacing="12">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Border Width="16" Height="16" CornerRadius="4">
              <Border.Background>
                <SolidColorBrush Color="#14B8A6" Opacity="0.15"/>
              </Border.Background>
              <TextBlock Text="ℹ" FontSize="8" Foreground="#14B8A6"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock x:Name="AboutLabel" FontSize="13" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
          </StackPanel>
          <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto">
            <TextBlock x:Name="VersionKeyLabel" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                       Margin="0,0,24,8"/>
            <TextBlock x:Name="VersionValueLabel" Grid.Column="1" FontSize="12"
                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
            <TextBlock x:Name="RuntimeKeyLabel" Grid.Row="1" FontSize="12"
                       Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,24,8"/>
            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="RuntimeLabel"
                       FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
            <TextBlock x:Name="PlatformKeyLabel" Grid.Row="2" FontSize="12"
                       Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,24,8"/>
            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="PlatformLabel"
                       FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
            <TextBlock x:Name="UiFrameworkKeyLabel" Grid.Row="3" FontSize="12"
                       Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,24,0"/>
            <TextBlock x:Name="UiFrameworkValueLabel" Grid.Row="3" Grid.Column="1" FontSize="12"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
          </Grid>
        </StackPanel>
      </Border>

      <!-- Account -->
      <Border CornerRadius="{StaticResource RadiusLg}" BorderThickness="1" Padding="16">
        <Border.Background>
          <SolidColorBrush Color="#FFFFFF" Opacity="0.025"/>
        </Border.Background>
        <Border.BorderBrush>
          <SolidColorBrush Color="#FFFFFF" Opacity="0.05"/>
        </Border.BorderBrush>
        <StackPanel Spacing="12">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Border Width="16" Height="16" CornerRadius="4">
              <Border.Background>
                <SolidColorBrush Color="#14B8A6" Opacity="0.15"/>
              </Border.Background>
              <TextBlock Text="○" FontSize="8" Foreground="#14B8A6"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock x:Name="AccountLabel" FontSize="13" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
          </StackPanel>
          <Grid ColumnDefinitions="*,Auto">
            <StackPanel>
              <TextBlock x:Name="AccountEmail" FontSize="12"
                         Foreground="{DynamicResource TextPrimaryBrush}"/>
              <TextBlock x:Name="AccountTier" FontSize="11"
                         Foreground="{DynamicResource TextMutedBrush}"/>
            </StackPanel>
            <Button Grid.Column="1" x:Name="LogoutBtn" Click="Logout_Click"
                    Background="{DynamicResource ErrorBgBrush}" Foreground="#EF4444"
                    Padding="16,8" CornerRadius="{StaticResource RadiusMd}"
                    FontWeight="SemiBold" FontSize="12"/>
          </Grid>
        </StackPanel>
      </Border>

      <!-- Links -->
      <Border CornerRadius="{StaticResource RadiusLg}"
              Background="{DynamicResource AccentBgBrush}" Padding="16,12"
              BorderBrush="{DynamicResource AccentBorderBrush}" BorderThickness="1">
        <Grid ColumnDefinitions="Auto,*">
          <TextBlock Text="🌐" FontSize="16" VerticalAlignment="Center" Margin="0,0,12,0"/>
          <TextBlock x:Name="WebsiteLinkLabel" Grid.Column="1"
                     FontSize="12" Foreground="{DynamicResource AccentPrimaryBrush}"
                     VerticalAlignment="Center"/>
        </Grid>
      </Border>

    </StackPanel>
  </ScrollViewer>
</UserControl>
