<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:AuraCore.UI.Avalonia.Views.Controls"
             x:Class="AuraCore.UI.Avalonia.Views.Pages.CronManagerView">
  <ScrollViewer>
    <StackPanel Spacing="16">

      <!-- Header -->
      <controls:ModuleHeader x:Name="CronHeader"
                             Title=""
                             Subtitle="">
        <controls:ModuleHeader.Actions>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button x:Name="CronRefreshBtn" Content="" Click="Scan_Click" Classes="action-btn" Padding="16,8"/>
            <!-- PageTitle: hidden bridge, code-behind writes localized string -->
            <TextBlock x:Name="PageTitle" IsVisible="False"/>
          </StackPanel>
        </controls:ModuleHeader.Actions>
      </controls:ModuleHeader>

      <!-- Hidden TextBlocks that code-behind populates via .Text = ... -->
      <StackPanel IsVisible="False" Height="0">
        <TextBlock x:Name="UserJobCount"   Text="--"/>
        <TextBlock x:Name="SystemJobCount" Text="--"/>
      </StackPanel>

      <!-- Stat counters -->
      <controls:StatRow>
        <controls:StatCard x:Name="UserJobsStat"
                           Label=""
                           Value="{Binding #UserJobCount.Text}"
                           ValueBrush="{DynamicResource TextPrimaryBrush}"/>
        <controls:StatCard x:Name="SystemCronStat"
                           Label=""
                           Value="{Binding #SystemJobCount.Text}"
                           ValueBrush="{DynamicResource AccentBlueBrush}"/>
      </controls:StatRow>

      <!-- User crontab -->
      <controls:GlassCard>
        <StackPanel Spacing="12">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Border Width="16" Height="16" CornerRadius="4" Background="{DynamicResource AccentBgBrush}">
              <TextBlock Text="&#x2630;" FontSize="8" Foreground="{DynamicResource AccentPrimaryBrush}"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock x:Name="UserCrontabHeading" Text="" FontSize="{DynamicResource FontSizeLabel}" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
          </StackPanel>
          <TextBlock x:Name="SubText" Text=""
                     FontSize="{DynamicResource FontSizeBodySmall}"
                     Foreground="{DynamicResource TextMutedBrush}"/>
          <ItemsControl x:Name="CronList"/>
        </StackPanel>
      </controls:GlassCard>

      <!-- System cron directories -->
      <controls:GlassCard>
        <StackPanel Spacing="12">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Border Width="16" Height="16" CornerRadius="4" Background="{DynamicResource AccentBgBrush}">
              <TextBlock Text="&#x2630;" FontSize="8" Foreground="{DynamicResource AccentPrimaryBrush}"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock x:Name="SysCronDirsHeading" Text="" FontSize="{DynamicResource FontSizeLabel}" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
          </StackPanel>
          <ItemsControl x:Name="SystemCronList"/>
        </StackPanel>
      </controls:GlassCard>

      <!-- Cron syntax help -->
      <Border CornerRadius="{StaticResource RadiusLg}" Background="{DynamicResource InfoBgBrush}" Padding="16,12"
              BorderBrush="{DynamicResource InfoBorderBrush}" BorderThickness="1">
        <StackPanel Spacing="6">
          <TextBlock x:Name="CronSyntaxTitle"
                     Text=""
                     FontSize="{DynamicResource FontSizeBodySmall}"
                     FontWeight="SemiBold" Foreground="#0080FF"/>
          <TextBlock x:Name="CronSyntaxExamples"
                     Text=""
                     FontSize="{DynamicResource FontSizeLabel}" Foreground="#6699CC" TextWrapping="Wrap"/>
        </StackPanel>
      </Border>

    </StackPanel>
  </ScrollViewer>
</UserControl>
