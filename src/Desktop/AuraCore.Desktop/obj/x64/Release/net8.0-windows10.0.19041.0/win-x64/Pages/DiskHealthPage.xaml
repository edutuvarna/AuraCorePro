<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AuraCore.Desktop.Pages.DiskHealthPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Padding="32">
        <StackPanel Spacing="20" MaxWidth="960">

            <StackPanel Spacing="4">
                <TextBlock x:ConnectionId='6' x:Name="PageTitle" Text="Disk Health Monitor" Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock x:ConnectionId='7' x:Name="PageSubtitle" Text="Monitor drive health, temperature, and SMART diagnostics"
                           Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button x:ConnectionId='3' x:Name="ScanBtn" Content="Scan Drives"                      
                        Style="{StaticResource AccentButtonStyle}" Padding="24,10" />
                <ProgressRing x:ConnectionId='4' x:Name="Progress" IsActive="False" Visibility="Collapsed" Width="28" Height="28" />
                <TextBlock x:ConnectionId='5' x:Name="StatusText" Text="Click Scan to check disk health"
                           VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <!-- Drive cards -->
            <StackPanel x:ConnectionId='2' x:Name="DriveList" Spacing="12" />

        </StackPanel>
    </ScrollViewer>
</Page>

