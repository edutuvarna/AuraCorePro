<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AuraCore.UI.Avalonia.Views.Pages.SystemHealthView">
  <ScrollViewer>
    <StackPanel Spacing="20">

      <!-- Header -->
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Spacing="4">
          <TextBlock x:Name="PageTitle" Text="System Health" FontSize="22" FontWeight="Bold"
                     Foreground="{DynamicResource TextPrimaryBrush}"/>
          <TextBlock Text="Real-time system monitoring and diagnostics"
                     FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"/>
        </StackPanel>
        <Button Grid.Column="1" Classes="action-btn" Click="Scan_Click"
                VerticalAlignment="Center" Padding="16,10">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="&#x1F504;" FontSize="14"/>
            <TextBlock x:Name="ScanBtnText" Text="Scan Now" FontSize="12" FontWeight="SemiBold"/>
          </StackPanel>
        </Button>
      </Grid>


      <!-- Health Score + System Info Row -->
      <Grid ColumnDefinitions="Auto,*">
        <!-- Health Score Badge -->
        <Border Grid.Column="0" Margin="0,0,16,0" CornerRadius="{StaticResource RadiusLg}"
                Background="{DynamicResource BgCardBrush}"
                BorderBrush="{DynamicResource BorderCardBrush}" BorderThickness="1"
                Padding="32" MinWidth="180" MinHeight="180">
          <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
            <TextBlock x:Name="ScoreValue" Text="--" FontSize="40" FontWeight="Bold"
                       Foreground="{DynamicResource AccentPrimaryBrush}" HorizontalAlignment="Center"/>
            <TextBlock Text="Health Score" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                       HorizontalAlignment="Center"/>
            <Border x:Name="ScoreBadge" CornerRadius="12" Padding="12,4" HorizontalAlignment="Center"
                    Background="#1500D4AA">
              <TextBlock x:Name="ScoreLabel" Text="Scanning..." FontSize="11" FontWeight="SemiBold"
                         Foreground="{DynamicResource AccentPrimaryBrush}"/>
            </Border>
          </StackPanel>
        </Border>

        <!-- System Info Cards -->
        <Grid Grid.Column="1" RowDefinitions="*,*" ColumnDefinitions="*,*">
          <!-- OS -->
          <Border Grid.Row="0" Grid.Column="0" Margin="0,0,8,8" CornerRadius="{StaticResource RadiusMd}"
                  Background="{DynamicResource BgCardBrush}" BorderBrush="{DynamicResource BorderCardBrush}"
                  BorderThickness="1" Padding="16">
            <StackPanel Spacing="6">
              <TextBlock Text="Operating System" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
              <TextBlock x:Name="OsName" Text="--" FontSize="14" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"/>
              <TextBlock x:Name="OsVersion" Text="" FontSize="11"
                         Foreground="{DynamicResource TextSecondaryBrush}"/>
            </StackPanel>
          </Border>
          <!-- Processor -->
          <Border Grid.Row="0" Grid.Column="1" Margin="8,0,0,8" CornerRadius="{StaticResource RadiusMd}"
                  Background="{DynamicResource BgCardBrush}" BorderBrush="{DynamicResource BorderCardBrush}"
                  BorderThickness="1" Padding="16">
            <StackPanel Spacing="6">
              <TextBlock Text="Processor" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
              <TextBlock x:Name="CpuName" Text="--" FontSize="14" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"/>
              <TextBlock x:Name="CpuCores" Text="" FontSize="11"
                         Foreground="{DynamicResource TextSecondaryBrush}"/>
            </StackPanel>
          </Border>
          <!-- Memory -->
          <Border Grid.Row="1" Grid.Column="0" Margin="0,8,8,0" CornerRadius="{StaticResource RadiusMd}"
                  Background="{DynamicResource BgCardBrush}" BorderBrush="{DynamicResource BorderCardBrush}"
                  BorderThickness="1" Padding="16">
            <StackPanel Spacing="6">
              <TextBlock Text="Memory" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
              <StackPanel Orientation="Horizontal" Spacing="4">
                <TextBlock x:Name="RamUsed" Text="--" FontSize="22" FontWeight="Bold"
                           Foreground="{DynamicResource AccentBlueBrush}"/>
                <TextBlock x:Name="RamTotal" Text="" FontSize="12"
                           Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Bottom" Margin="0,0,0,3"/>
              </StackPanel>
              <Border Height="4" CornerRadius="2" Background="#1A1A28">
                <Border x:Name="RamBar" Height="4" CornerRadius="2"
                        Background="{DynamicResource AccentBlueBrush}" HorizontalAlignment="Left" Width="0"/>
              </Border>
            </StackPanel>
          </Border>
          <!-- Uptime -->
          <Border Grid.Row="1" Grid.Column="1" Margin="8,8,0,0" CornerRadius="{StaticResource RadiusMd}"
                  Background="{DynamicResource BgCardBrush}" BorderBrush="{DynamicResource BorderCardBrush}"
                  BorderThickness="1" Padding="16">
            <StackPanel Spacing="6">
              <TextBlock Text="Uptime" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
              <TextBlock x:Name="UptimeVal" Text="--" FontSize="22" FontWeight="Bold"
                         Foreground="{DynamicResource TextPrimaryBrush}"/>
              <TextBlock x:Name="ProcessCount" Text="" FontSize="11"
                         Foreground="{DynamicResource TextSecondaryBrush}"/>
            </StackPanel>
          </Border>
        </Grid>
      </Grid>

      <!-- Drives Section -->
      <TextBlock Text="Storage Drives" FontSize="13" FontWeight="SemiBold"
                 Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,8,0,0"/>
      <ItemsControl x:Name="DriveList">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Margin="0,0,0,8" CornerRadius="{StaticResource RadiusMd}"
                    Background="{DynamicResource BgCardBrush}"
                    BorderBrush="{DynamicResource BorderCardBrush}" BorderThickness="1" Padding="16">
              <Grid RowDefinitions="Auto,Auto,Auto">
                <Grid ColumnDefinitions="*,Auto">
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="{Binding Label}" FontSize="11"
                               Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
                  </StackPanel>
                  <TextBlock Grid.Column="1" Text="{Binding SizeText}" FontSize="12"
                             Foreground="{DynamicResource TextSecondaryBrush}"/>
                </Grid>
                <Border Grid.Row="1" Height="6" CornerRadius="3" Background="#1A1A28" Margin="0,10,0,4">
                  <Border Height="6" CornerRadius="3" Background="{Binding BarBrush}"
                          HorizontalAlignment="Left" Width="{Binding BarWidth}"/>
                </Border>
                <Grid Grid.Row="2" ColumnDefinitions="*,Auto">
                  <TextBlock Text="{Binding FreeText}" FontSize="11"
                             Foreground="{DynamicResource TextMutedBrush}"/>
                  <TextBlock Grid.Column="1" Text="{Binding UsedPct}" FontSize="11" FontWeight="SemiBold"
                             Foreground="{Binding PctBrush}"/>
                </Grid>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <!-- GPU Section -->
      <TextBlock x:Name="GpuHeader" Text="Graphics" FontSize="13" FontWeight="SemiBold"
                 Foreground="{DynamicResource TextPrimaryBrush}" IsVisible="False"/>
      <ItemsControl x:Name="GpuList">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Margin="0,0,0,8" CornerRadius="{StaticResource RadiusMd}"
                    Background="{DynamicResource BgCardBrush}"
                    BorderBrush="{DynamicResource BorderCardBrush}" BorderThickness="1" Padding="16">
              <StackPanel Spacing="4">
                <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Text="{Binding Detail}" FontSize="11"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

    </StackPanel>
  </ScrollViewer>
</UserControl>
