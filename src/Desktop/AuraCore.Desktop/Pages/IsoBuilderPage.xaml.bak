<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="AuraCore.Desktop.Pages.IsoBuilderPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Loaded="Page_Loaded">

    <Grid>

        <!-- ═══════════ WIZARD LAYOUT ═══════════ -->
        <Grid x:Name="WizardGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ═══════════ LEFT SIDEBAR ═══════════ -->
            <Border Grid.Column="0" Grid.RowSpan="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Sidebar Header -->
                    <StackPanel Grid.Row="0" Padding="20,20,20,12" Spacing="4">
                        <TextBlock Text="ISO Builder" Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="Bold" />
                        <TextBlock x:Name="StepIndicator" Text="Step 1 of 12" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    </StackPanel>

                    <!-- Step Buttons -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="StepperPanel" Spacing="2" Padding="8,0,8,8" />
                    </ScrollViewer>

                    <!-- Sidebar Footer -->
                    <StackPanel Grid.Row="2" Padding="12" Spacing="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,1,0,0">
                        <TextBlock x:Name="AdminStatusText" Text="" FontSize="11" TextWrapping="Wrap" />
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <!-- Templates -->
                            <TextBlock Text="TEMPLATES" FontSize="9" FontWeight="SemiBold" Opacity="0.35"
                                       Margin="0,8,0,4" />
                            <ComboBox x:Name="TemplateCombo" PlaceholderText="Load Template..."
                                      SelectionChanged="TemplateCombo_Changed"
                                      HorizontalAlignment="Stretch" FontSize="12">
                                <ComboBoxItem Content="Gaming PC" Tag="gaming" />
                                <ComboBoxItem Content="Office PC" Tag="office" />
                                <ComboBoxItem Content="Privacy PC" Tag="privacy" />
                                <ComboBoxItem Content="Developer PC" Tag="developer" />
                                <ComboBoxItem Content="Minimal (Clean)" Tag="minimal" />
                            </ComboBox>

                            <TextBlock Text="CONFIG" FontSize="9" FontWeight="SemiBold" Opacity="0.35"
                                       Margin="0,8,0,4" />
                            <Button Click="ImportConfig_Click" Padding="8,4" ToolTipService.ToolTip="Import config">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <FontIcon Glyph="&#xE896;" FontSize="12" />
                                    <TextBlock Text="Import" FontSize="11" />
                                </StackPanel>
                            </Button>
                            <Button Click="ExportConfig_Click" Padding="8,4" ToolTipService.ToolTip="Export config">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <FontIcon Glyph="&#xE898;" FontSize="12" />
                                    <TextBlock Text="Export" FontSize="11" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Divider Line -->
            <Border Grid.Column="1" Grid.RowSpan="2" Background="{ThemeResource CardStrokeColorDefaultBrush}" />

            <!-- ═══════════ RIGHT CONTENT AREA ═══════════ -->
            <ScrollViewer Grid.Column="2" Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="32,24,32,24">
                <Grid>

                    <!-- Tier Lock -->
                    <Border x:Name="TierLockBanner" Visibility="Collapsed" Background="#14F59E0B" BorderBrush="#33F59E0B" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,16" VerticalAlignment="Top" HorizontalAlignment="Center">
                        <StackPanel Spacing="8" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE72E;" FontSize="32" Foreground="#f59e0b" HorizontalAlignment="Center" />
                            <TextBlock Text="Pro Feature" FontWeight="Bold" FontSize="18" Foreground="#f59e0b" HorizontalAlignment="Center" />
                            <TextBlock Text="Upgrade to Pro or Enterprise to use ISO Builder." Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" TextWrapping="Wrap" />
                            <Button Content="Upgrade Now" Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Center" Padding="24,8" Click="Upgrade_Click" Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- ══════ PANEL 0: Select ISO ══════ -->
                    <StackPanel x:Name="Panel_0" Visibility="Visible" Spacing="16" MaxWidth="600">
                        <TextBlock Text="Select Windows ISO" Style="{StaticResource TitleTextBlockStyle}" />
                        <TextBlock Text="Choose a Windows 10 or 11 ISO file to customize." Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                        <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,8,0,0">
                            <Button Content="Browse ISO File..." Click="BrowseIso_Click" Padding="16,10" Style="{StaticResource AccentButtonStyle}" />
                            <TextBlock x:Name="IsoPathText" Text="No file selected" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorTertiaryBrush}" TextTrimming="CharacterEllipsis" MaxWidth="350" />
                        </StackPanel>
                        <Border x:Name="IsoInfoPanel" Visibility="Collapsed" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Margin="0,8,0,0">
                            <StackPanel Spacing="6">
                                <TextBlock x:Name="IsoOsText" FontSize="14" FontWeight="SemiBold" />
                                <TextBlock x:Name="IsoArchText" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock x:Name="IsoSizeText" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock x:Name="IsoFileText" FontSize="13" Foreground="{ThemeResource TextFillColorTertiaryBrush}" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- ══════ PANEL 1: User Account ══════ -->
                    <StackPanel x:Name="Panel_1" Visibility="Collapsed" Spacing="16" MaxWidth="600">
                        <TextBlock Text="User Account" Style="{StaticResource TitleTextBlockStyle}" />
                        <TextBlock Text="Configure the default user account for Windows." Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                        <RadioButton x:Name="LocalAccountRadio" Content="Local Account (no Microsoft account required)" IsChecked="True" GroupName="account" Checked="AccountType_Changed" Margin="0,8,0,0" />
                        <RadioButton x:Name="MsAccountRadio" Content="Microsoft Account (standard Windows setup)" GroupName="account" Checked="AccountType_Changed" />
                        <StackPanel x:Name="LocalAccountPanel" Spacing="12" Margin="28,8,0,0">
                            <TextBox x:Name="UsernameBox" Header="Username" PlaceholderText="e.g. Admin" Width="320" />
                            <PasswordBox x:Name="PasswordBox" Header="Password (optional)" PlaceholderText="Leave empty for no password" Width="320" />
                            <CheckBox x:Name="AutoLoginCheck" Content="Auto-login (skip password screen at boot)" IsChecked="True" />
                        </StackPanel>
                    </StackPanel>

                    <!-- ══════ PANEL 2: OOBE Settings ══════ -->
                    <StackPanel x:Name="Panel_2" Visibility="Collapsed" Spacing="12" MaxWidth="600">
                        <TextBlock Text="OOBE Settings" Style="{StaticResource TitleTextBlockStyle}" />
                        <TextBlock Text="Skip Windows setup screens and pre-configure regional settings." Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                        <CheckBox x:Name="SkipOobeCheck" Content="Skip all OOBE screens" IsChecked="True" />
                        <CheckBox x:Name="SkipEulaCheck" Content="Auto-accept EULA" IsChecked="True" />
                        <CheckBox x:Name="DisableTelemetryCheck" Content="Disable telemetry and data collection" IsChecked="True" />
                        <CheckBox x:Name="DisableCortanaCheck" Content="Disable Cortana" IsChecked="True" />
                        <CheckBox x:Name="DisableOneDriveCheck" Content="Prevent OneDrive auto-install" IsChecked="True" />
                        <TextBox x:Name="ComputerNameBox" Header="Computer Name" PlaceholderText="Leave empty for random" Width="320" MaxLength="15" Margin="0,8,0,0" />
                        <ComboBox x:Name="LanguageCombo" Header="Language" Width="280" SelectedIndex="0" Margin="0,4,0,0">
                            <ComboBoxItem Content="English (US)" Tag="en-US" />
                            <ComboBoxItem Content="Turkish" Tag="tr-TR" />
                            <ComboBoxItem Content="German" Tag="de-DE" />
                            <ComboBoxItem Content="French" Tag="fr-FR" />
                            <ComboBoxItem Content="Spanish" Tag="es-ES" />
                            <ComboBoxItem Content="Russian" Tag="ru-RU" />
                        </ComboBox>
                        <ComboBox x:Name="TimezoneCombo" Header="Timezone" Width="320" SelectedIndex="0">
                            <ComboBoxItem Content="UTC" Tag="UTC" />
                            <ComboBoxItem Content="Eastern (US)" Tag="Eastern Standard Time" />
                            <ComboBoxItem Content="Pacific (US)" Tag="Pacific Standard Time" />
                            <ComboBoxItem Content="CET" Tag="Central European Standard Time" />
                            <ComboBoxItem Content="Turkey" Tag="Turkey Standard Time" />
                            <ComboBoxItem Content="Moscow" Tag="Russian Standard Time" />
                        </ComboBox>
                    </StackPanel>

                    <!-- ══════ PANEL 3: WiFi ══════ -->
                    <StackPanel x:Name="Panel_3" Visibility="Collapsed" Spacing="12" MaxWidth="600">
                        <TextBlock Text="WiFi Auto-Connect" Style="{StaticResource TitleTextBlockStyle}" />
                        <TextBlock Text="Pre-configure your WiFi so Windows connects right after installation. This enables Winget downloads immediately." Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                        <CheckBox x:Name="EnableWifiCheck" Content="Enable WiFi Auto-Connect" Checked="WifiToggle_Changed" Unchecked="WifiToggle_Changed" Margin="0,4,0,0" />
                        <StackPanel x:Name="WifiPanel" Visibility="Collapsed" Spacing="12" Margin="28,0,0,0">
                            <TextBox x:Name="WifiSsidBox" Header="WiFi Network Name (SSID)" PlaceholderText="e.g. MyHomeWiFi" Width="320" />
                            <PasswordBox x:Name="WifiPasswordBox" Header="WiFi Password" Width="320" />
                            <ComboBox x:Name="WifiSecurityCombo" Header="Security Type" Width="260" SelectedIndex="0">
                                <ComboBoxItem Content="WPA2-Personal (most common)" Tag="WPA2PSK" />
                                <ComboBoxItem Content="WPA3-Personal" Tag="WPA3SAE" />
                                <ComboBoxItem Content="WPA-Personal (legacy)" Tag="WPAPSK" />
                                <ComboBoxItem Content="Open (no password)" Tag="open" />
                            </ComboBox>
                            <TextBlock Text="Note: WiFi password is stored in plain text. Use only for personal networks." Foreground="{ThemeResource TextFillColorTertiaryBrush}" FontSize="11" TextWrapping="Wrap" />
                        </StackPanel>
                    </StackPanel>

                    <!-- ══════ PANEL 4: Win11 Bypass ══════ -->
                    <StackPanel x:Name="Panel_4" Visibility="Collapsed" Spacing="12" MaxWidth="600">
                        <TextBlock Text="Win11 Bypass" Style="{StaticResource TitleTextBlockStyle}" />
                        <Border Background="#14F59E0B" BorderBrush="#33F59E0B" BorderThickness="1" CornerRadius="6" Padding="12">
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Grid.Column="0" Glyph="&#xE7BA;" FontSize="14" Foreground="#f59e0b" VerticalAlignment="Top" Margin="0,2,0,0" />
                                <TextBlock Grid.Column="1" Text="Advanced: Only use if you know what you are doing! May cause stability issues on unsupported hardware." Foreground="#f59e0b" FontSize="12" TextWrapping="Wrap" />
                            </Grid>
                        </Border>
                        <CheckBox x:Name="BypassTpmCheck" Content="Bypass TPM 2.0" IsChecked="True" />
                        <CheckBox x:Name="BypassSecureBootCheck" Content="Bypass Secure Boot" IsChecked="True" />
                        <CheckBox x:Name="BypassRamCheck" Content="Bypass 4GB RAM minimum" IsChecked="True" />
                        <CheckBox x:Name="BypassStorageCheck" Content="Bypass 64GB storage minimum" IsChecked="True" />
                        <CheckBox x:Name="BypassCpuCheck" Content="Bypass CPU compatibility check" IsChecked="True" />
                    </StackPanel>

                    <!-- ══════ PANEL 5: Bloatware ══════ -->
                    <StackPanel x:Name="Panel_5" Visibility="Collapsed" Spacing="12" MaxWidth="700">
                        <TextBlock Text="Bloatware Removal" Style="{StaticResource TitleTextBlockStyle}" />
                        <TextBlock Text="Select pre-installed apps to remove during installation." Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                        <Border Background="#14EF4444" BorderBrush="#26EF4444" BorderThickness="1" CornerRadius="6" Padding="12">
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Grid.Column="0" Glyph="&#xE7BA;" FontSize="14" Foreground="#ef4444" VerticalAlignment="Top" Margin="0,2,0,0" />
                                <TextBlock Grid.Column="1" Text="Removing Microsoft Edge may break some Windows features. Only remove if you use an alternative browser." Foreground="#f87171" FontSize="12" TextWrapping="Wrap" />
                            </Grid>
                        </Border>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="Select All" Click="SelectAllBloat_Click" Padding="12,6" />
                            <Button Content="Deselect All" Click="DeselectAllBloat_Click" Padding="12,6" />
                        </StackPanel>
                        <StackPanel x:Name="BloatwareList" Spacing="4" />
                    </StackPanel>

                    <!-- ══════ PANEL 6: EXE Bundler ══════ -->
                    <StackPanel x:Name="Panel_6" Visibility="Collapsed" Spacing="12" MaxWidth="600">
                        <TextBlock Text="Custom EXE Bundler" Style="{StaticResource TitleTextBlockStyle}" />
                        <TextBlock Text="Add .exe/.msi installers to auto-run after first boot. No internet needed - perfect for offline installs." Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                            <Button Content="Add Files..." Click="AddExe_Click" Padding="16,8" Style="{StaticResource AccentButtonStyle}" />
                            <Button Content="Clear All" Click="ClearExe_Click" Padding="12,8" />
                        </StackPanel>
                        <StackPanel x:Name="ExeFilesList" Spacing="4" />
                        <TextBlock x:Name="ExeCountText" Text="No files added" Foreground="{ThemeResource TextFillColorTertiaryBrush}" FontSize="12" />
                        <CheckBox x:Name="SilentInstallCheck" Content="Attempt silent install (/S /silent /quiet)" IsChecked="True" Margin="0,4,0,0" />
                    </StackPanel>

                    <!-- ══════ PANEL 7: Driver Backup ══════ -->
                    <StackPanel x:Name="Panel_7" Visibility="Collapsed" Spacing="12" MaxWidth="700">
                        <TextBlock Text="Driver Backup" Style="{StaticResource TitleTextBlockStyle}" />
                        <TextBlock Text="Export your current hardware drivers and bundle them. Windows auto-installs them after setup." Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                            <Button x:Name="ScanDriversBtn" Content="Scan My Drivers" Click="ScanDrivers_Click" Padding="16,8" Style="{StaticResource AccentButtonStyle}" />
                            <ProgressRing x:Name="DriverScanProgress" IsActive="False" Visibility="Collapsed" Width="20" Height="20" VerticalAlignment="Center" />
                            <TextBlock x:Name="DriverScanStatus" Text="" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                        </StackPanel>
                        <Border Background="#14F59E0B" BorderBrush="#33F59E0B" BorderThickness="1" CornerRadius="6" Padding="12">
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Grid.Column="0" Glyph="&#xE7EF;" FontSize="14" Foreground="#f59e0b" VerticalAlignment="Top" Margin="0,2,0,0" />
                                <TextBlock Grid.Column="1" Text="Requires Administrator: Right-click AuraCore Pro and select Run as administrator to scan drivers." Foreground="#f59e0b" FontSize="12" TextWrapping="Wrap" />
                            </Grid>
                        </Border>
                        <StackPanel x:Name="DriverList" Spacing="4" />
                        <CheckBox x:Name="IncludeDriversCheck" Content="Include selected drivers in build" IsChecked="True" />
                    </StackPanel>

                    <!-- ══════ PANEL 8: Winget Apps ══════ -->
                    <StackPanel x:Name="Panel_8" Visibility="Collapsed" Spacing="12" MaxWidth="600">
                        <TextBlock Text="Winget App List" Style="{StaticResource TitleTextBlockStyle}" />
                        <TextBlock Text="Auto-install apps via Winget after first boot (requires internet connection)." Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                        <StackPanel x:Name="WingetAppList" Spacing="4" />
                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                            <TextBox x:Name="CustomWingetBox" PlaceholderText="Custom Winget ID (e.g. Mozilla.Firefox)" Width="320" />
                            <Button Content="Add" Click="AddCustomWinget_Click" Padding="12,8" />
                        </StackPanel>
                        <StackPanel x:Name="CustomWingetList" Spacing="4" />
                    </StackPanel>

                    <!-- ══════ PANEL 9: Registry Presets ══════ -->
                    <StackPanel x:Name="Panel_9" Visibility="Collapsed" Spacing="12" MaxWidth="600">
                        <TextBlock Text="Registry Presets" Style="{StaticResource TitleTextBlockStyle}" />
                        <TextBlock Text="Apply pre-built optimization presets. Multiple can be combined." Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                        <CheckBox x:Name="PresetDefaultCheck" Content="Default (Balanced) - Clean taskbar, disable ads, minor privacy tweaks" IsChecked="True" Margin="0,8,0,0" />
                        <CheckBox x:Name="PresetGamingCheck" Content="Gaming PC - Disable Game DVR, fullscreen optimizations, High Performance" />
                        <CheckBox x:Name="PresetPrivacyCheck" Content="Privacy - Disable telemetry, ad tracking, activity history" />
                        <CheckBox x:Name="PresetDevCheck" Content="Developer - File extensions, long paths, hidden files, Git" />
                        <CheckBox x:Name="PresetOfficeCheck" Content="Office - Dark mode, clean taskbar, disable notifications" />
                    </StackPanel>

                    <!-- ══════ PANEL 10: Post-Install ══════ -->
                    <StackPanel x:Name="Panel_10" Visibility="Collapsed" Spacing="12" MaxWidth="600">
                        <TextBlock Text="Post-Install Actions" Style="{StaticResource TitleTextBlockStyle}" />
                        <TextBlock Text="Additional tweaks applied after Windows first login." Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                        <CheckBox x:Name="InstallWingetCheck" Content="Install Winget package manager" IsChecked="True" Margin="0,4,0,0" />
                        <CheckBox x:Name="EnableDarkModeCheck" Content="Enable Dark Mode" IsChecked="True" />
                        <CheckBox x:Name="ShowFileExtCheck" Content="Show file extensions in Explorer" IsChecked="True" />
                        <CheckBox x:Name="ShowHiddenFilesCheck" Content="Show hidden files" />
                        <CheckBox x:Name="DisableWebSearchCheck" Content="Disable web search in Start Menu" IsChecked="True" />
                        <CheckBox x:Name="ClassicRightClickCheck" Content="Classic right-click context menu (Win11)" IsChecked="True" />
                        <CheckBox x:Name="DisableWidgetsCheck" Content="Disable Widgets" IsChecked="True" />
                        <CheckBox x:Name="DisableCopilotCheck" Content="Disable Copilot" IsChecked="True" />
                        <CheckBox x:Name="TaskbarLeftCheck" Content="Align taskbar to left (Win11)" />
                    </StackPanel>

                    <!-- ══════ PANEL 11: Review and Build ══════ -->
                    <StackPanel x:Name="Panel_11" Visibility="Collapsed" Spacing="16" MaxWidth="600">
                        <TextBlock Text="Review and Build" Style="{StaticResource TitleTextBlockStyle}" />
                        <TextBlock Text="Review your configuration and choose output format." Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

                        <!-- Output Mode -->
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="20">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Output Format" FontWeight="SemiBold" />
                                <RadioButton x:Name="OutputUnattendOnly" Content="Generate files only (save to folder)" IsChecked="True" GroupName="output" Checked="OutputMode_Changed" />
                                <RadioButton x:Name="OutputUsbWrite" Content="Write ISO + config to USB drive" GroupName="output" Checked="OutputMode_Changed" />
                                <StackPanel x:Name="UsbPanel" Visibility="Collapsed" Spacing="12" Margin="28,0,0,0">
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <ComboBox x:Name="UsbDriveCombo" Header="USB Drive" Width="320" PlaceholderText="No USB drives" />
                                        <Button Content="Refresh" Click="RefreshUsb_Click" VerticalAlignment="Bottom" Padding="12,8" />
                                    </StackPanel>
                                    <Border Background="#14EF4444" BorderBrush="#26EF4444" BorderThickness="1" CornerRadius="6" Padding="12">
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <FontIcon Grid.Column="0" Glyph="&#xE7BA;" FontSize="14" Foreground="#ef4444" VerticalAlignment="Top" Margin="0,2,0,0" />
                                            <TextBlock Grid.Column="1" Text="DESTRUCTIVE: All data on USB will be permanently erased!" Foreground="#f87171" FontSize="12" TextWrapping="Wrap" />
                                        </Grid>
                                    </Border>
                                    <Border Background="#14F59E0B" BorderBrush="#33F59E0B" BorderThickness="1" CornerRadius="6" Padding="12">
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <FontIcon Grid.Column="0" Glyph="&#xE7EF;" FontSize="14" Foreground="#f59e0b" VerticalAlignment="Top" Margin="0,2,0,0" />
                                            <TextBlock Grid.Column="1" Text="Requires Administrator for USB formatting." Foreground="#f59e0b" FontSize="12" TextWrapping="Wrap" />
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Summary -->
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource AccentFillColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="20">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Build Summary" FontWeight="SemiBold" />
                                <TextBlock x:Name="SummaryText" Text="" FontFamily="Cascadia Mono, Consolas" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                <TextBlock x:Name="EstimatedTimeText" Text="" FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
                            </StackPanel>
                        </Border>

                        <!-- Disclaimer -->
                        <Border Background="#10F59E0B" BorderBrush="#26F59E0B" BorderThickness="1" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="8">
                                <TextBlock Text="By clicking Build, you acknowledge that AuraCore Pro modifies Windows installation files and system settings. You are responsible for ensuring compatibility. AuraCore Pro is not liable for data loss or system instability." Foreground="{ThemeResource TextFillColorTertiaryBrush}" FontSize="11" TextWrapping="Wrap" />
                                <CheckBox x:Name="DisclaimerCheck" Content="I understand the risks and accept responsibility" FontSize="12" Checked="DisclaimerCheck_Changed" Unchecked="DisclaimerCheck_Changed" />
                            </StackPanel>
                        </Border>

                        <Button Content="Preview Unattend.xml" Click="Preview_Click" Padding="16,8" HorizontalAlignment="Left" />
                    </StackPanel>

                </Grid>
            </ScrollViewer>

            <!-- ═══════════ BOTTOM NAV BAR ═══════════ -->
            <Border Grid.Column="2" Grid.Row="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,1,0,0" Padding="32,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                        <Button x:Name="BackBtn" Content="Back" Click="Back_Click" Padding="20,8" Visibility="Collapsed" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                        <Button x:Name="NextBtn" Content="Next" Click="Next_Click" Style="{StaticResource AccentButtonStyle}" Padding="24,8" />
                        <Button x:Name="BuildBtn" Content="Build Custom ISO" Click="Build_Click" Style="{StaticResource AccentButtonStyle}" Padding="24,8" Visibility="Collapsed" IsEnabled="False" />
                    </StackPanel>
                </Grid>
            </Border>

        </Grid>

        <!-- ═══════════ BUILD TERMINAL OVERLAY ═══════════ -->
        <Grid x:Name="TerminalOverlay" Visibility="Collapsed" Background="{ThemeResource SolidBackgroundFillColorBaseBrush}">
            <Grid Padding="32" MaxWidth="800" HorizontalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Terminal Header -->
                <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,16">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <FontIcon Glyph="&#xE756;" FontSize="24" Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
                        <TextBlock Text="Building Custom ISO..." Style="{StaticResource TitleTextBlockStyle}" />
                    </StackPanel>
                    <ProgressBar x:Name="TerminalProgress" Value="0" Maximum="100" Height="4" CornerRadius="2" />
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <TextBlock x:Name="TerminalStepText" Text="Initializing..." FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="TerminalTimeText" Text="" FontSize="13" Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
                    </StackPanel>
                </StackPanel>

                <!-- Terminal Output -->
                <Border Grid.Row="1" Background="#0a0a0a" CornerRadius="8" Padding="16" BorderBrush="#1e1e1e" BorderThickness="1">
                    <ScrollViewer x:Name="TerminalScroll" VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="TerminalOutput" FontFamily="Cascadia Mono, Consolas, monospace" FontSize="12" Foreground="#06d6a0" TextWrapping="Wrap" IsTextSelectionEnabled="True" />
                    </ScrollViewer>
                </Border>

                <!-- Terminal Footer -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="12" Margin="0,16,0,0" HorizontalAlignment="Right">
                    <Button x:Name="TerminalCloseBtn" Content="Close" Click="TerminalClose_Click" Padding="24,10" Visibility="Collapsed" />
                </StackPanel>
            </Grid>
        </Grid>

    </Grid>
</Page>
