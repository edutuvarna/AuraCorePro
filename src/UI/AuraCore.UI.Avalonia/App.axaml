<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="using:AuraCore.UI.Avalonia.Converters"
             x:Class="AuraCore.UI.Avalonia.App">

  <Application.Styles>
    <FluentTheme />
    <StyleInclude Source="avares://AuraCore.Pro/Themes/AuraCoreThemeV2.axaml"/>
    <StyleInclude Source="avares://AuraCore.Pro/Themes/Icons.axaml"/>
  </Application.Styles>

  <Application.Resources>
    <ResourceDictionary>
      <!-- Phase 5.3 narrow-mode converters -->
      <conv:BoundsToIsNarrowModeConverter        x:Key="BoundsToIsNarrowModeConverter" />
      <conv:NarrowToColumnCountConverter         x:Key="NarrowToColumnCountConverter" />
      <conv:BoolToGridLengthConverter            x:Key="BoolToGridLengthConverter" />
      <conv:NarrowModeGridLengthChainConverter   x:Key="NarrowModeGridLengthChainConverter" />
      <!-- Phase 5.4 uppercase transform converter -->
      <conv:UppercaseTransformConverter          x:Key="UppercaseTransformConverter" />
    </ResourceDictionary>
  </Application.Resources>

</Application>
