<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:AuraCore.UI.Avalonia.Views.Controls"
             x:Class="AuraCore.UI.Avalonia.Views.Pages.HostsEditorView">
  <ScrollViewer>
    <StackPanel Spacing="16">

      <!-- Header -->
      <controls:ModuleHeader Title="Hosts Editor"
                             Subtitle="Manage /etc/hosts entries with a visual interface">
        <controls:ModuleHeader.Actions>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Classes="action-btn" Click="Backup_Click"
                    VerticalAlignment="Center" Padding="12,8">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="&#x1F4BE;" FontSize="{DynamicResource FontSizeBody}"/>
                <TextBlock Text="Backup" FontSize="{DynamicResource FontSizeBodySmall}" FontWeight="SemiBold"/>
              </StackPanel>
            </Button>
            <Button Classes="action-btn" Click="Reload_Click"
                    VerticalAlignment="Center" Padding="12,8">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="&#x1F504;" FontSize="{DynamicResource FontSizeBody}"/>
                <TextBlock x:Name="ReloadLabel" Text="Reload" FontSize="{DynamicResource FontSizeBodySmall}" FontWeight="SemiBold"/>
              </StackPanel>
            </Button>
            <!-- PageTitle preserved for localization -->
            <TextBlock x:Name="PageTitle" IsVisible="False"/>
          </StackPanel>
        </controls:ModuleHeader.Actions>
      </controls:ModuleHeader>

      <!-- Status Bar -->
      <controls:GlassCard>
        <Grid ColumnDefinitions="*,*,*,Auto">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Border Width="20" Height="20" CornerRadius="5" VerticalAlignment="Center"
                    Background="{DynamicResource BgCardBrush}">
              <TextBlock Text="&#x25CF;" FontSize="{DynamicResource FontSizeLabel}"
                         Foreground="#F59E0B"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="File:" FontSize="{DynamicResource FontSizeBodySmall}"
                       Foreground="{DynamicResource TextMutedBrush}"
                       VerticalAlignment="Center"/>
            <TextBlock x:Name="FilePath" Text="--"
                       FontSize="{DynamicResource FontSizeBodySmall}" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"/>
          </StackPanel>
          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
            <TextBlock Text="Entries:" FontSize="{DynamicResource FontSizeBodySmall}"
                       Foreground="{DynamicResource TextMutedBrush}"
                       VerticalAlignment="Center"/>
            <TextBlock x:Name="EntryCount" Text="--"
                       FontSize="{DynamicResource FontSizeBody}" FontWeight="Bold"
                       Foreground="#F59E0B" VerticalAlignment="Center"/>
          </StackPanel>
          <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
            <TextBlock Text="Admin:" FontSize="{DynamicResource FontSizeBodySmall}"
                       Foreground="{DynamicResource TextMutedBrush}"
                       VerticalAlignment="Center"/>
            <TextBlock x:Name="AdminStatus" Text="--"
                       FontSize="{DynamicResource FontSizeBodySmall}" FontWeight="Bold"
                       VerticalAlignment="Center"/>
          </StackPanel>
          <Border Grid.Column="3" x:Name="UnsavedBadge" IsVisible="False"
                  CornerRadius="8" Background="{DynamicResource BgCardBrush}" Padding="10,4">
            <TextBlock Text="Unsaved Changes" FontSize="{DynamicResource FontSizeLabel}" FontWeight="SemiBold"
                       Foreground="{DynamicResource StatusWarningBrush}"/>
          </Border>
        </Grid>
      </controls:GlassCard>

      <!-- Subtitle / status text -->
      <TextBlock x:Name="SubtitleText"
                 Text="Manage /etc/hosts entries with a visual interface"
                 FontSize="{DynamicResource FontSizeBodySmall}"
                 Foreground="{DynamicResource TextMutedBrush}"
                 IsVisible="False"/>

      <!-- Add Entry Row -->
      <controls:GlassCard>
        <Grid ColumnDefinitions="150,*,*,Auto">
          <TextBox x:Name="NewIp" Watermark="IP Address" Margin="0,0,8,0"
                   Background="Transparent" BorderBrush="{DynamicResource BorderSubtleBrush}"
                   Foreground="{DynamicResource TextPrimaryBrush}" FontSize="{DynamicResource FontSizeBody}"
                   CornerRadius="{StaticResource RadiusSm}" Padding="8,6"/>
          <TextBox Grid.Column="1" x:Name="NewHost" Watermark="Hostname" Margin="0,0,8,0"
                   Background="Transparent" BorderBrush="{DynamicResource BorderSubtleBrush}"
                   Foreground="{DynamicResource TextPrimaryBrush}" FontSize="{DynamicResource FontSizeBody}"
                   CornerRadius="{StaticResource RadiusSm}" Padding="8,6"/>
          <TextBox Grid.Column="2" x:Name="NewComment" Watermark="Comment (optional)" Margin="0,0,8,0"
                   Background="Transparent" BorderBrush="{DynamicResource BorderSubtleBrush}"
                   Foreground="{DynamicResource TextPrimaryBrush}" FontSize="{DynamicResource FontSizeBody}"
                   CornerRadius="{StaticResource RadiusSm}" Padding="8,6"/>
          <Button Grid.Column="3" Classes="action-btn" Click="AddEntry_Click" Padding="14,6">
            <TextBlock Text="+ Add" FontSize="{DynamicResource FontSizeBodySmall}" FontWeight="SemiBold"
                       Foreground="{DynamicResource AccentPrimaryBrush}"/>
          </Button>
        </Grid>
      </controls:GlassCard>

      <!-- Hosts Entry List -->
      <controls:GlassCard>
        <StackPanel Spacing="0">
          <!-- Column Headers -->
          <Grid ColumnDefinitions="40,150,2*,*,80,80" Margin="0,0,0,4">
            <TextBlock Text="" FontSize="{DynamicResource FontSizeLabel}" FontWeight="Bold"
                       Foreground="{DynamicResource TextMutedBrush}"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
              <Border Width="16" Height="16" CornerRadius="4"
                      Background="{DynamicResource BgCardBrush}">
                <TextBlock Text="&#x25C9;" FontSize="{DynamicResource FontSizeLabel}" Foreground="#F59E0B"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
              <TextBlock Text="IP ADDRESS" FontSize="{DynamicResource FontSizeLabel}" FontWeight="Bold"
                         Foreground="{DynamicResource TextMutedBrush}"/>
            </StackPanel>
            <TextBlock Grid.Column="2" Text="HOSTNAME" FontSize="{DynamicResource FontSizeLabel}" FontWeight="Bold"
                       Foreground="{DynamicResource TextMutedBrush}"/>
            <TextBlock Grid.Column="3" Text="COMMENT" FontSize="{DynamicResource FontSizeLabel}" FontWeight="Bold"
                       Foreground="{DynamicResource TextMutedBrush}"/>
            <TextBlock Grid.Column="4" Text="SOURCE" FontSize="{DynamicResource FontSizeLabel}" FontWeight="Bold"
                       Foreground="{DynamicResource TextMutedBrush}" TextAlignment="Center"/>
            <TextBlock Grid.Column="5" Text="ACTIONS" FontSize="{DynamicResource FontSizeLabel}" FontWeight="Bold"
                       Foreground="{DynamicResource TextMutedBrush}" TextAlignment="Center"/>
          </Grid>
          <ItemsControl x:Name="HostsList">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Padding="12,6" Margin="2,1" CornerRadius="6"
                        Background="Transparent" Opacity="{Binding RowOpacity}">
                  <Grid ColumnDefinitions="40,150,2*,*,80,80">
                    <!-- Toggle -->
                    <CheckBox IsChecked="{Binding IsEnabled}" IsEnabled="{Binding CanEdit}"
                              Click="Toggle_Click" Tag="{Binding ToggleTag}"
                              VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{Binding IpAddress}"
                               FontSize="{DynamicResource FontSizeBodySmall}"
                               Foreground="{DynamicResource AccentBlueBrush}" VerticalAlignment="Center"
                               FontFamily="Consolas, monospace"/>
                    <TextBlock Grid.Column="2" Text="{Binding Hostname}"
                               FontSize="{DynamicResource FontSizeBodySmall}" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Grid.Column="3" Text="{Binding Comment}"
                               FontSize="{DynamicResource FontSizeLabel}"
                               Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Grid.Column="4" Text="{Binding SourceLabel}"
                               FontSize="{DynamicResource FontSizeLabel}"
                               Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"
                               TextAlignment="Center"/>
                    <Button Grid.Column="5" Tag="{Binding DeleteTag}" Classes="action-btn"
                            Padding="6,3" Click="Delete_Click"
                            FontSize="{DynamicResource FontSizeLabel}"
                            Content="Delete" IsVisible="{Binding CanEdit}" HorizontalAlignment="Center"/>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </controls:GlassCard>

      <!-- Bottom Bar: Import + Save -->
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <TextBox x:Name="ImportUrl" Watermark="Block list URL (e.g. StevenBlack hosts)"
                   MinWidth="350" Background="Transparent"
                   BorderBrush="{DynamicResource BorderSubtleBrush}"
                   Foreground="{DynamicResource TextPrimaryBrush}" FontSize="{DynamicResource FontSizeBodySmall}"
                   CornerRadius="{StaticResource RadiusSm}" Padding="8,6"/>
          <Button Classes="action-btn" Click="Import_Click" Padding="12,6">
            <TextBlock Text="Import Block List" FontSize="{DynamicResource FontSizeBodySmall}" FontWeight="SemiBold"/>
          </Button>
        </StackPanel>
        <Button Grid.Column="1" x:Name="SaveBtn" Click="Save_Click"
                Background="{DynamicResource AccentPrimaryBrush}"
                Foreground="{DynamicResource TextPrimaryBrush}" Padding="20,10"
                CornerRadius="{StaticResource RadiusMd}"
                FontWeight="Bold" FontSize="{DynamicResource FontSizeBody}" Content="Save Changes"
                HorizontalAlignment="Right"/>
      </Grid>

    </StackPanel>
  </ScrollViewer>
</UserControl>
