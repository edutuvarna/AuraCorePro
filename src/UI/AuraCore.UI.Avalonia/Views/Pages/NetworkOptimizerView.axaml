<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AuraCore.UI.Avalonia.Views.Pages.NetworkOptimizerView">
  <ScrollViewer>
    <StackPanel Spacing="12">
      <Grid ColumnDefinitions="*,Auto,Auto">
        <StackPanel Spacing="4">
          <TextBlock x:Name="PageTitle" Text="Network" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
          <TextBlock x:Name="SubText" Text="Monitor, optimize and benchmark your network" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
        </StackPanel>
        <Button Grid.Column="1" Classes="action-btn" Click="Scan_Click" Margin="0,0,8,0" Padding="14,8" VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Text="&#x1F50D;" FontSize="12"/><TextBlock x:Name="ScanLabel" Text="Scan" FontSize="11" FontWeight="SemiBold"/>
          </StackPanel>
        </Button>
        <Button Grid.Column="2" x:Name="BenchBtn" Classes="action-btn" Click="Bench_Click" Padding="14,8" VerticalAlignment="Center"
                Background="{DynamicResource AccentPrimaryBrush}" Foreground="#0A0A0F" FontWeight="Bold">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Text="&#x26A1;" FontSize="12"/><TextBlock x:Name="BenchLabel" Text="Benchmark DNS" FontSize="11" FontWeight="Bold"/>
          </StackPanel>
        </Button>
      </Grid>

      <!-- Current DNS -->
      <Border CornerRadius="{StaticResource RadiusMd}" Background="{DynamicResource BgCardBrush}" BorderBrush="{DynamicResource BorderCardBrush}" BorderThickness="1" Padding="14">
        <Grid ColumnDefinitions="*,*,*">
          <StackPanel Spacing="4"><TextBlock Text="Current DNS" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
            <TextBlock x:Name="DnsPrimary" Text="--" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource AccentPrimaryBrush}"/>
            <TextBlock x:Name="DnsSecondary" Text="" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/></StackPanel>
          <StackPanel Grid.Column="1" Spacing="4"><TextBlock Text="Provider" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
            <TextBlock x:Name="DnsProvider" Text="--" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/></StackPanel>
          <StackPanel Grid.Column="2" Spacing="4"><TextBlock Text="Response Time" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
            <TextBlock x:Name="DnsLatency" Text="--" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource AccentBlueBrush}"/></StackPanel>
        </Grid>
      </Border>

      <!-- Network Traffic Stats -->
      <Border CornerRadius="{StaticResource RadiusMd}" Background="{DynamicResource BgCardBrush}" BorderBrush="{DynamicResource BorderCardBrush}" BorderThickness="1" Padding="14">
        <Grid ColumnDefinitions="*,*,*">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="Interfaces:" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
            <TextBlock x:Name="IfaceCount" Text="--" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource AccentPrimaryBrush}" VerticalAlignment="Center"/>
          </StackPanel>
          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
            <TextBlock Text="&#x2B06; Sent:" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
            <TextBlock x:Name="TotalSent" Text="--" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource AccentBlueBrush}" VerticalAlignment="Center"/>
          </StackPanel>
          <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
            <TextBlock Text="&#x2B07; Recv:" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
            <TextBlock x:Name="TotalRecv" Text="--" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}" VerticalAlignment="Center"/>
          </StackPanel>
        </Grid>
      </Border>

      <!-- Network Adapters -->
      <TextBlock Text="NETWORK ADAPTERS" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextMutedBrush}"/>
      <ItemsControl x:Name="AdapterList">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Margin="0,0,0,4" CornerRadius="{StaticResource RadiusMd}" Background="{DynamicResource BgCardBrush}" BorderBrush="{DynamicResource BorderCardBrush}" BorderThickness="1" Padding="12,8">
              <Grid ColumnDefinitions="*,Auto,Auto">
                <StackPanel Spacing="2"><TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                  <TextBlock Text="{Binding Desc}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/></StackPanel>
                <StackPanel Grid.Column="1" Margin="12,0" Spacing="2">
                  <TextBlock Text="{Binding Sent}" FontSize="10" Foreground="{DynamicResource AccentBlueBrush}" TextAlignment="Right"/>
                  <TextBlock Text="{Binding Recv}" FontSize="10" Foreground="{DynamicResource SuccessBrush}" TextAlignment="Right"/></StackPanel>
                <StackPanel Grid.Column="2" HorizontalAlignment="Right" Spacing="2">
                  <TextBlock Text="{Binding Ip}" FontSize="11" Foreground="{DynamicResource AccentBlueBrush}" TextAlignment="Right"/>
                  <TextBlock Text="{Binding Speed}" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" TextAlignment="Right"/></StackPanel>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <!-- DNS Presets + Switch -->
      <TextBlock Text="DNS PRESETS" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextMutedBrush}"/>
      <ItemsControl x:Name="DnsPresetList">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Margin="0,0,0,4" CornerRadius="{StaticResource RadiusMd}" Background="{DynamicResource BgCardBrush}" BorderBrush="{DynamicResource BorderCardBrush}" BorderThickness="1" Padding="12,8">
              <Grid ColumnDefinitions="*,100,70,70">
                <StackPanel><TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                  <TextBlock Text="{Binding Servers}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/></StackPanel>
                <TextBlock Grid.Column="1" Text="{Binding Category}" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" TextAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="{Binding ActiveLabel}" FontSize="10" FontWeight="SemiBold" Foreground="{Binding ActiveBrush}" VerticalAlignment="Center" TextAlignment="Center"/>
                <Button Grid.Column="3" Tag="{Binding Name}" Classes="action-btn" Padding="6,3" Click="SwitchDns_Click" FontSize="9"
                        Content="Switch" HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <!-- DNS Benchmark Results -->
      <TextBlock x:Name="BenchHeader" Text="DNS BENCHMARK" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextMutedBrush}" IsVisible="False"/>
      <TextBlock x:Name="RecommendText" Text="" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource AccentPrimaryBrush}" IsVisible="False"/>
      <StackPanel x:Name="BenchResults" Spacing="4"/>
    </StackPanel>
  </ScrollViewer>
</UserControl>
