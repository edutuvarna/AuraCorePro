<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AuraCore.Desktop.Pages.SpaceAnalyzerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Padding="32">
        <StackPanel Spacing="20" MaxWidth="960">

            <StackPanel Spacing="4">
                <TextBlock x:Name="PageTitle" Text="Space Analyzer" Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock x:Name="PageSubtitle" Text="Visualize disk usage — find what's eating your storage"
                           Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="12">
                <ComboBox x:Name="DriveSelector" PlaceholderText="Select drive" Width="160" />
                <Button x:Name="ScanBtn" Content="Analyze Drive" Click="ScanBtn_Click"
                        Style="{StaticResource AccentButtonStyle}" Padding="24,10" />
                <ProgressRing x:Name="Progress" IsActive="False" Visibility="Collapsed" Width="28" Height="28" />
                <TextBlock x:Name="StatusText" Text="Select a drive and click Analyze"
                           VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <!-- Drive summary -->
            <Border x:Name="SummaryCard" Visibility="Collapsed"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <Grid ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="2">
                        <TextBlock Text="Total Size" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="TotalSizeText" Style="{StaticResource SubtitleTextBlockStyle}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="2">
                        <TextBlock Text="Used" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="UsedSizeText" Style="{StaticResource SubtitleTextBlockStyle}" Foreground="#E65100" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="2">
                        <TextBlock Text="Free" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="FreeSizeText" Style="{StaticResource SubtitleTextBlockStyle}" Foreground="#2E7D32" />
                    </StackPanel>
                    <StackPanel Grid.Column="3" Spacing="2">
                        <TextBlock Text="Folders Scanned" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="FolderCountText" Style="{StaticResource SubtitleTextBlockStyle}" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Usage bar -->
            <ProgressBar x:Name="UsageBar" Minimum="0" Maximum="100" Height="12" CornerRadius="6" Visibility="Collapsed" />

            <!-- Breadcrumb navigation for drill-down -->
            <StackPanel x:Name="BreadcrumbBar" Orientation="Horizontal" Spacing="4" Visibility="Collapsed" />

            <!-- Tree map -->
            <TextBlock x:Name="TreeMapHeader" Text="" Visibility="Collapsed" Style="{StaticResource BodyStrongTextBlockStyle}" />
            <Border x:Name="TreeMapContainer" Visibility="Collapsed"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="4" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    MinHeight="300">
                <Canvas x:Name="TreeMapCanvas" />
            </Border>

            <!-- File type distribution -->
            <TextBlock x:Name="FileTypesHeader" Text="" Visibility="Collapsed" Style="{StaticResource BodyStrongTextBlockStyle}" />
            <StackPanel x:Name="FileTypesList" Spacing="4" Visibility="Collapsed" />

            <!-- Top folders list -->
            <TextBlock x:Name="TopFoldersHeader" Text="" Visibility="Collapsed" Style="{StaticResource BodyStrongTextBlockStyle}" />
            <StackPanel x:Name="TopFoldersList" Spacing="4" />

        </StackPanel>
    </ScrollViewer>
</Page>
