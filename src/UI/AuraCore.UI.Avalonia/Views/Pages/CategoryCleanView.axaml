<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AuraCore.UI.Avalonia.Views.Pages.CategoryCleanView">
  <Grid RowDefinitions="Auto,Auto,*,Auto">

    <!-- Header -->
    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,16">
      <StackPanel Spacing="4">
        <TextBlock x:Name="PageTitle" Text="Cleanup" FontSize="28" FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>
        <TextBlock x:Name="PageSubtitle" Text="Scan and clean system files"
                   FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"/>
      </StackPanel>
      <Button Grid.Column="1" Classes="action-btn" Click="Scan_Click"
              VerticalAlignment="Center" Padding="14,8">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <TextBlock Text="&#x1F50D;" FontSize="12"/>
          <TextBlock x:Name="ScanLabel" Text="Scan" FontSize="11" FontWeight="SemiBold"/>
        </StackPanel>
      </Button>
    </Grid>

    <!-- Stats -->
    <Border Grid.Row="1" CornerRadius="{StaticResource RadiusMd}"
            Background="{DynamicResource BgCardBrush}"
            BorderBrush="{DynamicResource BorderCardBrush}" BorderThickness="1"
            Padding="16,10" Margin="0,0,0,12">
      <Grid ColumnDefinitions="*,*,*,Auto">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <TextBlock Text="Categories:" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
          <TextBlock x:Name="CatCount" Text="--" FontSize="13" FontWeight="Bold"
                     Foreground="{DynamicResource AccentPrimaryBrush}" VerticalAlignment="Center"/>
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
          <TextBlock Text="Files:" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
          <TextBlock x:Name="FileCount" Text="--" FontSize="13" FontWeight="Bold"
                     Foreground="{DynamicResource AccentBlueBrush}" VerticalAlignment="Center"/>
        </StackPanel>
        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
          <TextBlock Text="Total Size:" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
          <TextBlock x:Name="TotalSize" Text="--" FontSize="15" FontWeight="Bold"
                     Foreground="{DynamicResource AccentPurpleBrush}" VerticalAlignment="Center"/>
        </StackPanel>
        <Button Grid.Column="3" Classes="action-btn" Click="SelectAll_Click" Padding="10,4" VerticalAlignment="Center">
          <TextBlock x:Name="SelectAllLabel" Text="Select All" FontSize="10" FontWeight="SemiBold"/>
        </Button>
      </Grid>
    </Border>

    <!-- Category List -->
    <Border Grid.Row="2" CornerRadius="{StaticResource RadiusLg}"
            Background="{DynamicResource BgCardBrush}"
            BorderBrush="{DynamicResource BorderCardBrush}" BorderThickness="1" Padding="8">
      <ScrollViewer>
        <StackPanel x:Name="CategoryPanel" Spacing="6"/>
      </ScrollViewer>
    </Border>

    <!-- Clean Button -->
    <Grid Grid.Row="3" ColumnDefinitions="*,Auto" Margin="0,12,0,0">
      <TextBlock x:Name="StatusText" Text="" FontSize="11"
                 Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
      <Button Grid.Column="1" x:Name="CleanBtn" Click="Clean_Click"
              Background="{DynamicResource AccentPrimaryBrush}" Foreground="#0A0A0F"
              Padding="20,10" CornerRadius="{StaticResource RadiusMd}"
              FontWeight="Bold" FontSize="12" IsEnabled="False">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <TextBlock Text="&#x2702;" FontSize="12"/>
          <TextBlock x:Name="CleanLabel" Text="Clean Selected" FontSize="12" FontWeight="Bold"/>
        </StackPanel>
      </Button>
    </Grid>
  </Grid>
</UserControl>
