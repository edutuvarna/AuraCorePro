<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="AuraCore.Desktop.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer Padding="32">
        <StackPanel Spacing="20" MaxWidth="700">

            <TextBlock x:ConnectionId='2' x:Name="PageTitle" Text="Settings" Style="{StaticResource TitleTextBlockStyle}" />

            <!-- Account -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="10">
                    <TextBlock x:ConnectionId='16' x:Name="AccountTitle" Text="Account" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <Grid ColumnSpacing="12" RowSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" /><ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition /><RowDefinition /><RowDefinition />
                        </Grid.RowDefinitions>
                        <TextBlock x:ConnectionId='18' Grid.Row="0" Grid.Column="0" x:Name="LblEmail" Text="Email" Opacity="0.6" VerticalAlignment="Center" />
                        <TextBlock x:ConnectionId='19' Grid.Row="0" Grid.Column="1" x:Name="AccountEmail" VerticalAlignment="Center" />
                        <TextBlock x:ConnectionId='20' Grid.Row="1" Grid.Column="0" x:Name="LblSubscription" Text="Subscription" Opacity="0.6" VerticalAlignment="Center" />
                        <TextBlock x:ConnectionId='21' Grid.Row="1" Grid.Column="1" x:Name="AccountTier" VerticalAlignment="Center" FontWeight="SemiBold" />
                        <TextBlock x:ConnectionId='22' Grid.Row="2" Grid.Column="0" x:Name="LblRole" Text="Role" Opacity="0.6" VerticalAlignment="Center" />
                        <TextBlock x:ConnectionId='23' Grid.Row="2" Grid.Column="1" x:Name="AccountRole" VerticalAlignment="Center" />
                    </Grid>
                    <Button x:ConnectionId='17' x:Name="LogOutBtn" Content="Log Out"                      Padding="16,8" />
                </StackPanel>
            </Border>

            <!-- Appearance -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="12">
                    <TextBlock x:ConnectionId='10' x:Name="AppearanceTitle" Text="Appearance" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <TextBlock x:ConnectionId='11' x:Name="ThemeDesc" Text="Choose your preferred theme" FontSize="12" Opacity="0.6" />
                    <RadioButtons x:ConnectionId='12' x:Name="ThemeSelector"                                         >
                        <RadioButton x:ConnectionId='13' x:Name="ThemeSystem" Content="System default" Tag="System" />
                        <RadioButton x:ConnectionId='14' x:Name="ThemeLight" Content="Light" Tag="Light" />
                        <RadioButton x:ConnectionId='15' x:Name="ThemeDark" Content="Dark" Tag="Dark" />
                    </RadioButtons>
                </StackPanel>
            </Border>

            <!-- Language -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="12">
                    <TextBlock x:ConnectionId='7' x:Name="LanguageTitle" Text="Language" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <TextBlock x:ConnectionId='8' x:Name="LanguageDesc" Text="Choose your preferred language" FontSize="12" Opacity="0.6" />
                    <RadioButtons x:ConnectionId='9' x:Name="LanguageSelector"                                            >
                        <RadioButton Content="English" Tag="EN" />
                        <RadioButton Content="Türkçe" Tag="TR" />
                    </RadioButtons>
                </StackPanel>
            </Border>

            <!-- App Info -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="8">
                    <TextBlock x:ConnectionId='3' x:Name="AboutTitle" Text="About Aura Core Pro" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <TextBlock x:ConnectionId='4' x:Name="VersionText" Text="Version 1.0.0" FontSize="13" Opacity="0.6" />
                    <TextBlock x:ConnectionId='5' x:Name="TaglineText" Text="AI Powered Windows Intelligence" FontSize="13" Opacity="0.6" />
                    <TextBlock x:ConnectionId='6' x:Name="DescriptionText" FontSize="12" Opacity="0.4" TextWrapping="Wrap"
                               Text="Aura Core Pro is a comprehensive Windows optimization suite featuring 12 modules for system health analysis, cleanup, performance tuning, and customization." />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>

