<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:AuraCore.UI.Avalonia.Views.Controls"
             x:Class="AuraCore.UI.Avalonia.Views.Pages.BrewManagerView">
  <ScrollViewer>
    <StackPanel Spacing="16">

      <controls:ModuleHeader x:Name="BrewHeader"
                             Title=""
                             Subtitle="">
        <controls:ModuleHeader.Actions>
          <TextBlock x:Name="PageTitle" IsVisible="False"/>
        </controls:ModuleHeader.Actions>
      </controls:ModuleHeader>

      <!-- Hidden TextBlocks that code-behind populates via .Text = ... -->
      <StackPanel IsVisible="False" Height="0">
        <TextBlock x:Name="FormulaCount"  Text="--"/>
        <TextBlock x:Name="CaskCount"     Text="--"/>
        <TextBlock x:Name="OutdatedCount" Text="--"/>
      </StackPanel>

      <!-- Stat counters -->
      <controls:StatRow>
        <controls:StatCard x:Name="FormulaeStat"
                           Label=""
                           Value="{Binding #FormulaCount.Text}"
                           ValueBrush="{DynamicResource TextPrimaryBrush}"/>
        <controls:StatCard x:Name="CasksStat"
                           Label=""
                           Value="{Binding #CaskCount.Text}"
                           ValueBrush="{DynamicResource AccentBlueBrush}"/>
        <controls:StatCard x:Name="OutdatedStat"
                           Label=""
                           Value="{Binding #OutdatedCount.Text}"
                           ValueBrush="{DynamicResource StatusWarningBrush}"/>
      </controls:StatRow>

      <!-- Installed packages list -->
      <controls:GlassCard>
        <StackPanel Spacing="12">
          <Grid ColumnDefinitions="*,Auto,Auto">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Border Width="16" Height="16" CornerRadius="4" Background="{DynamicResource AccentBgBrush}">
                <TextBlock Text="&#x25A0;"
                           FontSize="{DynamicResource FontSizeLabel}"
                           Foreground="{DynamicResource AccentPrimaryBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
              <TextBlock x:Name="InstalledPkgHeading"
                         Text=""
                         FontSize="{DynamicResource FontSizeLabel}"
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource TextSecondaryBrush}"/>
            </StackPanel>
            <Button x:Name="BrewScanBtn"
                    Content=""
                    Click="Scan_Click"
                    Grid.Column="1"
                    Classes="action-btn"
                    Padding="16,8"
                    Margin="0,0,8,0"/>
            <Button x:Name="BrewCleanupBtn"
                    Content=""
                    Click="Cleanup_Click"
                    Grid.Column="2"
                    Padding="12,8"
                    Background="#12FFFFFF"
                    CornerRadius="{StaticResource RadiusSm}"/>
          </Grid>
          <TextBlock x:Name="SubText"
                     Text=""
                     FontSize="{DynamicResource FontSizeBodySmall}"
                     Foreground="{DynamicResource TextMutedBrush}"/>
          <ItemsControl x:Name="PkgList"/>
        </StackPanel>
      </controls:GlassCard>

    </StackPanel>
  </ScrollViewer>
</UserControl>
