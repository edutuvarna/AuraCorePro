<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="AuraCore.Desktop.LoginWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Aura Core Pro — Sign In">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" Padding="40">

        <!-- Language selector — top right corner -->
        <StackPanel Orientation="Horizontal" Spacing="4"
                    HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-20,0,0">
            <Button x:Name="LangEN" Content="EN" Click="LangEN_Click"
                    Padding="10,4" FontSize="11" MinWidth="0" />
            <Button x:Name="LangTR" Content="TR" Click="LangTR_Click"
                    Padding="10,4" FontSize="11" MinWidth="0" />
        </StackPanel>

        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                    Width="400" Spacing="24">

            <StackPanel Spacing="8" HorizontalAlignment="Center">
                <FontIcon Glyph="&#xE95E;" FontSize="48" Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
                <TextBlock x:Name="TitleText" Text="Aura Core Pro" Style="{StaticResource TitleTextBlockStyle}" HorizontalAlignment="Center" />
                <TextBlock x:Name="SubtitleText" Text="AI Powered Windows Intelligence"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                <Button x:Name="LoginTab" Content="Sign In" Click="LoginTab_Click"
                        Style="{StaticResource AccentButtonStyle}" Padding="24,8" />
                <Button x:Name="RegisterTab" Content="Create Account" Click="RegisterTab_Click"
                        Padding="24,8" />
            </StackPanel>

            <StackPanel x:Name="LoginForm" Spacing="12">
                <TextBox x:Name="LoginEmail" Header="Email" PlaceholderText="your@email.com" />
                <PasswordBox x:Name="LoginPassword" Header="Password" PlaceholderText="Enter your password" />
                <Button x:Name="LoginBtn" Content="Sign In" Click="LoginBtn_Click"
                        Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Stretch" Padding="0,10" />
            </StackPanel>

            <StackPanel x:Name="RegisterForm" Spacing="12" Visibility="Collapsed">
                <TextBox x:Name="RegEmail" Header="Email" PlaceholderText="your@email.com" />
                <PasswordBox x:Name="RegPassword" Header="Password" PlaceholderText="Minimum 8 characters" />
                <PasswordBox x:Name="RegConfirm" Header="Confirm Password" PlaceholderText="Repeat your password" />
                <Button x:Name="RegisterBtn" Content="Create Account" Click="RegisterBtn_Click"
                        Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Stretch" Padding="0,10" />
            </StackPanel>

            <ProgressRing x:Name="Progress" IsActive="False" Visibility="Collapsed" Width="28" Height="28"
                          HorizontalAlignment="Center" />
            <TextBlock x:Name="StatusText" Text="" HorizontalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"
                       TextAlignment="Center" />

            <HyperlinkButton x:Name="OfflineBtn" Content="Continue offline (Free tier)"
                             Click="OfflineBtn_Click" HorizontalAlignment="Center" />

        </StackPanel>
    </Grid>
</Window>
