<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="AuraCore.Desktop.LoginWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Aura Core Pro — Sign In">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" Padding="40">

        <!-- Language selector — top right corner -->
        <StackPanel Orientation="Horizontal" Spacing="4"
                    HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-20,0,0">
            <Button x:ConnectionId='32' x:Name="LangEN" Content="EN"                     
                    Padding="10,4" FontSize="11" MinWidth="0" />
            <Button x:ConnectionId='33' x:Name="LangTR" Content="TR"                     
                    Padding="10,4" FontSize="11" MinWidth="0" />
        </StackPanel>

        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                    Width="400" Spacing="24">

            <StackPanel Spacing="8" HorizontalAlignment="Center">
                <FontIcon Glyph="&#xE95E;" FontSize="48" Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
                <TextBlock x:ConnectionId='30' x:Name="TitleText" Text="Aura Core Pro" Style="{StaticResource TitleTextBlockStyle}" HorizontalAlignment="Center" />
                <TextBlock x:ConnectionId='31' x:Name="SubtitleText" Text="AI Powered Windows Intelligence"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                <Button x:ConnectionId='28' x:Name="LoginTab" Content="Sign In"                       
                        Style="{StaticResource AccentButtonStyle}" Padding="24,8" />
                <Button x:ConnectionId='29' x:Name="RegisterTab" Content="Create Account"                          
                        Padding="24,8" />
            </StackPanel>

            <StackPanel x:ConnectionId='2' x:Name="LoginForm" Spacing="12">
                <TextBox x:ConnectionId='24' x:Name="LoginEmail" Header="Email" PlaceholderText="your@email.com" />
                <PasswordBox x:ConnectionId='25' x:Name="LoginPassword" Header="Password" PlaceholderText="Enter your password" />
                <HyperlinkButton x:ConnectionId='26' x:Name="ForgotLink" Content="Forgot password?"                         
                                 HorizontalAlignment="Right" Margin="0,-8,0,0" Padding="0" FontSize="12" />
                <Button x:ConnectionId='27' x:Name="LoginBtn" Content="Sign In"                       
                        Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Stretch" Padding="0,10" />
            </StackPanel>

            <StackPanel x:ConnectionId='3' x:Name="ForgotForm" Spacing="12" Visibility="Collapsed">
                <TextBlock Text="Reset Password" Style="{StaticResource SubtitleTextBlockStyle}" HorizontalAlignment="Center" />
                <TextBlock x:ConnectionId='20' x:Name="ForgotDesc" Text="Enter your email and we'll send you a 6-digit reset code."
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" />
                <TextBox x:ConnectionId='21' x:Name="ForgotEmail" Header="Email" PlaceholderText="your@email.com" />
                <Button x:ConnectionId='22' x:Name="ForgotBtn" Content="Send Reset Code"                        
                        Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Stretch" Padding="0,10" />
                <HyperlinkButton x:ConnectionId='23' x:Name="BackToLoginLink" Content="← Back to Sign In"                          
                                 HorizontalAlignment="Center" FontSize="12" />
            </StackPanel>

            <StackPanel x:ConnectionId='4' x:Name="ResetForm" Spacing="12" Visibility="Collapsed">
                <TextBlock Text="Enter Reset Code" Style="{StaticResource SubtitleTextBlockStyle}" HorizontalAlignment="Center" />
                <TextBlock x:ConnectionId='13' x:Name="ResetDesc" Text="Check your email for the 6-digit code."
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" />
                <TextBox x:ConnectionId='14' x:Name="ResetEmail" Header="Email" IsReadOnly="True" />
                <TextBox x:ConnectionId='15' x:Name="ResetCode" Header="6-Digit Code" PlaceholderText="123456" MaxLength="6"
                         TextAlignment="Center" FontSize="20" CharacterSpacing="300" />
                <PasswordBox x:ConnectionId='16' x:Name="ResetNewPass" Header="New Password" PlaceholderText="Minimum 8 characters" />
                <PasswordBox x:ConnectionId='17' x:Name="ResetConfirmPass" Header="Confirm New Password" PlaceholderText="Repeat new password" />
                <Button x:ConnectionId='18' x:Name="ResetBtn" Content="Reset Password"                       
                        Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Stretch" Padding="0,10" />
                <HyperlinkButton x:ConnectionId='19' x:Name="BackToForgotLink" Content="← Request new code"                         
                                 HorizontalAlignment="Center" FontSize="12" />
            </StackPanel>

            <StackPanel x:ConnectionId='5' x:Name="RegisterForm" Spacing="12" Visibility="Collapsed">
                <TextBox x:ConnectionId='9' x:Name="RegEmail" Header="Email" PlaceholderText="your@email.com" />
                <PasswordBox x:ConnectionId='10' x:Name="RegPassword" Header="Password" PlaceholderText="Minimum 8 characters" />
                <PasswordBox x:ConnectionId='11' x:Name="RegConfirm" Header="Confirm Password" PlaceholderText="Repeat your password" />
                <Button x:ConnectionId='12' x:Name="RegisterBtn" Content="Create Account"                          
                        Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Stretch" Padding="0,10" />
            </StackPanel>

            <ProgressRing x:ConnectionId='6' x:Name="Progress" IsActive="False" Visibility="Collapsed" Width="28" Height="28"
                          HorizontalAlignment="Center" />
            <TextBlock x:ConnectionId='7' x:Name="StatusText" Text="" HorizontalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"
                       TextAlignment="Center" />

            <HyperlinkButton x:ConnectionId='8' x:Name="OfflineBtn" Content="Continue offline (Free tier)"
                                                      HorizontalAlignment="Center" />

        </StackPanel>
    </Grid>
</Window>

