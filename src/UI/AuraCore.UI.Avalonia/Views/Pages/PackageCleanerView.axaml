<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:AuraCore.UI.Avalonia.Views.Controls"
             x:Class="AuraCore.UI.Avalonia.Views.Pages.PackageCleanerView">
  <ScrollViewer>
    <StackPanel Spacing="16">

      <controls:ModuleHeader x:Name="PkgHeader"
                             Title=""
                             Subtitle="">
        <controls:ModuleHeader.Actions>
          <TextBlock x:Name="PageTitle" IsVisible="False"/>
        </controls:ModuleHeader.Actions>
      </controls:ModuleHeader>

      <!-- Hidden TextBlocks that code-behind populates via .Text = ... -->
      <StackPanel IsVisible="False" Height="0">
        <TextBlock x:Name="AptCacheSize"  Text="--"/>
        <TextBlock x:Name="SnapCacheSize" Text="--"/>
        <TextBlock x:Name="PipCacheSize"  Text="--"/>
      </StackPanel>

      <!-- Stat counters -->
      <controls:StatRow>
        <controls:StatCard x:Name="AptCacheStat"
                           Label=""
                           Value="{Binding #AptCacheSize.Text}"
                           ValueBrush="{DynamicResource TextPrimaryBrush}"/>
        <controls:StatCard x:Name="SnapCacheStat"
                           Label=""
                           Value="{Binding #SnapCacheSize.Text}"
                           ValueBrush="{DynamicResource AccentBlueBrush}"/>
        <controls:StatCard x:Name="PipCacheStat"
                           Label=""
                           Value="{Binding #PipCacheSize.Text}"
                           ValueBrush="{DynamicResource StatusWarningBrush}"/>
      </controls:StatRow>

      <!-- Cache categories list -->
      <controls:GlassCard>
        <StackPanel Spacing="12">
          <Grid ColumnDefinitions="*,Auto">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Border Width="16" Height="16" CornerRadius="4" Background="{DynamicResource AccentBgBrush}">
                <TextBlock Text="&#x25A0;"
                           FontSize="{DynamicResource FontSizeLabel}"
                           Foreground="{DynamicResource AccentPrimaryBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
              <TextBlock x:Name="CacheCategHeading"
                         Text=""
                         FontSize="{DynamicResource FontSizeLabel}"
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource TextSecondaryBrush}"/>
            </StackPanel>
            <Button x:Name="ScanBtn" Content="" Click="Scan_Click"
                    Grid.Column="1" Classes="action-btn" Padding="16,8"/>
          </Grid>
          <TextBlock x:Name="SubText"
                     Text=""
                     FontSize="{DynamicResource FontSizeBodySmall}"
                     Foreground="{DynamicResource TextMutedBrush}"/>
          <ItemsControl x:Name="CacheList"/>
        </StackPanel>
      </controls:GlassCard>

      <!-- Warning notice -->
      <controls:GlassCard>
        <TextBlock x:Name="PrivilegeWarning"
                   Text=""
                   FontSize="{DynamicResource FontSizeBodySmall}"
                   Foreground="{DynamicResource StatusWarningBrush}"
                   TextWrapping="Wrap"/>
      </controls:GlassCard>

    </StackPanel>
  </ScrollViewer>
</UserControl>
