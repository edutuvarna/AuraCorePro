<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AuraCore.Desktop.Pages.BloatwarePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Padding="32">
        <StackPanel Spacing="20" MaxWidth="960">

            <StackPanel Spacing="4">
                <TextBlock x:ConnectionId='24' x:Name="PageTitle" Text="Bloatware Removal" Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock x:ConnectionId='25' x:Name="PageSubtitle" Text="Detect and remove pre-installed Windows apps you don't need"
                           Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <!-- Action Bar -->
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button x:ConnectionId='20' x:Name="ScanBtn" Content="Scan Apps"                      
                        Style="{StaticResource AccentButtonStyle}" Padding="24,10" />
                <Button x:ConnectionId='21' x:Name="RemoveBtn" Content="Remove Selected (0)"                        
                        Padding="24,10" IsEnabled="False" />
                <ProgressRing x:ConnectionId='22' x:Name="Progress" IsActive="False" Visibility="Collapsed" Width="28" Height="28" />
                <TextBlock x:ConnectionId='23' x:Name="StatusText" Text="Click Scan to detect installed apps"
                           VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <!-- Summary Card -->
            <Border x:ConnectionId='2' x:Name="SummaryCard" Visibility="Collapsed"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <Grid ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="2">
                        <TextBlock Text="Total apps" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:ConnectionId='19' x:Name="TotalAppsText" Style="{StaticResource SubtitleTextBlockStyle}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="2">
                        <TextBlock Text="Removable" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:ConnectionId='18' x:Name="RemovableText" Style="{StaticResource SubtitleTextBlockStyle}" Foreground="#E65100" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="2">
                        <TextBlock Text="Safe to remove" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:ConnectionId='17' x:Name="SafeCountText" Style="{StaticResource SubtitleTextBlockStyle}" Foreground="#2E7D32" />
                    </StackPanel>
                    <StackPanel Grid.Column="3" Spacing="2">
                        <TextBlock Text="System required" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:ConnectionId='16' x:Name="SystemCountText" Style="{StaticResource SubtitleTextBlockStyle}" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Filter Buttons -->
            <StackPanel x:ConnectionId='3' x:Name="FilterBar" Orientation="Horizontal" Spacing="8" Visibility="Collapsed">
                <Button x:ConnectionId='9' x:Name="FilterAll" Content="All"                      Tag="all" />
                <Button x:ConnectionId='10' x:Name="FilterSafe" Content="Safe"                      Tag="safe" />
                <Button x:ConnectionId='11' x:Name="FilterCaution" Content="Caution"                      Tag="caution" />
                <Button x:ConnectionId='12' x:Name="FilterOem" Content="OEM"                      Tag="oem" />

                <Border Width="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" Margin="4,4" />

                <Button x:ConnectionId='13' x:Name="PresetFresh" Content="Fresh Windows Cleanup"                          
                        Style="{StaticResource AccentButtonStyle}" Padding="14,6" FontSize="12" />
                <Button x:ConnectionId='14' x:Name="SelectAllSafe" Content="Select All Safe"                            
                        Padding="14,6" FontSize="12" />
                <Button x:ConnectionId='15' x:Name="DeselectAll" Content="Deselect All"                          
                        Padding="14,6" FontSize="12" />
            </StackPanel>

            <!-- App List -->
            <!-- Search -->
            <TextBox x:ConnectionId='4' x:Name="SearchBox" PlaceholderText="Search apps by name..." Visibility="Collapsed"
                                                         />

            <StackPanel x:ConnectionId='5' x:Name="AppList" Spacing="4" />

            <!-- Result Card -->
            <Border x:ConnectionId='6' x:Name="ResultCard" Visibility="Collapsed"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="4">
                    <TextBlock x:ConnectionId='7' x:Name="ResultTitle" Style="{StaticResource BodyStrongTextBlockStyle}" Foreground="#2E7D32" />
                    <TextBlock x:ConnectionId='8' x:Name="ResultDetail" Style="{StaticResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>

