<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:AuraCore.UI.Avalonia.Views.Controls"
             x:Class="AuraCore.UI.Avalonia.Views.Pages.AdminPanelView">
  <ScrollViewer>
    <StackPanel Spacing="16">

      <!-- Header -->
      <controls:ModuleHeader x:Name="PageHeader" Title=""
                             Subtitle="">
        <controls:ModuleHeader.Actions>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <!-- PageTitle: invisible, no localization key but preserve slot -->
            <TextBlock x:Name="PageTitle" IsVisible="False"/>
          </StackPanel>
        </controls:ModuleHeader.Actions>
      </controls:ModuleHeader>

      <!-- Quick Access card -->
      <controls:GlassCard>
        <StackPanel Spacing="12">
          <TextBlock x:Name="QuickAccessTitle" Text="" FontSize="{DynamicResource FontSizeBody}" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextPrimaryBrush}"/>
          <TextBlock x:Name="QuickAccessDesc" Text=""
                     FontSize="{DynamicResource FontSizeBodySmall}" Foreground="{DynamicResource TextSecondaryBrush}"
                     TextWrapping="Wrap"/>
          <Button x:Name="OpenAdminBtn" Click="OpenAdmin_Click"
                  Background="{DynamicResource AccentPrimaryBrush}" Foreground="#0A0A0F"
                  Padding="20,12" CornerRadius="{StaticResource RadiusMd}"
                  HorizontalAlignment="Left" FontWeight="SemiBold" Cursor="Hand">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="🌐" FontSize="{DynamicResource FontSizeBody}" VerticalAlignment="Center"/>
              <TextBlock x:Name="OpenAdminLabel" Text="" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>
          <TextBlock x:Name="AdminUrlText" Text=""
                     FontSize="{DynamicResource FontSizeBodySmall}"
                     Foreground="{DynamicResource TextMutedBrush}"/>
        </StackPanel>
      </controls:GlassCard>

      <!-- Server Status card -->
      <controls:GlassCard>
        <StackPanel Spacing="12">
          <TextBlock x:Name="ServerStatusTitle" Text="" FontSize="{DynamicResource FontSizeBody}" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextPrimaryBrush}"/>
          <Grid ColumnDefinitions="Auto,*,Auto,*" RowDefinitions="Auto,Auto,Auto">
            <TextBlock x:Name="ApiLabel" Text="" FontSize="{DynamicResource FontSizeBodySmall}"
                       Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,16,8"/>
            <TextBlock x:Name="ApiStatusText" Grid.Column="1" Text=""
                       FontSize="{DynamicResource FontSizeBodySmall}"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
            <TextBlock x:Name="VersionLabel" Grid.Column="2" Text="" FontSize="{DynamicResource FontSizeBodySmall}"
                       Foreground="{DynamicResource TextMutedBrush}" Margin="16,0,16,8"/>
            <TextBlock x:Name="ApiVersionText" Grid.Column="3" Text="--"
                       FontSize="{DynamicResource FontSizeBodySmall}"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>

            <TextBlock x:Name="UptimeLabel" Grid.Row="1" Text="" FontSize="{DynamicResource FontSizeBodySmall}"
                       Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,16,8"/>
            <TextBlock x:Name="UptimeText" Grid.Row="1" Grid.Column="1" Text="--"
                       FontSize="{DynamicResource FontSizeBodySmall}"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
            <TextBlock x:Name="MemoryLabel" Grid.Row="1" Grid.Column="2" Text="" FontSize="{DynamicResource FontSizeBodySmall}"
                       Foreground="{DynamicResource TextMutedBrush}" Margin="16,0,16,8"/>
            <TextBlock x:Name="MemoryText" Grid.Row="1" Grid.Column="3" Text="--"
                       FontSize="{DynamicResource FontSizeBodySmall}"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>

            <TextBlock x:Name="EnvLabel" Grid.Row="2" Text="" FontSize="{DynamicResource FontSizeBodySmall}"
                       Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,16,0"/>
            <TextBlock x:Name="EnvText" Grid.Row="2" Grid.Column="1" Text="--"
                       FontSize="{DynamicResource FontSizeBodySmall}"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
          </Grid>
          <Button x:Name="RefreshStatusBtn" Click="RefreshStatus_Click" Content=""
                  Padding="12,6" Background="#12FFFFFF" CornerRadius="{StaticResource RadiusSm}"
                  HorizontalAlignment="Left" FontSize="{DynamicResource FontSizeBodySmall}" Cursor="Hand"/>
        </StackPanel>
      </controls:GlassCard>

      <!-- Admin-only notice -->
      <Border CornerRadius="{StaticResource RadiusLg}" Background="{DynamicResource WarningBgBrush}"
              Padding="16,12" BorderBrush="{DynamicResource WarningBorderBrush}" BorderThickness="1">
        <TextBlock x:Name="AdminNoticeText" Text=""
                   FontSize="{DynamicResource FontSizeBodySmall}" Foreground="#F59E0B"/>
      </Border>

    </StackPanel>
  </ScrollViewer>
</UserControl>
