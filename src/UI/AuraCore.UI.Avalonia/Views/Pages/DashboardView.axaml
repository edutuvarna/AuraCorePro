<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AuraCore.UI.Avalonia.Views.Pages.DashboardView">

  <ScrollViewer>
    <StackPanel Spacing="24">

      <!-- ── HERO ──────────────────────────────────────── -->
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Spacing="4">
          <TextBlock x:Name="WelcomeLabel" Text="Welcome back" FontSize="13"
                     Foreground="{DynamicResource TextSecondaryBrush}"/>
          <TextBlock x:Name="HeroTitle" Text="System Overview"
                     FontSize="28" FontWeight="Bold"
                     Foreground="{DynamicResource TextPrimaryBrush}"/>
        </StackPanel>
        <Border Grid.Column="1" CornerRadius="{StaticResource RadiusMd}"
                Background="#1500D4AA" Padding="14,8"
                VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Border Width="8" Height="8" CornerRadius="4"
                    Background="{DynamicResource SuccessBrush}"/>
            <TextBlock x:Name="StatusLabel" Text="All Systems Healthy"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource AccentPrimaryBrush}"/>
          </StackPanel>
        </Border>
      </Grid>

      <!-- ── KPI Cards ─────────────────────────────────── -->
      <Grid ColumnDefinitions="*,*,*,*">
        <!-- CPU -->
        <Border Grid.Column="0" Margin="0,0,8,0" CornerRadius="{StaticResource RadiusLg}"
                Background="{DynamicResource BgCardBrush}"
                BorderBrush="{DynamicResource BorderCardBrush}" BorderThickness="1" Padding="20">
          <StackPanel Spacing="8">
            <TextBlock x:Name="CpuLabel" Text="CPU Usage" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
            <StackPanel Orientation="Horizontal" Spacing="4">
              <TextBlock x:Name="CpuValue" Text="--" FontSize="32" FontWeight="Bold"
                         Foreground="{DynamicResource AccentPrimaryBrush}"/>
              <TextBlock Text="%" FontSize="14" Foreground="{DynamicResource TextMutedBrush}"
                         VerticalAlignment="Bottom" Margin="0,0,0,6"/>
            </StackPanel>
            <Border Height="4" CornerRadius="2" Background="#1A1A28">
              <Border x:Name="CpuBar" Height="4" CornerRadius="2"
                      Background="{DynamicResource AccentPrimaryBrush}"
                      HorizontalAlignment="Left" Width="0"/>
            </Border>
          </StackPanel>
        </Border>
        <!-- RAM -->
        <Border Grid.Column="1" Margin="4,0" CornerRadius="{StaticResource RadiusLg}"
                Background="{DynamicResource BgCardBrush}"
                BorderBrush="{DynamicResource BorderCardBrush}" BorderThickness="1" Padding="20">
          <StackPanel Spacing="8">
            <TextBlock x:Name="RamLabel" Text="RAM Used" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
            <StackPanel Orientation="Horizontal" Spacing="4">
              <TextBlock x:Name="RamValue" Text="--" FontSize="32" FontWeight="Bold"
                         Foreground="{DynamicResource AccentBlueBrush}"/>
              <TextBlock x:Name="RamTotal" Text="/ -- GB" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                         VerticalAlignment="Bottom" Margin="0,0,0,6"/>
            </StackPanel>
            <Border Height="4" CornerRadius="2" Background="#1A1A28">
              <Border x:Name="RamBar" Height="4" CornerRadius="2"
                      Background="{DynamicResource AccentBlueBrush}"
                      HorizontalAlignment="Left" Width="0"/>
            </Border>
          </StackPanel>
        </Border>
        <!-- Disk -->
        <Border Grid.Column="2" Margin="4,0" CornerRadius="{StaticResource RadiusLg}"
                Background="{DynamicResource BgCardBrush}"
                BorderBrush="{DynamicResource BorderCardBrush}" BorderThickness="1" Padding="20">
          <StackPanel Spacing="8">
            <TextBlock x:Name="DiskLabel" Text="Disk Free" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
            <StackPanel Orientation="Horizontal" Spacing="4">
              <TextBlock x:Name="DiskValue" Text="--" FontSize="32" FontWeight="Bold"
                         Foreground="{DynamicResource AccentPurpleBrush}"/>
              <TextBlock Text="GB" FontSize="14" Foreground="{DynamicResource TextMutedBrush}"
                         VerticalAlignment="Bottom" Margin="0,0,0,6"/>
            </StackPanel>
            <Border Height="4" CornerRadius="2" Background="#1A1A28">
              <Border x:Name="DiskBar" Height="4" CornerRadius="2"
                      Background="{DynamicResource AccentPurpleBrush}"
                      HorizontalAlignment="Left" Width="0"/>
            </Border>
          </StackPanel>
        </Border>
        <!-- Uptime -->
        <Border Grid.Column="3" Margin="8,0,0,0" CornerRadius="{StaticResource RadiusLg}"
                Background="{DynamicResource BgCardBrush}"
                BorderBrush="{DynamicResource BorderCardBrush}" BorderThickness="1" Padding="20">
          <StackPanel Spacing="8">
            <TextBlock x:Name="UptimeLabel" Text="Uptime" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
            <TextBlock x:Name="UptimeValue" Text="--" FontSize="28" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock x:Name="OsLabel" Text="" FontSize="11"
                       Foreground="{DynamicResource TextMutedBrush}"/>
          </StackPanel>
        </Border>
      </Grid>

      <!-- ── Large cards row ───────────────────────────── -->
      <Grid ColumnDefinitions="2*,*">
        <!-- Active Modules -->
        <Border Grid.Column="0" Margin="0,0,8,0" CornerRadius="{StaticResource RadiusLg}"
                Background="{DynamicResource BgCardBrush}"
                BorderBrush="{DynamicResource BorderCardBrush}" BorderThickness="1" Padding="24">
          <StackPanel Spacing="16">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock x:Name="ModulesLabel" Text="Active Modules" FontSize="15" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}"/>
              <TextBlock x:Name="ModuleCount" Grid.Column="1" Text="0 loaded"
                         FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
            </Grid>
            <ItemsControl x:Name="ModuleList">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Margin="0,0,0,6" CornerRadius="8" Background="#12FFFFFF" Padding="14,10">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                      <Border Width="6" Height="6" CornerRadius="3"
                              Background="{DynamicResource AccentPrimaryBrush}"
                              VerticalAlignment="Center" Margin="0,0,10,0"/>
                      <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="{Binding Category}" FontSize="10"
                                   Foreground="{DynamicResource TextMutedBrush}"/>
                      </StackPanel>
                      <TextBlock Grid.Column="2" Text="{Binding Platform}" FontSize="10"
                                 Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>
        <!-- Quick Actions -->
        <Border Grid.Column="1" Margin="8,0,0,0" CornerRadius="{StaticResource RadiusLg}"
                Background="{DynamicResource BgCardBrush}"
                BorderBrush="{DynamicResource BorderCardBrush}" BorderThickness="1" Padding="24">
          <StackPanel Spacing="16">
            <TextBlock x:Name="QuickActionsLabel" Text="Quick Actions" FontSize="15" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <StackPanel Spacing="8">
              <Button Classes="action-btn" Click="ScanAll_Click">
                <StackPanel Orientation="Horizontal" Spacing="10">
                  <TextBlock Text="&#x1F50D;" FontSize="16"/>
                  <StackPanel>
                    <TextBlock Text="Full System Scan" FontSize="12" FontWeight="SemiBold"/>
                    <TextBlock Text="Analyze all modules" FontSize="10"
                               Foreground="{DynamicResource TextMutedBrush}"/>
                  </StackPanel>
                </StackPanel>
              </Button>
              <Button Classes="action-btn">
                <StackPanel Orientation="Horizontal" Spacing="10">
                  <TextBlock Text="&#x1F4CA;" FontSize="16"/>
                  <StackPanel>
                    <TextBlock Text="Performance Report" FontSize="12" FontWeight="SemiBold"/>
                    <TextBlock Text="Generate system report" FontSize="10"
                               Foreground="{DynamicResource TextMutedBrush}"/>
                  </StackPanel>
                </StackPanel>
              </Button>
            </StackPanel>
          </StackPanel>
        </Border>
      </Grid>

      <!-- ── Platform Info ─────────────────────────────── -->
      <Border CornerRadius="{StaticResource RadiusLg}"
              Background="#0D00D4AA" Padding="16,12"
              BorderBrush="#2000D4AA" BorderThickness="1">
        <Grid ColumnDefinitions="Auto,*">
          <TextBlock Text="&#x2699;" FontSize="16" VerticalAlignment="Center" Margin="0,0,12,0"/>
          <TextBlock x:Name="PlatformInfo" Grid.Column="1"
                     FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                     VerticalAlignment="Center" TextWrapping="Wrap"/>
        </Grid>
      </Border>

    </StackPanel>
  </ScrollViewer>
</UserControl>
