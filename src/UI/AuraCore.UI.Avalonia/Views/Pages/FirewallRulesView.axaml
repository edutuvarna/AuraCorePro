<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:AuraCore.UI.Avalonia.Views.Controls"
             x:Class="AuraCore.UI.Avalonia.Views.Pages.FirewallRulesView">
  <ScrollViewer>
    <StackPanel Spacing="16">

      <!-- Header -->
      <controls:ModuleHeader x:Name="ModuleHdr"
                             Title=""
                             Subtitle="Manage Windows Firewall inbound and outbound rules">
        <controls:ModuleHeader.Actions>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button x:Name="ScanBtn" Classes="action-btn" Click="Scan_Click"
                    VerticalAlignment="Center" Padding="14,8">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="🛡" FontSize="{DynamicResource FontSizeBody}"/>
                <TextBlock x:Name="ScanRulesLabel" Text=""
                           FontSize="{DynamicResource FontSizeBodySmall}" FontWeight="SemiBold"/>
              </StackPanel>
            </Button>
            <!-- PageTitle: invisible, code-behind writes localized string -->
            <TextBlock x:Name="PageTitle" IsVisible="False"/>
          </StackPanel>
        </controls:ModuleHeader.Actions>
      </controls:ModuleHeader>

      <!-- Hidden TextBlocks that code-behind populates via .Text = ... -->
      <StackPanel IsVisible="False" Height="0">
        <TextBlock x:Name="TotalRules"   Text="--"/>
        <TextBlock x:Name="EnabledRules" Text="--"/>
        <TextBlock x:Name="BlockedRules" Text="--"/>
      </StackPanel>

      <!-- Stat counters -->
      <controls:StatRow>
        <controls:StatCard x:Name="StatTotal"
                           Value="{Binding #TotalRules.Text}"
                           ValueBrush="{DynamicResource TextPrimaryBrush}"/>
        <controls:StatCard x:Name="StatEnabled"
                           Value="{Binding #EnabledRules.Text}"
                           ValueBrush="{DynamicResource StatusSuccessBrush}"/>
        <controls:StatCard x:Name="StatBlocked"
                           Value="{Binding #BlockedRules.Text}"
                           ValueBrush="{DynamicResource StatusErrorBrush}"/>
      </controls:StatRow>

      <!-- Rules list -->
      <controls:GlassCard>
        <StackPanel Spacing="12">
          <Grid ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
              <Border Width="16" Height="16" CornerRadius="4">
                <Border.Background>
                  <SolidColorBrush Color="#EF4444" Opacity="0.15"/>
                </Border.Background>
                <TextBlock Text="⛔" FontSize="{DynamicResource FontSizeLabel}" Foreground="#EF4444"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
              <TextBox x:Name="SearchBox" Width="300" HorizontalAlignment="Left"/>
            </StackPanel>
          </Grid>
          <TextBlock x:Name="SubText" Text=""
                     FontSize="{DynamicResource FontSizeBody}"
                     Foreground="{DynamicResource TextMutedBrush}"/>
          <ItemsControl x:Name="RulesList"/>
        </StackPanel>
      </controls:GlassCard>

    </StackPanel>
  </ScrollViewer>
</UserControl>
