<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:AuraCore.UI.Avalonia.Views.Controls"
             x:Class="AuraCore.UI.Avalonia.Views.Pages.FontManagerView">
  <ScrollViewer>
    <StackPanel Spacing="16">

      <!-- Header -->
      <controls:ModuleHeader Title="Font Manager"
                             Subtitle="Browse installed fonts with live preview">
        <controls:ModuleHeader.Actions>
          <!-- PageTitle: invisible, code-behind writes localized string -->
          <TextBlock x:Name="PageTitle" IsVisible="False"/>
        </controls:ModuleHeader.Actions>
      </controls:ModuleHeader>

      <!-- Search + count row -->
      <controls:GlassCard>
        <StackPanel Spacing="12">
          <Grid ColumnDefinitions="*,Auto">
            <TextBox x:Name="SearchBox" Watermark="Search fonts..." TextChanged="Search_Changed"/>
            <TextBlock x:Name="FontCount" Grid.Column="1" Text="--"
                       FontSize="{DynamicResource FontSizeBody}"
                       Foreground="{DynamicResource TextMutedBrush}"
                       VerticalAlignment="Center" Margin="12,0,0,0"/>
          </Grid>
          <TextBox x:Name="PreviewText"
                   Text="The quick brown fox jumps over the lazy dog. 0123456789"
                   Watermark="Preview text..."/>
        </StackPanel>
      </controls:GlassCard>

      <!-- Font list -->
      <controls:GlassCard>
        <StackPanel Spacing="8">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Border Width="16" Height="16" CornerRadius="4"
                    Background="{DynamicResource BgCardBrush}">
              <TextBlock Text="A" FontSize="{DynamicResource FontSizeLabel}" FontWeight="Bold"
                         Foreground="{DynamicResource AccentPrimaryBrush}"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="Installed Fonts"
                       FontSize="{DynamicResource FontSizeBodySmall}" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
          </StackPanel>
          <ItemsControl x:Name="FontList"/>
        </StackPanel>
      </controls:GlassCard>

    </StackPanel>
  </ScrollViewer>
</UserControl>
