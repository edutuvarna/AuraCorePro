<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AuraCore.UI.Avalonia.Views.Pages.SwapOptimizerView">
  <ScrollViewer>
    <StackPanel Spacing="20">
      <StackPanel Spacing="4">
        <TextBlock x:Name="PageTitle" Text="Swap Optimizer" FontSize="28" FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>
        <TextBlock Text="Monitor and optimize Linux swap usage and swappiness settings"
                   FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"/>
      </StackPanel>
      <Grid ColumnDefinitions="*,*,*">
        <Border Margin="0,0,8,0" CornerRadius="{StaticResource RadiusMd}" Background="{DynamicResource BgCardBrush}"
                BorderBrush="{DynamicResource BorderCardBrush}" BorderThickness="1" Padding="16">
          <StackPanel Spacing="4">
            <TextBlock Text="Swap Total" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
            <TextBlock x:Name="SwapTotal" Text="--" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
          </StackPanel>
        </Border>
        <Border Margin="4,0" CornerRadius="{StaticResource RadiusMd}" Background="{DynamicResource BgCardBrush}"
                BorderBrush="{DynamicResource BorderCardBrush}" BorderThickness="1" Padding="16">
          <StackPanel Spacing="4">
            <TextBlock Text="Swap Used" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
            <TextBlock x:Name="SwapUsed" Text="--" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource WarningBrush}"/>
          </StackPanel>
        </Border>
        <Border Margin="8,0,0,0" CornerRadius="{StaticResource RadiusMd}" Background="{DynamicResource BgCardBrush}"
                BorderBrush="{DynamicResource BorderCardBrush}" BorderThickness="1" Padding="16">
          <StackPanel Spacing="4">
            <TextBlock Text="Swappiness" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
            <TextBlock x:Name="Swappiness" Text="--" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource AccentBlueBrush}"/>
          </StackPanel>
        </Border>
      </Grid>
      <Border CornerRadius="{StaticResource RadiusLg}" Background="{DynamicResource BgCardBrush}"
              BorderBrush="{DynamicResource BorderCardBrush}" BorderThickness="1" Padding="24">
        <StackPanel Spacing="12">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="Swap Partitions/Files" FontSize="15" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <Button Content="Refresh" Click="Scan_Click" Grid.Column="1" Classes="action-btn" Padding="16,8"/>
          </Grid>
          <ItemsControl x:Name="SwapList"/>
          <TextBlock x:Name="SubText" Text="Click Refresh to read swap information" FontSize="12"
                     Foreground="{DynamicResource TextMutedBrush}"/>
        </StackPanel>
      </Border>
      <Border CornerRadius="{StaticResource RadiusLg}" Background="{DynamicResource BgCardBrush}"
              BorderBrush="{DynamicResource BorderCardBrush}" BorderThickness="1" Padding="24">
        <StackPanel Spacing="12">
          <TextBlock Text="Swappiness Recommendations" FontSize="15" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextPrimaryBrush}"/>
          <TextBlock x:Name="RecommendationText" Text="" FontSize="12" TextWrapping="Wrap"
                     Foreground="{DynamicResource TextSecondaryBrush}"/>
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
