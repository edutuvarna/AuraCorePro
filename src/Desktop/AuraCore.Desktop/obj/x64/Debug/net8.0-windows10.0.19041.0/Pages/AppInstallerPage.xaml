<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AuraCore.Desktop.Pages.AppInstallerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Padding="32">
        <StackPanel Spacing="20" MaxWidth="960">

            <StackPanel Spacing="4">
                <TextBlock x:ConnectionId='40' x:Name="PageTitle" Text="App Installer" Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock x:ConnectionId='41' x:Name="PageSubtitle" Text="Install, update, search, and manage applications with WinGet"
                           Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <Border x:ConnectionId='2' x:Name="WingetStatus"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="16" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <ProgressRing x:ConnectionId='38' x:Name="LoadProgress" IsActive="True" Width="20" Height="20" />
                    <TextBlock x:ConnectionId='39' x:Name="WingetStatusText" Text="Checking WinGet..." VerticalAlignment="Center" />
                </StackPanel>
            </Border>

            <StackPanel x:ConnectionId='3' x:Name="TabBar" Orientation="Horizontal" Spacing="4" Visibility="Collapsed">
                <Button x:ConnectionId='33' x:Name="TabBundles" Content="App Bundles"                   Tag="bundles"
                        Style="{StaticResource AccentButtonStyle}" Padding="16,8" />
                <Button x:ConnectionId='34' x:Name="TabCustom" Content="My Bundles"                   Tag="custom" Padding="16,8" />
                <Button x:ConnectionId='35' x:Name="TabSearch" Content="Search Apps"                   Tag="search" Padding="16,8" />
                <Button x:ConnectionId='36' x:Name="TabInstalled" Content="Installed Apps"                   Tag="installed" Padding="16,8" />
                <Button x:ConnectionId='37' x:Name="TabUpdates" Content="Updates"                   Tag="updates" Padding="16,8" />
            </StackPanel>

            <StackPanel x:ConnectionId='4' x:Name="BundlesPanel" Spacing="12" />

            <!-- CUSTOM BUNDLES TAB -->
            <StackPanel x:ConnectionId='5' x:Name="CustomBundlesPanel" Spacing="12" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button x:ConnectionId='31' x:Name="CreateBundleBtn" Content="Create New Bundle"                           
                            Style="{StaticResource AccentButtonStyle}" Padding="16,8" />
                    <TextBlock x:ConnectionId='32' x:Name="CustomBundleStatus" Text="" VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                </StackPanel>
                <StackPanel x:ConnectionId='30' x:Name="CustomBundlesList" Spacing="12" />
            </StackPanel>

            <StackPanel x:ConnectionId='6' x:Name="SearchPanel" Spacing="12" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBox x:ConnectionId='27' x:Name="SearchBox" PlaceholderText="Search for apps (e.g. Chrome, VS Code, Python)..."
                             Width="500"                             />
                    <Button x:ConnectionId='28' x:Name="SearchBtn" Content="Search"                         Padding="16,8" />
                    <ProgressRing x:ConnectionId='29' x:Name="SearchProgress" IsActive="False" Visibility="Collapsed" Width="24" Height="24" />
                </StackPanel>
                <StackPanel x:ConnectionId='25' x:Name="SearchResults" Spacing="4" />
                <Button x:ConnectionId='26' x:Name="BulkInstallBtn" Content="Install Selected (0)"                          
                        IsEnabled="False" Padding="16,8" Visibility="Collapsed" />
            </StackPanel>

            <StackPanel x:ConnectionId='7' x:Name="InstalledPanel" Spacing="8" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button x:ConnectionId='19' x:Name="RefreshInstalledBtn" Content="Refresh"                                Padding="16,8" />
                    <Button x:ConnectionId='20' x:Name="BulkUninstallBtn" Content="Uninstall Selected (0)"                            
                            IsEnabled="False" Padding="16,8" />
                    <Button x:ConnectionId='21' x:Name="ExportBtn" Content="Export List"                          Padding="16,8" />
                    <Button x:ConnectionId='22' x:Name="ImportBtn" Content="Import &amp; Install"                          Padding="16,8" />
                    <ProgressRing x:ConnectionId='23' x:Name="InstalledProgress" IsActive="False" Visibility="Collapsed" Width="24" Height="24" />
                    <TextBlock x:ConnectionId='24' x:Name="InstalledStatusText" Text="" VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
                <TextBox x:ConnectionId='17' x:Name="InstalledFilterBox" PlaceholderText="Filter installed apps..."
                         Width="400" HorizontalAlignment="Left"                                           />
                <StackPanel x:ConnectionId='18' x:Name="InstalledList" Spacing="4" />
            </StackPanel>

            <!-- UPDATES TAB -->
            <StackPanel x:ConnectionId='8' x:Name="UpdatesPanel" Spacing="8" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button x:ConnectionId='12' x:Name="CheckUpdatesBtn" Content="Check for Updates"                           
                            Style="{StaticResource AccentButtonStyle}" Padding="16,8" />
                    <Button x:ConnectionId='13' x:Name="UpdateAllBtn" Content="Update All"                        
                            Padding="16,8" IsEnabled="False" />
                    <Button x:ConnectionId='14' x:Name="UpdateSelectedBtn" Content="Update Selected (0)"                             
                            Padding="16,8" IsEnabled="False" />
                    <ProgressRing x:ConnectionId='15' x:Name="UpdateProgress" IsActive="False" Visibility="Collapsed" Width="24" Height="24" />
                    <TextBlock x:ConnectionId='16' x:Name="UpdateStatusText" Text="Click 'Check for Updates' to scan"
                               VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
                <StackPanel x:ConnectionId='11' x:Name="UpdateList" Spacing="4" />
            </StackPanel>

            <Border x:ConnectionId='9' x:Name="ResultCard" Visibility="Collapsed"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <TextBlock x:ConnectionId='10' x:Name="ResultText" Style="{StaticResource BodyTextBlockStyle}" Foreground="#2E7D32" TextWrapping="Wrap" />
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>

