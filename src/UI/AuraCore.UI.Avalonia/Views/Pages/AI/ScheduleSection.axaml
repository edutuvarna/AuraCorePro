<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AuraCore.UI.Avalonia.Views.Pages.AI.ScheduleSection">
  <DockPanel>

    <!-- Section header (§4.5 template) -->
    <Border DockPanel.Dock="Top" Padding="0,0,0,12">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Grid.Column="0"
                   x:Name="PageTitle"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}" />
        <!-- Section label badge -->
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
          <Border Width="18" Height="18" CornerRadius="5">
            <Border.Background>
              <SolidColorBrush Color="#F59E0B" Opacity="0.15"/>
            </Border.Background>
            <TextBlock Text="⏰" FontSize="9" Foreground="#F59E0B"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <TextBlock x:Name="ScheduledTasksLabel" FontSize="10" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
        </StackPanel>
      </Grid>
    </Border>

    <!-- Content (all existing code-behind bindings/x:Names preserved) -->
    <ScrollViewer>
      <StackPanel Spacing="10" Margin="0,0,0,24">

        <!-- Subtitle -->
        <TextBlock x:Name="ScheduleSubtitle" FontSize="12"
                   Foreground="{DynamicResource TextMutedBrush}"/>

        <!-- Task cards container (populated in code-behind via x:Name="TaskList") -->
        <StackPanel x:Name="TaskList" Spacing="8"/>

        <!-- Info banner -->
        <Border CornerRadius="{StaticResource RadiusMd}" Padding="16,10" BorderThickness="1">
          <Border.Background>
            <SolidColorBrush Color="#F59E0B" Opacity="0.06"/>
          </Border.Background>
          <Border.BorderBrush>
            <SolidColorBrush Color="#F59E0B" Opacity="0.15"/>
          </Border.BorderBrush>
          <TextBlock x:Name="ScheduleInfoBanner" FontSize="11" Foreground="#F59E0B" TextWrapping="Wrap"/>
        </Border>

      </StackPanel>
    </ScrollViewer>

  </DockPanel>
</UserControl>
