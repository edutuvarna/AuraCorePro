<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:AuraCore.UI.Avalonia.Views.Controls"
             x:Class="AuraCore.UI.Avalonia.Views.Pages.FontManagerView">
  <ScrollViewer>
    <StackPanel Spacing="16">

      <!-- Header -->
      <controls:ModuleHeader x:Name="ModuleHdr"
                             Title=""
                             Subtitle="Browse installed fonts with live preview">
        <controls:ModuleHeader.Actions>
          <!-- PageTitle: invisible, code-behind writes localized string -->
          <TextBlock x:Name="PageTitle" IsVisible="False"/>
        </controls:ModuleHeader.Actions>
      </controls:ModuleHeader>

      <!-- Info banner: Explorer restart notice (not a warning — just heads-up) -->
      <Border CornerRadius="{StaticResource RadiusMd}"
              Background="{DynamicResource InfoBgBrush}"
              BorderBrush="{DynamicResource InfoBorderBrush}" BorderThickness="1"
              Padding="14,10">
        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
          <TextBlock Text="ℹ"
                     FontSize="{DynamicResource FontSizeBody}"
                     Foreground="{DynamicResource AccentBlueBrush}"
                     VerticalAlignment="Center"/>
          <TextBlock x:Name="ExplorerRestartText" Text=""
                     FontSize="{DynamicResource FontSizeBodySmall}"
                     Foreground="{DynamicResource AccentBlueBrush}"
                     TextWrapping="Wrap"
                     VerticalAlignment="Center"/>
        </StackPanel>
      </Border>

      <!-- Search + count row -->
      <controls:GlassCard>
        <StackPanel Spacing="12">
          <Grid ColumnDefinitions="*,Auto">
            <TextBox x:Name="SearchBox" TextChanged="Search_Changed"/>
            <TextBlock x:Name="FontCount" Grid.Column="1" Text="--"
                       FontSize="{DynamicResource FontSizeBody}"
                       Foreground="{DynamicResource TextMutedBrush}"
                       VerticalAlignment="Center" Margin="12,0,0,0"/>
          </Grid>
          <TextBox x:Name="PreviewText" Text=""/>
        </StackPanel>
      </controls:GlassCard>

      <!-- Font list -->
      <controls:GlassCard>
        <StackPanel Spacing="8">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Border Width="16" Height="16" CornerRadius="4"
                    Background="{DynamicResource BgCardBrush}">
              <TextBlock Text="A" FontSize="{DynamicResource FontSizeLabel}" FontWeight="Bold"
                         Foreground="{DynamicResource AccentPrimaryBrush}"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock x:Name="InstalledFontsLabel" Text=""
                       FontSize="{DynamicResource FontSizeBodySmall}" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
          </StackPanel>
          <ItemsControl x:Name="FontList"/>
        </StackPanel>
      </controls:GlassCard>

    </StackPanel>
  </ScrollViewer>
</UserControl>
