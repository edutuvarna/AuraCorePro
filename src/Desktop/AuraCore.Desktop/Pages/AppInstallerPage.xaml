<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AuraCore.Desktop.Pages.AppInstallerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Padding="32">
        <StackPanel Spacing="20" MaxWidth="960">

            <StackPanel Spacing="4">
                <TextBlock x:Name="PageTitle" Text="App Installer" Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock x:Name="PageSubtitle" Text="Install, update, search, and manage applications with WinGet"
                           Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <Border x:Name="WingetStatus"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="16" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <ProgressRing x:Name="LoadProgress" IsActive="True" Width="20" Height="20" />
                    <TextBlock x:Name="WingetStatusText" Text="Checking WinGet..." VerticalAlignment="Center" />
                </StackPanel>
            </Border>

            <StackPanel x:Name="TabBar" Orientation="Horizontal" Spacing="4" Visibility="Collapsed">
                <Button x:Name="TabBundles" Content="App Bundles" Click="Tab_Click" Tag="bundles"
                        Style="{StaticResource AccentButtonStyle}" Padding="16,8" />
                <Button x:Name="TabCustom" Content="My Bundles" Click="Tab_Click" Tag="custom" Padding="16,8" />
                <Button x:Name="TabSearch" Content="Search Apps" Click="Tab_Click" Tag="search" Padding="16,8" />
                <Button x:Name="TabInstalled" Content="Installed Apps" Click="Tab_Click" Tag="installed" Padding="16,8" />
                <Button x:Name="TabUpdates" Content="Updates" Click="Tab_Click" Tag="updates" Padding="16,8" />
            </StackPanel>

            <StackPanel x:Name="BundlesPanel" Spacing="12" />

            <!-- CUSTOM BUNDLES TAB -->
            <StackPanel x:Name="CustomBundlesPanel" Spacing="12" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button x:Name="CreateBundleBtn" Content="Create New Bundle" Click="CreateBundle_Click"
                            Style="{StaticResource AccentButtonStyle}" Padding="16,8" />
                    <TextBlock x:Name="CustomBundleStatus" Text="" VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                </StackPanel>
                <StackPanel x:Name="CustomBundlesList" Spacing="12" />
            </StackPanel>

            <StackPanel x:Name="SearchPanel" Spacing="12" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBox x:Name="SearchBox" PlaceholderText="Search for apps (e.g. Chrome, VS Code, Python)..."
                             Width="500" KeyDown="SearchBox_KeyDown" />
                    <Button x:Name="SearchBtn" Content="Search" Click="SearchBtn_Click" Padding="16,8" />
                    <ProgressRing x:Name="SearchProgress" IsActive="False" Visibility="Collapsed" Width="24" Height="24" />
                </StackPanel>
                <StackPanel x:Name="SearchResults" Spacing="4" />
                <Button x:Name="BulkInstallBtn" Content="Install Selected (0)" Click="BulkInstall_Click"
                        IsEnabled="False" Padding="16,8" Visibility="Collapsed" />
            </StackPanel>

            <StackPanel x:Name="InstalledPanel" Spacing="8" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button x:Name="RefreshInstalledBtn" Content="Refresh" Click="RefreshInstalled_Click" Padding="16,8" />
                    <Button x:Name="BulkUninstallBtn" Content="Uninstall Selected (0)" Click="BulkUninstall_Click"
                            IsEnabled="False" Padding="16,8" />
                    <Button x:Name="ExportBtn" Content="Export List" Click="ExportList_Click" Padding="16,8" />
                    <Button x:Name="ImportBtn" Content="Import &amp; Install" Click="ImportList_Click" Padding="16,8" />
                    <ProgressRing x:Name="InstalledProgress" IsActive="False" Visibility="Collapsed" Width="24" Height="24" />
                    <TextBlock x:Name="InstalledStatusText" Text="" VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
                <TextBox x:Name="InstalledFilterBox" PlaceholderText="Filter installed apps..."
                         Width="400" HorizontalAlignment="Left" TextChanged="InstalledFilter_TextChanged" />
                <StackPanel x:Name="InstalledList" Spacing="4" />
            </StackPanel>

            <!-- UPDATES TAB -->
            <StackPanel x:Name="UpdatesPanel" Spacing="8" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button x:Name="CheckUpdatesBtn" Content="Check for Updates" Click="CheckUpdates_Click"
                            Style="{StaticResource AccentButtonStyle}" Padding="16,8" />
                    <Button x:Name="UpdateAllBtn" Content="Update All" Click="UpdateAll_Click"
                            Padding="16,8" IsEnabled="False" />
                    <Button x:Name="UpdateSelectedBtn" Content="Update Selected (0)" Click="UpdateSelected_Click"
                            Padding="16,8" IsEnabled="False" />
                    <ProgressRing x:Name="UpdateProgress" IsActive="False" Visibility="Collapsed" Width="24" Height="24" />
                    <TextBlock x:Name="UpdateStatusText" Text="Click 'Check for Updates' to scan"
                               VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
                <StackPanel x:Name="UpdateList" Spacing="4" />
            </StackPanel>

            <Border x:Name="ResultCard" Visibility="Collapsed"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <TextBlock x:Name="ResultText" Style="{StaticResource BodyTextBlockStyle}" Foreground="#2E7D32" TextWrapping="Wrap" />
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
