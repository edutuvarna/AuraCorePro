<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:AuraCore.UI.Avalonia.Views.Controls"
             x:Class="AuraCore.UI.Avalonia.Views.Pages.DiskHealthView">
  <ScrollViewer>
    <StackPanel Spacing="16">

      <!-- Header -->
      <controls:ModuleHeader x:Name="Header">
        <controls:ModuleHeader.Actions>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Classes="action-btn" Click="Scan_Click" Padding="14,8" VerticalAlignment="Center">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="🔍" FontSize="{DynamicResource FontSizeBody}"/>
                <TextBlock x:Name="ScanLabel" Text=""
                           FontSize="{DynamicResource FontSizeBodySmall}" FontWeight="SemiBold"/>
              </StackPanel>
            </Button>
            <!-- PageTitle: invisible, code-behind writes localized string -->
            <TextBlock x:Name="PageTitle" IsVisible="False"/>
          </StackPanel>
        </controls:ModuleHeader.Actions>
      </controls:ModuleHeader>

      <!-- Hidden subtitle bridge for code-behind -->
      <TextBlock x:Name="SubText"
                 Text=""
                 FontSize="{DynamicResource FontSizeBodySmall}"
                 Foreground="{DynamicResource TextMutedBrush}"
                 IsVisible="False"/>

      <!-- Drive list card -->
      <controls:GlassCard>
        <StackPanel Spacing="8">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Border Width="20" Height="20" CornerRadius="6"
                    Background="{DynamicResource BgCardBrush}">
              <TextBlock Text="💿" FontSize="{DynamicResource FontSizeLabel}"
                         Foreground="{DynamicResource AccentPrimaryBrush}"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock x:Name="DetectedDrivesLabel" Text=""
                       FontSize="{DynamicResource FontSizeBodySmall}" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
          </StackPanel>
          <ItemsControl x:Name="DriveList">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Margin="0,0,0,8" CornerRadius="10" BorderThickness="1" Padding="14,12"
                        Background="{DynamicResource BgCardBrush}"
                        BorderBrush="{DynamicResource BorderSubtleBrush}">
                  <StackPanel Spacing="10">
                    <Grid ColumnDefinitions="*,Auto">
                      <StackPanel>
                        <TextBlock Text="{Binding Model}"
                                   FontSize="{DynamicResource FontSizeBody}" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="{Binding Info}"
                                   FontSize="{DynamicResource FontSizeBodySmall}"
                                   Foreground="{DynamicResource TextMutedBrush}"/>
                      </StackPanel>
                      <Border Grid.Column="1" CornerRadius="8" Padding="10,4"
                              Background="{Binding HealthBg}" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Health}"
                                   FontSize="{DynamicResource FontSizeBodySmall}" FontWeight="Bold"
                                   Foreground="{Binding HealthFg}"/>
                      </Border>
                    </Grid>
                    <Grid ColumnDefinitions="*,*,*,*">
                      <StackPanel Spacing="2">
                        <TextBlock Text="{Binding SizeLabel}"
                                   FontSize="{DynamicResource FontSizeLabel}"
                                   Foreground="{DynamicResource TextMutedBrush}"/>
                        <TextBlock Text="{Binding Size}"
                                   FontSize="{DynamicResource FontSizeBodySmall}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                      </StackPanel>
                      <StackPanel Grid.Column="1" Spacing="2">
                        <TextBlock Text="{Binding TypeLabel}"
                                   FontSize="{DynamicResource FontSizeLabel}"
                                   Foreground="{DynamicResource TextMutedBrush}"/>
                        <TextBlock Text="{Binding MediaType}"
                                   FontSize="{DynamicResource FontSizeBodySmall}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentBlueBrush}"/>
                      </StackPanel>
                      <StackPanel Grid.Column="2" Spacing="2">
                        <TextBlock Text="{Binding FormatLabel}"
                                   FontSize="{DynamicResource FontSizeLabel}"
                                   Foreground="{DynamicResource TextMutedBrush}"/>
                        <TextBlock Text="{Binding Interface}"
                                   FontSize="{DynamicResource FontSizeBodySmall}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                      </StackPanel>
                      <StackPanel Grid.Column="3" Spacing="2">
                        <TextBlock Text="{Binding PartitionsLabel}"
                                   FontSize="{DynamicResource FontSizeLabel}"
                                   Foreground="{DynamicResource TextMutedBrush}"/>
                        <TextBlock Text="{Binding Partitions}"
                                   FontSize="{DynamicResource FontSizeBodySmall}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                      </StackPanel>
                    </Grid>
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </controls:GlassCard>

    </StackPanel>
  </ScrollViewer>
</UserControl>
