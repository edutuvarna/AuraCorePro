<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:AuraCore.UI.Avalonia.Views.Controls"
             xmlns:converters="using:AuraCore.UI.Avalonia.Converters"
             x:Class="AuraCore.UI.Avalonia.Views.Pages.SpaceAnalyzerView">
  <UserControl.Resources>
    <converters:DirectoryGlyphConverter x:Key="DirectoryGlyphConverter"/>
    <converters:ByteSizeConverter       x:Key="ByteSizeConverter"/>
  </UserControl.Resources>
  <ScrollViewer>
    <StackPanel Spacing="16">

      <!-- Header -->
      <controls:ModuleHeader Title="Space Analyzer"
                             Subtitle="Visualize disk usage by folder">
        <controls:ModuleHeader.Actions>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button x:Name="BackBtn" Click="Back_Click" Classes="action-btn"
                    Padding="14,8" VerticalAlignment="Center" IsVisible="False"
                    Content="&#x2190; Back"/>
            <Button Classes="action-btn" Click="Scan_Click" Padding="14,8" VerticalAlignment="Center">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="&#x1F50D;" FontSize="{DynamicResource FontSizeBody}"/>
                <TextBlock x:Name="ScanLabel" Text="Scan"
                           FontSize="{DynamicResource FontSizeBodySmall}" FontWeight="SemiBold"/>
              </StackPanel>
            </Button>
            <!-- PageTitle: invisible, code-behind writes localized string -->
            <TextBlock x:Name="PageTitle" IsVisible="False"/>
          </StackPanel>
        </controls:ModuleHeader.Actions>
      </controls:ModuleHeader>

      <!-- Hidden PathLabel bridge for code-behind -->
      <TextBlock x:Name="PathLabel"
                 Text="Select a drive to analyze"
                 FontSize="{DynamicResource FontSizeBodySmall}"
                 Foreground="{DynamicResource TextMutedBrush}"
                 IsVisible="False"/>

      <!-- Stats row card -->
      <controls:GlassCard>
        <Grid ColumnDefinitions="*,*,*">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="Total:" FontSize="{DynamicResource FontSizeBodySmall}"
                       Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
            <TextBlock x:Name="TotalSize" Text="--"
                       FontSize="{DynamicResource FontSizeBody}" FontWeight="Bold"
                       Foreground="{DynamicResource AccentPrimaryBrush}" VerticalAlignment="Center"/>
          </StackPanel>
          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
            <TextBlock Text="Used:" FontSize="{DynamicResource FontSizeBodySmall}"
                       Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
            <TextBlock x:Name="UsedSize" Text="--"
                       FontSize="{DynamicResource FontSizeBody}" FontWeight="Bold"
                       Foreground="{DynamicResource AccentBlueBrush}" VerticalAlignment="Center"/>
          </StackPanel>
          <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
            <TextBlock Text="Free:" FontSize="{DynamicResource FontSizeBodySmall}"
                       Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
            <TextBlock x:Name="FreeSize" Text="--"
                       FontSize="{DynamicResource FontSizeBody}" FontWeight="Bold"
                       Foreground="{DynamicResource StatusSuccessBrush}" VerticalAlignment="Center"/>
          </StackPanel>
        </Grid>
      </controls:GlassCard>

      <!-- Directory tree card — lazy-loading drill-down (Phase 5.5.4) -->
      <controls:GlassCard>
        <TreeView x:Name="DirectoryTree" MinHeight="200">
          <TreeView.ItemTemplate>
            <TreeDataTemplate ItemsSource="{Binding Children}">
              <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,2">
                <TextBlock Text="{Binding IsDirectory, Converter={StaticResource DirectoryGlyphConverter}}"
                           FontSize="{DynamicResource FontSizeBody}"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding DisplayName}"
                           Margin="8,0,0,0"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           FontSize="{DynamicResource FontSizeBodySmall}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Grid.Column="2"
                           Text="{Binding SizeBytes, Converter={StaticResource ByteSizeConverter}}"
                           Foreground="{DynamicResource AccentBlueBrush}"
                           FontSize="{DynamicResource FontSizeBodySmall}"
                           VerticalAlignment="Center"
                           Margin="16,0,0,0"/>
              </Grid>
            </TreeDataTemplate>
          </TreeView.ItemTemplate>
        </TreeView>
      </controls:GlassCard>

    </StackPanel>
  </ScrollViewer>
</UserControl>
