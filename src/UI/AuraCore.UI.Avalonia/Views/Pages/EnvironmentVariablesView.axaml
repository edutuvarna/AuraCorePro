<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:AuraCore.UI.Avalonia.Views.Controls"
             x:Class="AuraCore.UI.Avalonia.Views.Pages.EnvironmentVariablesView">
  <ScrollViewer>
    <StackPanel Spacing="16">

      <!-- Header -->
      <controls:ModuleHeader x:Name="Header">
        <controls:ModuleHeader.Actions>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <!-- PageTitle: invisible, code-behind writes localized string -->
            <TextBlock x:Name="PageTitle" IsVisible="False"/>
          </StackPanel>
        </controls:ModuleHeader.Actions>
      </controls:ModuleHeader>

      <!-- PATH Editor card -->
      <controls:GlassCard>
        <StackPanel Spacing="12">
          <Grid ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
              <Border Width="16" Height="16" CornerRadius="4">
                <Border.Background>
                  <SolidColorBrush Color="#A855F7" Opacity="0.15"/>
                </Border.Background>
                <TextBlock Text="≡" FontSize="{DynamicResource FontSizeLabel}" Foreground="#A855F7"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
              <TextBlock x:Name="PathSectionLabel" Text=""
                         FontSize="{DynamicResource FontSizeBodySmall}" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextSecondaryBrush}"/>
            </StackPanel>
            <TextBlock x:Name="PathCount" Grid.Column="1" Text=""
                       FontSize="{DynamicResource FontSizeBody}"
                       Foreground="{DynamicResource TextMutedBrush}"/>
          </Grid>
          <ItemsControl x:Name="PathList"/>
          <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
            <TextBox x:Name="NewPathBox" Watermark="" Width="400"/>
            <Button x:Name="AddPathBtn" Content="" Click="AddPath_Click" Classes="action-btn" Padding="16,8"/>
          </StackPanel>
        </StackPanel>
      </controls:GlassCard>

      <!-- All Variables card -->
      <controls:GlassCard>
        <StackPanel Spacing="12">
          <Grid ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
              <Border Width="16" Height="16" CornerRadius="4">
                <Border.Background>
                  <SolidColorBrush Color="#A855F7" Opacity="0.15"/>
                </Border.Background>
                <TextBlock Text="■" FontSize="{DynamicResource FontSizeLabel}" Foreground="#A855F7"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
              <TextBlock x:Name="UserVarsLabel" Text=""
                         FontSize="{DynamicResource FontSizeBodySmall}" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextSecondaryBrush}"/>
            </StackPanel>
            <Button x:Name="RefreshBtn" Content="" Click="Refresh_Click" Padding="12,6" Grid.Column="1"
                    Background="#12FFFFFF" CornerRadius="{StaticResource RadiusSm}"/>
          </Grid>
          <TextBox x:Name="SearchBox" Watermark="" Margin="0,4,0,0"/>
          <ItemsControl x:Name="VarList"/>
        </StackPanel>
      </controls:GlassCard>

    </StackPanel>
  </ScrollViewer>
</UserControl>
