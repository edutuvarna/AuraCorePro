<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:AuraCore.UI.Avalonia.Views.Controls"
             x:Class="AuraCore.UI.Avalonia.Views.Pages.StartupOptimizerView">
  <ScrollViewer>
    <StackPanel Spacing="16">

      <!-- Header -->
      <controls:ModuleHeader x:Name="ModuleHdr" Title=""
                             Subtitle="">
        <controls:ModuleHeader.Actions>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Classes="action-btn" Click="Scan_Click" Padding="14,8" VerticalAlignment="Center">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="&#x1F50D;" FontSize="{DynamicResource FontSizeBody}"/>
                <TextBlock x:Name="ScanLabel" Text=""
                           FontSize="{DynamicResource FontSizeBodySmall}" FontWeight="SemiBold"/>
              </StackPanel>
            </Button>
            <!-- PageTitle: invisible, code-behind writes localized string -->
            <TextBlock x:Name="PageTitle" IsVisible="False"/>
          </StackPanel>
        </controls:ModuleHeader.Actions>
      </controls:ModuleHeader>

      <!-- Hidden subtitle bridge for code-behind -->
      <TextBlock x:Name="SubText"
                 Text=""
                 FontSize="{DynamicResource FontSizeBodySmall}"
                 Foreground="{DynamicResource TextMutedBrush}"
                 IsVisible="False"/>

      <!-- Stats row -->
      <controls:StatRow>
        <controls:StatCard x:Name="StatTotal" Label=""
                           Value="{Binding #TotalItems.Text}"
                           ValueBrush="{DynamicResource AccentPrimaryBrush}"/>
        <controls:StatCard x:Name="StatEnabled" Label=""
                           Value="{Binding #EnabledItems.Text}"
                           ValueBrush="{DynamicResource StatusSuccessBrush}"/>
        <controls:StatCard x:Name="StatHighImpact" Label=""
                           Value="{Binding #HighImpactItems.Text}"
                           ValueBrush="{DynamicResource StatusWarningBrush}"/>
      </controls:StatRow>

      <!-- Hidden stat TextBlocks — code-behind writes .Text directly -->
      <TextBlock x:Name="TotalItems"      Text="--" IsVisible="False"/>
      <TextBlock x:Name="EnabledItems"    Text="--" IsVisible="False"/>
      <TextBlock x:Name="HighImpactItems" Text="--" IsVisible="False"/>

      <!-- Startup item list card -->
      <controls:GlassCard>
        <ScrollViewer>
          <ItemsControl x:Name="ItemList">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Padding="12,8" Margin="0,0,0,4" CornerRadius="{StaticResource RadiusMd}"
                        BorderThickness="1"
                        Background="{DynamicResource BgCardBrush}"
                        BorderBrush="{DynamicResource BorderSubtleBrush}">
                  <Grid ColumnDefinitions="40,*,80,80,80">
                    <CheckBox IsChecked="{Binding IsEnabled}" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                      <TextBlock Text="{Binding Name}"
                                 FontSize="{DynamicResource FontSizeBodySmall}" FontWeight="SemiBold"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 TextTrimming="CharacterEllipsis"/>
                      <TextBlock Text="{Binding Command}"
                                 FontSize="{DynamicResource FontSizeLabel}"
                                 Foreground="{DynamicResource TextMutedBrush}"
                                 TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <TextBlock Grid.Column="2" Text="{Binding Location}"
                               FontSize="{DynamicResource FontSizeLabel}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center" TextAlignment="Center"/>
                    <Border Grid.Column="3" CornerRadius="8" Padding="6,2"
                            Background="{Binding ImpactBg}"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                      <TextBlock Text="{Binding Impact}"
                                 FontSize="{DynamicResource FontSizeLabel}" FontWeight="SemiBold"
                                 Foreground="{Binding ImpactFg}"/>
                    </Border>
                    <TextBlock Grid.Column="4" Text="{Binding Publisher}"
                               FontSize="{DynamicResource FontSizeLabel}"
                               Foreground="{DynamicResource TextMutedBrush}"
                               VerticalAlignment="Center" TextAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </controls:GlassCard>

    </StackPanel>
  </ScrollViewer>
</UserControl>
