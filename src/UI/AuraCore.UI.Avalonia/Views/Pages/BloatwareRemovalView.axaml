<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:AuraCore.UI.Avalonia.Views.Controls"
             x:Class="AuraCore.UI.Avalonia.Views.Pages.BloatwareRemovalView">
  <ScrollViewer>
    <StackPanel Spacing="16">

      <!-- Header -->
      <controls:ModuleHeader x:Name="PageHeader" Title=""
                             Subtitle="">
        <controls:ModuleHeader.Actions>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Classes="action-btn" Click="Scan_Click" VerticalAlignment="Center" Padding="14,8">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="🔍" FontSize="{DynamicResource FontSizeBody}"/>
                <TextBlock x:Name="ScanLabel" Text=""
                           FontSize="{DynamicResource FontSizeBodySmall}" FontWeight="SemiBold"/>
              </StackPanel>
            </Button>
            <Button x:Name="RemoveBtn" Click="RemoveSelected_Click" IsEnabled="False"
                    Background="{DynamicResource StatusErrorBrush}" Foreground="White"
                    Padding="14,8" CornerRadius="{StaticResource RadiusMd}" VerticalAlignment="Center"
                    FontWeight="Bold" FontSize="{DynamicResource FontSizeBodySmall}">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="✖" FontSize="{DynamicResource FontSizeBodySmall}"/>
                <TextBlock x:Name="RemoveBtnLabel" Text=""
                           FontSize="{DynamicResource FontSizeBodySmall}" FontWeight="Bold"/>
              </StackPanel>
            </Button>
            <!-- PageTitle: invisible, code-behind writes localized string -->
            <TextBlock x:Name="PageTitle" IsVisible="False"/>
            <!-- SubText: invisible bridge for code-behind error messages -->
            <TextBlock x:Name="SubText" IsVisible="False"/>
          </StackPanel>
        </controls:ModuleHeader.Actions>
      </controls:ModuleHeader>

      <!-- Hidden bridge TextBlocks — code-behind writes stat counts via .Text -->
      <StackPanel IsVisible="False" Height="0">
        <TextBlock x:Name="TotalApps"     Text="--"/>
        <TextBlock x:Name="RemovableApps" Text="--"/>
        <TextBlock x:Name="TotalSize"     Text="--"/>
      </StackPanel>

      <!-- Stats row -->
      <controls:StatRow>
        <controls:StatCard x:Name="StatTotal"
                           Value="{Binding #TotalApps.Text}"
                           ValueBrush="{DynamicResource AccentPrimaryBrush}"/>
        <controls:StatCard x:Name="StatRemovable"
                           Value="{Binding #RemovableApps.Text}"
                           ValueBrush="{DynamicResource StatusWarningBrush}"/>
        <controls:StatCard x:Name="StatSpace"
                           Value="{Binding #TotalSize.Text}"
                           ValueBrush="{DynamicResource AccentBlueBrush}"/>
      </controls:StatRow>

      <!-- Block-from-returning warning (conditional) -->
      <Border CornerRadius="{StaticResource RadiusMd}" Padding="10,6"
              IsVisible="{Binding #BlockReturnCheck.IsChecked}">
        <Border.Background>
          <SolidColorBrush Color="#F59E0B" Opacity="0.06"/>
        </Border.Background>
        <TextBlock x:Name="BlockWarningText" Text=""
                   FontSize="{DynamicResource FontSizeLabel}" Foreground="#F59E0B" TextWrapping="Wrap"/>
      </Border>

      <!-- App list card -->
      <controls:GlassCard>
        <StackPanel Spacing="0">
          <!-- Options row -->
          <Border Padding="12,6" Margin="0,0,0,2">
            <StackPanel Orientation="Horizontal" Spacing="16">
              <CheckBox x:Name="BlockReturnCheck" FontSize="{DynamicResource FontSizeLabel}"
                        VerticalAlignment="Center">
                <TextBlock x:Name="BlockReturnLabel" Text=""
                           FontSize="{DynamicResource FontSizeLabel}"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
              </CheckBox>
            </StackPanel>
          </Border>
          <!-- Column headers -->
          <Border Padding="12,8" Background="#08FFFFFF" CornerRadius="8,8,0,0">
            <Grid ColumnDefinitions="40,2*,100,80,80">
              <TextBlock Text="" FontSize="{DynamicResource FontSizeLabel}" FontWeight="Bold"
                         Foreground="{DynamicResource TextMutedBrush}"/>
              <TextBlock x:Name="ColAppName" Grid.Column="1" Text="" FontSize="{DynamicResource FontSizeLabel}"
                         FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}"/>
              <TextBlock x:Name="ColCategory" Grid.Column="2" Text="" FontSize="{DynamicResource FontSizeLabel}"
                         FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}"
                         TextAlignment="Center"/>
              <TextBlock x:Name="ColSize" Grid.Column="3" Text="" FontSize="{DynamicResource FontSizeLabel}"
                         FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}"
                         TextAlignment="Right"/>
              <TextBlock x:Name="ColRisk" Grid.Column="4" Text="" FontSize="{DynamicResource FontSizeLabel}"
                         FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}"
                         TextAlignment="Center"/>
            </Grid>
          </Border>
          <!-- App list -->
          <ScrollViewer>
            <ItemsControl x:Name="AppList"/>
          </ScrollViewer>
        </StackPanel>
      </controls:GlassCard>

      <!-- Status text -->
      <TextBlock x:Name="StatusText" Text=""
                 FontSize="{DynamicResource FontSizeBodySmall}"
                 Foreground="{DynamicResource TextMutedBrush}"
                 Margin="0,4,0,0"/>

    </StackPanel>
  </ScrollViewer>
</UserControl>
