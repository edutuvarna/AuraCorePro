<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:AuraCore.UI.Avalonia.Views.Controls"
             x:Class="AuraCore.UI.Avalonia.Views.Pages.DefaultsOptimizerView">
  <ScrollViewer>
    <StackPanel Spacing="16">

      <controls:ModuleHeader Title="Defaults Optimizer"
                             Subtitle="Read and write macOS system preferences via defaults command">
        <controls:ModuleHeader.Actions>
          <TextBlock x:Name="PageTitle" IsVisible="False" />
        </controls:ModuleHeader.Actions>
      </controls:ModuleHeader>

      <!-- Quick Tweaks -->
      <controls:GlassCard>
        <StackPanel Spacing="12">
          <TextBlock Text="Quick Tweaks"
                     FontSize="{DynamicResource FontSizeBody}"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource TextPrimaryBrush}"/>
          <TextBlock x:Name="SubText"
                     Text="macOS-only optimizations via defaults command"
                     FontSize="{DynamicResource FontSizeBodySmall}"
                     Foreground="{DynamicResource TextMutedBrush}"/>
          <ItemsControl x:Name="TweakList"/>
          <Button Content="Apply Selected"
                  Click="Apply_Click"
                  Classes="action-btn"
                  Padding="16,8"
                  HorizontalAlignment="Left"/>
        </StackPanel>
      </controls:GlassCard>

      <!-- Custom Defaults Read -->
      <controls:GlassCard>
        <StackPanel Spacing="12">
          <TextBlock Text="Custom Defaults Read"
                     FontSize="{DynamicResource FontSizeBody}"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource TextPrimaryBrush}"/>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBox x:Name="DomainBox" Watermark="Domain (e.g. com.apple.dock)" Width="300"/>
            <TextBox x:Name="KeyBox" Watermark="Key (e.g. autohide)" Width="200"/>
            <Button Content="Read"
                    Click="ReadDefault_Click"
                    Padding="12,8"
                    Background="#12FFFFFF"
                    CornerRadius="{StaticResource RadiusSm}"/>
          </StackPanel>
          <TextBlock x:Name="ReadResult"
                     Text=""
                     FontSize="{DynamicResource FontSizeBodySmall}"
                     Foreground="{DynamicResource TextMutedBrush}"
                     TextWrapping="Wrap"/>
        </StackPanel>
      </controls:GlassCard>

    </StackPanel>
  </ScrollViewer>
</UserControl>
