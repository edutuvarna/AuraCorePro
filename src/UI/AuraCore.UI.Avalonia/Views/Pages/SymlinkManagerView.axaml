<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:AuraCore.UI.Avalonia.Views.Controls"
             x:Class="AuraCore.UI.Avalonia.Views.Pages.SymlinkManagerView">
  <ScrollViewer>
    <StackPanel Spacing="16">

      <!-- Intro -->
      <TextBlock x:Name="IntroText" Text=""
                 FontSize="{DynamicResource FontSizeBodySmall}"
                 Foreground="{DynamicResource TextMutedBrush}"
                 Margin="0,0,0,-4"/>

      <!-- Header -->
      <controls:ModuleHeader x:Name="ModuleHdr" Title=""
                             Subtitle="">
        <controls:ModuleHeader.Actions>
          <!-- PageTitle: hidden bridge, code-behind writes localized string -->
          <TextBlock x:Name="PageTitle" IsVisible="False"/>
        </controls:ModuleHeader.Actions>
      </controls:ModuleHeader>

      <!-- Create New Link -->
      <controls:GlassCard>
        <StackPanel Spacing="12">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Border Width="16" Height="16" CornerRadius="4">
              <Border.Background>
                <SolidColorBrush Color="#3B82F6" Opacity="0.15"/>
              </Border.Background>
              <TextBlock Text="&#x2B06;" FontSize="8" Foreground="#3B82F6"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock x:Name="CreateHeader" Text="" FontSize="{DynamicResource FontSizeLabel}" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
          </StackPanel>
          <ComboBox x:Name="LinkTypeCombo" SelectedIndex="0" Width="260">
            <ComboBoxItem x:Name="LinkTypeFile" Content="" Tag="file"/>
            <ComboBoxItem x:Name="LinkTypeDir" Content="" Tag="dir"/>
            <ComboBoxItem x:Name="LinkTypeJunction" Content="" Tag="junction"/>
            <ComboBoxItem x:Name="LinkTypeHard" Content="" Tag="hard"/>
          </ComboBox>
          <TextBox x:Name="LinkPathBox" Watermark="" Width="500"/>
          <TextBox x:Name="TargetPathBox" Watermark="" Width="500"/>
          <Button x:Name="CreateLinkBtn" Content="" Click="CreateLink_Click" Classes="action-btn" Padding="16,10"
                  HorizontalAlignment="Left"/>
          <TextBlock x:Name="StatusText" Text="" FontSize="{DynamicResource FontSizeBodySmall}"
                     Foreground="{DynamicResource TextMutedBrush}"/>
        </StackPanel>
      </controls:GlassCard>

      <!-- Scan Existing -->
      <controls:GlassCard>
        <StackPanel Spacing="12">
          <Grid ColumnDefinitions="*,Auto">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Border Width="16" Height="16" CornerRadius="4">
                <Border.Background>
                  <SolidColorBrush Color="#3B82F6" Opacity="0.15"/>
                </Border.Background>
                <TextBlock Text="&#x1F50D;" FontSize="8" Foreground="#3B82F6"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
              <TextBlock x:Name="ExistingHeader" Text="" FontSize="{DynamicResource FontSizeLabel}" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextSecondaryBrush}"/>
            </StackPanel>
            <Button x:Name="ScanDirBtn" Content="" Click="Scan_Click" Grid.Column="1"
                    Padding="12,6" Classes="action-btn"/>
          </Grid>
          <TextBox x:Name="ScanPathBox" Watermark="" Width="500"/>
          <ItemsControl x:Name="LinkList"/>
          <TextBlock x:Name="ScanStatus" Text=""
                     FontSize="{DynamicResource FontSizeBodySmall}"
                     Foreground="{DynamicResource TextMutedBrush}"/>
        </StackPanel>
      </controls:GlassCard>

      <!-- Info -->
      <Border CornerRadius="{StaticResource RadiusLg}" Background="{DynamicResource WarningBgBrush}" Padding="16,12"
              BorderBrush="{DynamicResource WarningBorderBrush}" BorderThickness="1">
        <TextBlock x:Name="AdminWarningText" Text=""
                   FontSize="{DynamicResource FontSizeBodySmall}" Foreground="#F59E0B"/>
      </Border>

    </StackPanel>
  </ScrollViewer>
</UserControl>
