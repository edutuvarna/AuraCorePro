<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AuraCore.UI.Avalonia.Views.Pages.DefaultsOptimizerView">
  <ScrollViewer>
    <StackPanel Spacing="20">
      <StackPanel Spacing="4">
        <TextBlock x:Name="PageTitle" Text="Defaults Optimizer" FontSize="16" FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>
        <TextBlock Text="Read and write macOS system preferences via defaults command"
                   FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"/>
      </StackPanel>
      <Border CornerRadius="{StaticResource RadiusLg}" BorderThickness="1" Padding="16">
        <Border.Background>
          <SolidColorBrush Color="#FFFFFF" Opacity="0.025"/>
        </Border.Background>
        <Border.BorderBrush>
          <SolidColorBrush Color="#FFFFFF" Opacity="0.05"/>
        </Border.BorderBrush>
        <StackPanel Spacing="12">
          <TextBlock Text="Quick Tweaks" FontSize="13" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextPrimaryBrush}"/>
          <TextBlock x:Name="SubText" Text="macOS-only optimizations via defaults command" FontSize="12"
                     Foreground="{DynamicResource TextMutedBrush}"/>
          <ItemsControl x:Name="TweakList"/>
          <Button Content="Apply Selected" Click="Apply_Click" Classes="action-btn" Padding="16,8"
                  HorizontalAlignment="Left"/>
        </StackPanel>
      </Border>
      <Border CornerRadius="{StaticResource RadiusLg}" BorderThickness="1" Padding="16">
        <Border.Background>
          <SolidColorBrush Color="#FFFFFF" Opacity="0.025"/>
        </Border.Background>
        <Border.BorderBrush>
          <SolidColorBrush Color="#FFFFFF" Opacity="0.05"/>
        </Border.BorderBrush>
        <StackPanel Spacing="12">
          <TextBlock Text="Custom Defaults Read" FontSize="13" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextPrimaryBrush}"/>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBox x:Name="DomainBox" Watermark="Domain (e.g. com.apple.dock)" Width="300"/>
            <TextBox x:Name="KeyBox" Watermark="Key (e.g. autohide)" Width="200"/>
            <Button Content="Read" Click="ReadDefault_Click" Padding="12,8"
                    Background="#12FFFFFF" CornerRadius="{StaticResource RadiusSm}"/>
          </StackPanel>
          <TextBlock x:Name="ReadResult" Text="" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                     TextWrapping="Wrap"/>
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
