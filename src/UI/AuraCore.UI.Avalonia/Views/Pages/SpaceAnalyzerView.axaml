<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AuraCore.UI.Avalonia.Views.Pages.SpaceAnalyzerView">
  <Grid RowDefinitions="Auto,Auto,*">
    <Grid ColumnDefinitions="*,Auto,Auto" Margin="0,0,0,16">
      <StackPanel Spacing="4">
        <TextBlock x:Name="PageTitle" Text="Space Analyzer" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
        <TextBlock x:Name="PathLabel" Text="Select a drive to analyze" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
      </StackPanel>
      <Button Grid.Column="1" x:Name="BackBtn" Click="Back_Click" Classes="action-btn" Padding="14,8" VerticalAlignment="Center" Margin="0,0,8,0" IsVisible="False" Content="&#x2190; Back"/>
      <Button Grid.Column="2" Classes="action-btn" Click="Scan_Click" Padding="14,8" VerticalAlignment="Center">
        <StackPanel Orientation="Horizontal" Spacing="6"><TextBlock Text="&#x1F50D;" FontSize="12"/><TextBlock x:Name="ScanLabel" Text="Scan" FontSize="11" FontWeight="SemiBold"/></StackPanel>
      </Button>
    </Grid>
    <Border Grid.Row="1" CornerRadius="{StaticResource RadiusMd}" BorderThickness="1" Padding="16,10" Margin="0,0,0,12">
      <Border.Background>
        <SolidColorBrush Color="#FFFFFF" Opacity="0.025"/>
      </Border.Background>
      <Border.BorderBrush>
        <SolidColorBrush Color="#FFFFFF" Opacity="0.05"/>
      </Border.BorderBrush>
      <Grid ColumnDefinitions="*,*,*">
        <StackPanel Orientation="Horizontal" Spacing="8"><TextBlock Text="Total:" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
          <TextBlock x:Name="TotalSize" Text="--" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource AccentPrimaryBrush}" VerticalAlignment="Center"/></StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"><TextBlock Text="Used:" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
          <TextBlock x:Name="UsedSize" Text="--" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource AccentBlueBrush}" VerticalAlignment="Center"/></StackPanel>
        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8"><TextBlock Text="Free:" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
          <TextBlock x:Name="FreeSize" Text="--" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}" VerticalAlignment="Center"/></StackPanel>
      </Grid>
    </Border>
    <Border Grid.Row="2" CornerRadius="{StaticResource RadiusLg}" BorderThickness="1" Padding="4">
      <Border.Background>
        <SolidColorBrush Color="#FFFFFF" Opacity="0.025"/>
      </Border.Background>
      <Border.BorderBrush>
        <SolidColorBrush Color="#FFFFFF" Opacity="0.05"/>
      </Border.BorderBrush>
      <ScrollViewer>
        <ItemsControl x:Name="FolderList">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Button Background="Transparent" HorizontalAlignment="Stretch" Padding="12,8" Margin="0,1" CornerRadius="4" Click="Folder_Click" Tag="{Binding Path}">
                <Grid ColumnDefinitions="Auto,*,80,80">
                  <TextBlock Text="{Binding Icon}" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
                  <StackPanel Grid.Column="1" VerticalAlignment="Center"><TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="{Binding ItemCount}" FontSize="9" Foreground="{DynamicResource TextMutedBrush}"/></StackPanel>
                  <TextBlock Grid.Column="2" Text="{Binding Size}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource AccentBlueBrush}" VerticalAlignment="Center" TextAlignment="Right"/>
                  <Border Grid.Column="3" Height="6" CornerRadius="3" Background="#FFFFFF0A" VerticalAlignment="Center" Margin="8,0,0,0">
                    <Border Height="6" CornerRadius="3" Background="{Binding BarBrush}" HorizontalAlignment="Left" Width="{Binding BarWidth}"/></Border>
                </Grid>
              </Button>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Border>
  </Grid>
</UserControl>
