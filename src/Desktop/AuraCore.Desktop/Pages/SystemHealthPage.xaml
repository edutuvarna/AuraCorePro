<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AuraCore.Desktop.Pages.SystemHealthPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Padding="32">
        <StackPanel Spacing="20" MaxWidth="900">

            <StackPanel Spacing="4">
                <TextBlock x:Name="PageTitle" Text="System Health Analyzer" Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock x:Name="PageSubtitle" Text="Complete system diagnostic scan" 
                           Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button x:Name="ScanBtn" Content="Run Full Scan" Click="ScanBtn_Click"
                        Style="{StaticResource AccentButtonStyle}" Padding="24,10" />
                <Button x:Name="ExportPdfBtn" Content="Export PDF Report" Click="ExportPdfBtn_Click"
                        Padding="24,10" IsEnabled="False" />
                <ProgressRing x:Name="Progress" IsActive="False" Visibility="Collapsed" Width="28" Height="28" />
                <TextBlock x:Name="StatusText" Text="Ready" VerticalAlignment="Center" 
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <!-- OS Section -->
            <Border x:Name="OsSection" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                    CornerRadius="8" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    Visibility="Collapsed">
                <StackPanel Spacing="8">
                    <TextBlock Text="Operating System" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <TextBlock x:Name="OsName" Style="{StaticResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock x:Name="OsVersion" Style="{StaticResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock x:Name="OsArch" Style="{StaticResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock x:Name="OsMachine" Style="{StaticResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock x:Name="OsUptime" Style="{StaticResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>

            <!-- CPU Section -->
            <Border x:Name="CpuSection" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                    CornerRadius="8" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    Visibility="Collapsed">
                <StackPanel Spacing="8">
                    <TextBlock Text="Processor" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <TextBlock x:Name="CpuName" Style="{StaticResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock x:Name="CpuCores" Style="{StaticResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <ProgressBar x:Name="CpuBar" Minimum="0" Maximum="100" Height="8" CornerRadius="4" />
                    <TextBlock x:Name="CpuUsage" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                </StackPanel>
            </Border>

            <!-- Memory Section -->
            <Border x:Name="MemSection" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                    CornerRadius="8" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    Visibility="Collapsed">
                <StackPanel Spacing="8">
                    <TextBlock Text="Memory" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <TextBlock x:Name="MemTotal" Style="{StaticResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock x:Name="MemAvail" Style="{StaticResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <ProgressBar x:Name="MemBar" Minimum="0" Maximum="100" Height="8" CornerRadius="4" />
                    <TextBlock x:Name="MemUsage" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                </StackPanel>
            </Border>

            <!-- Drives Section -->
            <Border x:Name="DiskSection" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                    CornerRadius="8" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    Visibility="Collapsed">
                <StackPanel Spacing="8">
                    <TextBlock Text="Storage Drives" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <StackPanel x:Name="DriveList" Spacing="12" />
                </StackPanel>
            </Border>

            <!-- Processes Section -->
            <Border x:Name="ProcSection" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                    CornerRadius="8" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    Visibility="Collapsed">
                <StackPanel Spacing="8">
                    <TextBlock Text="Process Summary" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <TextBlock x:Name="ProcCount" Style="{StaticResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock x:Name="ProcTopRam" Style="{StaticResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>

            <!-- GPU Section -->
            <Border x:Name="GpuSection" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    Visibility="Collapsed">
                <StackPanel Spacing="8">
                    <TextBlock Text="Graphics (GPU)" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <StackPanel x:Name="GpuList" Spacing="10" />
                </StackPanel>
            </Border>

            <!-- Battery Section -->
            <Border x:Name="BatterySection" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    Visibility="Collapsed">
                <StackPanel Spacing="8">
                    <TextBlock Text="Battery" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <TextBlock x:Name="BatteryCharge" Style="{StaticResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <ProgressBar x:Name="BatteryBar" Minimum="0" Maximum="100" Height="8" CornerRadius="4" />
                    <TextBlock x:Name="BatteryStatus" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                </StackPanel>
            </Border>

            <!-- Startup Programs -->
            <Border x:Name="StartupSection" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    Visibility="Collapsed">
                <StackPanel Spacing="8">
                    <TextBlock x:Name="StartupHeader" Text="Startup Programs" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <StackPanel x:Name="StartupList" Spacing="4" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
