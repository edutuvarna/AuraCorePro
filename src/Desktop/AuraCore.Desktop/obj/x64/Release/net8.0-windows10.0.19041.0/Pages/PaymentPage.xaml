<?xml version="1.0" encoding="utf-8"?>
<Page x:ConnectionId='1' x:Class="AuraCore.Desktop.Pages.PaymentPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
                        >

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Top Bar -->
        <Border Grid.Row="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1"
                Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button x:ConnectionId='10' Grid.Column="0" Content="← Back"                   
                        Style="{StaticResource DefaultButtonStyle}" Padding="12,6" />

                <TextBlock x:ConnectionId='11' Grid.Column="1" x:Name="HeaderText" Text="Complete Your Purchase"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE72E;" FontSize="14" Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
                    <TextBlock Text="Secure Payment" FontSize="12"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- WebView2 -->
        <WebView2 x:ConnectionId='2' Grid.Row="1" x:Name="PaymentWebView"
                                                                        
                                                                           />

        <!-- Loading Overlay -->
        <Grid x:ConnectionId='3' Grid.Row="1" x:Name="LoadingOverlay" Background="{ThemeResource SolidBackgroundFillColorBaseBrush}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
                <ProgressRing IsActive="True" Width="48" Height="48" />
                <TextBlock x:ConnectionId='9' x:Name="LoadingText" Text="Loading payment page..."
                           Style="{StaticResource BodyTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </Grid>

        <!-- Success Overlay -->
        <Grid x:ConnectionId='4' Grid.Row="1" x:Name="SuccessOverlay" Visibility="Collapsed"
              Background="{ThemeResource SolidBackgroundFillColorBaseBrush}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16" MaxWidth="400">
                <FontIcon Glyph="&#xE73E;" FontSize="64" Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
                <TextBlock Text="Payment Successful!" Style="{StaticResource TitleTextBlockStyle}"
                           HorizontalAlignment="Center" />
                <TextBlock x:ConnectionId='6' x:Name="SuccessMessage" Text="Your subscription has been activated."
                           Style="{StaticResource BodyTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center" TextAlignment="Center" />
                <TextBlock x:ConnectionId='7' x:Name="TierUpdateText" Text="Updating your account..."
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                           HorizontalAlignment="Center" />
                <Button x:ConnectionId='8' Content="Continue" Style="{StaticResource AccentButtonStyle}"
                        HorizontalAlignment="Center" Padding="32,10"                        Margin="0,8,0,0" />
            </StackPanel>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,1,0,0"
                Padding="16,8">
            <TextBlock x:ConnectionId='5' x:Name="StatusText" Text="Powered by Stripe — your payment details are never stored on our servers"
                       FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                       HorizontalAlignment="Center" />
        </Border>
    </Grid>
</Page>

