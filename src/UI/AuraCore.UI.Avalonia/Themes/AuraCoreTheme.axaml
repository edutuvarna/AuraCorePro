<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- ══════════════════════════════════════════════════════
       AuraCore Pro V1 Legacy Bridge (Phase 2)

       This file exists to keep pages not yet migrated to V2 rendering
       correctly. It re-exports V1 resource keys as V2-backed brushes so
       existing XAML continues to resolve. Phase 4 module-page refactors
       will rewrite pages against V2 directly, after which individual
       aliases can be removed.

       Do NOT add new keys here. Add new tokens to AuraCoreThemeV2.axaml.
       ══════════════════════════════════════════════════════ -->

  <Styles.Resources>
    <ResourceDictionary>
      <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Dark">

          <!-- Accent aliases -->
          <SolidColorBrush x:Key="AccentPrimaryBrush" Color="#00D4AA"/>
          <SolidColorBrush x:Key="AccentPrimaryDimBrush" Color="#00A888"/>
          <SolidColorBrush x:Key="AccentBlueBrush" Color="#0080FF"/>

          <!-- Semantic brushes -->
          <SolidColorBrush x:Key="SuccessBrush" Color="#22C55E"/>
          <SolidColorBrush x:Key="WarningBrush" Color="#F59E0B"/>
          <SolidColorBrush x:Key="ErrorBrush" Color="#EF4444"/>
          <SolidColorBrush x:Key="InfoBrush" Color="#3B82F6"/>

          <!-- Semantic tinted backgrounds + borders (V1 legacy) -->
          <SolidColorBrush x:Key="WarningBgBrush" Color="#F59E0B0D"/>
          <SolidColorBrush x:Key="WarningBorderBrush" Color="#F59E0B33"/>
          <SolidColorBrush x:Key="ErrorBgBrush" Color="#EF444420"/>
          <SolidColorBrush x:Key="ErrorBorderBrush" Color="#EF444430"/>
          <SolidColorBrush x:Key="InfoBgBrush" Color="#3B82F60D"/>
          <SolidColorBrush x:Key="InfoBorderBrush" Color="#3B82F620"/>
          <SolidColorBrush x:Key="SuccessBgBrush" Color="#22C55E20"/>
          <SolidColorBrush x:Key="SuccessBorderBrush" Color="#22C55E30"/>
          <SolidColorBrush x:Key="AccentBgBrush" Color="#00D4AA0D"/>
          <SolidColorBrush x:Key="AccentBorderBrush" Color="#00D4AA20"/>

          <!-- Border legacy -->
          <SolidColorBrush x:Key="BorderCardBrush" Color="#FFFFFF10"/>

          <!-- Window/sidebar legacy (V2 uses Bg*Brush family) -->
          <SolidColorBrush x:Key="WindowBgBrush" Color="#0A0A10"/>
          <SolidColorBrush x:Key="WindowFgBrush" Color="#E8E8F0"/>
          <SolidColorBrush x:Key="SidebarBgBrush" Color="#0B0B11"/>
          <SolidColorBrush x:Key="NavHoverBrush" Color="#1A1A28"/>
          <SolidColorBrush x:Key="NavActiveBrush" Color="#1500D4AA"/>
          <SolidColorBrush x:Key="SectionHeaderBrush" Color="#555570"/>
          <SolidColorBrush x:Key="ActionBtnBgBrush" Color="#12FFFFFF"/>
          <SolidColorBrush x:Key="ActionBtnHoverBrush" Color="#1500D4AA"/>
        </ResourceDictionary>
      </ResourceDictionary.ThemeDictionaries>

      <!-- Legacy icons (DrawingImage) kept for OrbitalLogo control + any page still using CpuIcon/RamIcon/DiskIcon/UptimeIcon -->
      <DrawingImage x:Key="CpuIcon">
        <GeometryDrawing Brush="#3B82F6">
          <GeometryDrawing.Geometry>
            <PathGeometry Figures="M9,2 L15,2 15,4 13,4 13,5 16,5 16,8 17,8 17,6 19,6 19,10 17,10 17,8 16,8 16,11 17,11 17,9 19,9 19,13 17,13 17,11 16,11 16,14 13,14 13,15 15,15 15,17 9,17 9,15 11,15 11,14 8,14 8,11 7,11 7,13 5,13 5,9 7,9 7,11 8,11 8,8 7,8 7,10 5,10 5,6 7,6 7,8 8,8 8,5 11,5 11,4 9,4 Z M10,7 L10,12 14,12 14,7 Z"/>
          </GeometryDrawing.Geometry>
        </GeometryDrawing>
      </DrawingImage>
      <DrawingImage x:Key="RamIcon">
        <GeometryDrawing Brush="#8B5CF6">
          <GeometryDrawing.Geometry>
            <PathGeometry Figures="M3,6 L21,6 21,16 19,16 19,18 17,18 17,16 15,16 15,18 13,18 13,16 11,16 11,18 9,18 9,16 7,16 7,18 5,18 5,16 3,16 Z M5,8 L5,14 7,14 7,8 Z M9,8 L9,14 11,14 11,8 Z M13,8 L13,14 15,14 15,8 Z M17,8 L17,14 19,14 19,8 Z"/>
          </GeometryDrawing.Geometry>
        </GeometryDrawing>
      </DrawingImage>
      <DrawingImage x:Key="DiskIcon">
        <GeometryDrawing Brush="#F59E0B">
          <GeometryDrawing.Geometry>
            <PathGeometry Figures="M4,5 L20,5 20,19 4,19 Z M6,7 L6,13 18,13 18,7 Z M6,15 L6,17 18,17 18,15 Z M15,15.5 A1,1 0 1,1 15,16.5 A1,1 0 1,1 15,15.5 Z"/>
          </GeometryDrawing.Geometry>
        </GeometryDrawing>
      </DrawingImage>
      <DrawingImage x:Key="UptimeIcon">
        <GeometryDrawing Brush="#EC4899">
          <GeometryDrawing.Geometry>
            <PathGeometry Figures="M12,2 A10,10 0 1,1 12,22 A10,10 0 1,1 12,2 Z M12,4 A8,8 0 1,1 12,20 A8,8 0 1,1 12,4 Z M11,7 L13,7 13,12.5 16,14.5 15,16 11,13.5 Z"/>
          </GeometryDrawing.Geometry>
        </GeometryDrawing>
      </DrawingImage>

      <!-- Legacy spacing/radius (V1 values preserved for old pages) -->
      <Thickness x:Key="CardPadding">16</Thickness>
      <Thickness x:Key="PageMargin">20</Thickness>

      <!-- Orbital logo (used by OrbitalLogo control) -->
      <DrawingImage x:Key="OrbitalCoreLogo">
        <DrawingGroup>
          <GeometryDrawing>
            <GeometryDrawing.Pen><Pen Brush="#1A06d6a0" Thickness="0.8"/></GeometryDrawing.Pen>
            <GeometryDrawing.Geometry><EllipseGeometry Center="100,100" RadiusX="94" RadiusY="94"/></GeometryDrawing.Geometry>
          </GeometryDrawing>
          <GeometryDrawing Brush="#06d6a0"><GeometryDrawing.Geometry><EllipseGeometry Center="100,100" RadiusX="6" RadiusY="6"/></GeometryDrawing.Geometry></GeometryDrawing>
        </DrawingGroup>
      </DrawingImage>

    </ResourceDictionary>
  </Styles.Resources>

  <!-- ══════════════════════════════════════════════════════
       Legacy Control Styles (V1) — still referenced by pages
       not yet migrated to V2 primitives. Will be removed as
       each page is rewritten in Phase 4.
       ══════════════════════════════════════════════════════ -->

  <!-- ── NAV ITEM STYLE (legacy sidebar) ─────────────── -->
  <Style Selector="Button.nav-item">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="HorizontalContentAlignment" Value="Left" />
    <Setter Property="Padding" Value="8,6" />
    <Setter Property="CornerRadius" Value="{DynamicResource RadiusSm}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>
  <Style Selector="Button.nav-item:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource NavHoverBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
  </Style>
  <Style Selector="Button.nav-item.active">
    <Setter Property="Background" Value="{DynamicResource NavActiveBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AccentPrimaryBrush}" />
  </Style>
  <Style Selector="Button.nav-item.active /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource NavActiveBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AccentPrimaryBrush}" />
  </Style>

  <!-- ── ACTION BUTTON STYLE (legacy) ───────────────── -->
  <Style Selector="Button.action-btn">
    <Setter Property="Background" Value="{DynamicResource ActionBtnBgBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="HorizontalContentAlignment" Value="Left" />
    <Setter Property="Padding" Value="12,9" />
    <Setter Property="CornerRadius" Value="{DynamicResource RadiusMd}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>
  <Style Selector="Button.action-btn:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource ActionBtnHoverBrush}" />
  </Style>

</Styles>
