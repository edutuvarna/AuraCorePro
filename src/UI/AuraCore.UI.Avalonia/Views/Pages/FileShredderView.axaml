<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:AuraCore.UI.Avalonia.Views.Controls"
             x:Class="AuraCore.UI.Avalonia.Views.Pages.FileShredderView">
  <ScrollViewer>
    <StackPanel Spacing="16">

      <!-- Header -->
      <controls:ModuleHeader Title="File Shredder"
                             Subtitle="Securely delete files beyond recovery with multi-pass overwrite">
        <controls:ModuleHeader.Actions>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <!-- PageTitle: invisible, code-behind writes localized string -->
            <TextBlock x:Name="PageTitle" IsVisible="False"/>
          </StackPanel>
        </controls:ModuleHeader.Actions>
      </controls:ModuleHeader>

      <!-- Shred Method Card -->
      <controls:GlassCard>
        <StackPanel Spacing="12">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Border Width="20" Height="20" CornerRadius="6"
                    Background="{DynamicResource StatusErrorBgBrush}">
              <TextBlock Text="&#x2699;" FontSize="{DynamicResource FontSizeLabel}" Foreground="{DynamicResource StatusErrorBrush}"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="Shred Method"
                       FontSize="{DynamicResource FontSizeBodySmall}" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
          </StackPanel>
          <RadioButton x:Name="Method1Pass" Content="Quick (1 pass - zero fill)" IsChecked="True" GroupName="method"/>
          <RadioButton x:Name="Method3Pass" Content="Standard (3 pass - DoD Short)" GroupName="method"/>
          <RadioButton x:Name="Method7Pass" Content="Secure (7 pass - DoD 5220.22-M)" GroupName="method"/>
        </StackPanel>
      </controls:GlassCard>

      <!-- File Selection Card -->
      <controls:GlassCard>
        <StackPanel Spacing="12">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Border Width="20" Height="20" CornerRadius="6"
                    Background="{DynamicResource StatusErrorBgBrush}">
              <TextBlock Text="&#x25A0;" FontSize="{DynamicResource FontSizeLabel}" Foreground="{DynamicResource StatusErrorBrush}"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="Files to Shred"
                       FontSize="{DynamicResource FontSizeBodySmall}" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="Add Files..." Click="AddFiles_Click" Classes="action-btn" Padding="16,8"/>
            <Button Content="Clear All" Click="ClearFiles_Click" Classes="action-btn" Padding="12,8"/>
          </StackPanel>
          <ItemsControl x:Name="FileList"/>
          <TextBlock x:Name="FileCount" Text="No files selected"
                     FontSize="{DynamicResource FontSizeBodySmall}"
                     Foreground="{DynamicResource TextMutedBrush}"/>
        </StackPanel>
      </controls:GlassCard>

      <!-- Shred Button -->
      <Button x:Name="ShredBtn" Content="SHRED FILES PERMANENTLY" Click="Shred_Click"
              Background="{DynamicResource StatusErrorBgBrush}" Foreground="{DynamicResource StatusErrorBrush}"
              FontWeight="Bold" Padding="24,14" CornerRadius="{StaticResource RadiusMd}"
              HorizontalAlignment="Left" Cursor="Hand"
              FontSize="{DynamicResource FontSizeBody}"/>

      <!-- Progress Card -->
      <controls:GlassCard x:Name="ProgressPanel" IsVisible="False">
        <StackPanel Spacing="8">
          <TextBlock x:Name="ProgressLabel" Text="Shredding..."
                     FontSize="{DynamicResource FontSizeBody}" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextPrimaryBrush}"/>
          <ProgressBar x:Name="ProgressBar" Value="0" Maximum="100" Height="6"
                       Foreground="{DynamicResource StatusErrorBrush}"/>
          <TextBlock x:Name="ProgressDetail" Text=""
                     FontSize="{DynamicResource FontSizeBodySmall}"
                     Foreground="{DynamicResource TextMutedBrush}"/>
        </StackPanel>
      </controls:GlassCard>

      <!-- Warning Card -->
      <controls:GlassCard>
        <TextBlock Text="WARNING: Shredded files CANNOT be recovered. This operation is irreversible. Make sure you have selected the correct files before proceeding."
                   FontSize="{DynamicResource FontSizeBodySmall}"
                   Foreground="{DynamicResource StatusErrorBrush}"
                   TextWrapping="Wrap"/>
      </controls:GlassCard>

    </StackPanel>
  </ScrollViewer>
</UserControl>
