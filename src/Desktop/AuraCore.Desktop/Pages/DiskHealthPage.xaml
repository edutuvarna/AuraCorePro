<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AuraCore.Desktop.Pages.DiskHealthPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Padding="32">
        <StackPanel Spacing="20" MaxWidth="960">

            <StackPanel Spacing="4">
                <TextBlock x:Name="PageTitle" Text="Disk Health Monitor" Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock x:Name="PageSubtitle" Text="Monitor drive health, temperature, and SMART diagnostics"
                           Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button x:Name="ScanBtn" Content="Scan Drives" Click="ScanBtn_Click"
                        Style="{StaticResource AccentButtonStyle}" Padding="24,10" />
                <ProgressRing x:Name="Progress" IsActive="False" Visibility="Collapsed" Width="28" Height="28" />
                <TextBlock x:Name="StatusText" Text="Click Scan to check disk health"
                           VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <!-- Summary sub-card -->
            <Border x:Name="SummaryCard" Visibility="Collapsed"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="10" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <Grid ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="2">
                        <TextBlock Text="Total Drives" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="TotalDrivesText" Style="{StaticResource SubtitleTextBlockStyle}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="2">
                        <TextBlock Text="Healthy" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="HealthyDrivesText" Style="{StaticResource SubtitleTextBlockStyle}" Foreground="#2E7D32" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="2">
                        <TextBlock Text="Avg. Temperature" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="AvgTempText" Style="{StaticResource SubtitleTextBlockStyle}" />
                    </StackPanel>
                    <StackPanel Grid.Column="3" Spacing="2">
                        <TextBlock Text="Total Capacity" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="TotalCapText" Style="{StaticResource SubtitleTextBlockStyle}" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Drive cards -->
            <StackPanel x:Name="DriveList" Spacing="12" />

        </StackPanel>
    </ScrollViewer>
</Page>
