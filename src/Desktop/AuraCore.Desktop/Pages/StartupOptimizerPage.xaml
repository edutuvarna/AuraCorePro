<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AuraCore.Desktop.Pages.StartupOptimizerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Padding="32">
        <StackPanel Spacing="20" MaxWidth="960">

            <StackPanel Spacing="4">
                <TextBlock x:Name="PageTitle" Text="Startup Optimizer" Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock x:Name="PageSubtitle" Text="Control which programs launch at startup — speed up your boot time"
                           Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button x:Name="ScanBtn" Content="Scan Startup" Click="ScanBtn_Click"
                        Style="{StaticResource AccentButtonStyle}" Padding="24,10" />
                <Button x:Name="BenchmarkBtn" Content="Boot Time Benchmark" Click="BenchmarkBtn_Click"
                        Padding="24,10" />
                <ProgressRing x:Name="Progress" IsActive="False" Visibility="Collapsed" Width="28" Height="28" />
                <TextBlock x:Name="StatusText" Text="Click Scan to analyze startup programs"
                           VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <!-- Boot Time Benchmark -->
            <Border x:Name="BenchmarkCard" Visibility="Collapsed"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="16">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE916;" FontSize="18" Foreground="#06B6D4" />
                        <TextBlock Text="Boot Time Analysis" FontWeight="SemiBold" FontSize="16" />
                    </StackPanel>

                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="Last Boot Time" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="LastBootText" Style="{StaticResource SubtitleTextBlockStyle}" Foreground="#3B82F6" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="System Uptime" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="UptimeText" Style="{StaticResource SubtitleTextBlockStyle}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="2">
                            <TextBlock Text="Startup Load" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="StartupLoadText" Style="{StaticResource SubtitleTextBlockStyle}" Foreground="#F59E0B" />
                        </StackPanel>
                        <StackPanel Grid.Column="3" Spacing="2">
                            <TextBlock Text="Est. Savings" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="SavingsText" Style="{StaticResource SubtitleTextBlockStyle}" Foreground="#10B981" />
                        </StackPanel>
                    </Grid>

                    <!-- Before/After visual -->
                    <StackPanel Spacing="8">
                        <TextBlock Text="Before vs After Optimization" FontSize="13" FontWeight="SemiBold" Opacity="0.7" />
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60" /><ColumnDefinition Width="*" /><ColumnDefinition Width="60" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Before" FontSize="11" Opacity="0.5" VerticalAlignment="Center" />
                            <ProgressBar x:Name="BeforeBar" Grid.Column="1" Minimum="0" Maximum="100" Height="10" CornerRadius="5" Foreground="#EF4444" />
                            <TextBlock x:Name="BeforeTimeText" Grid.Column="2" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" />
                        </Grid>
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60" /><ColumnDefinition Width="*" /><ColumnDefinition Width="60" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="After" FontSize="11" Opacity="0.5" VerticalAlignment="Center" />
                            <ProgressBar x:Name="AfterBar" Grid.Column="1" Minimum="0" Maximum="100" Height="10" CornerRadius="5" Foreground="#10B981" />
                            <TextBlock x:Name="AfterTimeText" Grid.Column="2" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" />
                        </Grid>
                    </StackPanel>

                    <!-- Boot history -->
                    <TextBlock x:Name="BootHistoryHeader" Text="" FontSize="12" Opacity="0.5" />
                    <StackPanel x:Name="BootHistoryList" Spacing="3" />
                </StackPanel>
            </Border>

            <!-- Summary -->
            <Border x:Name="SummaryCard" Visibility="Collapsed"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <Grid ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="2">
                        <TextBlock Text="Total" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="TotalText" Style="{StaticResource SubtitleTextBlockStyle}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="2">
                        <TextBlock Text="Enabled" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="EnabledText" Style="{StaticResource SubtitleTextBlockStyle}" Foreground="#E65100" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="2">
                        <TextBlock Text="Disabled" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="DisabledText" Style="{StaticResource SubtitleTextBlockStyle}" Foreground="#2E7D32" />
                    </StackPanel>
                    <StackPanel Grid.Column="3" Spacing="2">
                        <TextBlock Text="Impact" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="ImpactText" Style="{StaticResource SubtitleTextBlockStyle}" Foreground="#1565C0" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Startup items list -->
            <StackPanel x:Name="StartupList" Spacing="4" />

        </StackPanel>
    </ScrollViewer>
</Page>
