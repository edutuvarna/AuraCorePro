<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:AuraCore.UI.Avalonia.Views.Controls"
             x:Class="AuraCore.UI.Avalonia.Views.Pages.AutorunManagerView">
  <ScrollViewer>
    <StackPanel Spacing="16">

      <!-- Header -->
      <controls:ModuleHeader Title="Autorun Manager"
                             Subtitle="Manage programs that start with Windows">
        <controls:ModuleHeader.Actions>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Classes="action-btn" Click="Scan_Click"
                    VerticalAlignment="Center" Padding="14,8">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="&#x1F50D;" FontSize="{DynamicResource FontSizeBody}"/>
                <TextBlock x:Name="ScanLabel" Text="Scan"
                           FontSize="{DynamicResource FontSizeBodySmall}" FontWeight="SemiBold"/>
              </StackPanel>
            </Button>
            <!-- PageTitle: invisible, code-behind writes localized string -->
            <TextBlock x:Name="PageTitle" IsVisible="False"/>
          </StackPanel>
        </controls:ModuleHeader.Actions>
      </controls:ModuleHeader>

      <!-- Hidden TextBlocks that code-behind populates via .Text = ... -->
      <TextBlock x:Name="TotalCount"    Text="--" IsVisible="False"/>
      <TextBlock x:Name="EnabledCount"  Text="--" IsVisible="False"/>
      <TextBlock x:Name="DisabledCount" Text="--" IsVisible="False"/>
      <TextBlock x:Name="HighRiskCount" Text="--" IsVisible="False"/>
      <!-- SubtitleText: code-behind writes "Scan failed" on error -->
      <TextBlock x:Name="SubtitleText"
                 Text="Manage programs that start with Windows"
                 FontSize="{DynamicResource FontSizeBodySmall}"
                 Foreground="{DynamicResource TextMutedBrush}"
                 IsVisible="False"/>

      <!-- Stat counters -->
      <controls:StatRow>
        <controls:StatCard Label="TOTAL"
                           Value="{Binding #TotalCount.Text}"
                           ValueBrush="{DynamicResource TextPrimaryBrush}"/>
        <controls:StatCard Label="ENABLED"
                           Value="{Binding #EnabledCount.Text}"
                           ValueBrush="{DynamicResource StatusSuccessBrush}"/>
        <controls:StatCard Label="DISABLED"
                           Value="{Binding #DisabledCount.Text}"
                           ValueBrush="{DynamicResource TextMutedBrush}"/>
        <controls:StatCard Label="HIGH RISK"
                           Value="{Binding #HighRiskCount.Text}"
                           ValueBrush="{DynamicResource StatusErrorBrush}"/>
      </controls:StatRow>

      <!-- Autorun Entry List -->
      <controls:GlassCard>
        <StackPanel Spacing="0">
          <!-- Column Headers -->
          <Grid ColumnDefinitions="40,2*,*,100,80,120" Margin="0,0,0,4">
            <TextBlock Text="" FontSize="{DynamicResource FontSizeLabel}" FontWeight="Bold"
                       Foreground="{DynamicResource TextMutedBrush}"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
              <Border Width="16" Height="16" CornerRadius="4"
                      Background="{DynamicResource BgCardBrush}">
                <TextBlock Text="&#x25B6;" FontSize="{DynamicResource FontSizeLabel}" Foreground="#3B82F6"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
              <TextBlock Text="NAME" FontSize="{DynamicResource FontSizeLabel}" FontWeight="Bold"
                         Foreground="{DynamicResource TextMutedBrush}"/>
            </StackPanel>
            <TextBlock Grid.Column="2" Text="LOCATION" FontSize="{DynamicResource FontSizeLabel}"
                       FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}"/>
            <TextBlock Grid.Column="3" Text="RISK" FontSize="{DynamicResource FontSizeLabel}"
                       FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" TextAlignment="Center"/>
            <TextBlock Grid.Column="4" Text="STATUS" FontSize="{DynamicResource FontSizeLabel}"
                       FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" TextAlignment="Center"/>
            <TextBlock Grid.Column="5" Text="ACTIONS" FontSize="{DynamicResource FontSizeLabel}"
                       FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" TextAlignment="Center"/>
          </Grid>
          <ScrollViewer>
            <ItemsControl x:Name="AutorunList">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Padding="12,8" Margin="2,1" CornerRadius="6" Background="Transparent">
                    <Grid ColumnDefinitions="40,2*,*,100,80,120">
                      <CheckBox IsChecked="{Binding IsEnabled}" Tag="{Binding ToggleTag}"
                                Click="Toggle_Click" VerticalAlignment="Center"/>
                      <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Name}"
                                   FontSize="{DynamicResource FontSizeBodySmall}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding Command}"
                                   FontSize="{DynamicResource FontSizeLabel}"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                      </StackPanel>
                      <TextBlock Grid.Column="2" Text="{Binding Location}"
                                 FontSize="{DynamicResource FontSizeLabel}"
                                 Foreground="{DynamicResource TextSecondaryBrush}"
                                 VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                      <Border Grid.Column="3" CornerRadius="8" Padding="8,2"
                              Background="{Binding RiskBg}"
                              HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="{Binding RiskLevel}"
                                   FontSize="{DynamicResource FontSizeLabel}" FontWeight="SemiBold"
                                   Foreground="{Binding RiskFg}"/>
                      </Border>
                      <TextBlock Grid.Column="4" Text="{Binding StatusText}"
                                 FontSize="{DynamicResource FontSizeLabel}"
                                 Foreground="{Binding StatusBrush}"
                                 VerticalAlignment="Center" TextAlignment="Center" FontWeight="SemiBold"/>
                      <Button Grid.Column="5" Tag="{Binding DeleteTag}" Classes="action-btn"
                              Padding="6,3" Click="Delete_Click"
                              FontSize="{DynamicResource FontSizeLabel}"
                              Content="Delete" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </StackPanel>
      </controls:GlassCard>

    </StackPanel>
  </ScrollViewer>
</UserControl>
