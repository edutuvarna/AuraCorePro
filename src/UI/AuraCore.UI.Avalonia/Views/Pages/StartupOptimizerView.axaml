<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AuraCore.UI.Avalonia.Views.Pages.StartupOptimizerView">
  <Grid RowDefinitions="Auto,Auto,*">
    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,16">
      <StackPanel Spacing="4">
        <TextBlock x:Name="PageTitle" Text="Startup Optimizer" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
        <TextBlock x:Name="SubText" Text="Manage programs that run at Windows startup" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"/>
      </StackPanel>
      <Button Grid.Column="1" Classes="action-btn" Click="Scan_Click" Padding="14,8" VerticalAlignment="Center">
        <StackPanel Orientation="Horizontal" Spacing="6"><TextBlock Text="&#x1F50D;" FontSize="12"/><TextBlock x:Name="ScanLabel" Text="Scan" FontSize="11" FontWeight="SemiBold"/></StackPanel>
      </Button>
    </Grid>
    <Border Grid.Row="1" CornerRadius="{StaticResource RadiusMd}" Background="{DynamicResource BgCardBrush}" BorderBrush="{DynamicResource BorderCardBrush}" BorderThickness="1" Padding="16,10" Margin="0,0,0,12">
      <Grid ColumnDefinitions="*,*,*">
        <StackPanel Orientation="Horizontal" Spacing="8"><TextBlock Text="Total:" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
          <TextBlock x:Name="TotalItems" Text="--" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource AccentPrimaryBrush}" VerticalAlignment="Center"/></StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"><TextBlock Text="Enabled:" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
          <TextBlock x:Name="EnabledItems" Text="--" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}" VerticalAlignment="Center"/></StackPanel>
        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8"><TextBlock Text="High Impact:" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
          <TextBlock x:Name="HighImpactItems" Text="--" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource WarningBrush}" VerticalAlignment="Center"/></StackPanel>
      </Grid>
    </Border>
    <Border Grid.Row="2" CornerRadius="{StaticResource RadiusLg}" Background="{DynamicResource BgCardBrush}" BorderBrush="{DynamicResource BorderCardBrush}" BorderThickness="1" Padding="4">
      <ScrollViewer>
        <ItemsControl x:Name="ItemList">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border Padding="12,8" Margin="0,1" CornerRadius="4">
                <Grid ColumnDefinitions="40,*,80,80,80">
                  <CheckBox IsChecked="{Binding IsEnabled}" VerticalAlignment="Center"/>
                  <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding Command}" FontSize="9" Foreground="{DynamicResource TextMutedBrush}" TextTrimming="CharacterEllipsis"/></StackPanel>
                  <TextBlock Grid.Column="2" Text="{Binding Location}" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" TextAlignment="Center"/>
                  <Border Grid.Column="3" CornerRadius="8" Padding="6,2" Background="{Binding ImpactBg}" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Impact}" FontSize="9" FontWeight="SemiBold" Foreground="{Binding ImpactFg}"/></Border>
                  <TextBlock Grid.Column="4" Text="{Binding Publisher}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" TextAlignment="Center" TextTrimming="CharacterEllipsis"/>
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Border>
  </Grid>
</UserControl>
