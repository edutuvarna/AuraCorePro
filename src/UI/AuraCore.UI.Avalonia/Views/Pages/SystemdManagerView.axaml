<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:AuraCore.UI.Avalonia.Views.Controls"
             x:Class="AuraCore.UI.Avalonia.Views.Pages.SystemdManagerView">
  <ScrollViewer>
    <StackPanel Spacing="16">

      <controls:ModuleHeader x:Name="SvcHeader"
                             Title=""
                             Subtitle="">
        <controls:ModuleHeader.Actions>
          <TextBlock x:Name="PageTitle" IsVisible="False"/>
        </controls:ModuleHeader.Actions>
      </controls:ModuleHeader>

      <!-- Hidden TextBlocks that code-behind populates via .Text = ... -->
      <StackPanel IsVisible="False" Height="0">
        <TextBlock x:Name="TotalSvc"   Text="--"/>
        <TextBlock x:Name="RunningSvc" Text="--"/>
        <TextBlock x:Name="FailedSvc"  Text="--"/>
        <TextBlock x:Name="EnabledSvc" Text="--"/>
      </StackPanel>

      <!-- Stat counters -->
      <controls:StatRow>
        <controls:StatCard x:Name="TotalSvcStat"
                           Label=""
                           Value="{Binding #TotalSvc.Text}"
                           ValueBrush="{DynamicResource TextPrimaryBrush}"/>
        <controls:StatCard x:Name="RunningSvcStat"
                           Label=""
                           Value="{Binding #RunningSvc.Text}"
                           ValueBrush="{DynamicResource StatusSuccessBrush}"/>
        <controls:StatCard x:Name="FailedSvcStat"
                           Label=""
                           Value="{Binding #FailedSvc.Text}"
                           ValueBrush="{DynamicResource StatusErrorBrush}"/>
        <controls:StatCard x:Name="EnabledSvcStat"
                           Label=""
                           Value="{Binding #EnabledSvc.Text}"
                           ValueBrush="{DynamicResource AccentBlueBrush}"/>
      </controls:StatRow>

      <!-- Service list -->
      <controls:GlassCard>
        <StackPanel Spacing="12">
          <Grid ColumnDefinitions="*,Auto">
            <TextBox x:Name="SearchBox" Watermark="" Width="300"
                     HorizontalAlignment="Left" TextChanged="Search_Changed"/>
            <Button x:Name="ScanBtn" Content="" Click="Scan_Click"
                    Grid.Column="1" Classes="action-btn" Padding="16,8"/>
          </Grid>
          <TextBlock x:Name="SubText"
                     Text=""
                     FontSize="{DynamicResource FontSizeBodySmall}"
                     Foreground="{DynamicResource TextMutedBrush}"/>
          <ItemsControl x:Name="SvcList"/>
        </StackPanel>
      </controls:GlassCard>

      <!-- Phase 6.17 Wave F post-action banner -->
      <TextBlock x:Name="PostActionBanner"
                 IsVisible="False"
                 Margin="0,12,0,0"
                 TextWrapping="Wrap"
                 FontSize="13"/>

    </StackPanel>
  </ScrollViewer>
</UserControl>
