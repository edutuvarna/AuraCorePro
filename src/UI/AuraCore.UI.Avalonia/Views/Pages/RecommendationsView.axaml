<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AuraCore.UI.Avalonia.Views.Pages.RecommendationsView">
  <ScrollViewer>
    <StackPanel Spacing="12">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Spacing="4">
          <TextBlock x:Name="PageTitle" Text="AI Recommendations" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
          <TextBlock Text="Smart suggestions based on your system analysis" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"/>
        </StackPanel>
        <Button Grid.Column="1" Classes="action-btn" Click="Refresh_Click" Padding="14,8" VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal" Spacing="6"><TextBlock Text="&#x1F504;" FontSize="12"/><TextBlock x:Name="RefreshLabel" Text="Analyze" FontSize="11" FontWeight="SemiBold"/></StackPanel>
        </Button>
      </Grid>
      <ItemsControl x:Name="RecList">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Margin="0,0,0,8" CornerRadius="12" Background="{DynamicResource BgCardBrush}" BorderBrush="{DynamicResource BorderCardBrush}" BorderThickness="1" Padding="14">
              <Grid ColumnDefinitions="Auto,*,Auto">
                <Border Width="44" Height="44" CornerRadius="12" Background="{Binding PriorityBg}" VerticalAlignment="Top" Margin="0,0,16,0">
                  <TextBlock Text="{Binding Icon}" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                <StackPanel Grid.Column="1" Spacing="4">
                  <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                  <TextBlock Text="{Binding Description}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <Border CornerRadius="6" Padding="6,2" Background="{Binding PriorityBg}">
                      <TextBlock Text="{Binding Priority}" FontSize="9" FontWeight="Bold" Foreground="{Binding PriorityFg}"/></Border>
                    <TextBlock Text="{Binding Module}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
                  </StackPanel>
                </StackPanel>
                <TextBlock Grid.Column="2" Text="{Binding Impact}" FontSize="20" FontWeight="Bold" Foreground="{Binding PriorityFg}" VerticalAlignment="Center"/>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </StackPanel>
  </ScrollViewer>
</UserControl>
