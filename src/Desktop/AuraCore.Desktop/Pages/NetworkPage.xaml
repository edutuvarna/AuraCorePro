<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AuraCore.Desktop.Pages.NetworkPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Padding="32">
        <StackPanel Spacing="20" MaxWidth="960">

            <StackPanel Spacing="4">
                <TextBlock x:Name="PageTitle" Text="Network Optimizer" Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock x:Name="PageSubtitle" Text="Diagnose network performance and optimize DNS settings"
                           Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <!-- Action Bar -->
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button x:Name="ScanBtn" Content="Diagnose Network" Click="ScanBtn_Click"
                        Style="{StaticResource AccentButtonStyle}" Padding="24,10" />
                <Button x:Name="BenchmarkBtn" Content="Find Best DNS" Click="BenchmarkBtn_Click" Padding="24,10" />
                <Button x:Name="SpeedTestBtn" Content="Speed Test" Click="SpeedTestBtn_Click" Padding="24,10" />
                <ProgressRing x:Name="Progress" IsActive="False" Visibility="Collapsed" Width="28" Height="28" />
                <TextBlock x:Name="StatusText" Text="Click Diagnose to analyze your network"
                           VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <!-- Speed Test Result -->
            <Border x:Name="SpeedTestCard" Visibility="Collapsed"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="12">
                    <TextBlock Text="Speed Test Results" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <Grid ColumnSpacing="24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="Download Speed" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="SpeedDownloadText" Style="{StaticResource SubtitleTextBlockStyle}" Foreground="#2E7D32" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="Latency" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="SpeedLatencyText" Style="{StaticResource SubtitleTextBlockStyle}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="2">
                            <TextBlock Text="Downloaded" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="SpeedBytesText" Style="{StaticResource SubtitleTextBlockStyle}" />
                        </StackPanel>
                        <StackPanel Grid.Column="3" Spacing="2">
                            <TextBlock Text="Server" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="SpeedServerText" Style="{StaticResource SubtitleTextBlockStyle}" />
                        </StackPanel>
                    </Grid>
                    <ProgressBar x:Name="SpeedProgressBar" Minimum="0" Maximum="100" Value="0"
                                 Height="6" CornerRadius="3" Visibility="Collapsed" />
                </StackPanel>
            </Border>

            <!-- Current DNS Card -->
            <Border x:Name="DnsCard" Visibility="Collapsed"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="8">
                    <TextBlock Text="Current DNS" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <Grid ColumnSpacing="24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="Provider" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="DnsProviderText" Style="{StaticResource BodyTextBlockStyle}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="Primary" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="DnsPrimaryText" Style="{StaticResource BodyTextBlockStyle}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="2">
                            <TextBlock Text="Secondary" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="DnsSecondaryText" Style="{StaticResource BodyTextBlockStyle}" />
                        </StackPanel>
                        <StackPanel Grid.Column="3" Spacing="2">
                            <TextBlock Text="Response" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="DnsLatencyText" Style="{StaticResource BodyTextBlockStyle}" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Ping Results -->
            <Border x:Name="PingCard" Visibility="Collapsed"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="8">
                    <TextBlock Text="Connection Test" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <StackPanel x:Name="PingList" Spacing="6" />
                </StackPanel>
            </Border>

            <!-- DNS Presets -->
            <!-- DNS Benchmark Result -->
            <Border x:Name="BenchmarkCard" Visibility="Collapsed"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="10">
                    <TextBlock Text="DNS Benchmark Results" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <TextBlock x:Name="BenchmarkRecommendation" Text="" FontSize="14" TextWrapping="Wrap" />
                    <StackPanel x:Name="BenchmarkList" Spacing="4" />
                </StackPanel>
            </Border>

            <TextBlock x:Name="DnsPresetsHeader" Text="Switch DNS Provider" Visibility="Collapsed"
                       Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,8,0,0" />
            <StackPanel x:Name="DnsPresetList" Spacing="8" />

            <!-- Custom DNS Input -->
            <Border x:Name="CustomDnsCard" Visibility="Collapsed"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="12">
                    <TextBlock Text="Custom DNS" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <TextBlock Text="Enter your own DNS server addresses (IPv4 format)"
                               FontSize="12" Opacity="0.6" />
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Primary DNS" FontSize="12" Opacity="0.7" />
                            <TextBox x:Name="CustomPrimaryDns" PlaceholderText="e.g. 1.1.1.1"
                                     Width="200" />
                        </StackPanel>
                        <StackPanel Spacing="4">
                            <TextBlock Text="Secondary DNS" FontSize="12" Opacity="0.7" />
                            <TextBox x:Name="CustomSecondaryDns" PlaceholderText="e.g. 1.0.0.1"
                                     Width="200" />
                        </StackPanel>
                        <Button x:Name="ApplyCustomDnsBtn" Content="Apply Custom DNS"
                                Click="ApplyCustomDns_Click" Padding="16,8"
                                VerticalAlignment="Bottom" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Quick Actions -->
            <TextBlock x:Name="ActionsHeader" Text="Quick Actions" Visibility="Collapsed"
                       Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,8,0,0" />
            <StackPanel x:Name="ActionsPanel" Orientation="Horizontal" Spacing="8" Visibility="Collapsed">
                <Button x:Name="FixAllNetworkBtn" Content="Fix Common Issues" Click="FixAllNetwork_Click"
                        Style="{StaticResource AccentButtonStyle}" Padding="16,8" />
                <Button x:Name="FlushDnsBtn" Content="Flush DNS" Click="FlushDns_Click" Padding="16,8" />
                <Button x:Name="ResetAdapterBtn" Content="Reset Adapter" Click="ResetAdapter_Click" Padding="16,8" />
                <Button x:Name="ResetWinsockBtn" Content="Reset Winsock" Click="ResetWinsock_Click" Padding="16,8" />
            </StackPanel>

            <!-- Adapters -->
            <Border x:Name="AdapterCard" Visibility="Collapsed"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="8">
                    <TextBlock Text="Network Adapters" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <StackPanel x:Name="AdapterList" Spacing="10" />
                </StackPanel>
            </Border>

            <!-- Result -->
            <Border x:Name="ResultCard" Visibility="Collapsed"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <TextBlock x:Name="ResultText" Style="{StaticResource BodyTextBlockStyle}" Foreground="#2E7D32" />
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
