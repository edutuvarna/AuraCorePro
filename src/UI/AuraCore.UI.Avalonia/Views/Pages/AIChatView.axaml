<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AuraCore.UI.Avalonia.Views.Pages.AIChatView">

  <Grid RowDefinitions="Auto,*,Auto" MaxWidth="760">

    <!-- HEADER -->
    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,10">
      <StackPanel Spacing="1">
        <TextBlock x:Name="HeaderTitle" Text="AI Assistant"
                   FontSize="18" FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>
        <TextBlock x:Name="StatusText" Text="Ready"
                   FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
      </StackPanel>
      <Border Grid.Column="1" CornerRadius="14"
              Padding="8,4" VerticalAlignment="Center" BorderThickness="1">
        <Border.Background>
          <SolidColorBrush Color="#8B5CF6" Opacity="0.06"/>
        </Border.Background>
        <Border.BorderBrush>
          <SolidColorBrush Color="#8B5CF6" Opacity="0.12"/>
        </Border.BorderBrush>
        <StackPanel Orientation="Horizontal" Spacing="5">
          <Border Width="5" Height="5" CornerRadius="3" Background="#8B5CF6"/>
          <TextBlock x:Name="ModelBadgeText" Text="AI CHAT"
                     FontSize="9" FontWeight="Bold" Foreground="#8B5CF6"/>
        </StackPanel>
      </Border>
    </Grid>

    <!-- CHAT MESSAGES -->
    <Border Grid.Row="1" CornerRadius="{StaticResource RadiusMd}" BorderThickness="1"
            Padding="10" Margin="0,0,0,10">
      <Border.Background>
        <SolidColorBrush Color="#FFFFFF" Opacity="0.025"/>
      </Border.Background>
      <Border.BorderBrush>
        <SolidColorBrush Color="#FFFFFF" Opacity="0.05"/>
      </Border.BorderBrush>
      <ScrollViewer x:Name="ChatScroll" VerticalScrollBarVisibility="Auto">
        <StackPanel x:Name="MessagesPanel" Spacing="8"/>
      </ScrollViewer>
    </Border>

    <!-- INPUT AREA -->
    <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Margin="0,0,0,4">
      <Border CornerRadius="{StaticResource RadiusMd}" BorderThickness="1" Padding="4">
        <Border.Background>
          <SolidColorBrush Color="#FFFFFF" Opacity="0.03"/>
        </Border.Background>
        <Border.BorderBrush>
          <SolidColorBrush Color="#FFFFFF" Opacity="0.08"/>
        </Border.BorderBrush>
        <TextBox x:Name="InputBox"
                 Watermark="Type a message..."
                 FontSize="12"
                 AcceptsReturn="False"
                 TextWrapping="Wrap"
                 MinHeight="36"
                 Background="Transparent"
                 BorderThickness="0"/>
      </Border>
      <Button x:Name="SendButton" Grid.Column="1"
              Margin="8,0,0,0" Padding="12,8"
              VerticalAlignment="Stretch"
              CornerRadius="{StaticResource RadiusMd}">
        <Button.Background>
          <SolidColorBrush Color="#8B5CF6" Opacity="0.15"/>
        </Button.Background>
        <TextBlock Text="&#x27A4;" FontSize="14" Foreground="#8B5CF6"
                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
      </Button>
    </Grid>

  </Grid>

</UserControl>
