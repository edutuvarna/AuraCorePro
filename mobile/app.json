{
  "expo": {
    "name": "AuraCore Admin",
    "slug": "auracore-admin-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "auracore",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#08080c"
    },
    "android": {
      "package": "com.auracore.admin",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#08080c"
      },
      "permissions": [
        "NOTIFICATIONS",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      "expo-local-authentication",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "77a51287-96ab-4641-8514-38aeabf05f5a"
      },
      "mobileClientSecret": "492a54a35f704065cabad30d9906feabea0c6c633e028cef150719a81b5b3f0b"
    },
    "owner": "ozgurdeniz"
  }
}
