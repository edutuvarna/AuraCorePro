<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:AuraCore.UI.Avalonia.Views.Controls"
        x:Class="AuraCore.UI.Avalonia.Views.MainWindow"
        Title="AuraCore Pro"
        Width="1100" Height="720"
        MinWidth="860" MinHeight="560"
        Background="{DynamicResource BgDeepBrush}"
        WindowStartupLocation="CenterScreen"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="40">

  <Grid ColumnDefinitions="220,*">

    <!-- ══ SIDEBAR ══════════════════════════════════════════ -->
    <Border Grid.Column="0"
            Background="{DynamicResource BgSurfaceBrush}"
            BorderBrush="{DynamicResource BorderSubtleBrush}"
            BorderThickness="0,0,1,0">
      <Grid RowDefinitions="Auto,*,Auto">

        <!-- Logo + Title -->
        <StackPanel Grid.Row="0" Margin="14,12,14,14" Spacing="4">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <ctrl:OrbitalLogo Width="30" Height="30"/>
            <StackPanel VerticalAlignment="Center">
              <TextBlock Text="AuraCore Pro" FontSize="14" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}"/>
              <TextBlock Text="System Optimizer" FontSize="9"
                         Foreground="{DynamicResource TextMutedBrush}"/>
            </StackPanel>
          </StackPanel>
          <!-- User + Tier Badge -->
          <Border CornerRadius="{StaticResource RadiusSm}"
                  Background="{DynamicResource BgCardBrush}"
                  Padding="8,5" Margin="0,6,0,0">
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel VerticalAlignment="Center" Spacing="1">
                <TextBlock x:Name="UserEmailLabel" Text="Guest" FontSize="10" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis"/>
                <TextBlock x:Name="UserStatusLabel" Text="Not signed in" FontSize="9"
                           Foreground="{DynamicResource TextMutedBrush}"/>
              </StackPanel>
              <Border Grid.Column="1" x:Name="TierBadge" CornerRadius="6"
                      Padding="6,2" VerticalAlignment="Center" Background="#2000D4AA">
                <TextBlock x:Name="TierBadgeText" Text="FREE" FontSize="9" FontWeight="Bold"
                           Foreground="{DynamicResource AccentPrimaryBrush}"/>
              </Border>
            </Grid>
          </Border>
        </StackPanel>

        <!-- Dynamic Navigation (built from code-behind) -->
        <ScrollViewer Grid.Row="1" Margin="6,0">
          <StackPanel x:Name="NavPanel" Spacing="1"/>
        </ScrollViewer>

        <!-- Bottom: Platform + Settings -->
        <StackPanel Grid.Row="2" Margin="10,0,10,12" Spacing="4">
          <Border Background="{DynamicResource BgCardBrush}"
                  CornerRadius="{StaticResource RadiusSm}"
                  Padding="10,6" Margin="0,0,0,6">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Border Width="8" Height="8" CornerRadius="4"
                      Background="{DynamicResource SuccessBrush}"/>
              <TextBlock x:Name="PlatformLabel" Text="Windows"
                         FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
            </StackPanel>
          </Border>
          <Button Tag="settings" Classes="nav-item" Click="Nav_Click">
            <StackPanel Orientation="Horizontal" Spacing="10">
              <TextBlock Text="&#x2699;" FontSize="14" VerticalAlignment="Center"/>
              <TextBlock x:Name="SettingsNavLabel" Text="Settings" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>
        </StackPanel>

      </Grid>
    </Border>

    <!-- ══ CONTENT AREA ═════════════════════════════════════ -->
    <Border Grid.Column="1" Background="{DynamicResource BgDeepBrush}">
      <ContentControl x:Name="ContentArea" Margin="20"/>
    </Border>

  </Grid>
</Window>
