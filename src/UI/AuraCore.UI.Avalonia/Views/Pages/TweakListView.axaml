<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:AuraCore.UI.Avalonia.Views.Controls"
             x:Class="AuraCore.UI.Avalonia.Views.Pages.TweakListView">
  <ScrollViewer>
    <StackPanel Spacing="16">

      <!-- Header -->
      <controls:ModuleHeader x:Name="ModuleHdr" Title=""
                             Subtitle="">
        <controls:ModuleHeader.Actions>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Classes="action-btn" Click="Scan_Click"
                    VerticalAlignment="Center" Padding="14,8">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="&#x1F504;" FontSize="{DynamicResource FontSizeBody}"/>
                <TextBlock x:Name="ScanLabel" Text=""
                           FontSize="{DynamicResource FontSizeBodySmall}" FontWeight="SemiBold"/>
              </StackPanel>
            </Button>
            <!-- PageTitle: invisible, code-behind writes localized/module name -->
            <TextBlock x:Name="PageTitle" IsVisible="False"/>
            <!-- PageSubtitle: invisible, code-behind writes subtitle -->
            <TextBlock x:Name="PageSubtitle" IsVisible="False"/>
          </StackPanel>
        </controls:ModuleHeader.Actions>
      </controls:ModuleHeader>

      <!-- Info banner: Explorer restart notice (not a warning — just heads-up) -->
      <Border CornerRadius="{StaticResource RadiusMd}"
              Background="{DynamicResource InfoBgBrush}"
              BorderBrush="{DynamicResource InfoBorderBrush}" BorderThickness="1"
              Padding="14,10">
        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
          <TextBlock Text="&#x2139;"
                     FontSize="{DynamicResource FontSizeBody}"
                     Foreground="{DynamicResource AccentBlueBrush}"
                     VerticalAlignment="Center"/>
          <TextBlock x:Name="ExplorerRestartNote" Text=""
                     FontSize="{DynamicResource FontSizeBodySmall}"
                     Foreground="{DynamicResource AccentBlueBrush}"
                     TextWrapping="Wrap"
                     VerticalAlignment="Center"/>
        </StackPanel>
      </Border>

      <!-- Hidden bridge TextBlocks — code-behind writes stat counts via .Text -->
      <StackPanel IsVisible="False" Height="0">
        <TextBlock x:Name="TotalCount"    Text="--"/>
        <TextBlock x:Name="AppliedCount"  Text="--"/>
        <TextBlock x:Name="AvailableCount" Text="--"/>
      </StackPanel>

      <!-- Stats row -->
      <controls:StatRow>
        <controls:StatCard x:Name="StatTotal" Label=""
                           Value="{Binding #TotalCount.Text}"
                           ValueBrush="{DynamicResource AccentBlueBrush}"/>
        <controls:StatCard x:Name="StatApplied" Label=""
                           Value="{Binding #AppliedCount.Text}"
                           ValueBrush="{DynamicResource StatusSuccessBrush}"/>
        <controls:StatCard x:Name="StatAvailable" Label=""
                           Value="{Binding #AvailableCount.Text}"
                           ValueBrush="{DynamicResource AccentPrimaryBrush}"/>
      </controls:StatRow>

      <!-- Tweak list card -->
      <controls:GlassCard>
        <ScrollViewer>
          <StackPanel x:Name="TweakPanel" Spacing="2"/>
        </ScrollViewer>
      </controls:GlassCard>

      <!-- Apply row -->
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock x:Name="StatusText" Text=""
                   FontSize="{DynamicResource FontSizeBodySmall}"
                   Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
        <Button Grid.Column="1" x:Name="ApplyBtn" Click="Apply_Click"
                Background="{DynamicResource AccentPrimaryBrush}" Foreground="#0A0A0F"
                Padding="20,10" CornerRadius="{StaticResource RadiusMd}"
                FontWeight="Bold" FontSize="{DynamicResource FontSizeBodySmall}" IsEnabled="False">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="&#x26A1;" FontSize="{DynamicResource FontSizeBodySmall}"/>
            <TextBlock x:Name="ApplyLabel" Text=""
                       FontSize="{DynamicResource FontSizeBodySmall}" FontWeight="Bold"/>
          </StackPanel>
        </Button>
      </Grid>

    </StackPanel>
  </ScrollViewer>
</UserControl>
