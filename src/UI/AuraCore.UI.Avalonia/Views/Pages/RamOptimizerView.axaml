<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:AuraCore.UI.Avalonia.Views.Controls"
             x:Class="AuraCore.UI.Avalonia.Views.Pages.RamOptimizerView">
  <ScrollViewer>
    <StackPanel Spacing="16">

      <!-- Header -->
      <controls:ModuleHeader x:Name="ModuleHdr" Title=""
                             Subtitle="">
        <controls:ModuleHeader.Actions>
          <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <!-- Auto-Optimize Toggle -->
            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Margin="0,0,4,0">
              <TextBlock x:Name="AutoLabel" Text="" FontSize="{DynamicResource FontSizeLabel}"
                         Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
              <CheckBox x:Name="AutoOptToggle" IsChecked="False" Click="AutoOpt_Toggle"
                        VerticalAlignment="Center"
                        ToolTip.Tip=""/>
            </StackPanel>
            <!-- Scan Button -->
            <Button Classes="action-btn" Click="Scan_Click" VerticalAlignment="Center" Padding="14,8">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="&#x1F50D;" FontSize="{DynamicResource FontSizeBody}"/>
                <TextBlock x:Name="ScanLabel" Text=""
                           FontSize="{DynamicResource FontSizeBodySmall}" FontWeight="SemiBold"/>
              </StackPanel>
            </Button>
            <!-- Optimize Button -->
            <Button x:Name="OptBtn" Click="Optimize_Click"
                    Background="{DynamicResource AccentPrimaryBrush}" Foreground="#0A0A0F"
                    Padding="16,8" CornerRadius="{StaticResource RadiusMd}"
                    FontWeight="Bold" FontSize="{DynamicResource FontSizeBody}" IsEnabled="False">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="&#x26A1;" FontSize="{DynamicResource FontSizeBody}"/>
                <TextBlock x:Name="OptLabel" Text=""
                           FontSize="{DynamicResource FontSizeBody}" FontWeight="Bold"/>
              </StackPanel>
            </Button>
            <!-- Boost Button (aggressive mode) -->
            <Button x:Name="BoostBtn" Click="Boost_Click"
                    Background="{DynamicResource StatusErrorBrush}" Foreground="White"
                    Padding="18,9" CornerRadius="{StaticResource RadiusMd}"
                    FontWeight="Bold" FontSize="{DynamicResource FontSizeSubheading}"
                    ToolTip.Tip="">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="&#x1F680;" FontSize="{DynamicResource FontSizeSubheading}"/>
                <TextBlock x:Name="BoostLabel" Text=""
                           FontSize="{DynamicResource FontSizeSubheading}" FontWeight="Bold"/>
              </StackPanel>
            </Button>
            <!-- PageTitle: invisible, code-behind writes localized string -->
            <TextBlock x:Name="PageTitle" IsVisible="False"/>
          </StackPanel>
        </controls:ModuleHeader.Actions>
      </controls:ModuleHeader>

      <!-- Hidden SubText — code-behind writes "Scan failed" on error -->
      <TextBlock x:Name="SubText"
                 Text=""
                 FontSize="{DynamicResource FontSizeBodySmall}"
                 Foreground="{DynamicResource TextMutedBrush}"
                 IsVisible="False"/>

      <!-- RAM Bar - GlassCard -->
      <controls:GlassCard>
        <StackPanel Spacing="10">
          <Grid ColumnDefinitions="*,Auto">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock x:Name="UsedRam" Text="--"
                         FontSize="{DynamicResource FontSizeDisplay}"
                         FontWeight="Bold" Foreground="{DynamicResource AccentBlueBrush}"/>
              <TextBlock x:Name="TotalRam" Text=""
                         FontSize="{DynamicResource FontSizeHeading}"
                         Foreground="{DynamicResource TextMutedBrush}"
                         VerticalAlignment="Bottom" Margin="0,0,0,6"/>
            </StackPanel>
            <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
              <TextBlock x:Name="RamPct" Text="--%"
                         FontSize="20" FontWeight="Bold"
                         Foreground="{DynamicResource TextPrimaryBrush}"/>
              <TextBlock x:Name="Reclaimable" Text=""
                         FontSize="{DynamicResource FontSizeBodySmall}"
                         Foreground="{DynamicResource AccentPrimaryBrush}"/>
            </StackPanel>
          </Grid>
          <!-- Gradient Progress Bar -->
          <Border Height="6" CornerRadius="3" Background="#FFFFFF0A">
            <Border x:Name="RamBar" Height="6" CornerRadius="3" HorizontalAlignment="Left" Width="0">
              <Border.Background>
                <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
                  <GradientStop Offset="0" Color="#3B82F6"/>
                  <GradientStop Offset="1" Color="#67E8F9"/>
                </LinearGradientBrush>
              </Border.Background>
            </Border>
          </Border>
        </StackPanel>
      </controls:GlassCard>

      <!-- Historical RAM Graph (last hour) - GlassCard -->
      <controls:GlassCard>
        <Grid RowDefinitions="Auto,*" Height="66">
          <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,4">
            <TextBlock x:Name="LblRamUsageHistory" Text=""
                       FontSize="{DynamicResource FontSizeLabel}" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextMutedBrush}"/>
            <TextBlock x:Name="GraphMinMax" Text=""
                       FontSize="{DynamicResource FontSizeLabel}"
                       Foreground="{DynamicResource TextMutedBrush}"/>
          </StackPanel>
          <Canvas Grid.Row="1" x:Name="RamGraphCanvas" ClipToBounds="True">
            <Polyline x:Name="RamGraphLine" StrokeThickness="1.5" Opacity="0.7">
              <Polyline.Stroke>
                <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
                  <GradientStop Offset="0" Color="#8B5CF6"/>
                  <GradientStop Offset="1" Color="#67E8F9"/>
                </LinearGradientBrush>
              </Polyline.Stroke>
            </Polyline>
          </Canvas>
        </Grid>
      </controls:GlassCard>

      <!-- Top Memory Consumers Section Title -->
      <StackPanel Orientation="Horizontal" Spacing="8">
        <Border Width="20" Height="20" CornerRadius="6" Background="{DynamicResource AccentBgBrush}">
          <TextBlock Text="&#x25A0;" FontSize="{DynamicResource FontSizeLabel}"
                     Foreground="{DynamicResource AccentPrimaryBrush}"
                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
        <TextBlock x:Name="LblTopConsumers" Text=""
                   FontSize="{DynamicResource FontSizeBodySmall}" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextSecondaryBrush}"/>
        <TextBlock x:Name="LblToggleHint" Text=""
                   FontSize="{DynamicResource FontSizeLabel}"
                   Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
      </StackPanel>

      <!-- Process List - GlassCard -->
      <controls:GlassCard>
        <ScrollViewer>
          <ItemsControl x:Name="ProcessList">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Padding="12,6" Margin="0,1" CornerRadius="{StaticResource RadiusMd}" BorderThickness="1">
                  <Border.Background>
                    <SolidColorBrush Color="#FFFFFF" Opacity="0.015"/>
                  </Border.Background>
                  <Border.BorderBrush>
                    <SolidColorBrush Color="#FFFFFF" Opacity="0.03"/>
                  </Border.BorderBrush>
                  <Grid ColumnDefinitions="50,2*,90,70,70,40,40">
                    <TextBlock Text="{Binding Pid}"
                               FontSize="{DynamicResource FontSizeLabel}"
                               Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{Binding Name}"
                               FontSize="{DynamicResource FontSizeBodySmall}" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="{Binding Memory}"
                               FontSize="{DynamicResource FontSizeBodySmall}" FontWeight="SemiBold"
                               Foreground="{DynamicResource AccentBlueBrush}"
                               VerticalAlignment="Center" TextAlignment="Right"/>
                    <TextBlock Grid.Column="3" Text="{Binding Category}"
                               FontSize="{DynamicResource FontSizeLabel}"
                               Foreground="{DynamicResource TextMutedBrush}"
                               VerticalAlignment="Center" TextAlignment="Center"/>
                    <Border Grid.Column="4" CornerRadius="4" Width="8" Height="8"
                            VerticalAlignment="Center" HorizontalAlignment="Center"
                            Background="{Binding EssentialBrush}"/>
                    <!-- Whitelist toggle -->
                    <Button Grid.Column="5" Tag="{Binding Name}" Click="ToggleWhitelist_Click"
                            Background="Transparent" Foreground="{Binding WhitelistFg}"
                            FontSize="{DynamicResource FontSizeLabel}" FontWeight="Bold"
                            Padding="4,2" CornerRadius="4"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            ToolTip.Tip="">
                      <TextBlock Text="W" FontSize="{DynamicResource FontSizeLabel}"
                                 FontWeight="Bold" Foreground="{Binding WhitelistFg}"/>
                    </Button>
                    <!-- Blacklist toggle -->
                    <Button Grid.Column="6" Tag="{Binding Name}" Click="ToggleBlacklist_Click"
                            Background="Transparent" Foreground="{Binding BlacklistFg}"
                            FontSize="{DynamicResource FontSizeLabel}" FontWeight="Bold"
                            Padding="4,2" CornerRadius="4"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            ToolTip.Tip="">
                      <TextBlock Text="B" FontSize="{DynamicResource FontSizeLabel}"
                                 FontWeight="Bold" Foreground="{Binding BlacklistFg}"/>
                    </Button>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </controls:GlassCard>

      <!-- Status Text -->
      <TextBlock x:Name="StatusText" Text=""
                 FontSize="{DynamicResource FontSizeBodySmall}"
                 Foreground="{DynamicResource TextMutedBrush}"/>

      <!-- Phase 6.17 Wave F post-action banner -->
      <TextBlock x:Name="PostActionBanner"
                 IsVisible="False"
                 Margin="0,12,0,0"
                 TextWrapping="Wrap"
                 FontSize="13"/>

    </StackPanel>
  </ScrollViewer>
</UserControl>
