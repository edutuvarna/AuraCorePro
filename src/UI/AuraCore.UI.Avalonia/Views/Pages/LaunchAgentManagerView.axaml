<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:AuraCore.UI.Avalonia.Views.Controls"
             x:Class="AuraCore.UI.Avalonia.Views.Pages.LaunchAgentManagerView">
  <ScrollViewer>
    <StackPanel Spacing="16">

      <controls:ModuleHeader Title="Launch Agent Manager"
                             Subtitle="Manage macOS LaunchAgents and LaunchDaemons (startup services)">
        <controls:ModuleHeader.Actions>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Classes="action-btn" Click="Scan_Click"
                    VerticalAlignment="Center" Padding="16,8"
                    Content="Scan"/>
            <TextBlock x:Name="PageTitle" IsVisible="False"/>
          </StackPanel>
        </controls:ModuleHeader.Actions>
      </controls:ModuleHeader>

      <!-- Hidden TextBlocks that code-behind populates via .Text = ... -->
      <StackPanel IsVisible="False" Height="0">
        <TextBlock x:Name="UserAgents"   Text="--"/>
        <TextBlock x:Name="SystemAgents" Text="--"/>
        <TextBlock x:Name="DaemonCount"  Text="--"/>
      </StackPanel>

      <!-- Stat counters -->
      <controls:StatRow>
        <controls:StatCard Label="USER AGENTS"
                           Value="{Binding #UserAgents.Text}"
                           ValueBrush="{DynamicResource TextPrimaryBrush}"/>
        <controls:StatCard Label="SYSTEM AGENTS"
                           Value="{Binding #SystemAgents.Text}"
                           ValueBrush="{DynamicResource AccentBlueBrush}"/>
        <controls:StatCard Label="DAEMONS"
                           Value="{Binding #DaemonCount.Text}"
                           ValueBrush="{DynamicResource StatusWarningBrush}"/>
      </controls:StatRow>

      <!-- Launch items list -->
      <controls:GlassCard>
        <StackPanel Spacing="12">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Border Width="16" Height="16" CornerRadius="4" Background="{DynamicResource AccentBgBrush}">
              <TextBlock Text="&#x2630;"
                         FontSize="{DynamicResource FontSizeLabel}"
                         Foreground="{DynamicResource AccentPrimaryBrush}"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="Launch Items"
                       FontSize="{DynamicResource FontSizeLabel}"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
          </StackPanel>
          <TextBlock x:Name="SubText"
                     Text="Click Scan to list LaunchAgents/Daemons (macOS only)"
                     FontSize="{DynamicResource FontSizeBodySmall}"
                     Foreground="{DynamicResource TextMutedBrush}"/>
          <ItemsControl x:Name="AgentList"/>
        </StackPanel>
      </controls:GlassCard>

    </StackPanel>
  </ScrollViewer>
</UserControl>
