<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:AuraCore.UI.Avalonia.Views.Controls"
             x:Class="AuraCore.UI.Avalonia.Views.Pages.WakeOnLanView">
  <ScrollViewer>
    <StackPanel Spacing="16">

      <!-- Header -->
      <controls:ModuleHeader x:Name="ModuleHdr" Title=""
                             Subtitle="">
        <controls:ModuleHeader.Actions>
          <!-- PageTitle: invisible, code-behind writes localized string -->
          <TextBlock x:Name="PageTitle" IsVisible="False"/>
        </controls:ModuleHeader.Actions>
      </controls:ModuleHeader>

      <!-- Send Magic Packet card -->
      <controls:GlassCard>
        <StackPanel Spacing="12">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Border Width="20" Height="20" CornerRadius="6"
                    Background="{DynamicResource BgCardBrush}">
              <TextBlock Text="&#x26A1;" FontSize="{DynamicResource FontSizeLabel}"
                         Foreground="{DynamicResource AccentBlueBrush}"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock x:Name="SendMagicPacketLabel" Text=""
                       FontSize="{DynamicResource FontSizeBodySmall}" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
          </StackPanel>
          <TextBox x:Name="MacBox" Watermark=""
                   Width="350" HorizontalAlignment="Left"/>
          <TextBox x:Name="BroadcastBox" Text="255.255.255.255" Watermark=""
                   Width="250" HorizontalAlignment="Left"/>
          <Button x:Name="SendBtn" Content="" Click="Send_Click" Classes="action-btn"
                  Padding="16,10" HorizontalAlignment="Left"/>
          <TextBlock x:Name="StatusText" Text=""
                     FontSize="{DynamicResource FontSizeBodySmall}"
                     Foreground="{DynamicResource TextMutedBrush}"/>
        </StackPanel>
      </controls:GlassCard>

      <!-- Recent Devices card -->
      <controls:GlassCard>
        <StackPanel Spacing="12">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Border Width="20" Height="20" CornerRadius="6"
                    Background="{DynamicResource BgCardBrush}">
              <TextBlock Text="&#x25CF;" FontSize="{DynamicResource FontSizeLabel}"
                         Foreground="{DynamicResource AccentBlueBrush}"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock x:Name="RecentDevicesLabel" Text=""
                       FontSize="{DynamicResource FontSizeBodySmall}" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
          </StackPanel>
          <ItemsControl x:Name="HistoryList"/>
          <TextBlock x:Name="HistoryStatus" Text=""
                     FontSize="{DynamicResource FontSizeBodySmall}"
                     Foreground="{DynamicResource TextMutedBrush}"/>
        </StackPanel>
      </controls:GlassCard>

      <!-- Info banner -->
      <Border CornerRadius="{StaticResource RadiusLg}"
              Background="{DynamicResource InfoBgBrush}" Padding="16,12"
              BorderBrush="{DynamicResource InfoBorderBrush}" BorderThickness="1">
        <TextBlock x:Name="InfoBannerText" Text=""
                   FontSize="{DynamicResource FontSizeBodySmall}"
                   Foreground="{DynamicResource AccentBlueBrush}"
                   TextWrapping="Wrap"/>
      </Border>

      <!-- Usage instructions -->
      <Border CornerRadius="{StaticResource RadiusLg}"
              Background="{DynamicResource BgCardBrush}" Padding="16,12"
              BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1">
        <StackPanel Spacing="6">
          <TextBlock x:Name="HowToUseLabel" Text=""
                     FontSize="{DynamicResource FontSizeBodySmall}" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextPrimaryBrush}"/>
          <TextBlock x:Name="Step1Text" Text=""
                     FontSize="{DynamicResource FontSizeBodySmall}"
                     Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"/>
          <TextBlock x:Name="Step2Text" Text=""
                     FontSize="{DynamicResource FontSizeBodySmall}"
                     Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"/>
          <TextBlock x:Name="Step3Text" Text=""
                     FontSize="{DynamicResource FontSizeBodySmall}"
                     Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"/>
          <TextBlock x:Name="Step4Text" Text=""
                     FontSize="{DynamicResource FontSizeBodySmall}"
                     Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"/>
        </StackPanel>
      </Border>

    </StackPanel>
  </ScrollViewer>
</UserControl>
