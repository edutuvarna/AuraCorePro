<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:AuraCore.UI.Avalonia.Views.Controls"
             x:Class="AuraCore.UI.Avalonia.Views.Pages.FileShredderView">
  <ScrollViewer>
    <StackPanel Spacing="16">

      <!-- Header -->
      <controls:ModuleHeader x:Name="Header">
        <controls:ModuleHeader.Actions>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <!-- PageTitle: invisible, code-behind writes localized string -->
            <TextBlock x:Name="PageTitle" IsVisible="False"/>
          </StackPanel>
        </controls:ModuleHeader.Actions>
      </controls:ModuleHeader>

      <!-- Shred Method Card -->
      <controls:GlassCard>
        <StackPanel Spacing="12">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Border Width="20" Height="20" CornerRadius="6"
                    Background="{DynamicResource StatusErrorBgBrush}">
              <TextBlock Text="⚙" FontSize="{DynamicResource FontSizeLabel}" Foreground="{DynamicResource StatusErrorBrush}"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock x:Name="MethodLabel" Text=""
                       FontSize="{DynamicResource FontSizeBodySmall}" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
          </StackPanel>
          <RadioButton x:Name="Method1Pass" Content="" IsChecked="True" GroupName="method"/>
          <RadioButton x:Name="Method3Pass" Content="" GroupName="method"/>
          <RadioButton x:Name="Method7Pass" Content="" GroupName="method"/>
        </StackPanel>
      </controls:GlassCard>

      <!-- File Selection Card -->
      <controls:GlassCard>
        <StackPanel Spacing="12">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Border Width="20" Height="20" CornerRadius="6"
                    Background="{DynamicResource StatusErrorBgBrush}">
              <TextBlock Text="■" FontSize="{DynamicResource FontSizeLabel}" Foreground="{DynamicResource StatusErrorBrush}"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock x:Name="FilesToShredLabel" Text=""
                       FontSize="{DynamicResource FontSizeBodySmall}" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button x:Name="AddFilesBtn" Content="" Click="AddFiles_Click" Classes="action-btn" Padding="16,8"/>
            <Button x:Name="ClearAllBtn" Content="" Click="ClearFiles_Click" Classes="action-btn" Padding="12,8"/>
          </StackPanel>
          <ItemsControl x:Name="FileList"/>
          <TextBlock x:Name="FileCount" Text=""
                     FontSize="{DynamicResource FontSizeBodySmall}"
                     Foreground="{DynamicResource TextMutedBrush}"/>
        </StackPanel>
      </controls:GlassCard>

      <!-- Shred Button -->
      <Button x:Name="ShredBtn" Content="" Click="Shred_Click"
              Background="{DynamicResource StatusErrorBgBrush}" Foreground="{DynamicResource StatusErrorBrush}"
              FontWeight="Bold" Padding="24,14" CornerRadius="{StaticResource RadiusMd}"
              HorizontalAlignment="Left" Cursor="Hand"
              FontSize="{DynamicResource FontSizeBody}"/>

      <!-- Progress Card -->
      <controls:GlassCard x:Name="ProgressPanel" IsVisible="False">
        <StackPanel Spacing="8">
          <TextBlock x:Name="ProgressLabel" Text=""
                     FontSize="{DynamicResource FontSizeBody}" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextPrimaryBrush}"/>
          <ProgressBar x:Name="ProgressBar" Value="0" Maximum="100" Height="6"
                       Foreground="{DynamicResource StatusErrorBrush}"/>
          <TextBlock x:Name="ProgressDetail" Text=""
                     FontSize="{DynamicResource FontSizeBodySmall}"
                     Foreground="{DynamicResource TextMutedBrush}"/>
        </StackPanel>
      </controls:GlassCard>

      <!-- Warning Card -->
      <controls:GlassCard>
        <TextBlock x:Name="WarningText" Text=""
                   FontSize="{DynamicResource FontSizeBodySmall}"
                   Foreground="{DynamicResource StatusErrorBrush}"
                   TextWrapping="Wrap"/>
      </controls:GlassCard>

    </StackPanel>
  </ScrollViewer>
</UserControl>
