<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:AuraCore.UI.Avalonia.Views.Controls"
             x:Class="AuraCore.UI.Avalonia.Views.Pages.DefaultsOptimizerView">
  <ScrollViewer>
    <StackPanel Spacing="16">

      <controls:ModuleHeader x:Name="PageHeader" Title=""
                             Subtitle="">
        <controls:ModuleHeader.Actions>
          <TextBlock x:Name="PageTitle" IsVisible="False" />
        </controls:ModuleHeader.Actions>
      </controls:ModuleHeader>

      <!-- Quick Tweaks -->
      <controls:GlassCard>
        <StackPanel Spacing="12">
          <TextBlock x:Name="QuickTweaksTitle" Text=""
                     FontSize="{DynamicResource FontSizeBody}"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource TextPrimaryBrush}"/>
          <TextBlock x:Name="SubText"
                     Text=""
                     FontSize="{DynamicResource FontSizeBodySmall}"
                     Foreground="{DynamicResource TextMutedBrush}"/>
          <ItemsControl x:Name="TweakList"/>
          <Button x:Name="ApplyBtn" Content=""
                  Click="Apply_Click"
                  Classes="action-btn"
                  Padding="16,8"
                  HorizontalAlignment="Left"/>
        </StackPanel>
      </controls:GlassCard>

      <!-- Custom Defaults Read -->
      <controls:GlassCard>
        <StackPanel Spacing="12">
          <TextBlock x:Name="CustomDefaultsTitle" Text=""
                     FontSize="{DynamicResource FontSizeBody}"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource TextPrimaryBrush}"/>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBox x:Name="DomainBox" Watermark="" Width="300"/>
            <TextBox x:Name="KeyBox" Watermark="" Width="200"/>
            <Button x:Name="ReadBtn" Content=""
                    Click="ReadDefault_Click"
                    Padding="12,8"
                    Background="#12FFFFFF"
                    CornerRadius="{StaticResource RadiusSm}"/>
          </StackPanel>
          <TextBlock x:Name="ReadResult"
                     Text=""
                     FontSize="{DynamicResource FontSizeBodySmall}"
                     Foreground="{DynamicResource TextMutedBrush}"
                     TextWrapping="Wrap"/>
        </StackPanel>
      </controls:GlassCard>

    </StackPanel>
  </ScrollViewer>
</UserControl>
