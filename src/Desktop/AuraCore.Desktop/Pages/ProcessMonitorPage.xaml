<Page x:Class="AuraCore.Desktop.Pages.ProcessMonitorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid RowDefinitions="Auto,Auto,*">

    <!-- Header -->
    <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,16">
      <TextBlock x:Name="PageTitle" Style="{StaticResource TitleTextBlockStyle}"/>
      <TextBlock x:Name="PageSubtitle" Opacity="0.6" FontSize="13" TextWrapping="Wrap"/>
    </StackPanel>

    <!-- Sub-cards + toolbar -->
    <Grid Grid.Row="1" ColumnDefinitions="*,*,*,Auto" ColumnSpacing="12" Margin="0,0,0,16">
      <Border Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
              CornerRadius="8" Padding="16,12" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
        <StackPanel Spacing="2">
          <TextBlock Text="Processes" FontSize="11" Opacity="0.5"/>
          <TextBlock x:Name="StatCount" Text="0" FontSize="22" FontWeight="SemiBold"/>
        </StackPanel>
      </Border>
      <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
              CornerRadius="8" Padding="16,12" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
        <StackPanel Spacing="2">
          <TextBlock Text="Total CPU" FontSize="11" Opacity="0.5"/>
          <TextBlock x:Name="StatCpu" Text="0%" FontSize="22" FontWeight="SemiBold" Foreground="#2196F3"/>
        </StackPanel>
      </Border>
      <Border Grid.Column="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
              CornerRadius="8" Padding="16,12" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
        <StackPanel Spacing="2">
          <TextBlock Text="Total RAM" FontSize="11" Opacity="0.5"/>
          <TextBlock x:Name="StatRam" Text="0 MB" FontSize="22" FontWeight="SemiBold" Foreground="#9C27B0"/>
        </StackPanel>
      </Border>
      <!-- Toolbar -->
      <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
        <TextBox x:Name="SearchBox" PlaceholderText="Filter..." Width="160" TextChanged="Search_Changed"/>
        <Button x:Name="RefreshBtn" Click="Refresh_Click" Padding="10,8">
          <FontIcon Glyph="&#xE72C;" FontSize="14"/>
        </Button>
        <ToggleButton x:Name="AutoRefreshBtn" Content="Auto" Checked="AutoRefresh_Changed"
                      Unchecked="AutoRefresh_Changed" Padding="10,8"/>
        <ProgressRing x:Name="ScanProgress" IsActive="False" Width="18" Height="18" VerticalAlignment="Center"/>
      </StackPanel>
    </Grid>

    <!-- Table -->
    <Border Grid.Row="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            CornerRadius="10" Padding="16"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
      <Grid RowDefinitions="Auto,*">
        <!-- Column headers -->
        <Grid Grid.Row="0" ColumnDefinitions="*,70,70,55,180" Margin="0,0,0,6" Padding="4,0">
          <TextBlock Grid.Column="0" Text="Process" FontSize="11" Opacity="0.5" FontWeight="SemiBold"/>
          <TextBlock Grid.Column="1" Text="CPU %" FontSize="11" Opacity="0.5" FontWeight="SemiBold"/>
          <TextBlock Grid.Column="2" Text="RAM (MB)" FontSize="11" Opacity="0.5" FontWeight="SemiBold"/>
          <TextBlock Grid.Column="3" Text="PID" FontSize="11" Opacity="0.5" FontWeight="SemiBold"/>
          <TextBlock Grid.Column="4" Text="Actions" FontSize="11" Opacity="0.5" FontWeight="SemiBold"/>
        </Grid>
        <ListView x:Name="ProcessListView" Grid.Row="1" SelectionMode="None" IsItemClickEnabled="False">
          <ListView.ItemContainerStyle>
            <Style TargetType="ListViewItem">
              <Setter Property="Padding" Value="0"/>
              <Setter Property="MinHeight" Value="0"/>
              <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            </Style>
          </ListView.ItemContainerStyle>
          <ListView.ItemTemplate>
            <DataTemplate>
              <Grid ColumnSpacing="8" Padding="4,6"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,0.5">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="70"/>
                  <ColumnDefinition Width="70"/>
                  <ColumnDefinition Width="55"/>
                  <ColumnDefinition Width="180"/>
                </Grid.ColumnDefinitions>
                <!-- Name + Description -->
                <StackPanel VerticalAlignment="Center" Spacing="1">
                  <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold"/>
                  <TextBlock Text="{Binding Desc}" FontSize="10" Opacity="0.35"
                             MaxLines="1" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
                <!-- CPU -->
                <TextBlock Grid.Column="1" Text="{Binding Cpu}" FontSize="12"
                           VerticalAlignment="Center" Foreground="{Binding CpuBrush}"/>
                <!-- RAM -->
                <TextBlock Grid.Column="2" Text="{Binding Ram}" FontSize="12"
                           VerticalAlignment="Center" Foreground="{Binding RamBrush}"/>
                <!-- PID -->
                <TextBlock Grid.Column="3" Text="{Binding Pid}" FontSize="11"
                           Opacity="0.5" VerticalAlignment="Center"/>
                <!-- Actions -->
                <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                  <Button Content="Kill" Padding="8,2" FontSize="11" Tag="{Binding Pid}" Click="Kill_Click"/>
                  <Button Content="Tree" Padding="8,2" FontSize="11" Tag="{Binding Pid}" Click="KillTree_Click"/>
                  <Button Content="{Binding SuspLabel}" Padding="8,2" FontSize="11"
                          Tag="{Binding Pid}" Click="Suspend_Click"/>
                </StackPanel>
              </Grid>
            </DataTemplate>
          </ListView.ItemTemplate>
        </ListView>
      </Grid>
    </Border>

  </Grid>
</Page>
