<Page x:Class="AuraCore.Desktop.Pages.AutorunManagerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid RowDefinitions="Auto,Auto,*,Auto">

    <!-- Header -->
    <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,16">
      <TextBlock x:Name="PageTitle" Style="{StaticResource TitleTextBlockStyle}"/>
      <TextBlock x:Name="PageSubtitle" Opacity="0.6" FontSize="13" TextWrapping="Wrap"/>
    </StackPanel>

    <!-- Sub-cards -->
    <Grid Grid.Row="1" ColumnDefinitions="*,*,*" ColumnSpacing="12" Margin="0,0,0,16">
      <Border Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
              CornerRadius="8" Padding="16,12" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
        <StackPanel Spacing="2">
          <TextBlock Text="Total" FontSize="11" Opacity="0.5"/>
          <TextBlock x:Name="StatTotal" Text="0" FontSize="22" FontWeight="SemiBold"/>
        </StackPanel>
      </Border>
      <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
              CornerRadius="8" Padding="16,12" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
        <StackPanel Spacing="2">
          <TextBlock Text="Enabled" FontSize="11" Opacity="0.5"/>
          <TextBlock x:Name="StatEnabled" Text="0" FontSize="22" FontWeight="SemiBold" Foreground="#4CAF50"/>
        </StackPanel>
      </Border>
      <Border Grid.Column="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
              CornerRadius="8" Padding="16,12" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
        <StackPanel Spacing="2">
          <TextBlock Text="Disabled" FontSize="11" Opacity="0.5"/>
          <TextBlock x:Name="StatDisabled" Text="0" FontSize="22" FontWeight="SemiBold" Foreground="#FF9800"/>
        </StackPanel>
      </Border>
    </Grid>

    <!-- Main card -->
    <Border Grid.Row="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            CornerRadius="10" Padding="20"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
      <Grid RowDefinitions="Auto,Auto,*">

        <!-- Toolbar -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,Auto,Auto,*,Auto" ColumnSpacing="8" Margin="0,0,0,12">
          <Button x:Name="ScanBtn" Grid.Column="0" Content="Scan" Click="Scan_Click"
                  Style="{StaticResource AccentButtonStyle}" Padding="16,8"/>
          <ComboBox x:Name="FilterBox" Grid.Column="1" Width="150"
                    SelectionChanged="Filter_Changed" PlaceholderText="All Types"/>
          <TextBox x:Name="SearchBox" Grid.Column="2" PlaceholderText="Search..." Width="180"
                   TextChanged="Search_Changed"/>
          <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="8">
            <ProgressRing x:Name="ScanProgress" IsActive="False" Width="20" Height="20" VerticalAlignment="Center"/>
            <TextBlock x:Name="StatusText" VerticalAlignment="Center" FontSize="12" Opacity="0.6"/>
          </StackPanel>
        </Grid>

        <!-- Column headers -->
        <Grid Grid.Row="1" ColumnDefinitions="*,140,100,120,Auto" Margin="0,0,0,6" Padding="4,0">
          <TextBlock Grid.Column="0" Text="Name / Command" FontSize="11" Opacity="0.5" FontWeight="SemiBold"/>
          <TextBlock Grid.Column="1" Text="Location" FontSize="11" Opacity="0.5" FontWeight="SemiBold"/>
          <TextBlock Grid.Column="2" Text="Risk" FontSize="11" Opacity="0.5" FontWeight="SemiBold"/>
          <TextBlock Grid.Column="3" Text="Status" FontSize="11" Opacity="0.5" FontWeight="SemiBold"/>
          <TextBlock Grid.Column="4" Text="Actions" FontSize="11" Opacity="0.5" FontWeight="SemiBold" Width="160"/>
        </Grid>

        <!-- List -->
        <ScrollViewer Grid.Row="2">
          <StackPanel x:Name="EntryList" Spacing="2"/>
        </ScrollViewer>

      </Grid>
    </Border>

    <!-- Admin warning -->
    <Border Grid.Row="3" Background="#1AFFA000" CornerRadius="8" Padding="12,8"
            BorderBrush="#40FFA000" BorderThickness="1" Margin="0,12,0,0"
            x:Name="AdminWarning" Visibility="Collapsed">
      <StackPanel Orientation="Horizontal" Spacing="8">
        <FontIcon Glyph="&#xE7BA;" FontSize="14" Foreground="#FFA000"/>
        <TextBlock x:Name="AdminWarnText" FontSize="12" TextWrapping="Wrap" VerticalAlignment="Center"/>
      </StackPanel>
    </Border>

  </Grid>
</Page>