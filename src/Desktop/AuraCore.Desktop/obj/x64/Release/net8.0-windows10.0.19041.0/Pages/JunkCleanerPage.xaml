<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="AuraCore.Desktop.Pages.JunkCleanerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer Padding="32">
        <StackPanel Spacing="20" MaxWidth="960">

            <StackPanel Spacing="4">
                <TextBlock x:ConnectionId='14' x:Name="PageTitle" Text="Junk Cleaner" Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock x:ConnectionId='15' x:Name="PageSubtitle" Text="Find and remove temporary files, caches, and other junk"
                           Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button x:ConnectionId='10' x:Name="ScanBtn" Content="Scan for Junk"                      
                        Style="{StaticResource AccentButtonStyle}" Padding="24,10" />
                <Button x:ConnectionId='11' x:Name="CleanBtn" Content="Clean Selected (0)"                       
                        Padding="24,10" IsEnabled="False" />
                <ProgressRing x:ConnectionId='12' x:Name="Progress" IsActive="False" Visibility="Collapsed" Width="28" Height="28" />
                <TextBlock x:ConnectionId='13' x:Name="StatusText" Text="Click Scan to find junk files"
                           VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <!-- Summary -->
            <Border x:ConnectionId='2' x:Name="SummaryCard" Visibility="Collapsed"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <Grid ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="2">
                        <TextBlock Text="Total size" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:ConnectionId='9' x:Name="TotalSizeText" Style="{StaticResource SubtitleTextBlockStyle}" Foreground="#E65100" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="2">
                        <TextBlock Text="Files" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:ConnectionId='8' x:Name="TotalFilesText" Style="{StaticResource SubtitleTextBlockStyle}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="2">
                        <TextBlock Text="Categories" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:ConnectionId='7' x:Name="TotalCategoriesText" Style="{StaticResource SubtitleTextBlockStyle}" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Category List -->
            <StackPanel x:ConnectionId='3' x:Name="CategoryList" Spacing="6" />

            <!-- Result -->
            <Border x:ConnectionId='4' x:Name="ResultCard" Visibility="Collapsed"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="4">
                    <TextBlock x:ConnectionId='5' x:Name="ResultTitle" Style="{StaticResource BodyStrongTextBlockStyle}" Foreground="#2E7D32" />
                    <TextBlock x:ConnectionId='6' x:Name="ResultDetail" Style="{StaticResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>

