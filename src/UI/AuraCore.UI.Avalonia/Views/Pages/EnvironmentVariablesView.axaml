<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AuraCore.UI.Avalonia.Views.Pages.EnvironmentVariablesView">
  <ScrollViewer>
    <StackPanel Spacing="20">
      <StackPanel Spacing="4">
        <TextBlock x:Name="PageTitle" Text="Environment Variables" FontSize="16" FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>
        <TextBlock Text="View and edit system/user environment variables and PATH"
                   FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"/>
      </StackPanel>

      <!-- PATH Editor -->
      <Border CornerRadius="{StaticResource RadiusLg}" BorderThickness="1" Padding="16">
        <Border.Background>
          <SolidColorBrush Color="#FFFFFF" Opacity="0.025"/>
        </Border.Background>
        <Border.BorderBrush>
          <SolidColorBrush Color="#FFFFFF" Opacity="0.05"/>
        </Border.BorderBrush>
        <StackPanel Spacing="12">
          <Grid ColumnDefinitions="*,Auto">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Border Width="16" Height="16" CornerRadius="4">
                <Border.Background>
                  <SolidColorBrush Color="#A855F7" Opacity="0.15"/>
                </Border.Background>
                <TextBlock Text="&#x2261;" FontSize="8" Foreground="#A855F7"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
              <TextBlock Text="PATH Entries (User)" FontSize="11" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextSecondaryBrush}"/>
            </StackPanel>
            <TextBlock x:Name="PathCount" Grid.Column="1" Text="0 entries" FontSize="12"
                       Foreground="{DynamicResource TextMutedBrush}"/>
          </Grid>
          <ItemsControl x:Name="PathList"/>
          <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
            <TextBox x:Name="NewPathBox" Watermark="New PATH entry..." Width="400"/>
            <Button Content="Add" Click="AddPath_Click" Classes="action-btn" Padding="16,8"/>
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- All Variables -->
      <Border CornerRadius="{StaticResource RadiusLg}" BorderThickness="1" Padding="16">
        <Border.Background>
          <SolidColorBrush Color="#FFFFFF" Opacity="0.025"/>
        </Border.Background>
        <Border.BorderBrush>
          <SolidColorBrush Color="#FFFFFF" Opacity="0.05"/>
        </Border.BorderBrush>
        <StackPanel Spacing="12">
          <Grid ColumnDefinitions="*,Auto">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Border Width="16" Height="16" CornerRadius="4">
                <Border.Background>
                  <SolidColorBrush Color="#A855F7" Opacity="0.15"/>
                </Border.Background>
                <TextBlock Text="&#x25A0;" FontSize="8" Foreground="#A855F7"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
              <TextBlock Text="User Environment Variables" FontSize="11" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextSecondaryBrush}"/>
            </StackPanel>
            <Button Content="Refresh" Click="Refresh_Click" Padding="12,6"
                    Background="#12FFFFFF" CornerRadius="{StaticResource RadiusSm}" Grid.Column="1"/>
          </Grid>
          <TextBox x:Name="SearchBox" Watermark="Search variables..." Margin="0,4,0,0"/>
          <ItemsControl x:Name="VarList"/>
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
