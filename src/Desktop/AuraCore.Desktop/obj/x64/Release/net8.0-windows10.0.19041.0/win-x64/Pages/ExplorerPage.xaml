<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="AuraCore.Desktop.Pages.ExplorerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer Padding="32">
        <StackPanel Spacing="20" MaxWidth="960">
            <StackPanel Spacing="4">
                <TextBlock x:ConnectionId='10' x:Name="PageTitle" Text="Explorer Tweaks" Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock x:ConnectionId='11' x:Name="PageSubtitle" Text="Customize File Explorer behavior, privacy, and appearance"
                           Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button x:ConnectionId='5' x:Name="ScanBtn" Content="Scan Settings"                      
                        Style="{StaticResource AccentButtonStyle}" Padding="24,10" />
                <Button x:ConnectionId='6' x:Name="RecommendedBtn" Content="Recommended Preset"                             
                        Padding="24,10" IsEnabled="False" />
                <Button x:ConnectionId='7' x:Name="ApplyBtn" Content="Apply Changes (0)"                       
                        Padding="24,10" IsEnabled="False" />
                <ProgressRing x:ConnectionId='8' x:Name="Progress" IsActive="False" Visibility="Collapsed" Width="28" Height="28" />
                <TextBlock x:ConnectionId='9' x:Name="StatusText" Text="Click Scan to check Explorer settings"
                           VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
            <StackPanel x:ConnectionId='2' x:Name="TweakList" Spacing="12" />
            <Border x:ConnectionId='3' x:Name="ResultCard" Visibility="Collapsed"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <TextBlock x:ConnectionId='4' x:Name="ResultText" Style="{StaticResource BodyTextBlockStyle}" Foreground="#2E7D32" TextWrapping="Wrap" />
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>

