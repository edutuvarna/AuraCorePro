<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:AuraCore.UI.Avalonia.Views.Controls"
             x:Class="AuraCore.UI.Avalonia.Views.Pages.ScanOptimizeView">
  <ScrollViewer>
    <StackPanel Spacing="16">

      <!-- Header -->
      <controls:ModuleHeader x:Name="ModuleHdr" Title=""
                             Subtitle="">
        <controls:ModuleHeader.Actions>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Classes="action-btn" Click="Scan_Click"
                    VerticalAlignment="Center" Padding="14,8">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="&#x1F50D;" FontSize="{DynamicResource FontSizeBody}"/>
                <TextBlock x:Name="ScanLabel" Text=""
                           FontSize="{DynamicResource FontSizeBodySmall}" FontWeight="SemiBold"/>
              </StackPanel>
            </Button>
            <Button x:Name="OptimizeBtn" Classes="action-btn" Click="Optimize_Click"
                    VerticalAlignment="Center" Padding="14,8" IsEnabled="False">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="&#x26A1;" FontSize="{DynamicResource FontSizeBody}"/>
                <TextBlock x:Name="OptimizeLabel" Text="Optimize"
                           FontSize="{DynamicResource FontSizeBodySmall}" FontWeight="SemiBold"
                           Foreground="{DynamicResource AccentPrimaryBrush}"/>
              </StackPanel>
            </Button>
            <!-- PageTitle: invisible, code-behind writes localized string -->
            <TextBlock x:Name="PageTitle" IsVisible="False"/>
          </StackPanel>
        </controls:ModuleHeader.Actions>
      </controls:ModuleHeader>

      <!-- Hidden bridge for code-behind subtitle writes -->
      <TextBlock x:Name="PageSubtitle"
                 Text=""
                 FontSize="{DynamicResource FontSizeBodySmall}"
                 Foreground="{DynamicResource TextSecondaryBrush}"
                 IsVisible="False"/>

      <!-- Stats Row -->
      <controls:GlassCard>
        <Grid ColumnDefinitions="*,*,*">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock x:Name="LblItemsFound" Text=""
                       FontSize="{DynamicResource FontSizeBodySmall}"
                       Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
            <TextBlock x:Name="ItemsFound" Text="--"
                       FontSize="{DynamicResource FontSizeBody}" FontWeight="Bold"
                       Foreground="{DynamicResource AccentPrimaryBrush}" VerticalAlignment="Center"/>
          </StackPanel>
          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
            <TextBlock x:Name="LblSpace" Text=""
                       FontSize="{DynamicResource FontSizeBodySmall}"
                       Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
            <TextBlock x:Name="SpaceSaved" Text="--"
                       FontSize="{DynamicResource FontSizeBody}" FontWeight="Bold"
                       Foreground="{DynamicResource AccentBlueBrush}" VerticalAlignment="Center"/>
          </StackPanel>
          <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
            <TextBlock x:Name="LblRisk" Text=""
                       FontSize="{DynamicResource FontSizeBodySmall}"
                       Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
            <Border CornerRadius="8" Padding="10,2"
                    Background="{DynamicResource AccentBgBrush}" VerticalAlignment="Center">
              <TextBlock x:Name="RiskLabel" Text="--"
                         FontSize="{DynamicResource FontSizeBodySmall}" FontWeight="SemiBold"
                         Foreground="{DynamicResource AccentPrimaryBrush}"/>
            </Border>
          </StackPanel>
        </Grid>
      </controls:GlassCard>

      <!-- Main Content Card -->
      <controls:GlassCard MinHeight="200">
        <Grid>
          <!-- Before scan state -->
          <StackPanel x:Name="BeforeScanPanel"
                      VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
            <TextBlock x:Name="BeforeScanIcon" Text="&#x1F50D;"
                       FontSize="32" HorizontalAlignment="Center"/>
            <TextBlock x:Name="LblClickToScan" Text=""
                       FontSize="{DynamicResource FontSizeBody}"
                       Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
            <TextBlock x:Name="ModuleInfo" Text=""
                       FontSize="{DynamicResource FontSizeBodySmall}"
                       Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
          </StackPanel>

          <!-- After scan state -->
          <StackPanel x:Name="AfterScanPanel" IsVisible="False" Spacing="12">
            <TextBlock x:Name="ScanResultText" Text=""
                       FontSize="{DynamicResource FontSizeBody}" FontWeight="SemiBold"
                       Foreground="{DynamicResource AccentPrimaryBrush}"/>
            <TextBlock x:Name="ScanDetailText" Text=""
                       FontSize="{DynamicResource FontSizeBodySmall}"
                       Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
          </StackPanel>

          <!-- Progress state -->
          <StackPanel x:Name="ProgressPanel" IsVisible="False"
                      VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
            <TextBlock x:Name="ProgressText" Text=""
                       FontSize="{DynamicResource FontSizeHeading}" FontWeight="SemiBold"
                       Foreground="{DynamicResource AccentPrimaryBrush}" HorizontalAlignment="Center"/>
            <Border Height="6" CornerRadius="3"
                    Background="{DynamicResource BgSubtleBrush}" Width="300">
              <Border x:Name="ProgressBar" Height="6" CornerRadius="3"
                      Background="{DynamicResource AccentPrimaryBrush}"
                      HorizontalAlignment="Left" Width="0"/>
            </Border>
            <TextBlock x:Name="ProgressDetail" Text=""
                       FontSize="{DynamicResource FontSizeBodySmall}"
                       Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
          </StackPanel>

          <!-- Result state -->
          <StackPanel x:Name="ResultPanel" IsVisible="False"
                      VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
            <TextBlock Text="&#x2714;" FontSize="32" HorizontalAlignment="Center"
                       Foreground="{DynamicResource StatusSuccessBrush}"/>
            <TextBlock x:Name="ResultTitle" Text=""
                       FontSize="{DynamicResource FontSizeSubheading}" FontWeight="Bold"
                       Foreground="{DynamicResource StatusSuccessBrush}" HorizontalAlignment="Center"/>
            <TextBlock x:Name="ResultDetail" Text=""
                       FontSize="{DynamicResource FontSizeBody}"
                       Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"
                       TextWrapping="Wrap" MaxWidth="400" TextAlignment="Center"/>
          </StackPanel>
        </Grid>
      </controls:GlassCard>

      <!-- Module Metadata Card -->
      <controls:GlassCard>
        <Grid ColumnDefinitions="Auto,*,Auto">
          <TextBlock Text="&#x2699;" FontSize="{DynamicResource FontSizeBody}"
                     VerticalAlignment="Center" Margin="0,0,10,0"/>
          <TextBlock x:Name="ModuleMeta" Grid.Column="1"
                     FontSize="{DynamicResource FontSizeBodySmall}"
                     Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
          <TextBlock x:Name="PlatformBadge" Grid.Column="2"
                     FontSize="{DynamicResource FontSizeLabel}"
                     Foreground="{DynamicResource AccentPrimaryBrush}" VerticalAlignment="Center"/>
        </Grid>
      </controls:GlassCard>

    </StackPanel>
  </ScrollViewer>
</UserControl>
