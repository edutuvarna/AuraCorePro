<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AuraCore.Desktop.Pages.GamingModePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Padding="32">
        <StackPanel Spacing="20" MaxWidth="960">

            <StackPanel Spacing="4">
                <TextBlock x:Name="PageTitle" Text="Gaming Mode" Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock x:Name="PageSubtitle" Text="One-click optimization for maximum gaming performance"
                           Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <!-- Big Toggle Card -->
            <Border x:Name="ToggleCard"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="12" Padding="28" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Spacing="6" VerticalAlignment="Center">
                        <TextBlock x:Name="ModeStatusText" Text="Gaming Mode is OFF" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <TextBlock x:Name="ModeDetailText" Text="Click Analyze to see what can be optimized"
                                   Style="{StaticResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="PowerPlanText" Text="" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="8" VerticalAlignment="Center">
                        <Button x:Name="AnalyzeBtn" Content="Analyze System" Click="AnalyzeBtn_Click"
                                Padding="20,10" />
                        <Button x:Name="ActivateBtn" Content="Activate Gaming Mode" Click="ActivateBtn_Click"
                                Style="{StaticResource AccentButtonStyle}" Padding="20,10"
                                IsEnabled="False" Visibility="Collapsed" />
                        <Button x:Name="DeactivateBtn" Content="Deactivate" Click="DeactivateBtn_Click"
                                Padding="20,10" Visibility="Collapsed" />
                        <ProgressRing x:Name="Progress" IsActive="False" Visibility="Collapsed" Width="28" Height="28" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Auto-Detect Card -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="12">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="Auto-Detect Game Launch" FontWeight="SemiBold" FontSize="14" />
                            <TextBlock Text="Automatically activate Gaming Mode when a game starts, and deactivate when it closes. Monitors 60+ known games every 5 seconds."
                                       FontSize="12" Opacity="0.6" TextWrapping="Wrap" />
                            <TextBlock x:Name="AutoDetectStatusText" Text="" FontSize="11" Opacity="0.5" />
                        </StackPanel>
                        <ToggleSwitch x:Name="AutoDetectToggle" Grid.Column="1" VerticalAlignment="Center"
                                      OnContent="" OffContent="" Toggled="AutoDetectToggle_Toggled" />
                    </Grid>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBox x:Name="CustomGameBox" PlaceholderText="Add custom game process name (e.g. myGame)"
                                 Width="350" />
                        <Button Content="Add" Click="AddCustomGame_Click" Padding="12,6" />
                    </StackPanel>
                    <StackPanel x:Name="CustomGamesList" Spacing="4" />
                </StackPanel>
            </Border>

            <!-- Optimization Toggles -->
            <TextBlock x:Name="TogglesHeader" Text="Optimizations" Visibility="Collapsed"
                       Style="{StaticResource BodyStrongTextBlockStyle}" />
            <StackPanel x:Name="ToggleList" Spacing="6" />

            <!-- Game Profiles -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="12">
                    <TextBlock Text="Game Profiles" FontWeight="SemiBold" FontSize="14" />
                    <TextBlock Text="Create custom optimization profiles for specific games. Each profile controls which optimizations are applied when that game is detected."
                               FontSize="12" Opacity="0.6" TextWrapping="Wrap" />

                    <!-- Create new profile -->
                    <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                            CornerRadius="6" Padding="16">
                        <StackPanel Spacing="10">
                            <TextBlock Text="New Profile" FontWeight="SemiBold" FontSize="12" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBox x:Name="ProfileNameBox" PlaceholderText="Profile name (e.g. FPS Games)" Width="200" />
                                <TextBox x:Name="ProfileGamesBox" PlaceholderText="Processes: cs2, valorant, fortnite" Width="300" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <CheckBox x:Name="ProfPower" Content="Power Plan" IsChecked="True" />
                                <CheckBox x:Name="ProfNotif" Content="Silence Notifications" IsChecked="True" />
                                <CheckBox x:Name="ProfSuspend" Content="Suspend Background" IsChecked="True" />
                                <CheckBox x:Name="ProfRam" Content="Clean RAM" IsChecked="True" />
                                <CheckBox x:Name="ProfPriority" Content="Boost Priority" IsChecked="False" />
                            </StackPanel>
                            <Button Content="Create Profile" Click="CreateProfile_Click"
                                    Style="{StaticResource AccentButtonStyle}" Padding="16,6" />
                        </StackPanel>
                    </Border>

                    <!-- Existing profiles list -->
                    <StackPanel x:Name="ProfilesList" Spacing="6" />
                </StackPanel>
            </Border>

            <!-- Background Processes -->
            <TextBlock x:Name="BgHeader" Text="" Visibility="Collapsed"
                       Style="{StaticResource BodyStrongTextBlockStyle}" />
            <StackPanel x:Name="BgProcessList" Spacing="4" />

            <!-- Result -->
            <Border x:Name="ResultCard" Visibility="Collapsed"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <TextBlock x:Name="ResultText" Style="{StaticResource BodyTextBlockStyle}" TextWrapping="Wrap" />
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
