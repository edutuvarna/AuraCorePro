<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AuraCore.UI.Avalonia.Views.Pages.EnvironmentVariablesView">
  <ScrollViewer>
    <StackPanel Spacing="20">
      <StackPanel Spacing="4">
        <TextBlock x:Name="PageTitle" Text="Environment Variables" FontSize="28" FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>
        <TextBlock Text="View and edit system/user environment variables and PATH"
                   FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"/>
      </StackPanel>

      <!-- PATH Editor -->
      <Border CornerRadius="{StaticResource RadiusLg}" Background="{DynamicResource BgCardBrush}"
              BorderBrush="{DynamicResource BorderCardBrush}" BorderThickness="1" Padding="24">
        <StackPanel Spacing="12">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="PATH Entries (User)" FontSize="15" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock x:Name="PathCount" Grid.Column="1" Text="0 entries" FontSize="12"
                       Foreground="{DynamicResource TextMutedBrush}"/>
          </Grid>
          <ItemsControl x:Name="PathList"/>
          <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
            <TextBox x:Name="NewPathBox" Watermark="New PATH entry..." Width="400"/>
            <Button Content="Add" Click="AddPath_Click" Classes="action-btn" Padding="16,8"/>
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- All Variables -->
      <Border CornerRadius="{StaticResource RadiusLg}" Background="{DynamicResource BgCardBrush}"
              BorderBrush="{DynamicResource BorderCardBrush}" BorderThickness="1" Padding="24">
        <StackPanel Spacing="12">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="User Environment Variables" FontSize="15" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <Button Content="Refresh" Click="Refresh_Click" Padding="12,6"
                    Background="#12FFFFFF" CornerRadius="{StaticResource RadiusSm}" Grid.Column="1"/>
          </Grid>
          <TextBox x:Name="SearchBox" Watermark="Search variables..." Margin="0,4,0,0"/>
          <ItemsControl x:Name="VarList"/>
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
