<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:AuraCore.UI.Avalonia.Views.Controls"
             x:Class="AuraCore.UI.Avalonia.Views.Pages.IsoBuilderView">

  <Grid ColumnDefinitions="240,1,*" RowDefinitions="0,*,Auto">

    <!-- Hidden ModuleHeader (row 0 height=0) satisfies Phase 4 shell contract -->
    <controls:ModuleHeader x:Name="ModuleHdr" Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="0"
                           Title="" Subtitle=""
                           IsVisible="False">
      <controls:ModuleHeader.Actions>
        <!-- PageTitle: invisible, code-behind writes localized string -->
        <TextBlock x:Name="PageTitle" IsVisible="False"/>
      </controls:ModuleHeader.Actions>
    </controls:ModuleHeader>

    <!-- ═══ LEFT SIDEBAR ═══ -->
    <Border Grid.Column="0" Grid.Row="1" Grid.RowSpan="2" Background="{DynamicResource BgCardBrush}">
      <Grid RowDefinitions="Auto,*,Auto">
        <StackPanel Grid.Row="0" Margin="20,20,20,12" Spacing="4">
          <TextBlock x:Name="SidebarTitle" Text="" FontSize="{DynamicResource FontSizeHeading}" FontWeight="Bold"
                     Foreground="{DynamicResource TextPrimaryBrush}"/>
          <TextBlock x:Name="StepIndicator" Text=""
                     FontSize="{DynamicResource FontSizeBody}"
                     Foreground="{DynamicResource TextMutedBrush}"/>
        </StackPanel>
        <ScrollViewer Grid.Row="1">
          <StackPanel x:Name="StepperPanel" Spacing="2" Margin="8,0,8,8"/>
        </ScrollViewer>
        <Border Grid.Row="2" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="0,1,0,0" Margin="12" Padding="0">
          <StackPanel Spacing="6">
            <TextBlock x:Name="AdminStatusText" Text="" FontSize="{DynamicResource FontSizeBodySmall}"
                       Margin="0,8,0,0"
                       TextWrapping="Wrap" Foreground="{DynamicResource TextMutedBrush}"/>
            <TextBlock x:Name="TemplatesLabel" Text="" FontSize="{DynamicResource FontSizeLabel}" FontWeight="SemiBold"
                       Opacity="0.35" Margin="0,4,0,2"/>
            <ComboBox x:Name="TemplateCombo" PlaceholderText=""
                      HorizontalAlignment="Stretch" FontSize="{DynamicResource FontSizeBody}">
              <ComboBoxItem x:Name="TmplGaming" Content="" Tag="gaming"/>
              <ComboBoxItem x:Name="TmplOffice" Content="" Tag="office"/>
              <ComboBoxItem x:Name="TmplPrivacy" Content="" Tag="privacy"/>
              <ComboBoxItem x:Name="TmplDeveloper" Content="" Tag="developer"/>
              <ComboBoxItem x:Name="TmplMinimal" Content="" Tag="minimal"/>
            </ComboBox>
            <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
              <Button x:Name="ImportBtn" Click="ImportConfig_Click" Padding="8,4"
                      Background="#12FFFFFF" CornerRadius="{StaticResource RadiusSm}" Cursor="Hand">
                <TextBlock x:Name="ImportLabel" Text="" FontSize="{DynamicResource FontSizeBodySmall}"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
              </Button>
              <Button x:Name="ExportBtn" Click="ExportConfig_Click" Padding="8,4"
                      Background="#12FFFFFF" CornerRadius="{StaticResource RadiusSm}" Cursor="Hand">
                <TextBlock x:Name="ExportLabel" Text="" FontSize="{DynamicResource FontSizeBodySmall}"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
              </Button>
            </StackPanel>
          </StackPanel>
        </Border>
      </Grid>
    </Border>

    <!-- Divider -->
    <Border Grid.Column="1" Grid.Row="1" Grid.RowSpan="2" Background="{DynamicResource BorderSubtleBrush}"/>

    <!-- ═══ RIGHT CONTENT ═══ -->
    <ScrollViewer Grid.Column="2" Grid.Row="1" Margin="32,24">
      <Grid>
        <!-- Panel 0: Select ISO -->
        <StackPanel x:Name="Panel_0" IsVisible="True" Spacing="12" MaxWidth="600">
          <TextBlock x:Name="P0Title" Text="" FontSize="{DynamicResource FontSizeHeading}"
                     FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
          <TextBlock x:Name="P0Desc" Text=""
                     Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
          <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,8,0,0">
            <Button x:Name="BrowseIsoBtn" Content="" Click="BrowseIso_Click" Classes="action-btn" Padding="16,10"/>
            <TextBlock x:Name="IsoPathText" Text="" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextMutedBrush}"/>
          </StackPanel>
          <controls:GlassCard x:Name="IsoInfoPanel" IsVisible="False">
            <StackPanel Spacing="6">
              <TextBlock x:Name="IsoOsText" FontSize="{DynamicResource FontSizeBody}" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}"/>
              <TextBlock x:Name="IsoSizeText" FontSize="{DynamicResource FontSizeBody}"
                         Foreground="{DynamicResource TextSecondaryBrush}"/>
              <TextBlock x:Name="IsoFileText" FontSize="{DynamicResource FontSizeBody}"
                         Foreground="{DynamicResource TextMutedBrush}"/>
            </StackPanel>
          </controls:GlassCard>
        </StackPanel>

        <!-- Panel 1: User Account -->
        <StackPanel x:Name="Panel_1" IsVisible="False" Spacing="12" MaxWidth="600">
          <TextBlock x:Name="P1Title" Text="" FontSize="{DynamicResource FontSizeHeading}"
                     FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
          <TextBlock x:Name="P1Desc" Text=""
                     Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
          <RadioButton x:Name="LocalAccountRadio" Content=""
                       IsChecked="True" GroupName="account" Margin="0,8,0,0"/>
          <RadioButton x:Name="MsAccountRadio" Content="" GroupName="account"/>
          <StackPanel x:Name="LocalAccountPanel" Spacing="12" Margin="28,8,0,0">
            <TextBox x:Name="UsernameBox" Width="320"/>
            <TextBox x:Name="PasswordBox" PasswordChar="*" Width="320"/>
            <CheckBox x:Name="AutoLoginCheck" Content="" IsChecked="True"/>
          </StackPanel>
        </StackPanel>

        <!-- Panel 2: OOBE Settings -->
        <StackPanel x:Name="Panel_2" IsVisible="False" Spacing="12" MaxWidth="600">
          <TextBlock x:Name="P2Title" Text="" FontSize="{DynamicResource FontSizeHeading}"
                     FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
          <TextBlock x:Name="P2Desc" Text=""
                     Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
          <CheckBox x:Name="SkipOobeCheck" Content="" IsChecked="True"/>
          <CheckBox x:Name="SkipEulaCheck" Content="" IsChecked="True"/>
          <CheckBox x:Name="DisableTelemetryCheck" Content="" IsChecked="True"/>
          <CheckBox x:Name="DisableCortanaCheck" Content="" IsChecked="True"/>
          <CheckBox x:Name="DisableOneDriveCheck" Content="" IsChecked="True"/>
          <TextBox x:Name="ComputerNameBox" Width="320" MaxLength="15" Margin="0,8,0,0"/>
          <ComboBox x:Name="LanguageCombo" Width="280" SelectedIndex="0" Margin="0,4,0,0">
            <ComboBoxItem x:Name="LangEnUs" Content="" Tag="en-US"/>
            <ComboBoxItem x:Name="LangTrTr" Content="" Tag="tr-TR"/>
            <ComboBoxItem x:Name="LangDeDe" Content="" Tag="de-DE"/>
            <ComboBoxItem x:Name="LangFrFr" Content="" Tag="fr-FR"/>
            <ComboBoxItem x:Name="LangEsEs" Content="" Tag="es-ES"/>
            <ComboBoxItem x:Name="LangRuRu" Content="" Tag="ru-RU"/>
          </ComboBox>
          <ComboBox x:Name="TimezoneCombo" Width="320" SelectedIndex="0">
            <ComboBoxItem x:Name="TzUtc"     Content="" Tag="UTC"/>
            <ComboBoxItem x:Name="TzEastern" Content="" Tag="Eastern Standard Time"/>
            <ComboBoxItem x:Name="TzPacific" Content="" Tag="Pacific Standard Time"/>
            <ComboBoxItem x:Name="TzCet"     Content="" Tag="Central European Standard Time"/>
            <ComboBoxItem x:Name="TzTurkey"  Content="" Tag="Turkey Standard Time"/>
            <ComboBoxItem x:Name="TzMoscow"  Content="" Tag="Russian Standard Time"/>
          </ComboBox>
        </StackPanel>

        <!-- Panel 3: WiFi -->
        <StackPanel x:Name="Panel_3" IsVisible="False" Spacing="12" MaxWidth="600">
          <TextBlock x:Name="P3Title" Text="" FontSize="{DynamicResource FontSizeHeading}"
                     FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
          <TextBlock x:Name="P3Desc" Text=""
                     Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
          <CheckBox x:Name="EnableWifiCheck" Content=""/>
          <StackPanel x:Name="WifiPanel" IsVisible="False" Spacing="12" Margin="28,0,0,0">
            <TextBox x:Name="WifiSsidBox" Width="320"/>
            <TextBox x:Name="WifiPasswordBox" PasswordChar="*" Width="320"/>
            <ComboBox x:Name="WifiSecurityCombo" Width="260" SelectedIndex="0">
              <ComboBoxItem x:Name="WifiSec1" Content="" Tag="WPA2PSK"/>
              <ComboBoxItem x:Name="WifiSec2" Content="" Tag="WPA3SAE"/>
              <ComboBoxItem x:Name="WifiSec3" Content="" Tag="WPAPSK"/>
              <ComboBoxItem x:Name="WifiSec4" Content="" Tag="open"/>
            </ComboBox>
            <TextBlock x:Name="WifiPlainTextNote" Text=""
                       FontSize="{DynamicResource FontSizeBodySmall}"
                       Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"/>
          </StackPanel>
        </StackPanel>

        <!-- Panel 4: Win11 Bypass -->
        <StackPanel x:Name="Panel_4" IsVisible="False" Spacing="12" MaxWidth="600">
          <TextBlock x:Name="P4Title" Text="" FontSize="{DynamicResource FontSizeHeading}"
                     FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
          <Border Background="{DynamicResource WarningBgBrush}" CornerRadius="{StaticResource RadiusSm}" Padding="12"
                  BorderBrush="{DynamicResource WarningBorderBrush}" BorderThickness="1">
            <TextBlock x:Name="BypassWarning" Text=""
                       Foreground="#F59E0B" FontSize="{DynamicResource FontSizeBody}" TextWrapping="Wrap"/>
          </Border>
          <CheckBox x:Name="BypassTpmCheck" Content="" IsChecked="True"/>
          <CheckBox x:Name="BypassSecureBootCheck" Content="" IsChecked="True"/>
          <CheckBox x:Name="BypassRamCheck" Content="" IsChecked="True"/>
          <CheckBox x:Name="BypassStorageCheck" Content="" IsChecked="True"/>
          <CheckBox x:Name="BypassCpuCheck" Content="" IsChecked="True"/>
        </StackPanel>

        <!-- Panel 5: Bloatware Removal -->
        <StackPanel x:Name="Panel_5" IsVisible="False" Spacing="12" MaxWidth="700">
          <TextBlock x:Name="P5Title" Text="" FontSize="{DynamicResource FontSizeHeading}"
                     FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
          <TextBlock x:Name="P5Desc" Text=""
                     Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button x:Name="SelectAllBtn" Content="" Click="SelectAllBloat_Click" Padding="12,6"
                    Background="#12FFFFFF" CornerRadius="{StaticResource RadiusSm}"/>
            <Button x:Name="DeselectAllBtn" Content="" Click="DeselectAllBloat_Click" Padding="12,6"
                    Background="#12FFFFFF" CornerRadius="{StaticResource RadiusSm}"/>
          </StackPanel>
          <StackPanel x:Name="BloatwareList" Spacing="4"/>
        </StackPanel>

        <!-- Panel 6: EXE Bundler -->
        <StackPanel x:Name="Panel_6" IsVisible="False" Spacing="12" MaxWidth="600">
          <TextBlock x:Name="P6Title" Text="" FontSize="{DynamicResource FontSizeHeading}"
                     FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
          <TextBlock x:Name="P6Desc" Text=""
                     Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
          <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
            <Button x:Name="AddFilesBtn" Content="" Click="AddExe_Click" Classes="action-btn" Padding="16,8"/>
            <Button x:Name="ClearAllBtn" Content="" Click="ClearExe_Click" Padding="12,8"
                    Background="#12FFFFFF" CornerRadius="{StaticResource RadiusSm}"/>
          </StackPanel>
          <StackPanel x:Name="ExeFilesList" Spacing="4"/>
          <TextBlock x:Name="ExeCountText" Text=""
                     Foreground="{DynamicResource TextMutedBrush}"
                     FontSize="{DynamicResource FontSizeBody}"/>
          <CheckBox x:Name="SilentInstallCheck" Content="" IsChecked="True"/>
        </StackPanel>

        <!-- Panel 7: Driver Backup -->
        <StackPanel x:Name="Panel_7" IsVisible="False" Spacing="12" MaxWidth="700">
          <TextBlock x:Name="P7Title" Text="" FontSize="{DynamicResource FontSizeHeading}"
                     FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
          <TextBlock x:Name="P7Desc" Text=""
                     Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
          <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
            <Button x:Name="ScanDriversBtn" Content="" Click="ScanDrivers_Click"
                    Classes="action-btn" Padding="16,8"/>
            <TextBlock x:Name="DriverScanStatus" Text="" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="{DynamicResource FontSizeBody}"/>
          </StackPanel>
          <Border Background="{DynamicResource WarningBgBrush}" CornerRadius="{StaticResource RadiusSm}" Padding="12"
                  BorderBrush="{DynamicResource WarningBorderBrush}" BorderThickness="1">
            <TextBlock x:Name="DriverAdminNote" Text=""
                       Foreground="#F59E0B" FontSize="{DynamicResource FontSizeBody}" TextWrapping="Wrap"/>
          </Border>
          <StackPanel x:Name="DriverList" Spacing="4"/>
          <CheckBox x:Name="IncludeDriversCheck" Content="" IsChecked="True"/>
        </StackPanel>

        <!-- Panel 8: Winget Apps -->
        <StackPanel x:Name="Panel_8" IsVisible="False" Spacing="12" MaxWidth="600">
          <TextBlock x:Name="P8Title" Text="" FontSize="{DynamicResource FontSizeHeading}"
                     FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
          <TextBlock x:Name="P8Desc" Text=""
                     Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
          <StackPanel x:Name="WingetAppList" Spacing="4"/>
          <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
            <TextBox x:Name="CustomWingetBox" Width="320"/>
            <Button x:Name="AddWingetBtn" Content="" Click="AddCustomWinget_Click" Padding="12,8"
                    Background="#12FFFFFF" CornerRadius="{StaticResource RadiusSm}"/>
          </StackPanel>
          <StackPanel x:Name="CustomWingetList" Spacing="4"/>
        </StackPanel>

        <!-- Panel 9: Registry Presets -->
        <StackPanel x:Name="Panel_9" IsVisible="False" Spacing="12" MaxWidth="600">
          <TextBlock x:Name="P9Title" Text="" FontSize="{DynamicResource FontSizeHeading}"
                     FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
          <TextBlock x:Name="P9Desc" Text=""
                     Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
          <CheckBox x:Name="PresetDefaultCheck" Content=""
                    IsChecked="True" Margin="0,8,0,0"/>
          <CheckBox x:Name="PresetGamingCheck" Content=""/>
          <CheckBox x:Name="PresetPrivacyCheck" Content=""/>
          <CheckBox x:Name="PresetDevCheck" Content=""/>
          <CheckBox x:Name="PresetOfficeCheck" Content=""/>
        </StackPanel>

        <!-- Panel 10: Post-Install -->
        <StackPanel x:Name="Panel_10" IsVisible="False" Spacing="12" MaxWidth="600">
          <TextBlock x:Name="P10Title" Text="" FontSize="{DynamicResource FontSizeHeading}"
                     FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
          <TextBlock x:Name="P10Desc" Text=""
                     Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
          <CheckBox x:Name="InstallWingetCheck" Content="" IsChecked="True" Margin="0,4,0,0"/>
          <CheckBox x:Name="EnableDarkModeCheck" Content="" IsChecked="True"/>
          <CheckBox x:Name="ShowFileExtCheck" Content="" IsChecked="True"/>
          <CheckBox x:Name="ShowHiddenFilesCheck" Content=""/>
          <CheckBox x:Name="DisableWebSearchCheck" Content="" IsChecked="True"/>
          <CheckBox x:Name="ClassicRightClickCheck" Content="" IsChecked="True"/>
          <CheckBox x:Name="DisableWidgetsCheck" Content="" IsChecked="True"/>
          <CheckBox x:Name="DisableCopilotCheck" Content="" IsChecked="True"/>
          <CheckBox x:Name="TaskbarLeftCheck" Content=""/>
        </StackPanel>

        <!-- Panel 11: Review and Build -->
        <StackPanel x:Name="Panel_11" IsVisible="False" Spacing="12" MaxWidth="600">
          <TextBlock x:Name="P11Title" Text="" FontSize="{DynamicResource FontSizeHeading}"
                     FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
          <controls:GlassCard>
            <StackPanel Spacing="12">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <Border Width="16" Height="16" CornerRadius="4" Background="{DynamicResource AccentBgBrush}">
                  <TextBlock Text="ℹ" FontSize="{DynamicResource FontSizeLabel}"
                             Foreground="{DynamicResource AccentPrimaryBrush}"
                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock x:Name="OutputFormatLabel" Text="" FontSize="{DynamicResource FontSizeBodySmall}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
              </StackPanel>
              <RadioButton x:Name="OutputUnattendOnly" Content=""
                           IsChecked="True" GroupName="output"/>
              <RadioButton x:Name="OutputStandaloneIso" Content="" GroupName="output"/>
            </StackPanel>
          </controls:GlassCard>
          <controls:GlassCard>
            <StackPanel Spacing="8">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <Border Width="16" Height="16" CornerRadius="4" Background="{DynamicResource AccentBgBrush}">
                  <TextBlock Text="ℹ" FontSize="{DynamicResource FontSizeLabel}"
                             Foreground="{DynamicResource AccentPrimaryBrush}"
                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock x:Name="BuildSummaryLabel" Text="" FontSize="{DynamicResource FontSizeBodySmall}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
              </StackPanel>
              <TextBlock x:Name="SummaryText" Text="" FontFamily="Cascadia Mono, Consolas, monospace"
                         FontSize="{DynamicResource FontSizeBody}"
                         Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
              <TextBlock x:Name="EstimatedTimeText" Text=""
                         FontSize="{DynamicResource FontSizeBody}" FontWeight="SemiBold"
                         Foreground="{DynamicResource AccentPrimaryBrush}"/>
            </StackPanel>
          </controls:GlassCard>
          <Border Background="{DynamicResource WarningBgBrush}" CornerRadius="{StaticResource RadiusMd}" Padding="16"
                  BorderBrush="{DynamicResource WarningBorderBrush}" BorderThickness="1">
            <StackPanel Spacing="8">
              <TextBlock x:Name="DisclaimerText" Text=""
                         Foreground="{DynamicResource TextMutedBrush}"
                         FontSize="{DynamicResource FontSizeBodySmall}" TextWrapping="Wrap"/>
              <CheckBox x:Name="DisclaimerCheck" Content=""
                        FontSize="{DynamicResource FontSizeBody}"/>
            </StackPanel>
          </Border>
        </StackPanel>
      </Grid>
    </ScrollViewer>

    <!-- ═══ BOTTOM NAV BAR ═══ -->
    <Border Grid.Column="2" Grid.Row="2" Background="{DynamicResource BgCardBrush}"
            BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="0,1,0,0" Padding="32,12">
      <Grid ColumnDefinitions="*,Auto">
        <Button x:Name="BackBtn" Grid.Column="0" Content="" Click="Back_Click"
                Padding="20,8" IsVisible="False"
                Background="#12FFFFFF" CornerRadius="{StaticResource RadiusMd}"/>
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
          <Button x:Name="NextBtn" Content="" Click="Next_Click"
                  Classes="action-btn" Padding="24,8"
                  Background="{DynamicResource AccentPrimaryBrush}" Foreground="#0A0A0F"/>
          <Button x:Name="BuildBtn" Content="" Click="Build_Click"
                  IsVisible="False" IsEnabled="False"
                  Background="{DynamicResource AccentPrimaryBrush}" Foreground="#0A0A0F"
                  Padding="24,8" CornerRadius="{StaticResource RadiusMd}"/>
        </StackPanel>
      </Grid>
    </Border>

    <!-- ═══ BUILD TERMINAL OVERLAY ═══ -->
    <Grid x:Name="TerminalOverlay" Grid.ColumnSpan="3" Grid.Row="0" Grid.RowSpan="3" IsVisible="False"
          Background="{DynamicResource BgDeepBrush}">
      <Grid Margin="32" MaxWidth="800" HorizontalAlignment="Center" RowDefinitions="Auto,*,Auto">
        <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,16">
          <TextBlock x:Name="BuildingTitle" Text=""
                     FontSize="{DynamicResource FontSizeHeading}" FontWeight="Bold"
                     Foreground="{DynamicResource TextPrimaryBrush}"/>
          <ProgressBar x:Name="TerminalProgress" Value="0" Maximum="100" Height="4"
                       Foreground="{DynamicResource AccentPrimaryBrush}"/>
          <StackPanel Orientation="Horizontal" Spacing="16">
            <TextBlock x:Name="TerminalStepText" Text=""
                       FontSize="{DynamicResource FontSizeBody}"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
            <TextBlock x:Name="TerminalTimeText" Text=""
                       FontSize="{DynamicResource FontSizeBody}"
                       Foreground="{DynamicResource AccentPrimaryBrush}"/>
          </StackPanel>
        </StackPanel>
        <Border Grid.Row="1" Background="#0a0a0a" CornerRadius="{StaticResource RadiusMd}"
                Padding="16" BorderBrush="#1e1e1e" BorderThickness="1">
          <ScrollViewer x:Name="TerminalScroll">
            <TextBlock x:Name="TerminalOutput" FontFamily="Cascadia Mono, Consolas, monospace"
                       FontSize="{DynamicResource FontSizeBody}" Foreground="#06d6a0" TextWrapping="Wrap"/>
          </ScrollViewer>
        </Border>
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="12" Margin="0,16,0,0" HorizontalAlignment="Right">
          <Button x:Name="TerminalCloseBtn" Content="" Click="TerminalClose_Click"
                  Padding="24,10" IsVisible="False"
                  Background="#12FFFFFF" CornerRadius="{StaticResource RadiusMd}"/>
        </StackPanel>
      </Grid>
    </Grid>
  </Grid>

</UserControl>
