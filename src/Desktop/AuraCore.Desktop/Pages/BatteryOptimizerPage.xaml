<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="AuraCore.Desktop.Pages.BatteryOptimizerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer Padding="32">
        <StackPanel Spacing="20" MaxWidth="960">

            <StackPanel Spacing="4">
                <TextBlock x:Name="PageTitle" Text="Battery Optimizer" Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock x:Name="PageSubtitle" Text="Monitor battery health, manage power plans, and optimize battery life"
                           Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <!-- Action Buttons -->
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button x:Name="ScanBtn" Content="Check Battery" Click="ScanBtn_Click"
                        Style="{StaticResource AccentButtonStyle}" Padding="24,10" />
                <Button x:Name="ReportBtn" Content="Battery Report" Click="ReportBtn_Click" Padding="24,10" />
                <Button x:Name="SettingsBtn" Content="Power Settings" Click="SettingsBtn_Click" Padding="24,10" />
                <ProgressRing x:Name="Progress" IsActive="False" Visibility="Collapsed" Width="28" Height="28" />
                <TextBlock x:Name="StatusText" Text="Click Check Battery to analyze"
                           VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <!-- No Battery Message -->
            <Border x:Name="NoBatteryCard" Visibility="Collapsed" CornerRadius="8" Padding="24"
                    Background="#1AE65100" BorderBrush="#33E65100" BorderThickness="1">
                <StackPanel HorizontalAlignment="Center" Spacing="8">
                    <TextBlock Text="&#xEA94;" FontFamily="Segoe MDL2 Assets" FontSize="36" HorizontalAlignment="Center" Foreground="#E65100" />
                    <TextBlock x:Name="NoBatteryText" Text="No battery detected - this feature is for laptops and tablets" 
                               FontSize="14" HorizontalAlignment="Center" Opacity="0.7" TextWrapping="Wrap" TextAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- Battery Health Banner -->
            <Border x:Name="HealthBanner" Visibility="Collapsed" CornerRadius="8" Padding="20" BorderThickness="1">
                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Battery Icon + Percent -->
                    <StackPanel Spacing="4" VerticalAlignment="Center" MinWidth="80">
                        <TextBlock Text="&#xE83F;" FontFamily="Segoe MDL2 Assets" FontSize="36" HorizontalAlignment="Center" x:Name="BatteryIcon" />
                        <TextBlock x:Name="ChargePercentText" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" />
                        <TextBlock x:Name="ChargeStatusText" FontSize="11" Opacity="0.5" HorizontalAlignment="Center" />
                    </StackPanel>

                    <!-- Health Details -->
                    <Grid Grid.Column="1" RowSpacing="8" ColumnSpacing="16" VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Spacing="1">
                            <TextBlock Text="Health" FontSize="10" Opacity="0.4" />
                            <TextBlock x:Name="HealthText" FontSize="15" FontWeight="SemiBold" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="1">
                            <TextBlock Text="Wear Level" FontSize="10" Opacity="0.4" />
                            <TextBlock x:Name="WearText" FontSize="15" FontWeight="SemiBold" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Spacing="1">
                            <TextBlock Text="Design Capacity" FontSize="10" Opacity="0.4" />
                            <TextBlock x:Name="DesignCapText" FontSize="13" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1" Spacing="1">
                            <TextBlock Text="Current Capacity" FontSize="10" Opacity="0.4" />
                            <TextBlock x:Name="FullCapText" FontSize="13" />
                        </StackPanel>
                        <StackPanel Grid.Row="2" Spacing="1">
                            <TextBlock Text="Estimated Time" FontSize="10" Opacity="0.4" />
                            <TextBlock x:Name="EstTimeText" FontSize="13" />
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="1" Spacing="1">
                            <TextBlock Text="Cycle Count" FontSize="10" Opacity="0.4" />
                            <TextBlock x:Name="CycleCountText" FontSize="13" />
                        </StackPanel>
                    </Grid>

                    <!-- Battery Info -->
                    <StackPanel Grid.Column="2" Spacing="2" VerticalAlignment="Center" MinWidth="120">
                        <TextBlock x:Name="BatteryNameText" FontSize="11" Opacity="0.4" TextAlignment="Right" />
                        <TextBlock x:Name="ChemistryText" FontSize="11" Opacity="0.4" TextAlignment="Right" />
                        <TextBlock x:Name="MfrText" FontSize="11" Opacity="0.4" TextAlignment="Right" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Power Plans -->
            <Border x:Name="PowerPlanCard" Visibility="Collapsed"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="8">
                    <TextBlock x:Name="PowerPlanTitle" Text="Power Plans" FontWeight="SemiBold" FontSize="15" />
                    <StackPanel x:Name="PowerPlanList" Spacing="6" />
                </StackPanel>
            </Border>

            <!-- Power Drain Apps -->
            <Border x:Name="DrainCard" Visibility="Collapsed"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="8">
                    <TextBlock x:Name="DrainTitle" Text="Top Power Consumers" FontWeight="SemiBold" FontSize="15" />
                    <StackPanel x:Name="DrainList" Spacing="4" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
