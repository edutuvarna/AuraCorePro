<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="AuraCore.Desktop.Pages.RecommendationsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer Padding="32">
        <StackPanel Spacing="20" MaxWidth="960">

            <StackPanel Spacing="4">
                <TextBlock x:ConnectionId='12' x:Name="PageTitle" Text="AI Recommendations" Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock x:ConnectionId='13' x:Name="PageSubtitle" Text="Smart analysis of your system — prioritized suggestions to improve performance, security, and health"
                           Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button x:ConnectionId='9' x:Name="AnalyzeBtn" Content="Analyze My System"                         
                        Style="{StaticResource AccentButtonStyle}" Padding="24,10" />
                <ProgressRing x:ConnectionId='10' x:Name="Progress" IsActive="False" Visibility="Collapsed" Width="28" Height="28" />
                <TextBlock x:ConnectionId='11' x:Name="StatusText" Text="Click Analyze to get personalized recommendations"
                           VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <!-- Summary -->
            <Border x:ConnectionId='2' x:Name="SummaryCard" Visibility="Collapsed"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <Grid ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="2">
                        <TextBlock Text="Critical" FontSize="11" Foreground="#C62828" />
                        <TextBlock x:ConnectionId='8' x:Name="CriticalCount" Style="{StaticResource SubtitleTextBlockStyle}" Foreground="#C62828" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="2">
                        <TextBlock Text="High" FontSize="11" Foreground="#E65100" />
                        <TextBlock x:ConnectionId='7' x:Name="HighCount" Style="{StaticResource SubtitleTextBlockStyle}" Foreground="#E65100" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="2">
                        <TextBlock Text="Medium" FontSize="11" Foreground="#1565C0" />
                        <TextBlock x:ConnectionId='6' x:Name="MediumCount" Style="{StaticResource SubtitleTextBlockStyle}" Foreground="#1565C0" />
                    </StackPanel>
                    <StackPanel Grid.Column="3" Spacing="2">
                        <TextBlock Text="Tips" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:ConnectionId='5' x:Name="LowCount" Style="{StaticResource SubtitleTextBlockStyle}" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Recommendation List -->
            <StackPanel x:ConnectionId='3' x:Name="RecList" Spacing="8" />

            <!-- All Good -->
            <Border x:ConnectionId='4' x:Name="AllGoodCard" Visibility="Collapsed"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="24" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="8" HorizontalAlignment="Center">
                    <FontIcon Glyph="&#xE73E;" FontSize="36" Foreground="#2E7D32" HorizontalAlignment="Center" />
                    <TextBlock Text="Your system looks great!" FontWeight="SemiBold" FontSize="16" HorizontalAlignment="Center" />
                    <TextBlock Text="No critical issues found. Keep up the good work!" FontSize="13" Opacity="0.6" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>

