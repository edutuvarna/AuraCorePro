<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:AuraCore.UI.Avalonia.Views.Controls"
             xmlns:vm="using:AuraCore.UI.Avalonia.ViewModels"
             x:Class="AuraCore.UI.Avalonia.Views.Pages.AIFeaturesView"
             x:DataType="vm:AIFeaturesViewModel">

  <UserControl.Styles>
    <!-- Hero gradient background -->
    <Style Selector="Border.cortex-hero">
      <Setter Property="CornerRadius" Value="12" />
      <Setter Property="Padding" Value="22,18" />
      <Setter Property="Margin" Value="0,0,0,16" />
      <Setter Property="Background">
        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
          <GradientStop Offset="0" Color="#26B088FF" />
          <GradientStop Offset="0.6" Color="#1400D4AA" />
          <GradientStop Offset="1" Color="#00000000" />
        </LinearGradientBrush>
      </Setter>
      <Setter Property="BorderBrush" Value="#38B088FF" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>

    <!-- Phase 5.3 narrow-mode: section-nav buttons compress to icon-only at narrow (<1000px).
         When PART_IsNarrowNavMode is set on the UserControl, this style trims text
         and tightens padding to fit inside the 80-DIP sidebar. -->
    <Style Selector="UserControl.narrow-nav StackPanel#PART_SectionNav Button">
      <Setter Property="Padding" Value="4,6" />
      <Setter Property="FontSize" Value="10" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>
  </UserControl.Styles>

  <DockPanel Margin="20,16">

    <!-- CORTEX Hero -->
    <Border DockPanel.Dock="Top" Classes="cortex-hero">
      <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto">
        <TextBlock Grid.Row="0" Grid.Column="0"
                   x:Name="PART_HeroKicker"
                   FontSize="10"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource AccentPurpleBrush}" />

        <controls:StatusChip Grid.Row="0" Grid.Column="1"
                             x:Name="PART_HeroStatusChip"
                             Label="{Binding HeroStatusText}" />

        <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                   x:Name="PART_HeroTitle"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   Margin="0,6,0,0" />

        <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                   x:Name="PART_HeroTagline"
                   FontSize="11"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   Margin="0,4,0,0" />
      </Grid>
    </Border>

    <!-- Overview / Detail swap -->
    <Panel>

      <!-- Overview mode: 2x2 grid of AIFeatureCards.
           Phase 5.3 Task 10: at very-narrow (<900px) columns collapse to 1
           so cards stack vertically. Code-behind adjusts PART_OverviewGrid.Columns. -->
      <UniformGrid Rows="2" Columns="2"
                   x:Name="PART_OverviewGrid"
                   IsVisible="{Binding IsOverview}">
        <controls:AIFeatureCard DataContext="{Binding InsightsCard}" />
        <controls:AIFeatureCard DataContext="{Binding RecommendationsCard}" />
        <controls:AIFeatureCard DataContext="{Binding ScheduleCard}" />
        <controls:AIFeatureCard DataContext="{Binding ChatCard}" />
      </UniformGrid>

      <!-- Detail mode: sidebar nav + content.
           Phase 5.3 Task 10 narrow-mode column widths:
             Wide   (>= 1000px): sidebar col = 120 DIP (original)
             Narrow  (< 1000px): sidebar col =  80 DIP (icon-only style via .narrow-nav class)
             V-Narrow(< 900px) : sidebar col =   0 DIP (hidden)
           Code-behind drives PART_DetailRoot.ColumnDefinitions[0].Width. -->
      <Grid x:Name="PART_DetailRoot"
            IsVisible="{Binding IsDetail}">
        <Grid.ColumnDefinitions>
          <!-- Column 0 width managed by code-behind (NarrowModeService subscription) -->
          <ColumnDefinition Width="120" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" x:Name="PART_SectionNav" Spacing="2" Margin="0,8,8,0">
          <Button x:Name="PART_BackToOverviewBtn" Classes="section-nav-item"
                  Command="{Binding NavigateToOverview}" />
          <Button x:Name="PART_NavInsights" Classes="section-nav-item"
                  Command="{Binding NavigateToSection}"
                  CommandParameter="insights" />
          <Button x:Name="PART_NavRecs" Classes="section-nav-item"
                  Command="{Binding NavigateToSection}"
                  CommandParameter="recommendations" />
          <Button x:Name="PART_NavSchedule" Classes="section-nav-item"
                  Command="{Binding NavigateToSection}"
                  CommandParameter="schedule" />
          <Button x:Name="PART_NavChat" Classes="section-nav-item"
                  Command="{Binding NavigateToSection}"
                  CommandParameter="chat" />
        </StackPanel>

        <ContentControl Grid.Column="1"
                        x:Name="PART_SectionContent"
                        Content="{Binding ActiveSectionView}" />
      </Grid>
    </Panel>

  </DockPanel>
</UserControl>
