<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:AuraCore.UI.Avalonia.Views.Controls"
        xmlns:controls="clr-namespace:AuraCore.UI.Avalonia.Views.Controls"
        xmlns:banners="clr-namespace:AuraCore.UI.Avalonia.Views.Banners"
        x:Class="AuraCore.UI.Avalonia.Views.MainWindow"
        Width="1000" Height="640"
        MinWidth="900" MinHeight="580"
        Background="{DynamicResource BgDeepBrush}"
        WindowStartupLocation="CenterScreen"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="40">

  <!-- Outer shell grid: Row 0 = privilege banner (Auto), Row 1 = update banner (Auto), Row 2 = sidebar + content -->
  <Grid RowDefinitions="Auto,Auto,*">

    <!-- Privilege helper missing banner (Task 11).
         IsVisible is driven from code-behind via IHelperAvailabilityService.IsBannerVisible
         because this window uses App.Services directly (no DataContext VM). -->
    <banners:PrivilegeHelperMissingBanner
        x:Name="PrivilegeMissingBanner"
        Grid.Row="0"
        IsVisible="False"
        InstallNowClicked="OnPrivilegeInstallNowClicked"
        DismissClicked="OnPrivilegeDismissClicked" />

    <!-- Update banner (6.6.G). IsVisible=False by default; shown when UpdateChecker fires UpdateFound. -->
    <controls:UpdateBanner
        x:Name="UpdateBanner"
        Grid.Row="1"
        IsVisible="False"/>

  <!-- Sidebar + content area -->
  <Grid Grid.Row="2" ColumnDefinitions="200,*">

    <!-- SIDEBAR -->
    <Border Grid.Column="0"
            Background="{DynamicResource BgSidebarBrush}"
            BorderBrush="{DynamicResource BorderSubtleBrush}"
            BorderThickness="0,0,1,0">
      <DockPanel LastChildFill="True">
        <StackPanel DockPanel.Dock="Top" Spacing="2">
          <controls:AppLogoBadge/>
          <controls:UserChip x:Name="UserChipHost"
                             Email="user@example.com"
                             Role=""
                             AvatarInitial="?"/>
        </StackPanel>

        <Button x:Name="SettingsBtn" DockPanel.Dock="Bottom"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Left"
                Background="Transparent"
                BorderThickness="0"
                Padding="14,8"
                Foreground="{DynamicResource TextMutedBrush}"
                Click="Settings_Click"/>

        <ScrollViewer>
          <StackPanel x:Name="NavPanel" Margin="0,8,0,8"/>
        </ScrollViewer>
      </DockPanel>
    </Border>

    <!-- CONTENT AREA -->
    <Border Grid.Column="1" Background="{DynamicResource BgDeepBrush}">
      <Grid RowDefinitions="*,Auto">
        <ContentControl x:Name="ContentArea" Margin="20"/>

        <!-- Global Status Bar -->
        <Border Grid.Row="1" Padding="12,5" BorderThickness="0,1,0,0">
          <Border.Background>
            <SolidColorBrush Color="#0A0A14" Opacity="0.95"/>
          </Border.Background>
          <Border.BorderBrush>
            <SolidColorBrush Color="#FFFFFF" Opacity="0.05"/>
          </Border.BorderBrush>
          <Grid ColumnDefinitions="*,Auto,Auto">
            <!-- Left: Status text -->
            <TextBlock x:Name="GlobalStatusText" FontSize="10"
                       Foreground="{DynamicResource TextMutedBrush}"
                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
            <!-- Center: Progress info -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6"
                        VerticalAlignment="Center" Margin="16,0">
              <TextBlock x:Name="GlobalProgressText" Text="" FontSize="10"
                         Foreground="{DynamicResource AccentPrimaryBrush}"/>
              <Border x:Name="GlobalProgressBarBorder" Width="80" Height="4"
                      CornerRadius="2" IsVisible="False"
                      VerticalAlignment="Center">
                <Border.Background>
                  <SolidColorBrush Color="#FFFFFF" Opacity="0.06"/>
                </Border.Background>
                <Border x:Name="GlobalProgressBarFill" HorizontalAlignment="Left"
                        Width="0" Height="4" CornerRadius="2">
                  <Border.Background>
                    <SolidColorBrush Color="#00D4AA"/>
                  </Border.Background>
                </Border>
              </Border>
            </StackPanel>
            <!-- Right: Memory usage -->
            <TextBlock Grid.Column="2" x:Name="GlobalMemoryText" Text="" FontSize="10"
                       Foreground="{DynamicResource TextMutedBrush}"
                       VerticalAlignment="Center"/>
          </Grid>
        </Border>
      </Grid>
    </Border>

  </Grid><!-- end sidebar+content Grid -->
  </Grid><!-- end outer shell Grid -->
</Window>
