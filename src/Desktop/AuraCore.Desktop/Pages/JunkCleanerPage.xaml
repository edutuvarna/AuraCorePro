<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="AuraCore.Desktop.Pages.JunkCleanerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer Padding="32">
        <StackPanel Spacing="16" MaxWidth="960">

            <!-- HEADER -->
            <StackPanel Spacing="2">
                <TextBlock x:Name="PageTitle" Text="Junk Cleaner" Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock x:Name="PageSubtitle" Text="Find and remove temporary files, caches, and other junk"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <!-- ACTION BAR -->
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button x:Name="ScanBtn" Content="Scan for Junk" Click="ScanBtn_Click"
                        Style="{StaticResource AccentButtonStyle}" Padding="24,10" />
                <Button x:Name="CleanBtn" Content="Clean Selected (0)" Click="CleanBtn_Click"
                        Padding="24,10" IsEnabled="False" />
                <ProgressRing x:Name="Progress" IsActive="False" Visibility="Collapsed" Width="28" Height="28" />
                <TextBlock x:Name="StatusText" Text="Click Scan to find junk files"
                           VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <!-- SUMMARY CARDS (3 stat cards in a row) -->
            <Border x:Name="SummaryCard" Visibility="Collapsed"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="10" Padding="20"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Total Size -->
                    <Border Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                            CornerRadius="8" Padding="16,12">
                        <StackPanel Spacing="4">
                            <TextBlock x:Name="LblTotalSize" Text="Total size" FontSize="11"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock x:Name="TotalSizeText" Text="--"
                                       FontSize="22" FontWeight="SemiBold"
                                       Foreground="#FFE65100"/>
                        </StackPanel>
                    </Border>

                    <!-- Files -->
                    <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                            CornerRadius="8" Padding="16,12">
                        <StackPanel Spacing="4">
                            <TextBlock x:Name="LblFiles" Text="Files" FontSize="11"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock x:Name="TotalFilesText" Text="--"
                                       FontSize="22" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                    <!-- Categories -->
                    <Border Grid.Column="2" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                            CornerRadius="8" Padding="16,12">
                        <StackPanel Spacing="4">
                            <TextBlock x:Name="LblCategories" Text="Categories" FontSize="11"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock x:Name="TotalCategoriesText" Text="--"
                                       FontSize="22" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- CATEGORY LIST (populated by code-behind) -->
            <StackPanel x:Name="CategoryList" Spacing="6" />

            <!-- RESULT CARD -->
            <Border x:Name="ResultCard" Visibility="Collapsed"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="10" Padding="16,14"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <FontIcon Glyph="&#xE73E;" FontSize="20" Foreground="#FF2E7D32"
                              VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Spacing="2">
                        <TextBlock x:Name="ResultTitle" FontSize="14" FontWeight="SemiBold"
                                   Foreground="#FF2E7D32"/>
                        <TextBlock x:Name="ResultDetail" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
