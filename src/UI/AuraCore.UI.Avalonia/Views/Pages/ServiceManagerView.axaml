<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:AuraCore.UI.Avalonia.Views.Controls"
             x:Class="AuraCore.UI.Avalonia.Views.Pages.ServiceManagerView">
  <ScrollViewer>
    <StackPanel Spacing="16">

      <!-- Header -->
      <controls:ModuleHeader x:Name="ModuleHdr" Title=""
                             Subtitle="">
        <controls:ModuleHeader.Actions>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Classes="action-btn" Click="Scan_Click" Padding="14,8" VerticalAlignment="Center">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="&#x1F50D;" FontSize="{DynamicResource FontSizeBody}"/>
                <TextBlock x:Name="ScanLabel" Text=""
                           FontSize="{DynamicResource FontSizeBodySmall}" FontWeight="SemiBold"/>
              </StackPanel>
            </Button>
            <!-- PageTitle: invisible, code-behind writes localized string -->
            <TextBlock x:Name="PageTitle" IsVisible="False"/>
          </StackPanel>
        </controls:ModuleHeader.Actions>
      </controls:ModuleHeader>

      <!-- Hidden subtitle bridge for code-behind -->
      <TextBlock x:Name="SubText"
                 Text=""
                 FontSize="{DynamicResource FontSizeBodySmall}"
                 Foreground="{DynamicResource TextMutedBrush}"
                 IsVisible="False"/>

      <!-- Operation status banner (code-behind shows/hides) -->
      <Border x:Name="StatusBanner"
              IsVisible="False"
              CornerRadius="{StaticResource RadiusMd}"
              Background="{DynamicResource BgCardBrush}"
              BorderBrush="{DynamicResource BorderSubtleBrush}"
              BorderThickness="1" Padding="12,8">
        <TextBlock x:Name="StatusBannerText"
                   FontSize="{DynamicResource FontSizeBodySmall}"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   TextWrapping="Wrap"/>
      </Border>

      <!-- Stats row -->
      <controls:StatRow>
        <controls:StatCard x:Name="StatTotal" Label=""
                           Value="{Binding #TotalSvc.Text}"
                           ValueBrush="{DynamicResource AccentPrimaryBrush}"/>
        <controls:StatCard x:Name="StatRunning" Label=""
                           Value="{Binding #RunningSvc.Text}"
                           ValueBrush="{DynamicResource StatusSuccessBrush}"/>
        <controls:StatCard x:Name="StatStopped" Label=""
                           Value="{Binding #StoppedSvc.Text}"
                           ValueBrush="{DynamicResource StatusWarningBrush}"/>
        <controls:StatCard x:Name="StatAuto" Label=""
                           Value="{Binding #AutoSvc.Text}"
                           ValueBrush="{DynamicResource AccentBlueBrush}"/>
      </controls:StatRow>

      <!-- Hidden stat TextBlocks — code-behind writes .Text directly -->
      <TextBlock x:Name="TotalSvc"   Text="--" IsVisible="False"/>
      <TextBlock x:Name="RunningSvc" Text="--" IsVisible="False"/>
      <TextBlock x:Name="StoppedSvc" Text="--" IsVisible="False"/>
      <TextBlock x:Name="AutoSvc"    Text="--" IsVisible="False"/>

      <!-- Search box -->
      <TextBox x:Name="SearchBox" Watermark=""
               Background="{DynamicResource BgCardBrush}"
               Foreground="{DynamicResource TextPrimaryBrush}"
               BorderBrush="{DynamicResource BorderSubtleBrush}"
               CornerRadius="8" Padding="12,8"
               TextChanged="Search_Changed"/>

      <!-- Service list card -->
      <controls:GlassCard>
        <ScrollViewer>
          <ItemsControl x:Name="SvcList">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Padding="12,6" Margin="0,0,0,4" CornerRadius="{StaticResource RadiusMd}"
                        BorderThickness="1"
                        Background="{DynamicResource BgCardBrush}"
                        BorderBrush="{DynamicResource BorderSubtleBrush}">
                  <Border.ContextMenu>
                    <ContextMenu Opening="ContextMenu_Opening">
                      <MenuItem Header="" Click="ServiceStart_Click"/>
                      <MenuItem Header="" Click="ServiceStop_Click"/>
                      <MenuItem Header="" Click="ServiceRestart_Click"/>
                      <Separator/>
                      <MenuItem Header="">
                        <MenuItem Header="" Click="ServiceStartupAuto_Click"/>
                        <MenuItem Header="" Click="ServiceStartupManual_Click"/>
                        <MenuItem Header="" Click="ServiceStartupDisabled_Click"/>
                      </MenuItem>
                    </ContextMenu>
                  </Border.ContextMenu>
                  <Grid ColumnDefinitions="*,100,80,80">
                    <StackPanel VerticalAlignment="Center">
                      <TextBlock Text="{Binding DisplayName}"
                                 FontSize="{DynamicResource FontSizeBodySmall}" FontWeight="SemiBold"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 TextTrimming="CharacterEllipsis"/>
                      <TextBlock Text="{Binding ServiceName}"
                                 FontSize="{DynamicResource FontSizeLabel}"
                                 Foreground="{DynamicResource TextMutedBrush}"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="{Binding StartType}"
                               FontSize="{DynamicResource FontSizeLabel}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center" TextAlignment="Center"/>
                    <Border Grid.Column="2" CornerRadius="8" Padding="6,2"
                            Background="{Binding StatusBg}"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                      <TextBlock Text="{Binding Status}"
                                 FontSize="{DynamicResource FontSizeLabel}" FontWeight="SemiBold"
                                 Foreground="{Binding StatusFg}"/>
                    </Border>
                    <TextBlock Grid.Column="3" Text="{Binding Pid}"
                               FontSize="{DynamicResource FontSizeLabel}"
                               Foreground="{DynamicResource TextMutedBrush}"
                               VerticalAlignment="Center" TextAlignment="Center"/>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </controls:GlassCard>

    </StackPanel>
  </ScrollViewer>
</UserControl>
