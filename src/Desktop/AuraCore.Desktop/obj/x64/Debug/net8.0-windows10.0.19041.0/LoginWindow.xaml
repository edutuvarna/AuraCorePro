<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="AuraCore.Desktop.LoginWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Aura Core Pro — Sign In">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" Padding="40">

        <!-- Language selector — top right corner -->
        <StackPanel Orientation="Horizontal" Spacing="4"
                    HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-20,0,0">
            <Button x:ConnectionId='18' x:Name="LangEN" Content="EN"                     
                    Padding="10,4" FontSize="11" MinWidth="0" />
            <Button x:ConnectionId='19' x:Name="LangTR" Content="TR"                     
                    Padding="10,4" FontSize="11" MinWidth="0" />
        </StackPanel>

        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                    Width="400" Spacing="24">

            <StackPanel Spacing="8" HorizontalAlignment="Center">
                <FontIcon Glyph="&#xE95E;" FontSize="48" Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
                <TextBlock x:ConnectionId='16' x:Name="TitleText" Text="Aura Core Pro" Style="{StaticResource TitleTextBlockStyle}" HorizontalAlignment="Center" />
                <TextBlock x:ConnectionId='17' x:Name="SubtitleText" Text="AI Powered Windows Intelligence"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                <Button x:ConnectionId='14' x:Name="LoginTab" Content="Sign In"                       
                        Style="{StaticResource AccentButtonStyle}" Padding="24,8" />
                <Button x:ConnectionId='15' x:Name="RegisterTab" Content="Create Account"                          
                        Padding="24,8" />
            </StackPanel>

            <StackPanel x:ConnectionId='2' x:Name="LoginForm" Spacing="12">
                <TextBox x:ConnectionId='11' x:Name="LoginEmail" Header="Email" PlaceholderText="your@email.com" />
                <PasswordBox x:ConnectionId='12' x:Name="LoginPassword" Header="Password" PlaceholderText="Enter your password" />
                <Button x:ConnectionId='13' x:Name="LoginBtn" Content="Sign In"                       
                        Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Stretch" Padding="0,10" />
            </StackPanel>

            <StackPanel x:ConnectionId='3' x:Name="RegisterForm" Spacing="12" Visibility="Collapsed">
                <TextBox x:ConnectionId='7' x:Name="RegEmail" Header="Email" PlaceholderText="your@email.com" />
                <PasswordBox x:ConnectionId='8' x:Name="RegPassword" Header="Password" PlaceholderText="Minimum 8 characters" />
                <PasswordBox x:ConnectionId='9' x:Name="RegConfirm" Header="Confirm Password" PlaceholderText="Repeat your password" />
                <Button x:ConnectionId='10' x:Name="RegisterBtn" Content="Create Account"                          
                        Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Stretch" Padding="0,10" />
            </StackPanel>

            <ProgressRing x:ConnectionId='4' x:Name="Progress" IsActive="False" Visibility="Collapsed" Width="28" Height="28"
                          HorizontalAlignment="Center" />
            <TextBlock x:ConnectionId='5' x:Name="StatusText" Text="" HorizontalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"
                       TextAlignment="Center" />

            <HyperlinkButton x:ConnectionId='6' x:Name="OfflineBtn" Content="Continue offline (Free tier)"
                                                      HorizontalAlignment="Center" />

        </StackPanel>
    </Grid>
</Window>

